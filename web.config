<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.web>
        <!-- V18 i18n fix: recycle app pool -->
        <!-- 自定义错误页面 -->
        <customErrors mode="RemoteOnly" defaultRedirect="/error.asp" />
        <!-- HTTP 请求验证与执行超时 -->
        <httpRuntime requestValidationMode="2.0" executionTimeout="300" maxRequestLength="102400" />
    </system.web>
    
    <location path="database">
        <system.webServer>
            <!-- 拒绝所有对database目录的Web访问 -->
            <security>
                <requestFiltering>
                    <denyUrlSequences>
                        <add sequence=".mdb" />
                        <add sequence=".mde" />
                        <add sequence=".accdb" />
                        <add sequence=".accde" />
                    </denyUrlSequences>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".mdb" allowed="false" />
                        <add fileExtension=".mde" allowed="false" />
                        <add fileExtension=".accdb" allowed="false" />
                        <add fileExtension=".accde" allowed="false" />
                        <add fileExtension=".sql" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <location path="includes">
        <system.webServer>
            <!-- 拒绝直接访问includes目录 -->
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".asp" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <!-- V14.6: 恢复 setup 目录访问保护（数据迁移已完成） -->
    <location path="setup">
        <system.webServer>
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".asp" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <system.webServer>
        <!-- V12.0 性能优化：启用GZIP压缩 -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />
        
        <!-- V12.0 性能优化：浏览器缓存配置 -->
        <staticContent>
            <!-- WebP图片MIME类型 -->
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
        </staticContent>
        
        <!-- V14.6: HTTP安全响应头已迁移至 config.asp (Response.AddHeader)，避免重复设置 -->
        <!-- 以下安全头由 config.asp 统一管理：X-Content-Type-Options, X-Frame-Options, X-XSS-Protection, Referrer-Policy, Permissions-Policy, CSP, HSTS -->
        <httpProtocol>
            <customHeaders>
                <!-- 如需添加 config.asp 未覆盖的自定义头，在此处添加 -->
            </customHeaders>
        </httpProtocol>
        
        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="10485760" />
                <!-- 隐藏服务器版本信息 -->
                <verbs allowUnlisted="true">
                    <add verb="OPTIONS" allowed="false" />
                    <add verb="TRACE" allowed="false" />
                    <add verb="DELETE" allowed="false" />
                    <add verb="PUT" allowed="false" />
                </verbs>
            </requestFiltering>
        </security>
        
        <defaultDocument>
            <files>
                <clear />
                <add value="index.asp" />
                <add value="Default.asp" />
                <add value="Default.htm" />
                <add value="index.htm" />
                <add value="index.html" />
                <add value="iisstart.htm" />
                <add value="default.aspx" />
            </files>
        </defaultDocument>
        <asp enableParentPaths="true" scriptErrorSentToBrowser="true">
            <limits scriptTimeout="00:05:00" />
        </asp>
        
        <!-- ============================================
             V19 ASP.NET Core 反向代理规则
             依赖：IIS URL Rewrite Module 2.1 + ARR 3.0
             安装命令（管理员PowerShell）：
               winget install Microsoft.IIS.URLRewrite
               或手动下载: https://www.iis.net/downloads/microsoft/url-rewrite
             启用反向代理需要 ARR:
               https://www.iis.net/downloads/microsoft/application-request-routing
             共存策略: /api/v2/ 和 /admin/v2/ 路由到 .NET, 其余走 Classic ASP
             ============================================ -->
        <!-- V19: URL Rewrite 反向代理 — /api/v2/ → .NET API, /admin/v2/ → Blazor Admin -->
        <rewrite>
            <rules>
                <rule name="ApiV2" stopProcessing="true">
                    <match url="^api/v2/(.*)" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="http://localhost:5000/api/{R:1}" />
                </rule>
                <rule name="AdminV2" stopProcessing="true">
                    <match url="^admin/v2/(.*)" />
                    <conditions logicalGrouping="MatchAll" trackAllCaptures="false" />
                    <action type="Rewrite" url="http://localhost:5207/admin/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
