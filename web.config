<?xml version="1.0" encoding="UTF-8"?>
<!--
    ============================================================
    PerfumeShop V18 + V19 双栈并行版 web.config
    版本: V18-V19-DualStack
    日期: 2026-07-13
    说明:
      - V18 Classic ASP: 完全启用，所有页面正常访问
      - V19 路由规则: 已配置，待 ARR 注册后自动生效
      - V19 服务: 通过 start_v19_services.bat 自动启动
    ============================================================
-->
<configuration>
    <system.web>
        <customErrors mode="RemoteOnly" defaultRedirect="/error.asp" />
        <httpRuntime requestValidationMode="2.0" executionTimeout="300" maxRequestLength="102400" />
    </system.web>

    <!-- 目录安全 -->
    <location path="database">
        <system.webServer>
            <security>
                <requestFiltering>
                    <denyUrlSequences>
                        <add sequence=".mdb" /><add sequence=".mde" />
                        <add sequence=".accdb" /><add sequence=".accde" />
                    </denyUrlSequences>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".mdb" allowed="false" /><add fileExtension=".mde" allowed="false" />
                        <add fileExtension=".accdb" allowed="false" /><add fileExtension=".accde" allowed="false" />
                        <add fileExtension=".sql" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    <location path="includes">
        <system.webServer>
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".asp" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    <location path="setup">
        <system.webServer>
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".asp" allowed="false" />
                        <add fileExtension=".ps1" allowed="false" />
                        <add fileExtension=".sql" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    <location path="logs">
        <system.webServer>
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".log" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>

    <system.webServer>
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />

        <staticContent>
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
        </staticContent>

        <httpProtocol>
            <customHeaders>
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
                <add name="X-XSS-Protection" value="1; mode=block" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
            </customHeaders>
        </httpProtocol>

        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="10485760" />
                <verbs allowUnlisted="true">
                    <add verb="OPTIONS" allowed="false" />
                    <add verb="TRACE" allowed="false" />
                </verbs>
            </requestFiltering>
        </security>

        <defaultDocument>
            <files>
                <clear />
                <add value="index.asp" /><add value="Default.asp" />
                <add value="index.html" /><add value="default.aspx" />
                <add value="Default.htm" /><add value="index.htm" /><add value="iisstart.htm" />
            </files>
        </defaultDocument>

        <asp enableParentPaths="true" scriptErrorSentToBrowser="true">
            <limits scriptTimeout="00:05:00" />
        </asp>

        <!-- V18+V19 双栈路由规则（ARR 注册后自动生效） -->
        <rewrite>
            <rules>
                <rule name="V19-ApiV2" stopProcessing="true">
                    <match url="^api/v2/(.*)" />
                    <action type="Rewrite" url="http://localhost:5000/api/{R:1}" />
                </rule>
                <rule name="V19-AdminV2" stopProcessing="true">
                    <match url="^admin/v2/(.*)" />
                    <action type="Rewrite" url="http://localhost:5207/admin/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
