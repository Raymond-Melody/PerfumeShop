<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.web>
        <!-- 自定义错误页面 -->
        <customErrors mode="RemoteOnly" defaultRedirect="/error.asp" />
        <!-- HTTP 请求验证与执行超时 -->
        <httpRuntime requestValidationMode="2.0" executionTimeout="300" maxRequestLength="102400" />
    </system.web>
    
    <location path="database">
        <system.webServer>
            <!-- 拒绝所有对database目录的Web访问 -->
            <security>
                <requestFiltering>
                    <denyUrlSequences>
                        <add sequence=".mdb" />
                        <add sequence=".mde" />
                        <add sequence=".accdb" />
                        <add sequence=".accde" />
                    </denyUrlSequences>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".mdb" allowed="false" />
                        <add fileExtension=".mde" allowed="false" />
                        <add fileExtension=".accdb" allowed="false" />
                        <add fileExtension=".accde" allowed="false" />
                        <add fileExtension=".sql" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <location path="includes">
        <system.webServer>
            <!-- 拒绝直接访问includes目录 -->
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".asp" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <!-- V14.6: 恢复 setup 目录访问保护（数据迁移已完成） -->
    <location path="setup">
        <system.webServer>
            <security>
                <requestFiltering>
                    <fileExtensions allowUnlisted="true">
                        <add fileExtension=".asp" allowed="false" />
                    </fileExtensions>
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <system.webServer>
        <!-- V12.0 性能优化：启用GZIP压缩 -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />
        
        <!-- V12.0 性能优化：浏览器缓存配置 -->
        <staticContent>
            <!-- WebP图片MIME类型 -->
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
        </staticContent>
        
        <!-- V14.6: HTTP安全响应头已迁移至 config.asp (Response.AddHeader)，避免重复设置 -->
        <!-- 以下安全头由 config.asp 统一管理：X-Content-Type-Options, X-Frame-Options, X-XSS-Protection, Referrer-Policy, Permissions-Policy, CSP, HSTS -->
        <httpProtocol>
            <customHeaders>
                <!-- 如需添加 config.asp 未覆盖的自定义头，在此处添加 -->
            </customHeaders>
        </httpProtocol>
        
        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="10485760" />
                <!-- 隐藏服务器版本信息 -->
                <verbs allowUnlisted="true">
                    <add verb="OPTIONS" allowed="false" />
                    <add verb="TRACE" allowed="false" />
                    <add verb="DELETE" allowed="false" />
                    <add verb="PUT" allowed="false" />
                </verbs>
            </requestFiltering>
        </security>
        
        <defaultDocument>
            <files>
                <clear />
                <add value="index.asp" />
                <add value="Default.asp" />
                <add value="Default.htm" />
                <add value="index.htm" />
                <add value="index.html" />
                <add value="iisstart.htm" />
                <add value="default.aspx" />
            </files>
        </defaultDocument>
        <asp enableParentPaths="true" scriptErrorSentToBrowser="true">
            <limits scriptTimeout="00:05:00" />
        </asp>
        
        <!-- ============================================
             V13.3 CDN URL重写规则
             启用条件：cdn_config.asp中CDN_ENABLED=True
             取消下方注释即可启用，无需修改页面代码
             ============================================ -->
        <!--
        <rewrite>
            <rules>
                <rule name="ImageCDN" stopProcessing="false">
                    <match url="^images/(.*)$" />
                    <conditions>
                        <add input="{HTTP_HOST}" pattern="^localhost$" negate="true" />
                    </conditions>
                    <action type="Redirect" url="https://cdn.perfumeshop.com/images/{R:1}" redirectType="Temporary" />
                </rule>
                <rule name="CSSCDN" stopProcessing="false">
                    <match url="^css/(.*)$" />
                    <conditions>
                        <add input="{HTTP_HOST}" pattern="^localhost$" negate="true" />
                    </conditions>
                    <action type="Redirect" url="https://cdn.perfumeshop.com/css/{R:1}" redirectType="Temporary" />
                </rule>
                <rule name="JSCDN" stopProcessing="false">
                    <match url="^js/(.*)$" />
                    <conditions>
                        <add input="{HTTP_HOST}" pattern="^localhost$" negate="true" />
                    </conditions>
                    <action type="Redirect" url="https://cdn.perfumeshop.com/js/{R:1}" redirectType="Temporary" />
                </rule>
            </rules>
        </rewrite>
        -->
    </system.webServer>
</configuration>
