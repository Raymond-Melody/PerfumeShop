# Qoder AI assistant config
.qoder/

# === Classic ASP 项目排除规则 ===

# Access 数据库文件（不应进入版本控制）
*.mdb
*.accdb
*.ldb

# 数据库备份目录（全部排除）
database/backups/
database/sqldata/

# SSL 证书（安全）
*.pfx
*.pem
*.key
*.crt

# 日志文件
*.log
debug_checkout.log
admin/purchase/price_debug.log

# 临时备份目录
backup_*/
*_backup/

# 调试/临时 SQL
db_check.sql
*.tmp.sql

# Diff 文件
product_review_diff.txt

# 调试 HTML
ingredients_feature_guide.html

# 根目录截图（保留 images/ 目录）
/*.png

# 错误报告文件
/*.txt

# 测试脚本（保留 backup_database.ps1 等正式脚本）
test_*.ps1
debug_*.ps1
check_*.ps1
kill_*.ps1

# 调试 ASP 文件
setup/debug_token.asp
includes/test_*.asp
includes/config_*.asp
includes/cfg_*.asp

# 临时/缓存文件
*.tmp
*.temp
~*
*.~*asp

# 上传目录中的用户文件（保留目录结构）
images/uploads/*
!images/uploads/.gitkeep

# 操作系统文件
Thumbs.db
Desktop.ini
[Dd]esktop.ini
