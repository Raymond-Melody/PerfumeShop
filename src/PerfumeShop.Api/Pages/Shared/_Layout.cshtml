<body data-theme="light" class="theme-light has-mobile-nav has-bottom-nav">
    <script>
        /* V19: 主题初始化 — localStorage + Cookie 双存储，SSR 友好 */
        (function(){
            var THEME_KEY = 'perfumeshop_theme';
            var saved = localStorage.getItem(THEME_KEY);
            var cookieTheme = (document.cookie.match(/(?:^|;)\s*perfumeshop_theme=([^;]+)/) || [])[1];
            var theme = saved || cookieTheme;
            if (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                theme = 'dark';
            }
            if (!theme) theme = 'light';
            document.body.setAttribute('data-theme', theme);
            document.body.className = document.body.className.replace(/theme-(light|dark)/g, '') + ' theme-' + theme;
            /* 同步写入 Cookie 供 SSR 使用 */
            document.cookie = 'perfumeshop_theme=' + theme + '; path=/; max-age=31536000; SameSite=Lax';
        })();
    </script>
