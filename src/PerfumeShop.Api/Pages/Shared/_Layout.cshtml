    <!-- V19: 导航栏 active 状态检测（复刻 V18 header.asp） -->
    <script>
    (function() {
        var currentPath = window.location.pathname.toLowerCase().replace(/\/$/, '') || '/';
        var navAnchors = document.querySelectorAll('.main-nav .nav-list > li > a');
        var bestMatch = null, bestScore = 0;
        navAnchors.forEach(function(a) {
            var href = a.getAttribute('href');
            if (!href) return;
            var hrefNorm = href.toLowerCase().replace(/\/$/, '');
            var hrefPath = hrefNorm.split('?')[0];
            if (currentPath === hrefPath || currentPath === hrefNorm) {
                a.classList.add('active');
                bestMatch = a; bestScore = 100;
            } else if (hrefPath !== '/' && hrefPath !== '' && currentPath.indexOf(hrefPath) === 0) {
                var score = hrefPath.length;
                if (score > bestScore) { bestMatch = a; bestScore = score; }
            }
        });
        if (bestMatch && bestScore < 100 && bestScore > 0) {
            bestMatch.classList.add('active');
        }
    })();
    </script>

    <!-- V19: 动态溢出检测 — 导航栏超宽时自动切换汉堡菜单（复刻 V18 三阶段） -->
    <script>
    (function() {
        'use strict';
        var mainNav = document.querySelector('.main-nav');
        var navList = document.querySelector('.nav-list');
        var desktopBtn = document.getElementById('desktopHamburgerBtn');
        if (!mainNav || !navList) return;

        var container = mainNav.querySelector('.container');
        var body = document.body;
        var checking = false;
        var isResizeChecking = false;

        function measureOverflow() {
            if (mainNav.offsetParent === null) return null;
            var listWidth = navList.scrollWidth;
            var containerWidth = container ? container.clientWidth : mainNav.clientWidth;
            if (containerWidth <= 0) return null;
            return listWidth > containerWidth + 4;
        }

        function applyOverflow(overflows) {
            if (overflows) {
                body.classList.add('nav-overflow');
            } else {
                body.classList.remove('nav-overflow');
            }
        }

        function checkOverflow(allowRemove) {
            if (checking) return;
            checking = true;
            requestAnimationFrame(function() {
                if (!allowRemove && body.classList.contains('nav-overflow')) {
                    checking = false;
                    return;
                }
                var overflows = measureOverflow();
                if (overflows === null) { checking = false; return; }
                applyOverflow(overflows);
                checking = false;
            });
        }

        /* 初始检测 */
        (function initCheck() {
            if (checking) return;
            checking = true;
            requestAnimationFrame(function() {
                var overflows = measureOverflow();
                if (overflows !== null) applyOverflow(overflows);
                checking = false;
            });
        })();

        /* ResizeObserver：仅检测缩小方向 */
        if (container && window.ResizeObserver) {
            var ro = new ResizeObserver(function(entries) {
                if (isResizeChecking) return;
                if (!body.classList.contains('nav-overflow')) {
                    checkOverflow(false);
                }
            });
            ro.observe(container);
        }

        /* 窗口 resize：完整检测 */
        var resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function() {
                if (checking) return;
                checking = true;
                isResizeChecking = true;
                var hadOverflow = body.classList.contains('nav-overflow');
                if (hadOverflow) body.classList.remove('nav-overflow');
                var overflows = measureOverflow();
                if (overflows === null) {
                    if (hadOverflow) body.classList.add('nav-overflow');
                } else {
                    applyOverflow(overflows);
                }
                isResizeChecking = false;
                checking = false;
            }, 100);
        });
    })();
    </script>

