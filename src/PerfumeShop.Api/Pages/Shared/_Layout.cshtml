        .user-info.dropdown { position: relative; }
        .user-info.dropdown .dropdown-menu {
            display: none; position: absolute; top: 100%; right: 0;
            background: #fff; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            min-width: 180px; z-index: 1000; padding: 8px 0; margin-top: 8px;
        }
        .user-info.dropdown:hover .dropdown-menu,
