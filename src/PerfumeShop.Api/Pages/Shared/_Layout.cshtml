        .theme-toggle-btn {
            background: none; border: none; color: rgba(255,255,255,0.85);
            cursor: pointer; font-size: 1rem; padding: 6px 8px; margin-left: 10px;
            transition: color 0.2s, transform 0.2s; border-radius: 50%;
        }
        .theme-toggle-btn:hover { color: #fff; transform: rotate(15deg); }

