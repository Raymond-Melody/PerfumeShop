    <style>
        /* 品牌按钮 - 全站统一 */
        .btn-brand, a.btn-brand {
            background: var(--dt-color-primary, var(--primary-color, #8B4513));
            color: #fff; border: none;
            padding: var(--btn-padding-x-md, 18px) var(--btn-padding-x-lg, 24px);
            border-radius: var(--dt-radius-full, 9999px);
            cursor: pointer; font-weight: var(--dt-font-weight-medium, 500);
            transition: background var(--dt-transition-fast, 150ms ease);
            display: inline-flex; align-items: center; gap: 6px;
            text-decoration: none;
        }
        .btn-brand:hover { background: var(--dt-color-primary-hover, var(--primary-hover, #6B3410)); }
        .btn-outline-brand {
            background: transparent;
            color: var(--dt-color-primary, var(--primary-color, #8B4513));
            border: 2px solid var(--dt-color-primary, var(--primary-color, #8B4513));
            padding: var(--btn-padding-x-md, 18px) var(--btn-padding-x-lg, 24px);
            border-radius: var(--dt-radius-full, 9999px);
            cursor: pointer; font-weight: var(--dt-font-weight-medium, 500);
            transition: all var(--dt-transition-fast, 150ms ease);
            display: inline-flex; align-items: center; gap: 6px;
            text-decoration: none;
        }
