@page "/group-buy"
@model PerfumeShop.Api.Pages.GroupBuyModel
@{ ViewData["Title"] = "拼团优惠"; }

<section class="py-4">
    <div class="container">
        <h2 class="mb-4"><i class="bi bi-people-fill" style="color:var(--brand)"></i> 拼团优惠</h2>
        <p class="text-muted mb-4">邀请好友一起拼团，享受超低价格！</p>

        @if (!Model.Plans.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people display-1 text-muted"></i>
                <p class="text-muted mt-3">暂无拼团活动</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var plan in Model.Plans)
                {
                    var prod = Model.Products.GetValueOrDefault(plan.ProductId);
                    <div class="col-md-4 col-sm-6">
                        <div class="card product-card h-100">
                            <img class="card-img-top" src="@(prod?.ImageUrl ?? "/images/default-product.svg")" alt="" />
                            <div class="card-body">
                                <h5>@(prod?.ProductName ?? "商品")</h5>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="price" style="font-size:1.5rem">¥@plan.GroupPrice.ToString("F2")</span>
                                    <span class="badge bg-primary">@plan.TeamSize 人成团</span>
                                </div>
                                <p class="small text-muted mb-2">
                                    <i class="bi bi-clock"></i> 开团后 @plan.DurationHours 小时内有效
                                </p>
                                <p class="small text-muted">
                                    购买数量: @plan.MinUnit ~ @plan.MaxUnit 件
                                </p>
                                <a href="/product/@plan.ProductId" class="btn btn-brand w-100">去开团</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
