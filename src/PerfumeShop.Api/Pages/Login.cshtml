@page "/login"
@model PerfumeShop.Api.Pages.LoginModel
@{ ViewData["Title"] = "会员登录"; Layout = "_Layout"; }

@section Styles {
<style>
.auth-page { padding: 60px 0; }
.auth-container { display: flex; gap: 40px; max-width: 900px; margin: 0 auto; padding: 0 20px; }
.auth-card { flex: 1; background: #fff; border-radius: 12px; padding: 40px; box-shadow: 0 2px 16px rgba(0,0,0,0.08); max-width: 480px; }
.auth-header h1 { font-size: 24px; margin-bottom: 8px; color: #333; }
.auth-header p { color: #888; margin-bottom: 24px; font-size: 14px; }
.auth-form .form-group { margin-bottom: 18px; }
.auth-form label { display: block; font-weight: 500; margin-bottom: 6px; color: #444; font-size: 14px; }
.auth-form label i { margin-right: 6px; color: var(--dt-color-primary, #8B4513); width: 16px; text-align: center; }
.auth-form input[type="text"],
.auth-form input[type="email"],
.auth-form input[type="password"] { width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; transition: border-color 0.2s; box-sizing: border-box; }
.auth-form input:focus { outline: none; border-color: var(--dt-color-primary, #8B4513); box-shadow: 0 0 0 3px rgba(139,69,19,0.1); }
.password-input { position: relative; }
.password-input input { padding-right: 44px; }
.toggle-password { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #999; cursor: pointer; font-size: 16px; }
.form-options { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-size: 14px; }
.checkbox-label { display: flex; align-items: center; gap: 8px; color: #555; cursor: pointer; }
.forgot-link { color: var(--dt-color-primary, #8B4513); text-decoration: none; }
.forgot-link:hover { text-decoration: underline; }
.btn-block { width: 100%; justify-content: center; }
.auth-divider { text-align: center; margin: 24px 0; position: relative; }
.auth-divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #eee; }
.auth-divider span { background: #fff; padding: 0 16px; color: #999; position: relative; font-size: 14px; }
.auth-footer { text-align: center; margin-top: 16px; }
.auth-footer a { color: var(--dt-color-primary, #8B4513); font-weight: 500; }
.auth-footer .auth-notice { color: #999; font-size: 12px; margin-top: 8px; }
.auth-side { flex: 0 0 300px; }
.auth-promo { background: linear-gradient(135deg, #f8f0e8, #f5ebe0); border-radius: 12px; padding: 40px 30px; text-align: center; height: 100%; }
.auth-promo > i { font-size: 48px; color: var(--dt-color-primary, #8B4513); margin-bottom: 16px; }
.auth-promo h2 { font-size: 20px; margin-bottom: 8px; color: #333; }
.auth-promo p { color: #888; font-size: 14px; margin-bottom: 20px; }
.promo-features { list-style: none; padding: 0; text-align: left; }
.promo-features li { padding: 8px 0; color: #555; font-size: 14px; }
.promo-features li i { color: #4CAF50; margin-right: 10px; }
.alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
.alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.alert-success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
.alert i { margin-right: 8px; }
@@media (max-width: 768px) {
    .auth-container { flex-direction: column; }
    .auth-side { flex: auto; }
    .auth-card { max-width: 100%; }
}
</style>
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1><i class="fas fa-sign-in-alt"></i> 欢迎回来</h1>
                <p>登录您的账户，继续定制香氛之旅</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> @Model.Error</div>
            }
            @if (!string.IsNullOrEmpty(Model.Success))
            {
                <div class="alert alert-success"><i class="fas fa-check-circle"></i> @Model.Success</div>
            }

            <form method="post" class="auth-form" id="loginForm">
                <div class="form-group">
                    <label for="email"><i class="fas fa-user"></i> 用户名/邮箱</label>
                    <input type="text" id="email" name="email" placeholder="请输入用户名或邮箱" required />
                </div>

                <div class="form-group">
                    <label for="password"><i class="fas fa-lock"></i> 密码</label>
                    <div class="password-input">
                        <input type="password" id="password" name="password" placeholder="请输入密码" required />
                        <button type="button" class="toggle-password" onclick="togglePassword()">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" name="remember" value="true" /> 记住我
                    </label>
                    <a href="/user/forgot-password" class="forgot-link">忘记密码？</a>
                </div>

                <button type="submit" class="btn btn-brand btn-lg btn-block">
                    <i class="fas fa-sign-in-alt"></i> 登录
                </button>
            </form>

            <div class="auth-footer">
                <p>还没有账户？ <a href="/user/register">立即注册</a></p>
                <p class="auth-notice"><i class="fas fa-info-circle"></i> 本平台采用会员推荐制，需通过现有会员推荐链接注册</p>
            </div>
        </div>

        <div class="auth-side">
            <div class="auth-promo">
                <i class="fas fa-spray-can"></i>
                <h2>香氛定制</h2>
                <p>定制你的专属香水，让气味成为你独特的名片</p>
                <ul class="promo-features">
                    <li><i class="fas fa-check"></i> 个性化香调搭配</li>
                    <li><i class="fas fa-check"></i> 优质天然原料</li>
                    <li><i class="fas fa-check"></i> 专属瓶身定制</li>
                    <li><i class="fas fa-check"></i> 会员专属优惠</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePassword() {
    var pwd = document.getElementById('password');
    var icon = document.querySelector('.toggle-password i');
    if (pwd.type === 'password') {
        pwd.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        pwd.type = 'password';
        icon.className = 'fas fa-eye';
    }
}
</script>
}
