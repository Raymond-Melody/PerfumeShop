@page
@model PerfumeShop.Api.Pages.ProductModel
@{ ViewData["Title"] = Model.Product?.ProductName ?? "商品详情"; }

@if (Model.Product == null)
{
    <div class="container py-5 text-center">
        <h3>商品不存在或已下架</h3>
        <a href="/products" class="btn btn-brand mt-3">返回商品列表</a>
    </div>
}
else
{
    <section class="py-4">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">首页</a></li>
                    <li class="breadcrumb-item"><a href="/products">全部商品</a></li>
                    <li class="breadcrumb-item active">@Model.Product.ProductName</li>
                </ol>
            </nav>

            <div class="row g-5">
                <!-- 商品图片 -->
                <div class="col-md-5">
                    <div class="position-relative">
                        <img src="@(Model.Product.ImageUrl ?? "/images/default-product.svg")"
                             class="img-fluid rounded-3 shadow" alt="@Model.Product.ProductName"
                             style="width:100%; max-height:500px; object-fit:cover;" />
                        @if (Model.Product.Engravable == true)
                        {
                            <span class="badge bg-info position-absolute top-0 end-0 m-3 p-2">
                                <i class="bi bi-pencil"></i> 支持刻字
                            </span>
                        }
                    </div>
                </div>

                <!-- 商品信息 -->
                <div class="col-md-7">
                    <h2>@Model.Product.ProductName</h2>
                    <span class="badge bg-secondary me-2">@(Model.Product.Category ?? "香水")</span>
                    <span class="badge bg-outline-secondary">@(Model.Product.ProductType == "custom" ? "定制" : "成品")</span>

                    <div class="my-4">
                        <span class="price" style="font-size:2rem;">¥@Model.Product.BasePrice.ToString("F2")</span>
                        @if (Model.Product.Bomcost.HasValue)
                        {
                            <small class="text-muted ms-2">参考价 ¥@((Model.Product.BasePrice * 1.3m).ToString("F2"))</small>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Product.Description))
                    {
                        <p class="text-muted">@Model.Product.Description</p>
                    }

                    @if (Model.Product.Engravable == true)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-pencil"></i> 此商品支持刻字服务
                            @if (Model.Product.EngravingPrice.HasValue && Model.Product.EngravingPrice > 0)
                            {
                                <span class="ms-2">(刻字费 +¥@Model.Product.EngravingPrice.Value.ToString("F2"))</span>
                            }
                        </div>
                    }

                    <!-- 加入购物车 -->
                    <div class="d-flex gap-3 mt-4">
                        <a href="/cart?add=@Model.Product.ProductId" class="btn btn-brand btn-lg px-5">
                            <i class="bi bi-cart-plus"></i> 加入购物车
                        </a>
                        <a href="/checkout?product=@Model.Product.ProductId" class="btn btn-outline-primary btn-lg px-5">
                            立即购买
                        </a>
                    </div>

                    <!-- 商品信息表 -->
                    <table class="table table-borderless mt-4">
                        <tr><th width="100" class="text-muted">类型</th><td>@(Model.Product.ProductType == "custom" ? "定制香水" : "成品香水")</td></tr>
                        <tr><th class="text-muted">分类</th><td>@(Model.Product.Category ?? "-")</td></tr>
                        @if (!string.IsNullOrEmpty(Model.Product.BaseIngredients))
                        {
                            <tr><th class="text-muted">主要成分</th><td>@Model.Product.BaseIngredients</td></tr>
                        }
                    </table>
                </div>
            </div>

            @* 相关秒杀活动 *@
            @if (Model.ActiveFlashSale != null)
            {
                <div class="alert alert-danger mt-4">
                    <h5><i class="bi bi-lightning-charge"></i> 限时秒杀进行中！</h5>
                    <p class="mb-1">秒杀价: <strong>¥@Model.ActiveFlashSale.FlashPrice.ToString("F2")</strong>
                       <span class="text-decoration-line-through text-muted ms-2">¥@Model.Product.BasePrice.ToString("F2")</span>
                    </p>
                    <p class="mb-0 small">剩余库存: @Model.ActiveFlashSale.Stock | 限购: @Model.ActiveFlashSale.LimitPerUser 件/人</p>
                </div>
            }
        </div>
    </section>
}
