@page "/community"
@model PerfumeShop.Api.Pages.CommunityModel
@{ ViewData["Title"] = "香氛社区"; }

<section class="py-4">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-people" style="color:var(--brand)"></i> 香氛社区</h2>
            <a href="/login?returnUrl=/community/post" class="btn btn-brand"><i class="bi bi-pencil-square"></i> 发帖</a>
        </div>

        <!-- 分类筛选 -->
        <div class="mb-4">
            <div class="btn-group" role="group">
                <a href="/community" class="btn @(Model.Filter == null ? "btn-brand" : "btn-outline-secondary")">全部</a>
                <a href="/community?type=Review" class="btn @(Model.Filter == "Review" ? "btn-brand" : "btn-outline-secondary")">香评</a>
                <a href="/community?type=Share" class="btn @(Model.Filter == "Share" ? "btn-brand" : "btn-outline-secondary")">分享</a>
                <a href="/community?type=Question" class="btn @(Model.Filter == "Question" ? "btn-brand" : "btn-outline-secondary")">问答</a>
                <a href="/community?type=Diary" class="btn @(Model.Filter == "Diary" ? "btn-brand" : "btn-outline-secondary")">日记</a>
            </div>
        </div>

        @if (!Model.Posts.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-square-text display-1 text-muted"></i>
                <p class="text-muted mt-3">暂无内容，快来发表第一篇吧！</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var post in Model.Posts)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 post-card">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-2">
                                    @if (post.IsPinned)
                                    {
                                        <span class="badge bg-danger me-2">置顶</span>
                                    }
                                    <span class="badge bg-light text-dark">@post.PostType</span>
                                </div>
                                <h5 class="card-title">@post.Title</h5>
                                <p class="card-text text-muted small">@post.Content.Substring(0, Math.Min(100, post.Content.Length))...</p>
                                @if (!string.IsNullOrEmpty(post.Tags))
                                {
                                    <div class="mb-2">
                                        @foreach (var tag in post.Tags.Split(','))
                                        {
                                            <span class="badge bg-light text-muted me-1">#@tag.Trim()</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="card-footer bg-transparent d-flex justify-content-between small text-muted">
                                <span>@post.CreatedAt.ToString("yyyy-MM-dd")</span>
                                <span>
                                    <i class="bi bi-heart"></i> @post.LikeCount
                                    <i class="bi bi-chat ms-2"></i> @post.CommentCount
                                    <i class="bi bi-eye ms-2"></i> @post.ViewCount
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- 分页 -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="/community?page=@i@(Model.Filter != null ? $"&type={Model.Filter}" : "")">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</section>

<style>
    .post-card:hover { box-shadow: 0 4px 15px rgba(0,0,0,0.1); transform: translateY(-2px); transition: all 0.2s; }
</style>
