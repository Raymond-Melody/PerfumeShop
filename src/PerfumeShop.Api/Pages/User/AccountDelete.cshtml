@page "/user/account-delete"
@model PerfumeShop.Api.Pages.User.AccountDeleteModel
@{ ViewData["Title"] = "账户注销"; }

<section class="py-4">
    <div class="container" style="max-width:700px;">
        <nav class="breadcrumb-nav mb-3" style="font-size:.85rem;color:#999;">
            <a href="/" style="color:#8B4513;text-decoration:none;">首页</a> /
            <a href="/user" style="color:#8B4513;text-decoration:none;">个人中心</a> /
            <span>账户注销</span>
        </nav>

        <!-- 警告说明 -->
        <div class="card p-4 mb-4" style="border-radius:12px;border:2px solid #fce4ec;">
            <div class="text-center mb-3">
                <i class="fas fa-exclamation-triangle" style="font-size:3rem;color:#c62828;"></i>
                <h2 class="mt-2" style="color:#c62828;">账户注销</h2>
                <p class="text-muted mb-0">此操作不可恢复，请谨慎操作</p>
            </div>
            <div class="p-3" style="background:#fff3e0;border-radius:8px;border:1px solid #ffe0b2;">
                <h6 style="color:#e65100;"><i class="fas fa-info-circle"></i> 注销须知</h6>
                <ul class="mb-0 small" style="color:#555;">
                    <li class="mb-1">您的账户将被标记为待删除状态</li>
                    <li class="mb-1">提交后有 <strong>30 天冷静期</strong>，期间可联系客服撤销注销</li>
                    <li class="mb-1">冷静期结束后，您的数据将被永久删除且无法恢复</li>
                    <li class="mb-0">您的积分、优惠券、订阅等权益也将一并清除</li>
                </ul>
            </div>
        </div>

        <!-- 注销表单 -->
        <div class="card p-4" style="border-radius:12px;">
            <h5 class="mb-3">确认注销</h5>
            <div id="deleteResult"></div>

            <form id="deleteForm" onsubmit="return submitDelete()">
                <div class="mb-3">
                    <label class="form-label">请输入登录密码以确认操作 <span class="text-danger">*</span></label>
                    <input type="password" id="password" class="form-control" required placeholder="输入密码" />
                </div>

                <div class="mb-3">
                    <label class="form-label">数据清理选项</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="keepOrders" id="keepYes" value="true" checked />
                        <label class="form-check-label" for="keepYes">保留匿名化订单历史（用于统计分析）</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="keepOrders" id="keepNo" value="false" />
                        <label class="form-check-label" for="keepNo">全部删除（包括订单记录）</label>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="confirmCheck" required />
                        <label class="form-check-label" for="confirmCheck">
                            我已了解上述风险，确认要注销我的账户
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn w-100" style="background:#c62828;color:#fff;padding:10px;border-radius:8px;font-weight:500;">
                    <i class="fas fa-user-times"></i> 提交注销申请
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
<script>
function submitDelete() {
    var password = document.getElementById('password').value;
    var keepOrders = document.querySelector('input[name="keepOrders"]:checked').value === 'true';
    var confirmed = document.getElementById('confirmCheck').checked;
    if (!confirmed) { alert('请先勾选确认风险复选框'); return false; }

    fetch('/api/user/1/account-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: password, keepOrderHistory: keepOrders })
    }).then(r => r.json())
      .then(d => {
          var el = document.getElementById('deleteResult');
          if (d.success) {
              el.innerHTML = '<div class="alert alert-success p-3 mb-3" style="background:#e8f5e9;color:#2e7d32;border-radius:8px;">' +
                  '<i class="fas fa-check-circle"></i> ' + d.message + '</div>';
              document.getElementById('deleteForm').style.display = 'none';
          } else {
              el.innerHTML = '<div class="alert alert-error p-3 mb-3" style="background:#fce4ec;color:#c62828;border-radius:8px;">' +
                  '<i class="fas fa-exclamation-circle"></i> ' + (d.message || '操作失败') + '</div>';
          }
      });
    return false;
}
</script>
}
