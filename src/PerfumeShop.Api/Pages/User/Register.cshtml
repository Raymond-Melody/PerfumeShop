@page "/user/register"
@model PerfumeShop.Api.Pages.User.RegisterModel
@{ ViewData["Title"] = "会员注册"; Layout = "_Layout"; }

@section Styles {
<style>
.auth-page { padding: 40px 0; }
.auth-container { display: flex; gap: 40px; max-width: 960px; margin: 0 auto; padding: 0 20px; }
.auth-card { flex: 1; background: #fff; border-radius: 12px; padding: 40px; box-shadow: 0 2px 16px rgba(0,0,0,0.08); }
.auth-card.register-card { max-width: 560px; }
.auth-header h1 { font-size: 24px; margin-bottom: 8px; color: #333; }
.auth-header p { color: #888; margin-bottom: 20px; }
.auth-form .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.auth-form .form-group { margin-bottom: 18px; }
.auth-form label { display: block; font-weight: 500; margin-bottom: 6px; color: #444; font-size: 14px; }
.auth-form label i { margin-right: 6px; color: var(--dt-color-primary, #8B4513); width: 16px; text-align: center; }
.auth-form input[type="text"],
.auth-form input[type="email"],
.auth-form input[type="password"],
.auth-form input[type="tel"] {
    width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; transition: border-color 0.2s; box-sizing: border-box;
}
.auth-form input:focus { outline: none; border-color: var(--dt-color-primary, #8B4513); box-shadow: 0 0 0 3px rgba(139,69,19,0.1); }
.form-options { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.checkbox-label { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #555; cursor: pointer; }
.checkbox-label a { color: var(--dt-color-primary, #8B4513); }
.btn-block { width: 100%; justify-content: center; }
.auth-footer { text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee; }
.auth-footer a { color: var(--dt-color-primary, #8B4513); font-weight: 500; }
.auth-side { flex: 0 0 320px; }
.auth-promo { background: linear-gradient(135deg, #f8f0e8, #f5ebe0); border-radius: 12px; padding: 40px 30px; text-align: center; height: 100%; }
.auth-promo > i { font-size: 48px; color: var(--dt-color-primary, #8B4513); margin-bottom: 16px; }
.auth-promo h2 { font-size: 20px; margin-bottom: 8px; color: #333; }
.auth-promo p { color: #888; font-size: 14px; margin-bottom: 20px; }
.promo-features { list-style: none; padding: 0; text-align: left; }
.promo-features li { padding: 8px 0; color: #555; font-size: 14px; }
.promo-features li i { color: #4CAF50; margin-right: 10px; }
.alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; }
.alert-error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.alert-success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
.alert i { margin-right: 8px; }
.password-strength { margin-top: 6px; font-size: 12px; }
.password-strength .bar { height: 4px; border-radius: 2px; background: #eee; margin-top: 4px; }
.password-strength .bar .fill { height: 100%; border-radius: 2px; transition: width 0.3s, background 0.3s; }
.referral-info-box { text-align: center; padding: 30px 20px; }
@@media (max-width: 768px) {
    .auth-container { flex-direction: column; }
    .auth-side { flex: auto; }
    .auth-form .form-row { grid-template-columns: 1fr; }
}
</style>
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card register-card">
            <div class="auth-header">
                <h1><i class="fas fa-user-plus"></i> @Model.LocaleService.T("register.title")</h1>
                <p>@Model.LocaleService.T("register.subtitle")</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> @Model.Error</div>
            }
            @if (!string.IsNullOrEmpty(Model.Success))
            {
                <div class="alert alert-success"><i class="fas fa-check-circle"></i> @Model.Success</div>
            }

            <form method="post" class="auth-form" id="registerForm">
                <div class="form-row">
                    <div class="form-group">
                        <label for="username"><i class="fas fa-user"></i> @Model.LocaleService.T("register.username")</label>
                        <input type="text" id="username" name="username" asp-for="Input.Username" placeholder="@Model.LocaleService.T("register.username_placeholder")" required minlength="3" maxlength="20" />
                    </div>
                    <div class="form-group">
                        <label for="email"><i class="fas fa-envelope"></i> @Model.LocaleService.T("register.email")</label>
                        <input type="email" id="email" name="email" asp-for="Input.Email" placeholder="@Model.LocaleService.T("register.email_placeholder")" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="password"><i class="fas fa-lock"></i> @Model.LocaleService.T("register.password")</label>
                        <input type="password" id="password" name="password" asp-for="Input.Password" placeholder="@Model.LocaleService.T("register.password_placeholder")" required minlength="8" />
                        <div class="password-strength" id="pwdStrength">
                            <div class="bar"><div class="fill" id="pwdStrengthBar" style="width:0%;background:#eee;"></div></div>
                            <span id="pwdStrengthText"></span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword"><i class="fas fa-lock"></i> @Model.LocaleService.T("register.confirm_password")</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" asp-for="Input.ConfirmPassword" placeholder="@Model.LocaleService.T("register.confirm_placeholder")" required />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="fullName"><i class="fas fa-id-card"></i> @Model.LocaleService.T("register.fullname")</label>
                        <input type="text" id="fullName" name="fullName" asp-for="Input.FullName" placeholder="@Model.LocaleService.T("register.fullname_placeholder")" />
                    </div>
                    <div class="form-group">
                        <label for="phone"><i class="fas fa-phone"></i> @Model.LocaleService.T("register.phone")</label>
                        <input type="tel" id="phone" name="phone" asp-for="Input.Phone" placeholder="@Model.LocaleService.T("register.phone_placeholder")" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="referralCode"><i class="fas fa-gift"></i> @Model.LocaleService.T("register.referral_code")</label>
                    <input type="text" id="referralCode" name="referralCode" asp-for="Input.ReferralCode" placeholder="@Model.LocaleService.T("register.referral_placeholder")" />
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="agree" required />
                        @Model.LocaleService.T("register.agree_prefix") <a href="/terms" target="_blank">@Model.LocaleService.T("register.terms")</a> @Model.LocaleService.T("register.agree_and") <a href="/privacy" target="_blank">@Model.LocaleService.T("register.privacy")</a>
                    </label>
                </div>

                <button type="submit" class="btn btn-brand btn-lg btn-block">
                    <i class="fas fa-user-plus"></i> @Model.LocaleService.T("register.submit")
                </button>
            </form>

            <div class="auth-footer">
                <p>@Model.LocaleService.T("register.has_account") <a href="/login">@Model.LocaleService.T("register.login_now")</a></p>
            </div>
        </div>

        <div class="auth-side">
            <div class="auth-promo">
                <i class="fas fa-gift"></i>
                <h2>@Model.LocaleService.T("register.member_benefits")</h2>
                <p>@Model.LocaleService.T("register.member_subtitle")</p>
                <ul class="promo-features">
                    <li><i class="fas fa-check"></i> @Model.LocaleService.T("register.benefit1")</li>
                    <li><i class="fas fa-check"></i> @Model.LocaleService.T("register.benefit2")</li>
                    <li><i class="fas fa-check"></i> @Model.LocaleService.T("register.benefit3")</li>
                    <li><i class="fas fa-check"></i> @Model.LocaleService.T("register.benefit4")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var pwd = document.getElementById('password');
    var bar = document.getElementById('pwdStrengthBar');
    var txt = document.getElementById('pwdStrengthText');
    if (!pwd) return;
    pwd.addEventListener('input', function() {
        var v = this.value, score = 0;
        if (v.length >= 8) score++;
        if (/[A-Z]/.test(v)) score++;
        if (/[a-z]/.test(v)) score++;
        if (/\d/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;
        var pct = (score / 5) * 100;
        bar.style.width = pct + '%';
        bar.style.background = score <= 2 ? '#dc2626' : score <= 3 ? '#f59e0b' : '#16a34a';
        txt.textContent = score <= 1 ? '弱' : score <= 3 ? '中' : '强';
        txt.style.color = bar.style.background;
    });
    document.getElementById('registerForm').addEventListener('submit', function(e) {
        var p = document.getElementById('password').value;
        var c = document.getElementById('confirmPassword').value;
        if (p !== c) { e.preventDefault(); alert('两次输入的密码不一致'); return false; }
        if (p.length < 8) { e.preventDefault(); alert('密码长度至少8个字符'); return false; }
        if (!/[A-Z]/.test(p) || !/[a-z]/.test(p) || !/\d/.test(p)) {
            e.preventDefault(); alert('密码必须包含大写字母、小写字母和数字'); return false;
        }
    });
})();
</script>
}
