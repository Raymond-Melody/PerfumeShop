@page "/user/kol-products"
@model PerfumeShop.Api.Pages.User.KolProductsModel
@{ ViewData["Title"] = "KOL 推荐商品"; }

<section class="py-4">
    <div class="container">
        <nav class="breadcrumb-nav mb-3" style="font-size:.85rem;color:#999;">
            <a href="/" style="color:#8B4513;text-decoration:none;">首页</a> /
            <a href="/user" style="color:#8B4513;text-decoration:none;">个人中心</a> /
            <span>KOL 推荐</span>
        </nav>

        <h2 class="mb-4" style="color:var(--brand);"><i class="fas fa-fire"></i> KOL 推荐商品</h2>

        <!-- 筛选 -->
        <form method="get" class="row g-2 mb-4">
            <div class="col-md-3">
                <input type="text" name="keyword" value="@Model.FilterKeyword" placeholder="搜索关键词..." class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select form-select-sm">
                    <option value="">全部品类</option>
                    <option value="KOL推荐" selected="@(Model.FilterCategory == "KOL推荐")">KOL推荐</option>
                    <option value="限定款" selected="@(Model.FilterCategory == "限定款")">限定款</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-brand w-100" style="border-radius:6px;">筛选</button>
            </div>
        </form>

        @if (!Model.Products.Any())
        {
            <div class="text-center py-5" style="color:#bbb;">
                <i class="fas fa-box-open" style="font-size:3rem;display:block;margin-bottom:12px;"></i>
                <h5 style="color:#888;">暂无 KOL 推荐商品</h5>
                <p>还没有 KOL 推荐的商品，请稍后再来</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var p in Model.Products)
                {
                    var img = string.IsNullOrEmpty(p.ImageUrl) ? "/images/default-product.svg" : p.ImageUrl;
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100" style="border-radius:12px;overflow:hidden;transition:transform .2s,box-shadow .2s;">
                            <img src="@img" alt="@p.ProductName" loading="lazy"
                                 style="height:180px;object-fit:cover;background:#f5f5f5;"
                                 onerror="this.src='/images/default-product.svg'" />
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title mb-0" style="font-size:.95rem;">@p.ProductName</h6>
                                    <span style="background:linear-gradient(135deg,#ff416c,#ff4b2b);color:#fff;font-size:10px;padding:2px 6px;border-radius:4px;font-weight:600;">KOL</span>
                                </div>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@p.Description</p>
                                }
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <span style="font-size:1.1rem;font-weight:700;color:var(--brand);">¥@p.BasePrice.ToString("F2")</span>
                                    <button class="btn btn-sm btn-brand" style="padding:4px 12px;border-radius:20px;font-size:.8rem;"
                                            onclick="addToCart(@p.ProductId)">
                                        <i class="fas fa-shopping-cart"></i> 加入购物袋
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
<script>
function addToCart(productId) {
    fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId: productId, quantity: 1 })
    }).then(r => r.json())
      .then(d => { if (d.success) alert('已加入购物袋'); else alert(d.message || '添加失败'); });
}
</script>
}
