@page
@model PerfumeShop.Api.Pages.CartModel
@{ ViewData["Title"] = "购物车"; }

<section class="py-4">
    <div class="container">
        <h2 class="mb-4"><i class="bi bi-cart3"></i> 我的购物车</h2>

        @if (!Model.Items.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x display-1 text-muted"></i>
                <p class="text-muted mt-3">购物车是空的</p>
                <a href="/products" class="btn btn-brand">去选购</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>商品</th><th>单价</th><th>数量</th><th>小计</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@(item.Product?.ImageUrl ?? "/images/default-product.svg")" width="50" height="50" style="object-fit:cover;border-radius:8px" />
                                        <span>@(item.Product?.ProductName ?? "商品")</span>
                                    </div>
                                </td>
                                <td>¥@(item.Product?.BasePrice.ToString("F2") ?? "0.00")</td>
                                <td>@item.Quantity</td>
                                <td class="price">¥@((item.Product?.BasePrice * item.Quantity ?? 0).ToString("F2"))</td>
                                <td><a href="/cart?remove=@item.CartId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-4">
                <h4>合计: <span class="price">¥@Model.TotalAmount.ToString("F2")</span></h4>
                <a href="/checkout" class="btn btn-brand btn-lg px-5">去结算</a>
            </div>
        }
    </div>
</section>
