@page "/customize"
@model PerfumeShop.Api.Pages.CustomizeModel
@{ ViewData["Title"] = "定制专属香水"; }

<section class="py-4">
    <div class="container">
        <div class="text-center mb-5">
            <h2><i class="bi bi-palette" style="color:var(--brand)"></i> 定制专属香水</h2>
            <p class="text-muted">选择您喜爱的香调，调配独一无二的专属 fragrance</p>
        </div>

        <form id="customizeForm" method="post" action="/api/v2/customize/submit">
            <div class="row g-4">
                <!-- Step 1: 选择容量 -->
                <div class="col-12">
                    <div class="card p-4">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">1</span> 选择容量</h5>
                        <div class="row g-3">
                            @foreach (var (ml, price) in new[] { ("30ml", 199m), ("50ml", 299m), ("100ml", 499m) })
                            {
                                <div class="col-md-4">
                                    <div class="form-check card p-3 text-center volume-option" style="cursor:pointer">
                                        <input class="form-check-input" type="radio" name="volume" value="@ml" id="vol_@ml" @(ml == "50ml" ? "checked" : "") />
                                        <label class="form-check-label w-100" for="vol_@ml">
                                            <strong style="font-size:1.2rem">@ml</strong><br />
                                            <span class="price">¥@price</span>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Step 2: 选择前调 -->
                <div class="col-12">
                    <div class="card p-4">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">2</span> 选择前调 <small class="text-muted">(选1-2种)</small></h5>
                        <div class="row g-2">
                            @foreach (var note in Model.TopNotes)
                            {
                                <div class="col-lg-3 col-md-4 col-6">
                                    <div class="form-check card p-2 text-center note-option" style="cursor:pointer">
                                        <input class="form-check-input" type="checkbox" name="topNotes" value="@note.NoteId" id="top_@note.NoteId" />
                                        <label class="form-check-label small w-100" for="top_@note.NoteId">
                                            @if (!string.IsNullOrEmpty(note.ImageUrl))
                                            {
                                                <img src="@note.ImageUrl" class="rounded-circle mb-1" width="40" height="40" alt="" />
                                            }
                                            <br />@note.NoteName
                                            @if (note.PriceAddition > 0)
                                            {
                                                <br /><small class="text-danger">+¥@note.PriceAddition</small>
                                            }
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Step 3: 选择中调 -->
                <div class="col-12">
                    <div class="card p-4">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">3</span> 选择中调 <small class="text-muted">(选1-3种，核心香调)</small></h5>
                        <div class="row g-2">
                            @foreach (var note in Model.MiddleNotes)
                            {
                                <div class="col-lg-3 col-md-4 col-6">
                                    <div class="form-check card p-2 text-center note-option" style="cursor:pointer">
                                        <input class="form-check-input" type="checkbox" name="middleNotes" value="@note.NoteId" id="mid_@note.NoteId" />
                                        <label class="form-check-label small w-100" for="mid_@note.NoteId">
                                            @if (!string.IsNullOrEmpty(note.ImageUrl))
                                            {
                                                <img src="@note.ImageUrl" class="rounded-circle mb-1" width="40" height="40" alt="" />
                                            }
                                            <br />@note.NoteName
                                            @if (note.PriceAddition > 0)
                                            {
                                                <br /><small class="text-danger">+¥@note.PriceAddition</small>
                                            }
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Step 4: 选择后调 -->
                <div class="col-12">
                    <div class="card p-4">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">4</span> 选择后调 <small class="text-muted">(选1-2种)</small></h5>
                        <div class="row g-2">
                            @foreach (var note in Model.BaseNotes)
                            {
                                <div class="col-lg-3 col-md-4 col-6">
                                    <div class="form-check card p-2 text-center note-option" style="cursor:pointer">
                                        <input class="form-check-input" type="checkbox" name="baseNotes" value="@note.NoteId" id="base_@note.NoteId" />
                                        <label class="form-check-label small w-100" for="base_@note.NoteId">
                                            @if (!string.IsNullOrEmpty(note.ImageUrl))
                                            {
                                                <img src="@note.ImageUrl" class="rounded-circle mb-1" width="40" height="40" alt="" />
                                            }
                                            <br />@note.NoteName
                                            @if (note.PriceAddition > 0)
                                            {
                                                <br /><small class="text-danger">+¥@note.PriceAddition</small>
                                            }
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Step 5: 刻字服务 -->
                <div class="col-12">
                    <div class="card p-4">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">5</span> 瓶身刻字 <small class="text-muted">(可选，限20字)</small></h5>
                        <input type="text" name="engraving" class="form-control" maxlength="20" placeholder="输入刻字内容，如：For You, With Love" />
                    </div>
                </div>

                <!-- 提交 -->
                <div class="col-12 text-center">
                    <div id="priceSummary" class="mb-3">
                        <span class="fs-4 price">预估价格: ¥299</span>
                    </div>
                    <button type="submit" class="btn btn-brand btn-lg px-5">
                        <i class="bi bi-bag-plus"></i> 加入购物车
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<style>
    .volume-option:has(input:checked),
    .note-option:has(input:checked) {
        border-color: var(--brand);
        background: rgba(124, 77, 255, 0.05);
    }
    .form-check-input:checked { background-color: var(--brand); border-color: var(--brand); }
</style>
