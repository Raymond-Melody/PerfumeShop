@page "/checkout"
@model PerfumeShop.Api.Pages.CheckoutModel
@{ ViewData["Title"] = "确认订单"; }

<section class="py-4">
    <div class="container">
        <h2 class="mb-4"><i class="bi bi-bag-check" style="color:var(--brand)"></i> 确认订单</h2>

        <div class="row g-4">
            <!-- 收货信息 -->
            <div class="col-lg-8">
                <div class="card p-4 mb-4">
                    <h5 class="mb-3"><i class="bi bi-geo-alt"></i> 收货信息</h5>
                    <form id="checkoutForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">收货人</label>
                                <input type="text" name="shippingName" class="form-control" required placeholder="请输入收货人姓名" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">手机号码</label>
                                <input type="tel" name="shippingPhone" class="form-control" required placeholder="请输入手机号码" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">省份/城市</label>
                                <input type="text" name="shippingCity" class="form-control" required placeholder="如：广东省深圳市" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">邮编</label>
                                <input type="text" name="shippingPostalCode" class="form-control" placeholder="可选" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">详细地址</label>
                                <textarea name="shippingAddress" class="form-control" rows="2" required placeholder="街道、门牌号等"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">订单备注</label>
                                <input type="text" name="notes" class="form-control" placeholder="如有特殊要求请在此说明" />
                            </div>
                        </div>
                    </form>
                </div>

                <!-- 商品清单 -->
                <div class="card p-4">
                    <h5 class="mb-3"><i class="bi bi-box-seam"></i> 商品清单 (@Model.Items.Count 件)</h5>
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center py-3 border-bottom">
                            <img src="@(item.ImageUrl ?? "/images/default-product.svg")" class="rounded me-3" width="60" height="60" alt="" />
                            <div class="flex-grow-1">
                                <h6 class="mb-0">@item.ProductName</h6>
                                <small class="text-muted">x @item.Quantity</small>
                            </div>
                            <span class="price">¥@((item.UnitPrice * item.Quantity).ToString("F2"))</span>
                        </div>
                    }
                </div>
            </div>

            <!-- 订单摘要 -->
            <div class="col-lg-4">
                <div class="card p-4 sticky-top" style="top:80px">
                    <h5 class="mb-3">订单摘要</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>商品小计</span>
                        <span>¥@Model.SubTotal.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>运费</span>
                        <span>@(Model.ShippingFee > 0 ? $"¥{Model.ShippingFee:F2}" : "免运费")</span>
                    </div>
                    @if (Model.ShippingFee > 0)
                    {
                        <small class="text-muted d-block mb-2">满 ¥299 免运费，还差 ¥@((299 - Model.SubTotal).ToString("F2"))</small>
                    }
                    <hr />
                    <div class="d-flex justify-content-between mb-3">
                        <strong>合计</strong>
                        <strong class="price fs-4">¥@Model.Total.ToString("F2")</strong>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">支付方式</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="paymentMethod" value="wechat" id="pay_wechat" checked />
                            <label class="form-check-label" for="pay_wechat"><i class="bi bi-wechat text-success"></i> 微信支付</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="paymentMethod" value="alipay" id="pay_alipay" />
                            <label class="form-check-label" for="pay_alipay"><i class="bi bi-alipay text-primary"></i> 支付宝</label>
                        </div>
                    </div>

                    <button type="button" class="btn btn-brand w-100 btn-lg" onclick="submitOrder()">
                        <i class="bi bi-lock"></i> 提交订单
                    </button>
                    <small class="text-muted text-center d-block mt-2">提交即表示同意《用户服务协议》</small>
                </div>
            </div>
        </div>
    </div>
</section>
