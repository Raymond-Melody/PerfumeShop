@page
@model PerfumeShop.Api.Pages.IndexModel
@{ ViewData["Title"] = "首页"; }

<!-- Hero Banner -->
<section class="hero-banner">
    <div class="banner-slider">
        <div class="slide active">
            <div class="slide-content">
                <h1>定制你的专属香氛</h1>
                <p>从前调到后调，每一个选择都是你的独特表达</p>
                <a href="/customize" class="btn-brand" style="font-size:16px;padding:14px 36px;"><i class="fas fa-magic"></i> 开始定制</a>
            </div>
        </div>
    </div>
</section>

<!-- 限时秒杀 -->
@if (Model.ActiveFlashSales.Any())
{
<section class="products-section">
    <div class="container">
        <div class="section-header">
            <h2><i class="fas fa-bolt" style="color:#dc3545"></i> 限时秒杀</h2>
            <p>手慢无！限时特惠抢购</p>
        </div>
        <div class="products-grid">
            @foreach (var fs in Model.ActiveFlashSales.Take(4))
            {
                var prod = Model.FlashSaleProducts.GetValueOrDefault(fs.ProductId);
                <div class="product-card">
                    <div class="product-image">
                        <img src="@(prod?.ImageUrl ?? "/images/default-product.svg")" alt="@(prod?.ProductName ?? "商品")" loading="lazy" />
                        <div class="product-badges">
                            <span class="badge badge-premium"><i class="fas fa-bolt"></i> 秒杀</span>
                        </div>
                        <div class="product-overlay">
                            <a href="/product/@fs.ProductId" class="btn-brand"><i class="fas fa-eye"></i> 立即抢购</a>
                        </div>
                    </div>
                    <div class="product-info">
                        <span class="product-category">限时秒杀</span>
                        <h3><a href="/product/@fs.ProductId">@(prod?.ProductName ?? "商品")</a></h3>
                        <div class="product-price">
                            <span class="price">¥@fs.FlashPrice.ToString("F2")</span>
                            <span class="price-label" style="text-decoration:line-through">¥@(prod?.BasePrice.ToString("F2") ?? "")</span>
                        </div>
                        <div class="product-footer" style="margin-top:8px">
                            <small style="color:#888">已售 @fs.SoldCount</small>
                            <small style="color:#dc3545;font-weight:600">剩余 @(fs.Stock) 件</small>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="section-footer">
            <a href="/flash-sale" class="btn-outline-brand">查看全部秒杀 <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>
}

<!-- 热门商品 -->
<section class="products-section" style="background:#fff">
    <div class="container">
        <div class="section-header">
            <h2>热门商品</h2>
            <p>精选优质香氛，发现你的专属味道</p>
        </div>
        <div class="products-grid">
            @foreach (var p in Model.FeaturedProducts.Take(8))
            {
                <div class="product-card">
                    <div class="product-image">
                        <img src="@(p.ImageUrl ?? "/images/default-product.svg")" alt="@p.ProductName" loading="lazy" />
                        <div class="product-overlay">
                            <a href="/product/@p.ProductId" class="btn-brand"><i class="fas fa-eye"></i> 查看详情</a>
                        </div>
                    </div>
                    <div class="product-info">
                        <span class="product-category">@(p.Category ?? "香水")</span>
                        <h3><a href="/product/@p.ProductId">@p.ProductName</a></h3>
                        <p class="product-desc">@(p.Category ?? "")</p>
                        <div class="product-price">
                            <span class="price">¥@p.BasePrice.ToString("F2")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="section-footer">
            <a href="/products" class="btn-outline-brand">查看全部商品 <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>

<!-- 特色服务 -->
<section class="features-section">
    <div class="container">
        <div class="features-grid">
            <div class="feature-item">
                <i class="fas fa-palette"></i>
                <h3>专属定制</h3>
                <p>从香调到瓶身，打造独一无二的香水</p>
            </div>
            <div class="feature-item">
                <i class="fas fa-truck"></i>
                <h3>满299包邮</h3>
                <p>全场满299元免运费，闪电发货</p>
            </div>
            <div class="feature-item">
                <i class="fas fa-shield-alt"></i>
                <h3>品质保证</h3>
                <p>顶级原料，严格品控，安全无忧</p>
            </div>
            <div class="feature-item">
                <i class="fas fa-headset"></i>
                <h3>专属客服</h3>
                <p>一对一香氛顾问，全程贴心服务</p>
            </div>
        </div>
    </div>
</section>
