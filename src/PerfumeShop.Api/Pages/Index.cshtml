@page
@model PerfumeShop.Api.Pages.IndexModel
@{ ViewData["Title"] = "首页"; }

<!-- Hero Banner -->
<section class="hero-banner">
    <div class="container">
        <h1>定制你的专属香氛</h1>
        <p class="lead mb-4">从前调到后调，每一个选择都是你的独特表达</p>
        <a href="/products" class="btn btn-brand btn-lg px-5"><i class="bi bi-stars"></i> 开始探索</a>
    </div>
</section>

<!-- 限时活动 -->
@if (Model.ActiveFlashSales.Any())
{
<section class="py-5 bg-light">
    <div class="container">
        <h3 class="section-title mb-4"><i class="bi bi-lightning-charge text-danger"></i> 限时秒杀</h3>
        <div class="row g-4">
            @foreach (var fs in Model.ActiveFlashSales)
            {
                var prod = Model.FlashSaleProducts.GetValueOrDefault(fs.ProductId);
                <div class="col-md-3 col-sm-6">
                    <div class="card product-card position-relative">
                        <span class="badge-sale"><i class="bi bi-lightning-charge"></i> 秒杀</span>
                        <img class="card-img-top" src="@(prod?.ImageUrl ?? "/images/default-product.svg")" alt="" />
                        <div class="card-body">
                            <h6 class="card-title text-truncate">@(prod?.ProductName ?? "商品")</h6>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price">¥@fs.FlashPrice.ToString("F2")</span>
                                <small class="text-muted text-decoration-line-through">¥@(prod?.BasePrice.ToString("F2") ?? "")</small>
                            </div>
                            <div class="progress mt-2" style="height:6px">
                                <div class="progress-bar bg-danger" style="width:@(fs.Stock > 0 ? (int)((double)fs.SoldCount / (fs.Stock + fs.SoldCount) * 100) : 100)%"></div>
                            </div>
                            <small class="text-muted">已售 @fs.SoldCount / 库存 @(fs.Stock + fs.SoldCount)</small>
                            <a href="/product?id=@fs.ProductId" class="btn btn-brand btn-sm w-100 mt-2">立即抢购</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
}

<!-- 热门商品 -->
<section class="py-5">
    <div class="container">
        <h3 class="section-title mb-4">热门商品</h3>
        <div class="row g-4">
            @foreach (var p in Model.FeaturedProducts)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card product-card">
                        <img class="card-img-top" src="@(p.ImageUrl ?? "/images/default-product.svg")" alt="@p.ProductName" />
                        <div class="card-body">
                            <h6 class="card-title text-truncate">@p.ProductName</h6>
                            <p class="card-text small text-muted text-truncate">@(p.Category ?? "香水")</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price">¥@p.BasePrice.ToString("F2")</span>
                                <a href="/product?id=@p.ProductId" class="btn btn-outline-primary btn-sm">查看详情</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4">
            <a href="/products" class="btn btn-outline-primary px-5">查看全部商品 <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
</section>

<!-- 特色服务 -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-3">
                <i class="bi bi-palette display-4" style="color:var(--brand)"></i>
                <h5 class="mt-3">专属定制</h5>
                <p class="small text-muted">从香调到瓶身，打造独一无二的香水</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-truck display-4" style="color:var(--brand)"></i>
                <h5 class="mt-3">满299包邮</h5>
                <p class="small text-muted">全场满299元免运费</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-shield-check display-4" style="color:var(--brand)"></i>
                <h5 class="mt-3">品质保证</h5>
                <p class="small text-muted">顶级原料，严格品控</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-headset display-4" style="color:var(--brand)"></i>
                <h5 class="mt-3">专属客服</h5>
                <p class="small text-muted">一对一香氛顾问服务</p>
            </div>
        </div>
    </div>
</section>
