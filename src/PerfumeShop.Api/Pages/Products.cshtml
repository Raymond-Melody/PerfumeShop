@page
@model PerfumeShop.Api.Pages.ProductsModel
@{ ViewData["Title"] = "全部商品"; }

<section class="py-4">
    <div class="container">
        <!-- 搜索/筛选 -->
        <form method="get" class="row g-3 mb-4">
            <div class="col-md-4">
                <input name="keyword" value="@Model.Keyword" class="form-control" placeholder="搜索商品名称..." />
            </div>
            <div class="col-md-3">
                <select name="type" class="form-select">
                    <option value="">全部分类</option>
                    <option value="custom" selected="@(Model.TypeFilter == "custom")">定制香水</option>
                    <option value="fixed" selected="@(Model.TypeFilter == "fixed")">成品香水</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty(Model.SortBy))">默认排序</option>
                    <option value="price_asc" selected="@(Model.SortBy == "price_asc")">价格从低到高</option>
                    <option value="price_desc" selected="@(Model.SortBy == "price_desc")">价格从高到低</option>
                    <option value="newest" selected="@(Model.SortBy == "newest")">最新上架</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-brand w-100"><i class="bi bi-search"></i> 搜索</button>
            </div>
        </form>

        <p class="text-muted">共 @Model.TotalCount 件商品</p>

        <!-- 商品列表 -->
        <div class="row g-4">
            @foreach (var p in Model.Products)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a href="/product?id=@p.ProductId" class="text-decoration-none">
                        <div class="card product-card h-100">
                            <img class="card-img-top" src="@(p.ImageUrl ?? "/images/default-product.svg")" alt="@p.ProductName" />
                            <div class="card-body">
                                <h6 class="card-title text-dark text-truncate">@p.ProductName</h6>
                                <span class="badge bg-light text-dark mb-2">@(p.Category ?? "香水")</span>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="price">¥@p.BasePrice.ToString("F2")</span>
                                    @if (p.Engravable == true)
                                    {
                                        <span class="badge bg-info"><i class="bi bi-pencil"></i> 可刻字</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (!Model.Products.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-box-seam display-1 text-muted"></i>
                <p class="text-muted mt-3">暂无符合条件的商品</p>
            </div>
        }

        <!-- 分页 -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?keyword=@Model.Keyword&type=@Model.TypeFilter&sort=@Model.SortBy&page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</section>
