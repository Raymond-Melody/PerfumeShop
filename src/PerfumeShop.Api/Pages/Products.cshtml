@page
@model PerfumeShop.Api.Pages.ProductsModel
@{ ViewData["Title"] = "全部商品"; }

<!-- Page Header -->
<section class="page-header-section">
    <div class="container">
        <h1 class="page-title">全部商品</h1>
        <p class="page-subtitle">发现你的专属香氛</p>
    </div>
</section>

<section class="products-section">
    <div class="container">
        <!-- 搜索/筛选栏（V18 风格） -->
        <div class="filter-bar">
            <form method="get" style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;width:100%">
                <input name="keyword" value="@Model.Keyword" class="filter-input" placeholder="🔍 搜索商品名称..." style="flex:1;min-width:180px" />
                <select name="type" class="filter-select">
                    <option value="">全部分类</option>
                    @if (Model.TypeFilter == "custom") { <option value="custom" selected>定制香水</option> } else { <option value="custom">定制香水</option> }
                    @if (Model.TypeFilter == "fixed") { <option value="fixed" selected>成品香水</option> } else { <option value="fixed">成品香水</option> }
                </select>
                <select name="sort" class="filter-select">
                    @if (string.IsNullOrEmpty(Model.SortBy)) { <option value="" selected>默认排序</option> } else { <option value="">默认排序</option> }
                    @if (Model.SortBy == "price_asc") { <option value="price_asc" selected>价格从低到高</option> } else { <option value="price_asc">价格从低到高</option> }
                    @if (Model.SortBy == "price_desc") { <option value="price_desc" selected>价格从高到低</option> } else { <option value="price_desc">价格从高到低</option> }
                    @if (Model.SortBy == "newest") { <option value="newest" selected>最新上架</option> } else { <option value="newest">最新上架</option> }
                </select>
                <button type="submit" class="btn-brand"><i class="fas fa-search"></i> 搜索</button>
            </form>
        </div>

        <p style="color:var(--dt-color-text-light,var(--text-light));margin-bottom:20px">共 <strong>@Model.TotalCount</strong> 件商品</p>

        <!-- 商品列表（V18 product-card 体系） -->
        <div class="products-grid">
            @foreach (var p in Model.Products)
            {
                <div class="product-card">
                    <div class="product-image">
                        <img src="@(p.ImageUrl ?? "/images/default-product.svg")" alt="@p.ProductName" loading="lazy" />
                        @if (p.Engravable == true)
                        {
                            <div class="product-badges">
                                <span class="badge badge-engravable"><i class="fas fa-pencil-alt"></i> 可刻字</span>
                            </div>
                        }
                        <div class="product-overlay">
                            <a href="/product?id=@p.ProductId" class="btn-brand"><i class="fas fa-eye"></i> 查看详情</a>
                        </div>
                    </div>
                    <div class="product-info">
                        <span class="product-category">@(p.Category ?? "香水")</span>
                        <h3><a href="/product?id=@p.ProductId">@p.ProductName</a></h3>
                        <div class="product-price">
                            <span class="price">¥@p.BasePrice.ToString("F2")</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Products.Any())
        {
            <div class="empty-state">
                <i class="fas fa-box-open" style="font-size:64px;color:var(--dt-color-text-muted,var(--text-muted))"></i>
                <p>暂无符合条件的商品</p>
            </div>
        }

        <!-- 分页（V18 风格） -->
        @if (Model.TotalPages > 1)
        {
            <div class="pagination-wrapper">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?keyword=@Model.Keyword&type=@Model.TypeFilter&sort=@Model.SortBy&page=@i"
                       class="page-num @(i == Model.CurrentPage ? "active" : "")">@i</a>
                }
            </div>
        }
    </div>
</section>
