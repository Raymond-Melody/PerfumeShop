@page "/admin/Operation/Points"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
<PageTitle>积分管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-coins" style="color:#00bcd4;"></i> 积分管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>积分管理</span></div></div>
@if(_loaded){
<!-- 统计卡片 -->
<div class="stats-cards"><div class="stat-card"><i class="fas fa-coins" style="color:#00bcd4;"></i><h3>@_totalPoints.ToString("N0")</h3><p>总发放积分</p></div><div class="stat-card"><i class="fas fa-exchange-alt" style="color:#4CAF50;"></i><h3>@_todayTransactions</h3><p>今日交易</p></div><div class="stat-card"><i class="fas fa-users" style="color:#FF9800;"></i><h3>@_participantCount</h3><p>参与用户</p></div></div>
<!-- 积分调整表单 -->
<div class="adjust-form"><h3 style="margin-bottom:20px;color:#e0e0e0;"><i class="fas fa-sliders-h" style="color:#00bcd4;"></i> 积分调整</h3>
@if(!string.IsNullOrEmpty(_adjustMsg)){<div class="alert @(_adjustSuccess?"alert-success":"alert-error")">@_adjustMsg</div>}
<form @onsubmit="HandleAdjustPoints"><div class="form-row"><div class="form-group"><label>用户</label><select class="form-control" @bind="_selectedUserId" required><option value="">选择用户</option>@foreach(var u in _userList){<option value="@u.UserId">@u.Username @if(!string.IsNullOrEmpty(u.FullName)){<text>(@u.FullName)</text>}</option>}</select></div><div class="form-group"><label>积分变动</label><input type="number" class="form-control" @bind="_pointsChange" required placeholder="正数增加，负数扣减" /></div></div><div class="form-row"><div class="form-group" style="flex:2;"><label>调整原因</label><input type="text" class="form-control" @bind="_adjustReason" required placeholder="请输入积分调整原因" /></div><div class="form-group" style="display:flex;align-items:flex-end;"><button type="submit" class="btn btn-primary" disabled="@_adjusting"><i class="fas fa-save"></i> @(_adjusting?"处理中...":"确认调整")</button></div></div></form></div>
<!-- 交易记录 -->
<h3 style="margin-bottom:15px;color:#e0e0e0;"><i class="fas fa-history" style="color:#00bcd4;"></i> 最近50条积分交易记录</h3>
<div class="table-container"><table class="transactions-table"><thead><tr><th>时间</th><th>用户</th><th>变动</th><th>原因</th><th>操作人</th></tr></thead><tbody>@if(_transactions.Any()){@foreach(var t in _transactions){var uc=_userDict.TryGetValue(t.UserId,out var un)?un:$"#{t.UserId}";var pc=t.PointsChange??t.Points;<tr><td>@(t.CreatedAt?.ToString("yyyy-MM-dd HH:mm")??"-")</td><td>@uc</td><td>@if(pc>=0){<span class="points-positive">+@pc</span>}else{<span class="points-negative">@pc</span>}</td><td>@(t.Reason??t.Description??"-")</td><td>@(string.IsNullOrEmpty(t.CreatedBy)?"系统":t.CreatedBy)</td></tr>}}else{<tr><td colspan="5" class="empty-cell">暂无交易记录</td></tr>}</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>
.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.page-title{font-size:24px;color:#fff;margin:0;display:flex;align-items:center;gap:10px;}.breadcrumb{font-size:13px;color:#888;}
.stats-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:25px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:25px;border-radius:12px;border:1px solid rgba(255,255,255,0.05);text-align:center;transition:transform 0.2s;}.stat-card:hover{transform:translateY(-2px);}.stat-card i{font-size:36px;margin-bottom:10px;display:block;}.stat-card h3{font-size:28px;margin:10px 0;color:#e0e0e0;}.stat-card p{color:#888;margin:0;font-size:13px;}
.adjust-form{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:25px;border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.05);}.form-row{display:flex;gap:15px;margin-bottom:15px;}.form-group{flex:1;}.form-group label{display:block;margin-bottom:8px;color:#e0e0e0;font-weight:500;font-size:14px;}.form-control{width:100%;padding:12px 15px;border:1px solid rgba(255,255,255,0.12);border-radius:8px;background:rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;box-sizing:border-box;}.form-control:focus{border-color:#00bcd4;outline:none;}.form-control option{background:#2d2d44;color:#e0e0e0;}
.btn{padding:10px 20px;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.3s;text-decoration:none;}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}.btn-primary:hover{background:linear-gradient(135deg,#00bcd4,#0097a7);}.btn-primary[disabled]{opacity:0.5;cursor:not-allowed;}
.alert{padding:15px;border-radius:8px;margin-bottom:20px;font-size:14px;}.alert-success{background:rgba(46,125,50,0.2);color:#4caf50;border:1px solid rgba(46,125,50,0.3);}.alert-error{background:rgba(198,40,40,0.2);color:#c62828;border:1px solid rgba(198,40,40,0.3);}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}.transactions-table{width:100%;border-collapse:collapse;}.transactions-table th{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;padding:14px 16px;text-align:left;font-size:13px;font-weight:600;}.transactions-table td{padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}.transactions-table tr:last-child td{border-bottom:none;}.transactions-table tr:hover td{background:rgba(0,188,212,0.03);}.points-positive{color:#4CAF50;font-weight:bold;}.points-negative{color:#f44336;font-weight:bold;}.empty-cell{text-align:center;color:#666;padding:40px;}
@@media(max-width:768px){.stats-cards{grid-template-columns:1fr;}.form-row{flex-direction:column;}}
</style>
@code{
[Inject] private PerfumeShopContext Db{get;set;}=default!;
[Inject] private AuthenticationStateProvider AuthState{get;set;}=default!;
private bool _loaded,_adjusting,_adjustSuccess,_canAdjust;
private string? _adjustMsg;
private List<User> _userList=new();
private Dictionary<int,string> _userDict=new();
private List<PointTransaction> _transactions=new();
private int _totalPoints,_todayTransactions,_participantCount;
private int? _selectedUserId;
private int _pointsChange;
private string _adjustReason="";

protected override async Task OnInitializedAsync(){
try{
await CheckPermission();
await LoadData();
_loaded=true;
}catch{_loaded=true;}
}

async Task CheckPermission(){
var state=await AuthState.GetAuthenticationStateAsync();
var role=state.User.FindFirst("RoleCode")?.Value??"";
_canAdjust=role=="OP_MANAGER"||role=="SUPER_ADMIN";
}

async Task LoadData(){
// Stats
var users=await Db.Users.ToListAsync();
_totalPoints=users.Sum(u=>u.Points??0);
var today=DateTime.Today;
_todayTransactions=await Db.PointTransactions.CountAsync(t=>t.CreatedAt.HasValue&&t.CreatedAt.Value.Date==today);
_participantCount=await Db.PointTransactions.Select(t=>t.UserId).Distinct().CountAsync();

// User list for dropdown (deduplicate by username to avoid UI clutter from seed data)
_userList=await Db.Users.OrderBy(u=>u.Username).ToListAsync();
_userList=_userList.GroupBy(u=>u.Username??"").Select(g=>g.First()).OrderBy(u=>u.Username).ToList();
_userDict=_userList.ToDictionary(u=>u.UserId,u=>{
var name=u.Username??"";
if(!string.IsNullOrEmpty(u.FullName))name+=$" ({u.FullName})";
return name;
});

// Transactions
_transactions=await Db.PointTransactions.OrderByDescending(t=>t.CreatedAt).Take(50).ToListAsync();
}

async Task HandleAdjustPoints(){
_adjustMsg=null;
if(!_canAdjust){_adjustMsg="权限不足，仅运营经理或超级管理员可调整积分";_adjustSuccess=false;return;}
if(_selectedUserId==null||_selectedUserId<=0){_adjustMsg="请选择用户";_adjustSuccess=false;return;}
if(_pointsChange==0){_adjustMsg="积分变动不能为0";_adjustSuccess=false;return;}
if(string.IsNullOrWhiteSpace(_adjustReason)){_adjustMsg="请输入调整原因";_adjustSuccess=false;return;}
_adjusting=true;
try{
// Use execution strategy to wrap transactional operations
var strategy=Db.Database.CreateExecutionStrategy();
await strategy.ExecuteAsync(async()=>{
await Db.Users.Where(u=>u.UserId==_selectedUserId.Value).ExecuteUpdateAsync(s=>s.SetProperty(u=>u.Points,u=>(u.Points??0)+_pointsChange));

var pt=new PointTransaction{
UserId=_selectedUserId.Value,
Points=_pointsChange,
PointsChange=_pointsChange,
Reason=_adjustReason,
Description=_adjustReason,
TransactionType="ManualAdjust",
CreatedBy="管理员",
CreatedAt=DateTime.Now
};
Db.PointTransactions.Add(pt);
await Db.SaveChangesAsync();
});

_adjustMsg="积分调整成功！";
_adjustSuccess=true;
_selectedUserId=null;
_pointsChange=0;
_adjustReason="";
await LoadData();
}catch(Exception ex){
_adjustMsg="操作失败，积分已回滚: "+ex.Message;
_adjustSuccess=false;
}finally{
_adjusting=false;
}
}}