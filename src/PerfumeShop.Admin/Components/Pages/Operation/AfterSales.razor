@page "/admin/Operation/AfterSales"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
<PageTitle>售后管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-headset" style="color:#00bcd4;"></i> 售后管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>售后管理</span></div></div>
@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="alert @(_msgType=="success"?"alert-success":"alert-error")"><i class="fas fa-info-circle"></i> @_msg</div>}
<div class="stats-grid"><div class="stat-card pending" @onclick='()=>SetFilter("pending")'><div class="stat-num">@_pendingCount</div><div class="stat-label">待处理</div></div><div class="stat-card approved" @onclick='()=>SetFilter("approved")'><div class="stat-num">@_approvedCount</div><div class="stat-label">已通过</div></div><div class="stat-card rejected" @onclick='()=>SetFilter("rejected")'><div class="stat-num">@_rejectedCount</div><div class="stat-label">已拒绝</div></div><div class="stat-card" @onclick='()=>SetFilter(null)'><div class="stat-num">@_totalCount</div><div class="stat-label">全部记录</div></div></div>
<div class="card"><div class="card-header"><span><i class="fas fa-list"></i> 售后申请列表 @if(!string.IsNullOrEmpty(_statusFilter)){<text>(@_statusFilter)</text>}</span>@if(!string.IsNullOrEmpty(_statusFilter)){<a href="javascript:void(0)" class="btn btn-sm btn-outline" @onclick='()=>SetFilter(null)'>显示全部</a>}</div><div class="card-body"><table class="data-table"><thead><tr><th>ID</th><th>订单号</th><th>客户</th><th>类型</th><th>原因</th><th>金额</th><th>状态</th><th>申请时间</th><th>操作</th></tr></thead><tbody>@if(_displayItems.Any()){@foreach(var a in _displayItems){var order=_orderDict.TryGetValue(a.OrderId,out var o)?o:null;var un=_userDict.TryGetValue(a.UserId,out var u)?u:$"#{a.UserId}";<tr><td>@a.AfterSalesId</td><td><a href="/admin/Operation/OrderDetail/@a.OrderId" style="color:#00bcd4;">@(order?.OrderNo??$"#{a.OrderId}")</a></td><td>@un</td><td><span class="type-badge type-@(a.RequestType?.ToLower()??"")">@GetTypeLabel(a.RequestType)</span></td><td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(a.Reason??"-")</td><td>¥@((a.RefundAmount??0).ToString("N2"))</td><td><span class="status-badge @GetStatusClass(a.Status)">@GetStatusLabel(a.Status)</span></td><td style="font-size:13px;color:#888;">@(a.CreatedAt?.ToString("yyyy-MM-dd HH:mm")??"-")</td><td>@if(a.Status=="pending"){<button class="btn btn-primary btn-sm" @onclick='()=>OpenModal(a)'>处理</button>}else{<span style="font-size:12px;color:#888;">@(a.AdminNotes??"-")</span>}</td></tr>}}else{<tr><td colspan="9" class="empty-cell">暂无售后申请</td></tr>}</tbody></table></div></div>
<!-- 处理弹窗 -->
@if(_showModal&&_modalItem!=null){<div class="modal-overlay show" @onclick="CloseModal"><div class="modal" @onclick:stopPropagation="true"><h3><i class="fas fa-gavel" style="color:#00bcd4;"></i> 处理售后申请</h3><div style="font-size:13px;color:#888;margin-bottom:15px;">订单: <strong style="color:#00bcd4;">@(_orderDict.TryGetValue(_modalItem.OrderId,out var mo)?mo.OrderNo:$"#{_modalItem.OrderId}")</strong> | 客户: <strong style="color:#e0e0e0;">@(_userDict.TryGetValue(_modalItem.UserId,out var mu)?mu:$"#{_modalItem.UserId}")</strong> | 类型: <strong>@GetTypeLabel(_modalItem.RequestType)</strong> | 金额: <strong style="color:#FF9800;">¥@((_modalItem.RefundAmount??0).ToString("N2"))</strong></div><div class="form-group"><label>处理结果</label><select class="form-control" @bind="_modalStatus" required><option value="approved">通过</option><option value="rejected">拒绝</option></select></div><div class="form-group"><label>处理备注</label><textarea class="form-control" @bind="_modalNotes" placeholder="输入处理备注..."></textarea></div><div class="modal-actions"><button class="btn btn-outline" @onclick="CloseModal" disabled="@_processing">取消</button><button class="btn btn-primary" @onclick="ProcessAfterSale" disabled="@_processing"><i class="fas fa-check"></i> @(_processing?"处理中...":"确认处理")</button></div></div></div>}
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>
.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.page-title{font-size:24px;color:#fff;margin:0;display:flex;align-items:center;gap:10px;}.breadcrumb{font-size:13px;color:#888;}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:25px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;border:1px solid rgba(255,255,255,0.05);text-align:center;cursor:pointer;transition:all 0.2s;}.stat-card:hover{transform:translateY(-2px);border-color:rgba(0,188,212,0.3);}.stat-num{font-size:28px;font-weight:700;color:#00bcd4;}.stat-label{font-size:13px;color:#888;margin-top:5px;}.stat-card.pending .stat-num{color:#FF9800;}.stat-card.approved .stat-num{color:#4CAF50;}.stat-card.rejected .stat-num{color:#f44336;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;border:1px solid rgba(255,255,255,0.05);margin-bottom:20px;overflow:hidden;}.card-header{padding:15px 20px;border-bottom:1px solid rgba(255,255,255,0.06);font-weight:600;font-size:16px;color:#e0e0e0;display:flex;justify-content:space-between;align-items:center;}.card-body{padding:0;}
.data-table{width:100%;border-collapse:collapse;}.data-table th{text-align:left;padding:12px;background:rgba(0,188,212,0.06);border-bottom:1px solid rgba(255,255,255,0.06);font-size:13px;color:#888;}.data-table td{padding:12px;border-bottom:1px solid rgba(255,255,255,0.04);font-size:14px;color:#ccc;}.data-table tr:hover td{background:rgba(255,255,255,0.03);}.empty-cell{text-align:center;color:#666;padding:40px;}
.status-badge{display:inline-block;padding:3px 10px;border-radius:12px;font-size:12px;font-weight:600;}.status-pending{background:rgba(255,152,0,0.2);color:#FFB74D;}.status-approved{background:rgba(76,175,80,0.2);color:#A5D6A7;}.status-rejected{background:rgba(244,67,54,0.2);color:#EF9A9A;}
.type-badge{display:inline-block;padding:3px 10px;border-radius:12px;font-size:12px;font-weight:600;}.type-refund{background:rgba(233,30,99,0.2);color:#F48FB1;}.type-return{background:rgba(33,150,243,0.2);color:#90CAF9;}.type-exchange{background:rgba(156,39,176,0.2);color:#CE93D8;}
.btn{padding:10px 20px;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.3s;text-decoration:none;}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}.btn-primary:hover{background:linear-gradient(135deg,#00bcd4,#0097a7);}.btn-primary[disabled]{opacity:0.5;cursor:not-allowed;}.btn-outline{background:rgba(255,255,255,0.05);color:#b0b0b0;border:1px solid rgba(255,255,255,0.1);}.btn-outline:hover{background:rgba(255,255,255,0.1);color:#fff;}.btn-sm{padding:5px 12px;font-size:12px;border-radius:6px;}
.alert{padding:12px 20px;border-radius:8px;margin-bottom:20px;font-size:14px;}.alert-success{background:rgba(76,175,80,0.15);color:#4CAF50;border:1px solid rgba(76,175,80,0.3);}.alert-error{background:rgba(244,67,54,0.15);color:#EF9A9A;border:1px solid rgba(244,67,54,0.3);}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;justify-content:center;align-items:center;}.modal{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:16px;border:1px solid rgba(255,255,255,0.1);padding:30px;width:90%;max-width:500px;}.modal h3{margin:0 0 15px;font-size:18px;color:#fff;}.form-group{margin-bottom:15px;}.form-group label{display:block;color:#999;font-size:13px;margin-bottom:5px;}.form-control{width:100%;padding:10px;border:1px solid rgba(255,255,255,0.12);border-radius:8px;background:rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;box-sizing:border-box;}.form-control:focus{border-color:#00bcd4;outline:none;}.form-control option{background:#2d2d44;color:#e0e0e0;}textarea.form-control{min-height:80px;resize:vertical;}.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;}
@@media(max-width:768px){.stats-grid{grid-template-columns:1fr 1fr;}}
</style>
@code{
[Inject] private PerfumeShopContext Db{get;set;}=default!;
private bool _loaded,_processing,_showModal;
private string? _msg,_msgType,_statusFilter,_modalStatus,_modalNotes;
private List<AfterSale> _allItems=new();
private Dictionary<int,Order> _orderDict=new();
private Dictionary<int,string> _userDict=new();
private AfterSale? _modalItem;
private int _totalCount,_pendingCount,_approvedCount,_rejectedCount;

protected override async Task OnInitializedAsync(){
try{await LoadData();_loaded=true;}catch{_loaded=true;}
}

async Task LoadData(){
_allItems=await Db.AfterSales.OrderByDescending(a=>a.CreatedAt).ToListAsync();
_totalCount=_allItems.Count;
_pendingCount=_allItems.Count(a=>a.Status=="pending");
_approvedCount=_allItems.Count(a=>a.Status=="approved");
_rejectedCount=_allItems.Count(a=>a.Status=="rejected");
var oids=_allItems.Select(a=>a.OrderId).Distinct().ToList();
var uids=_allItems.Select(a=>a.UserId).Distinct().ToList();
var orders=await Db.Orders.Where(o=>oids.Contains(o.OrderId)).ToListAsync();
_orderDict=orders.ToDictionary(o=>o.OrderId);
var users=await Db.Users.Where(u=>uids.Contains(u.UserId)).ToListAsync();
_userDict=users.ToDictionary(u=>u.UserId,u=>u.Username??$"#{u.UserId}");
}

IEnumerable<AfterSale> _displayItems{
get{
var q=_allItems.AsEnumerable();
if(!string.IsNullOrEmpty(_statusFilter))q=q.Where(a=>a.Status==_statusFilter);
return q;
}
}

async Task SetFilter(string? s){
_statusFilter=s;
await InvokeAsync(StateHasChanged);
}

void OpenModal(AfterSale a){
_modalItem=a;
_modalStatus="approved";
_modalNotes="";
_showModal=true;
}

void CloseModal(){
if(!_processing){_showModal=false;_modalItem=null;}
}

async Task ProcessAfterSale(){
if(_modalItem==null)return;
_processing=true;
try{
await Db.AfterSales.Where(a=>a.AfterSalesId==_modalItem.AfterSalesId)
.ExecuteUpdateAsync(s=>s.SetProperty(a=>a.Status,_modalStatus)
.SetProperty(a=>a.AdminNotes,_modalNotes)
.SetProperty(a=>a.ProcessedAt,DateTime.Now));
if(_modalStatus=="approved"&&_modalItem.RequestType=="refund"){
await Db.Orders.Where(o=>o.OrderId==_modalItem.OrderId)
.ExecuteUpdateAsync(s=>s.SetProperty(o=>o.Status,"refunding"));
}
_msg="售后申请已处理";
_msgType="success";
_showModal=false;
_modalItem=null;
await LoadData();
}catch(Exception ex){
_msg="操作失败: "+ex.Message;
_msgType="error";
}finally{_processing=false;}
}

static string GetTypeLabel(string? t)=>t?.ToLower() switch{"refund"=>"退款","return"=>"退货","exchange"=>"换货",_=>t??"-"};
static string GetStatusClass(string? s)=>s?.ToLower() switch{"pending"=>"status-pending","approved"=>"status-approved","rejected"=>"status-rejected",_=>""};
static string GetStatusLabel(string? s)=>s?.ToLower() switch{"pending"=>"待处理","approved"=>"已通过","rejected"=>"已拒绝",_=>s??"-"};
}}
