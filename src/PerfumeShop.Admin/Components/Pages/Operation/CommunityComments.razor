@page "/admin/Operation/CommunityComments"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.operation")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Admin.Services

<PageTitle>评论管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-comment-dots"></i> 评论管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>评论管理</span></div></div>

@if (_loaded)
{
<div class="stats-row">
    <div class="stat-card"><div class="stat-value" style="color:#00bcd4;">@_totalComments</div><div class="stat-label">总评论</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#4CAF50;">@_activeComments</div><div class="stat-label">已通过</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#FF9800;">@_pendingComments</div><div class="stat-label">待审核</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#9C27B0;">@_replyComments</div><div class="stat-label">回复数</div></div>
</div>

<div class="filter-bar">
    <input type="text" class="filter-input" @bind="_keyword" @bind:event="oninput" placeholder="搜索评论内容/用户名..." />
    <select class="filter-select" @bind="_statusFilter">
        <option value="">全部状态</option>
        <option value="active">已通过</option>
        <option value="pending">待审核</option>
    </select>
    <button class="btn btn-outline btn-sm" @onclick="ResetFilter"><i class="fas fa-undo"></i> 重置</button>
    <span style="margin-left:auto;color:#888;font-size:13px;align-self:center;">共 @_filteredTotal 条</span>
</div>

<div class="table-container">
    <table class="data-table">
        <thead><tr><th>ID</th><th>用户</th><th>帖子ID</th><th>内容</th><th>回复</th><th>状态</th><th>时间</th><th>操作</th></tr></thead>
        <tbody>
            @if (_displayComments.Any())
            {
                @foreach (var c in _displayComments.Skip((_page - 1) * 20).Take(20))
                {
                    <tr>
                        <td>#@c.CommentId</td>
                        <td>@GetUserName(c.UserId)</td>
                        <td style="color:#00bcd4;">#@c.PostId @(c.ParentCommentId.HasValue ? $"(回复#{c.ParentCommentId})" : "")</td>
                        <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(c.Content ?? "-")</td>
                        <td>@(c.ParentCommentId.HasValue ? "↩ 回复" : "主评论")</td>
                        <td><span class="status-badge @(c.IsActive ? "status-approved" : "status-pending")">@(c.IsActive ? "已通过" : "待审核")</span></td>
                        <td>@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <button class="action-btn detail" @onclick='()=>ShowDetail(c)'>详情</button>
                            <button class="action-btn @(c.IsActive?"reject":"approve")" @onclick="()=>ToggleActive(c)">@(c.IsActive?"隐藏":"通过")</button>
                            <button class="action-btn" style="background:rgba(244,67,54,0.2);color:#ef5350;" @onclick="()=>DeleteComment(c.CommentId)"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="8" class="empty-cell">暂无评论数据</td></tr>
            }
        </tbody>
    </table>
</div>
@if (_totalPages > 1)
{
    <div class="pagination">
        @for (int p = 1; p <= _totalPages; p++)
        {
            var pi = p;
            <a href="javascript:void(0)" class="@(pi==_page?"page-item active":"page-item")" @onclick="()=>GoPage(pi)" @onclick:preventDefault>@pi</a>
        }
    </div>
}

@if(_showDetail&&_detailComment!=null){<div class="modal-overlay show" @onclick="()=>_showDetail=false"><div class="modal" @onclick:stopPropagation="true"><div class="modal-header"><h3>评论详情 #@_detailComment.CommentId</h3><button class="modal-close" @onclick="()=>_showDetail=false">&times;</button></div><div class="modal-body">
    <div class="detail-row"><label>评论ID</label><p>@_detailComment.CommentId</p></div>
    <div class="detail-row"><label>用户</label><p>@GetUserName(_detailComment.UserId)</p></div>
    <div class="detail-row"><label>所属帖子</label><p style="color:#00bcd4;">#@_detailComment.PostId @if(_detailComment.ParentCommentId.HasValue){<span style="color:#888;">(回复 #@_detailComment.ParentCommentId)</span>}</p></div>
    <div class="detail-row"><label>内容</label><p style="min-height:60px;white-space:pre-wrap;">@(_detailComment.Content ?? "（无内容）")</p></div>
    <div class="detail-row"><label>状态</label><p><span class="status-badge @(_detailComment.IsActive?"status-approved":"status-pending")">@(_detailComment.IsActive?"已通过":"待审核")</span></p></div>
    <div class="detail-row"><label>时间</label><p>@_detailComment.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p></div>
</div><div class="modal-footer">
    <button class="btn btn-outline" @onclick="()=>_showDetail=false">关闭</button>
    <button class="btn @(_detailComment.IsActive?"btn-outline":"btn-primary")" @onclick='()=>ToggleActive(_detailComment!)'>@(_detailComment.IsActive?"隐藏":"通过")</button>
    <button class="btn btn-danger" @onclick='()=>{DeleteComment(_detailComment!.CommentId);_showDetail=false;}'>删除</button>
</div></div></div>}
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

<style>

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:18px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}.stat-value{font-size:26px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}
.filter-bar{display:flex;gap:12px;align-items:center;margin-bottom:20px;padding:15px 20px;background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;border:1px solid rgba(255,255,255,0.05);}.filter-select{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;padding:8px 12px;font-size:13px;cursor:pointer;min-width:120px;}.filter-select:focus{border-color:#00bcd4;outline:none;}.filter-select option{background:#2d2d44;color:#e0e0e0;}.filter-input{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;padding:8px 12px;font-size:13px;min-width:200px;}.filter-input:focus{border-color:#00bcd4;outline:none;}.filter-input::placeholder{color:#666;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}.data-table{width:100%;border-collapse:collapse;}.data-table th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:12px 14px;font-size:13px;text-align:left;font-weight:600;}.data-table td{padding:12px 14px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}.data-table tr:last-child td{border-bottom:none;}.data-table tr:hover td{background:rgba(255,255,255,0.03);}
.status-badge{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}.status-pending{background:rgba(255,152,0,0.2);color:#ff9800;}.status-approved{background:rgba(76,175,80,0.2);color:#4caf50;}
.action-btn{padding:4px 8px;border-radius:4px;font-size:11px;border:none;cursor:pointer;margin-right:4px;margin-bottom:2px;}.action-btn.approve{background:rgba(76,175,80,0.2);color:#66bb6a;}.action-btn.approve:hover{background:#4CAF50;color:#fff;}.action-btn.reject{background:rgba(244,67,54,0.2);color:#ef5350;}.action-btn.reject:hover{background:#f44336;color:#fff;}.action-btn.detail{background:rgba(0,188,212,0.2);color:#4dd0e1;}.action-btn.detail:hover{background:#00bcd4;color:#fff;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:6px;text-decoration:none;}.btn-outline{background:rgba(255,255,255,0.05);color:#b0b0b0;border:1px solid rgba(255,255,255,0.1);}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;}.btn-danger{background:#c62828;color:#fff;}.btn-sm{padding:5px 12px;font-size:11px;}.empty-cell{text-align:center;color:#666;padding:40px;}
.pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;}.page-item{padding:8px 14px;background:#2d2d44;border-radius:6px;text-decoration:none;color:#b0b0b0;border:1px solid rgba(255,255,255,0.05);cursor:pointer;font-size:14px;}.page-item:hover,.page-item.active{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;justify-content:center;align-items:center;}.modal{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:16px;border:1px solid rgba(255,255,255,0.1);padding:30px;width:90%;max-width:600px;max-height:90vh;overflow-y:auto;}.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}.modal-header h3{color:#fff;margin:0;font-size:18px;}.modal-close{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.detail-row{margin-bottom:12px;}.detail-row label{display:block;color:#999;font-size:12px;margin-bottom:4px;}.detail-row p{background:rgba(255,255,255,0.05);color:#e0e0e0;padding:10px;border-radius:6px;margin:0;border:1px solid rgba(255,255,255,0.08);}.modal-footer{margin-top:20px;display:flex;justify-content:flex-end;gap:8px;}
@@media(max-width:768px){.stats-row{grid-template-columns:repeat(2,1fr);}.filter-bar{flex-wrap:wrap;}}
</style>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private IAdminAuditor Auditor { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;
    private bool _loaded;
    private int _adminId; private string _adminName = "";
    private List<PostComment> _comments = new();
    private Dictionary<int, string> _un = new();
    private string? _statusFilter, _keyword = "";
    private int _totalComments, _activeComments, _pendingComments, _replyComments, _filteredTotal, _page = 1, _totalPages = 1;
    private bool _showDetail;
    private PostComment? _detailComment;

    protected override async Task OnInitializedAsync()
    {
        try { var st = await AuthState.GetAuthenticationStateAsync(); int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _adminId); _adminName = st.User.FindFirst(ClaimTypes.Name)?.Value ?? ""; await LoadData(); _loaded = true; } catch { _loaded = true; }
    }

    async Task LoadData()
    {
        _comments = await Db.PostComments.AsNoTracking().OrderByDescending(c => c.CreatedAt).Take(500).ToListAsync();
        _totalComments = _comments.Count;
        _activeComments = _comments.Count(c => c.IsActive);
        _pendingComments = _comments.Count(c => !c.IsActive);
        _replyComments = _comments.Count(c => c.ParentCommentId.HasValue);
        var uids = _comments.Select(c => c.UserId).Distinct().ToList();
        _un = (await Db.Users.Where(u => uids.Contains(u.UserId)).ToListAsync()).ToDictionary(u => u.UserId, u => u.Username ?? "");
    }

    IEnumerable<PostComment> _displayComments
    {
        get
        {
            var q = _comments.AsEnumerable();
            if (!string.IsNullOrEmpty(_statusFilter))
            {
                var isActive = _statusFilter == "active";
                q = q.Where(c => c.IsActive == isActive);
            }
            if (!string.IsNullOrWhiteSpace(_keyword))
            {
                var kw = _keyword.Trim().ToLower();
                q = q.Where(c => (c.Content != null && c.Content.ToLower().Contains(kw))
                    || _un.TryGetValue(c.UserId, out var un) && un.ToLower().Contains(kw));
            }
            var list = q.ToList();
            _filteredTotal = list.Count;
            _totalPages = Math.Max(1, (int)Math.Ceiling((double)list.Count / 20));
            if (_page > _totalPages) _page = 1;
            return list;
        }
    }

    async Task ResetFilter() { _statusFilter = null; _keyword = ""; _page = 1; await InvokeAsync(StateHasChanged); }
    async Task GoPage(int p) { _page = p; await InvokeAsync(StateHasChanged); }

    async Task ToggleActive(PostComment c)
    {
        c.IsActive = !c.IsActive;
        await Db.PostComments.Where(x => x.CommentId == c.CommentId).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, c.IsActive));
        await Auditor.LogAsync(_adminId, _adminName, c.IsActive ? "通过评论" : "隐藏评论", "PostComment", c.CommentId, null);
        if(_detailComment?.CommentId == c.CommentId) _detailComment.IsActive = c.IsActive;
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    async Task DeleteComment(int id)
    {
        await Db.PostComments.Where(c => c.CommentId == id).ExecuteDeleteAsync();
        // Also delete replies to this comment
        await Db.PostComments.Where(c => c.ParentCommentId == id).ExecuteDeleteAsync();
        await Auditor.LogAsync(_adminId, _adminName, "删除评论", "PostComment", id, null);
        _comments = _comments.Where(c => c.CommentId != id && c.ParentCommentId != id).ToList();
        _totalComments = _comments.Count;
        await InvokeAsync(StateHasChanged);
    }

    void ShowDetail(PostComment c) { _detailComment = c; _showDetail = true; }

    string GetUserName(int uid) => _un.TryGetValue(uid, out var n) ? n : $"#{uid}";
}
