@page "/admin/Operation/OrderDetail/{OrderId:int}"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>订单详情</PageTitle>

@if (_loaded)
{
    @if (_order == null)
    {
        <div class="error-state"><i class="fas fa-exclamation-triangle"></i> 订单不存在或已被删除</div>
        <div style="margin-top:20px;"><a href="/admin/Operation/Orders" class="btn btn-outline"><i class="fas fa-arrow-left"></i> 返回订单列表</a></div>
    }
    else
    {
        <div class="page-header">
            <h2 class="page-title"><i class="fas fa-file-alt" style="color:#00bcd4;"></i> 订单详情 #@_order.OrderNo</h2>
            <div class="breadcrumb">
                <a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> /
                <a href="/admin/Operation/Orders" style="color:#00bcd4;text-decoration:none;">订单管理</a> /
                <span>订单详情</span>
            </div>
        </div>

        <div class="action-bar">
            <a href="/admin/Operation/Orders" class="btn btn-outline"><i class="fas fa-arrow-left"></i> 返回列表</a>
            <a href="/admin/Operation/OrderEdit/@(_order.OrderId)" class="btn btn-primary"><i class="fas fa-edit"></i> 编辑订单</a>
            <a href="/admin/prodcenter/sync-orders?orderId=@(_order.OrderId)" class="btn" style="background:#ff9800;color:#fff;" target="_blank"><i class="fas fa-print"></i> 打印生产工单</a>
        </div>

        <!-- 基本信息 -->
        <div class="detail-grid">
            <div class="info-card">
                <h3 class="info-title"><i class="fas fa-info-circle"></i> 订单基本信息</h3>
                <div class="info-rows">
                    <div class="info-row"><span class="info-label">订单号:</span><span class="info-value">@_order.OrderNo</span></div>
                    <div class="info-row"><span class="info-label">下单时间:</span><span class="info-value">@(_order.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span></div>
                    <div class="info-row"><span class="info-label">订单金额:</span><span class="info-value" style="font-size:18px;font-weight:600;color:#e0e0e0;">¥@_order.TotalAmount.ToString("N2")</span></div>
                    <div class="info-row"><span class="info-label">当前状态:</span><span class="info-value"><span class="status-badge @GetStatusClass(_order.Status)">@GetStatusLabel(_order.Status)</span></span></div>
                    <div class="info-row"><span class="info-label">支付方式:</span><span class="info-value">@GetPaymentMethod(_order.PaymentMethod)</span></div>
                    @if (_order.UpdatedAt.HasValue)
                    {
                        <div class="info-row"><span class="info-label">最后更新:</span><span class="info-value">@_order.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss")</span></div>
                    }
                </div>
            </div>

            <div class="info-card">
                <h3 class="info-title"><i class="fas fa-user"></i> 客户与收货信息</h3>
                <div class="info-rows">
                    <div class="info-row"><span class="info-label">客户账号:</span><span class="info-value">@GetCustomerName() (@GetCustomerEmail())</span></div>
                    <div class="info-row"><span class="info-label">收货人:</span><span class="info-value">@(_order.ShippingName ?? "-")</span></div>
                    <div class="info-row"><span class="info-label">联系电话:</span><span class="info-value">@(_order.ShippingPhone ?? "-")</span></div>
                    <div class="info-row"><span class="info-label">收货地址:</span><span class="info-value">@(_order.ShippingAddress ?? "-")</span></div>
                    @if (!string.IsNullOrEmpty(_order.TrackingNumber))
                    {
                        <div class="info-row"><span class="info-label">快递单号:</span><span class="info-value">@_order.TrackingNumber</span></div>
                    }
                </div>
            </div>
        </div>

        <!-- 订单商品 -->
        <h3 style="color:#e0e0e0;margin-bottom:15px;"><i class="fas fa-flask" style="color:#00bcd4;"></i> 生产明细 (商品快照)</h3>
        @if (_orderDetails.Any())
        {
            @foreach (var d in _orderDetails)
            {
                <div class="product-card">
                    <div class="product-header">
                        <span class="product-name">@(d.ProductName ?? "-")</span>
                        <span>数量: <strong>@d.Quantity</strong> | 单价: ¥@d.UnitPrice.ToString("N2")</span>
                    </div>
                    <div class="custom-detail">
                        <div class="note-section">
                            <h4>香调配比</h4>
                            @{
                                var notes = _detailNotes.Where(n => n.DetailId == d.DetailId).ToList();
                                if (notes.Any())
                                {
                                    foreach (var n in notes)
                                    {
                                        <div class="note-item"><span>[@(n.NoteType ?? "-")] @(GetNoteName(n.NoteId))</span><strong>@n.Percentage%</strong></div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted">无配比数据</div>
                                }
                            }
                        </div>
                        <div class="note-section">
                            <h4>规格参数</h4>
                            <div class="info-row"><span class="info-label">容量:</span><span class="info-value">@(d.VolumeMl?.ToString() ?? "0")ml (@(d.VolumeName ?? "-"))</span></div>
                            <div class="info-row"><span class="info-label">瓶身:</span><span class="info-value">@(d.BottleName ?? "-")</span></div>
                        </div>
                        <div class="note-section">
                            <h4>定制信息</h4>
                            @{var pt=GetProductType(d.ProductId);}
                            @if(!string.IsNullOrEmpty(pt)){<div class="info-row"><span class="info-label">产品类型:</span><span class="info-value"><span class="product-type-badge type-@pt.ToLower()">@GetProductTypeLabel(pt)</span></span></div>}
                            @if (!string.IsNullOrEmpty(d.CustomLabel))
                            {
                                <div class="info-row"><span class="info-label">瓶身刻字:</span><span class="info-value" style="color:#e67e22;border:1px solid #e67e22;padding:2px 5px;border-radius:3px;">@d.CustomLabel</span></div>
                            }
                            else
                            {
                                <div class="text-muted">无刻字</div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">此订单无详细商品数据</div>
        }

        <!-- 订单成分汇总 -->
        <div class="ingredients-box">
            <div class="ingredients-header"><i class="fas fa-microscope"></i> 订单成分汇总 (质控与过敏原管理)</div>
            <div class="ingredients-list">
                @if (_allIngredients.Any())
                {
                    @foreach (var ing in _allIngredients)
                    {
                        <span class="ingredient-tag">@ing</span>
                    }
                }
                else
                {
                    <div class="text-muted" style="padding:15px;">此订单暂无详细成分记录</div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_order.Notes))
        {
            <div class="notes-box">
                <h3><i class="fas fa-sticky-note"></i> 交易说明 / 备注</h3>
                <div style="font-size:14px;white-space:pre-wrap;">@_order.Notes</div>
            </div>
        }
    }
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

<style>
.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.page-title{font-size:24px;color:#fff;margin:0;display:flex;align-items:center;gap:10px;}.breadcrumb{font-size:13px;color:#888;}
.action-bar{margin-bottom:20px;display:flex;gap:10px;}
.btn{padding:10px 20px;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.3s;text-decoration:none;}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}.btn-primary:hover{background:linear-gradient(135deg,#00bcd4,#0097a7);}.btn-outline{background:rgba(255,255,255,0.05);color:#b0b0b0;border:1px solid rgba(255,255,255,0.1);}.btn-outline:hover{background:rgba(255,255,255,0.1);color:#fff;}
.detail-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-bottom:30px;}.info-card{background:rgba(255,255,255,0.04);padding:18px;border-radius:10px;border:1px solid rgba(255,255,255,0.08);}.info-title{margin:0 0 15px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,0.08);font-size:16px;color:#e0e0e0;}.info-title i{color:#00bcd4;margin-right:6px;}.info-rows{display:flex;flex-direction:column;gap:8px;}.info-row{display:flex;font-size:14px;}.info-label{width:100px;color:#888;font-weight:bold;flex-shrink:0;}.info-value{flex:1;color:#e0e0e0;}
.text-muted{color:#888;font-size:13px;}
.status-badge{display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:500;}.status-pending{background:rgba(255,152,0,0.12);color:#e65100;}.status-paid{background:rgba(46,125,50,0.2);color:#4caf50;}.status-processing{background:rgba(25,118,210,0.2);color:#2196f3;}.status-shipped{background:rgba(123,31,162,0.2);color:#9C27B0;}.status-completed{background:rgba(0,105,92,0.2);color:#4caf50;}.status-cancelled{background:rgba(198,40,40,0.2);color:#c62828;}.product-type-badge{display:inline-block;padding:2px 8px;border-radius:3px;font-size:11px;font-weight:600;}.type-fixed{background:rgba(33,150,243,0.2);color:#2196f3;}.type-custom{background:rgba(76,175,80,0.2);color:#4caf50;}.type-kol{background:rgba(156,39,176,0.2);color:#9c27b0;}
.product-card{border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:18px;margin-bottom:15px;background:linear-gradient(135deg,#2d2d44,#1e1e32);}.product-header{display:flex;justify-content:space-between;align-items:center;border-bottom:1px dashed rgba(255,255,255,0.08);padding-bottom:10px;margin-bottom:12px;}.product-name{font-weight:bold;font-size:16px;color:#00bcd4;}.custom-detail{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;}.note-section h4{font-size:14px;color:#e0e0e0;margin:0 0 5px;}.note-item{margin-bottom:3px;display:flex;justify-content:space-between;padding:2px 5px;background:rgba(255,255,255,0.04);border-radius:3px;font-size:13px;color:#ccc;}
.ingredients-box{margin-top:30px;background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.08);border-radius:10px;overflow:hidden;}.ingredients-header{background:rgba(0,188,212,0.1);padding:12px 18px;border-bottom:1px solid rgba(255,255,255,0.08);font-weight:bold;color:#00bcd4;}.ingredients-list{padding:15px;display:flex;flex-wrap:wrap;gap:8px;}.ingredient-tag{background:rgba(25,118,210,0.2);color:#00bcd4;padding:4px 12px;border-radius:15px;font-size:12px;border:1px solid rgba(255,255,255,0.08);}
.notes-box{margin-top:20px;background:rgba(255,193,7,0.1);padding:18px;border-radius:10px;border:1px solid rgba(255,193,7,0.3);}.notes-box h3{color:#e0e0e0;margin:0 0 10px;font-size:16px;}.notes-box h3 i{color:#ffc107;margin-right:6px;}
.empty-state{text-align:center;color:#888;padding:30px;font-size:14px;}
.error-state{text-align:center;color:#c62828;padding:40px;font-size:16px;background:rgba(198,40,40,0.1);border:1px solid rgba(198,40,40,0.3);border-radius:10px;}
@@media(max-width:768px){.detail-grid{grid-template-columns:1fr;}.custom-detail{grid-template-columns:1fr;}}
</style>

@code {
    [Parameter] public int OrderId { get; set; }

    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private bool _loaded;
    private Order? _order;
    private User? _customer;
    private List<PerfumeShop.Data.Models.OrderDetail> _orderDetails = new();
    private List<OrderDetailNoteSelection> _detailNotes = new();
    private Dictionary<int, string> _noteNames = new();
    private Dictionary<int, string> _productTypes = new();
    private List<string> _allIngredients = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _order = await Db.Orders.FirstOrDefaultAsync(o => o.OrderId == OrderId);
            if (_order != null)
            {
                _customer = await Db.Users.FirstOrDefaultAsync(u => u.UserId == _order.UserId);
                _orderDetails = await Db.OrderDetails.Where(d => d.OrderId == OrderId).ToListAsync();
                var detailIds = _orderDetails.Select(d => d.DetailId).ToList();
                _detailNotes = await Db.OrderDetailNoteSelections.Where(n => detailIds.Contains(n.DetailId)).ToListAsync();

                // Load note names
                var noteIds = _detailNotes.Select(n => n.NoteId).Distinct().ToList();
                var notes = await Db.FragranceNotes.Where(n => noteIds.Contains(n.NoteId)).ToListAsync();
                _noteNames = notes.ToDictionary(n => n.NoteId, n => n.NoteName);

                // Load product types for type badges
                var productIds = _orderDetails.Select(d => d.ProductId).Distinct().ToList();
                var products = await Db.Products.Where(p => productIds.Contains(p.ProductId)).ToListAsync();
                _productTypes = products.ToDictionary(p => p.ProductId, p => p.ProductType ?? "");

                // Load all ingredients for this order
                var rawIngredients = await Db.OrderIngredients
                    .Where(i => i.OrderId == OrderId)
                    .Select(i => i.IngredientName ?? "")
                    .ToListAsync();
                _allIngredients = rawIngredients
                    .SelectMany(r => r.Split(new[] { ',', '，', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
                    .Select(i => i.Trim())
                    .Where(i => !string.IsNullOrWhiteSpace(i))
                    .Distinct()
                    .OrderBy(i => i)
                    .ToList();
            }
            _loaded = true;
        }
        catch { _loaded = true; }
    }

    string GetNoteName(int noteId) => _noteNames.TryGetValue(noteId, out var name) ? name : $"#{noteId}";

    string GetCustomerName() => _customer?.FullName ?? _customer?.Username ?? $"(ID:{_order?.UserId})";
    string GetCustomerEmail() => _customer?.Email ?? "-";

    static string GetPaymentMethod(string? m) => (m ?? "").ToLower() switch
    {
        "1" or "wechat" => "微信支付",
        "2" or "alipay" => "支付宝",
        "3" or "paypal" => "PayPal",
        "4" or "cod" => "货到付款",
        _ => m ?? "-"
    };

    static string GetStatusClass(string? s) => s switch
    {
        "Pending" => "status-pending", "Paid" => "status-paid", "Processing" => "status-processing",
        "Shipped" => "status-shipped", "Completed" => "status-completed", "Cancelled" => "status-cancelled",
        _ => ""
    };

    string GetProductType(int productId) => _productTypes.TryGetValue(productId, out var pt) ? pt : "";
    static string GetProductTypeLabel(string? pt) => pt?.ToLower() switch { "fixed" => "品牌定香", "custom" => "用户定制", "kol" => "KOL推荐", _ => pt ?? "未知" };

    static string GetStatusLabel(string? s) => s switch
    {
        "Pending" => "待付款", "Paid" => "已支付", "Processing" => "处理中",
        "Shipped" => "已发货", "Completed" => "已完成", "Cancelled" => "已取消",
        _ => s ?? "-"
    };
}
