@page "/admin/Operation/CommunityPosts"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.operation")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Admin.Services

<PageTitle>社区帖子管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-comments"></i> 社区帖子管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>社区帖子</span></div></div>

@if (_loaded)
{
<div class="stats-row">
    <div class="stat-card"><div class="stat-value" style="color:#00bcd4;">@_totalPosts</div><div class="stat-label">总帖子</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#4CAF50;">@_activePosts</div><div class="stat-label">已发布</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#FF9800;">@_pinnedPosts</div><div class="stat-label">已置顶</div></div>
    <div class="stat-card"><div class="stat-value" style="color:#E91E63;">@_totalLikes</div><div class="stat-label">总点赞</div></div>
</div>

<div class="filter-bar">
    <input type="text" class="filter-input" @bind="_keyword" @bind:event="oninput" placeholder="搜索标题/内容..." />
    <select class="filter-select" @bind="_typeFilter">
        <option value="">全部类型</option>
        <option value="review">香评</option>
        <option value="discussion">讨论</option>
        <option value="question">问答</option>
        <option value="share">分享</option>
    </select>
    <button class="btn btn-outline btn-sm" @onclick="ResetFilter"><i class="fas fa-undo"></i> 重置</button>
    <span style="margin-left:auto;color:#888;font-size:13px;align-self:center;">共 @_filteredTotal 条</span>
</div>

<div class="table-container">
    <table class="data-table">
        <thead><tr><th>ID</th><th>用户</th><th>标题</th><th>类型</th><th>点赞</th><th>评论</th><th>状态</th><th>时间</th><th>操作</th></tr></thead>
        <tbody>
            @if (_displayPosts.Any())
            {
                @foreach (var p in _displayPosts.Skip((_page - 1) * 20).Take(20))
                {
                    <tr>
                        <td>#@p.PostId</td>
                        <td>@GetUserName(p.UserId)</td>
                        <td style="color:#00bcd4;font-weight:500;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(p.Title ?? "-")</td>
                        <td><span class="badge @GetTypeBadge(p.PostType)">@FormatType(p.PostType)</span></td>
                        <td>@p.LikeCount</td>
                        <td>@p.CommentCount</td>
                        <td>
                            @if (p.IsPinned) { <span class="status-badge status-pinned">置顶</span> }
                            <span class="status-badge @(p.IsActive ? "status-approved" : "status-pending")">@(p.IsActive ? "已发布" : "已隐藏")</span>
                        </td>
                        <td>@p.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <button class="action-btn detail" @onclick='()=>ShowDetail(p)'>详情</button>
                            <button class="action-btn @(p.IsActive?"reject":"approve")" @onclick="()=>ToggleActive(p)">@(p.IsActive?"隐藏":"发布")</button>
                            <button class="action-btn" style="background:rgba(255,152,0,0.2);color:#ffa726;" @onclick="()=>TogglePin(p)">@(p.IsPinned?"取消置顶":"置顶")</button>
                            <button class="action-btn" style="background:rgba(244,67,54,0.2);color:#ef5350;" @onclick="()=>DeletePost(p.PostId)"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="9" class="empty-cell">暂无帖子数据</td></tr>
            }
        </tbody>
    </table>
</div>
@if (_totalPages > 1)
{
    <div class="pagination">
        @for (int p = 1; p <= _totalPages; p++)
        {
            var pi = p;
            <a href="javascript:void(0)" class="@(pi==_page?"page-item active":"page-item")" @onclick="()=>GoPage(pi)" @onclick:preventDefault>@pi</a>
        }
    </div>
}

@if(_showDetail&&_detailPost!=null){<div class="modal-overlay show" @onclick="()=>_showDetail=false"><div class="modal" @onclick:stopPropagation="true"><div class="modal-header"><h3>帖子详情 #@_detailPost.PostId</h3><button class="modal-close" @onclick="()=>_showDetail=false">&times;</button></div><div class="modal-body">
    <div class="detail-row"><label>作者</label><p>@GetUserName(_detailPost.UserId)</p></div>
    <div class="detail-row"><label>标题</label><p style="color:#00bcd4;">@(_detailPost.Title??"-")</p></div>
    <div class="detail-row"><label>类型</label><p><span class="badge @GetTypeBadge(_detailPost.PostType)">@FormatType(_detailPost.PostType)</span></p></div>
    <div class="detail-row"><label>内容</label><p style="min-height:80px;white-space:pre-wrap;">@(_detailPost.Content??"（无内容）")</p></div>
    @if(!string.IsNullOrEmpty(_detailPost.Tags)){<div class="detail-row"><label>标签</label><p>@_detailPost.Tags</p></div>}
    @if(!string.IsNullOrEmpty(_detailPost.FragranceNotes)){<div class="detail-row"><label>香调</label><p>@_detailPost.FragranceNotes</p></div>}
    <div class="detail-row"><label>数据</label><p>👍 @_detailPost.LikeCount &nbsp; 💬 @_detailPost.CommentCount &nbsp; 👁 @_detailPost.ViewCount</p></div>
    <div class="detail-row"><label>状态</label><p>@if(_detailPost.IsPinned){<span class="status-badge status-pinned">置顶</span>} <span class="status-badge @(_detailPost.IsActive?"status-approved":"status-pending")">@(_detailPost.IsActive?"已发布":"已隐藏")</span> @(_detailPost.IsPublic?"🌐 公开":"🔒 私有")</p></div>
    <div class="detail-row"><label>时间</label><p>创建: @_detailPost.CreatedAt.ToString("yyyy-MM-dd HH:mm") @if(_detailPost.UpdatedAt.HasValue){<text> | 更新: @_detailPost.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</text>}</p></div>
</div><div class="modal-footer">
    <button class="btn btn-outline" @onclick="()=>_showDetail=false">关闭</button>
    <button class="btn @(_detailPost.IsActive?"btn-outline":"btn-primary")" @onclick='()=>ToggleActive(_detailPost!)'>@(_detailPost.IsActive?"隐藏":"发布")</button>
    <button class="btn btn-outline" style="color:#FF9800;border-color:#FF9800;" @onclick='()=>TogglePin(_detailPost!)'>@(_detailPost.IsPinned?"取消置顶":"置顶")</button>
    <button class="btn btn-danger" @onclick='()=>{DeletePost(_detailPost!.PostId);_showDetail=false;}'>删除</button>
</div></div></div>}
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

<style>

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:18px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}.stat-value{font-size:26px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}
.filter-bar{display:flex;gap:12px;align-items:center;margin-bottom:20px;padding:15px 20px;background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;border:1px solid rgba(255,255,255,0.05);}.filter-select{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;padding:8px 12px;font-size:13px;cursor:pointer;min-width:120px;}.filter-select:focus{border-color:#00bcd4;outline:none;}.filter-select option{background:#2d2d44;color:#e0e0e0;}.filter-input{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;padding:8px 12px;font-size:13px;min-width:200px;}.filter-input:focus{border-color:#00bcd4;outline:none;}.filter-input::placeholder{color:#666;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}.data-table{width:100%;border-collapse:collapse;}.data-table th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:12px 14px;font-size:13px;text-align:left;font-weight:600;}.data-table td{padding:12px 14px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}.data-table tr:last-child td{border-bottom:none;}.data-table tr:hover td{background:rgba(255,255,255,0.03);}
.status-badge{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;margin-right:4px;}.status-pending{background:rgba(255,152,0,0.2);color:#ff9800;}.status-approved{background:rgba(76,175,80,0.2);color:#4caf50;}.status-pinned{background:rgba(156,39,176,0.2);color:#CE93D8;}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;}.badge-review{background:rgba(0,188,212,0.2);color:#4dd0e1;}.badge-discussion{background:rgba(76,175,80,0.2);color:#66bb6a;}.badge-question{background:rgba(255,152,0,0.2);color:#ffa726;}.badge-share{background:rgba(156,39,176,0.2);color:#CE93D8;}
.action-btn{padding:4px 8px;border-radius:4px;font-size:11px;border:none;cursor:pointer;margin-right:4px;margin-bottom:2px;}.action-btn.approve{background:rgba(76,175,80,0.2);color:#66bb6a;}.action-btn.approve:hover{background:#4CAF50;color:#fff;}.action-btn.reject{background:rgba(244,67,54,0.2);color:#ef5350;}.action-btn.reject:hover{background:#f44336;color:#fff;}.action-btn.detail{background:rgba(0,188,212,0.2);color:#4dd0e1;}.action-btn.detail:hover{background:#00bcd4;color:#fff;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:6px;text-decoration:none;}.btn-outline{background:rgba(255,255,255,0.05);color:#b0b0b0;border:1px solid rgba(255,255,255,0.1);}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;}.btn-danger{background:#c62828;color:#fff;}.btn-sm{padding:5px 12px;font-size:11px;}.empty-cell{text-align:center;color:#666;padding:40px;}
.pagination{display:flex;justify-content:center;gap:8px;margin-top:20px;}.page-item{padding:8px 14px;background:#2d2d44;border-radius:6px;text-decoration:none;color:#b0b0b0;border:1px solid rgba(255,255,255,0.05);cursor:pointer;font-size:14px;}.page-item:hover,.page-item.active{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;justify-content:center;align-items:center;}.modal{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:16px;border:1px solid rgba(255,255,255,0.1);padding:30px;width:90%;max-width:650px;max-height:90vh;overflow-y:auto;}.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}.modal-header h3{color:#fff;margin:0;font-size:18px;}.modal-close{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.detail-row{margin-bottom:12px;}.detail-row label{display:block;color:#999;font-size:12px;margin-bottom:4px;}.detail-row p{background:rgba(255,255,255,0.05);color:#e0e0e0;padding:10px;border-radius:6px;margin:0;border:1px solid rgba(255,255,255,0.08);}.modal-footer{margin-top:20px;display:flex;justify-content:flex-end;gap:8px;}
@@media(max-width:768px){.stats-row{grid-template-columns:repeat(2,1fr);}.filter-bar{flex-wrap:wrap;}}
</style>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private IAdminAuditor Auditor { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;
    private bool _loaded;
    private int _adminId; private string _adminName = "";
    private List<CommunityPost> _posts = new();
    private Dictionary<int, string> _un = new();
    private string? _typeFilter, _keyword = "";
    private int _totalPosts, _activePosts, _pinnedPosts, _totalLikes, _filteredTotal, _page = 1, _totalPages = 1;
    private bool _showDetail;
    private CommunityPost? _detailPost;

    protected override async Task OnInitializedAsync()
    {
        try { var st = await AuthState.GetAuthenticationStateAsync(); int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _adminId); _adminName = st.User.FindFirst(ClaimTypes.Name)?.Value ?? ""; await LoadData(); _loaded = true; } catch { _loaded = true; }
    }

    async Task LoadData()
    {
        _posts = await Db.CommunityPosts.AsNoTracking().OrderByDescending(p => p.IsPinned).ThenByDescending(p => p.CreatedAt).Take(500).ToListAsync();
        _totalPosts = _posts.Count;
        _activePosts = _posts.Count(p => p.IsActive);
        _pinnedPosts = _posts.Count(p => p.IsPinned);
        _totalLikes = _posts.Sum(p => p.LikeCount);
        var uids = _posts.Select(p => p.UserId).Distinct().ToList();
        _un = (await Db.Users.Where(u => uids.Contains(u.UserId)).ToListAsync()).ToDictionary(u => u.UserId, u => u.Username ?? "");
    }

    IEnumerable<CommunityPost> _displayPosts
    {
        get
        {
            var q = _posts.AsEnumerable();
            if (!string.IsNullOrEmpty(_typeFilter))
                q = q.Where(p => p.PostType == _typeFilter);
            if (!string.IsNullOrWhiteSpace(_keyword))
            {
                var kw = _keyword.Trim().ToLower();
                q = q.Where(p => (p.Title != null && p.Title.ToLower().Contains(kw))
                    || (p.Content != null && p.Content.ToLower().Contains(kw))
                    || _un.TryGetValue(p.UserId, out var un) && un.ToLower().Contains(kw));
            }
            var list = q.ToList();
            _filteredTotal = list.Count;
            _totalPages = Math.Max(1, (int)Math.Ceiling((double)list.Count / 20));
            if (_page > _totalPages) _page = 1;
            return list;
        }
    }

    async Task ResetFilter() { _typeFilter = null; _keyword = ""; _page = 1; await InvokeAsync(StateHasChanged); }
    async Task GoPage(int p) { _page = p; await InvokeAsync(StateHasChanged); }

    async Task ToggleActive(CommunityPost p)
    {
        p.IsActive = !p.IsActive;
        await Db.CommunityPosts.Where(x => x.PostId == p.PostId).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, p.IsActive).SetProperty(x => x.UpdatedAt, DateTime.Now));
        await Auditor.LogAsync(_adminId, _adminName, p.IsActive ? "发布社区帖子" : "隐藏社区帖子", "CommunityPost", p.PostId, p.Title);
        if(_detailPost?.PostId == p.PostId) _detailPost.IsActive = p.IsActive;
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    async Task TogglePin(CommunityPost p)
    {
        p.IsPinned = !p.IsPinned;
        await Db.CommunityPosts.Where(x => x.PostId == p.PostId).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsPinned, p.IsPinned).SetProperty(x => x.UpdatedAt, DateTime.Now));
        await Auditor.LogAsync(_adminId, _adminName, p.IsPinned ? "置顶社区帖子" : "取消置顶", "CommunityPost", p.PostId, p.Title);
        if(_detailPost?.PostId == p.PostId) _detailPost.IsPinned = p.IsPinned;
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    async Task DeletePost(int id)
    {
        await Db.CommunityPosts.Where(p => p.PostId == id).ExecuteDeleteAsync();
        // Also delete associated comments
        await Db.PostComments.Where(c => c.PostId == id).ExecuteDeleteAsync();
        await Auditor.LogAsync(_adminId, _adminName, "删除社区帖子", "CommunityPost", id, null);
        _posts = _posts.Where(p => p.PostId != id).ToList();
        _totalPosts--;
        await InvokeAsync(StateHasChanged);
    }

    void ShowDetail(CommunityPost p) { _detailPost = p; _showDetail = true; }

    string GetUserName(int uid) => _un.TryGetValue(uid, out var n) ? n : $"#{uid}";

    static string FormatType(string? t) => t?.ToLower() switch
    {
        "review" => "香评",
        "discussion" => "讨论",
        "question" => "问答",
        "share" => "分享",
        _ => t ?? "讨论"
    };

    static string GetTypeBadge(string? t) => t?.ToLower() switch
    {
        "review" => "badge-review",
        "discussion" => "badge-discussion",
        "question" => "badge-question",
        "share" => "badge-share",
        _ => "badge-discussion"
    };
}
