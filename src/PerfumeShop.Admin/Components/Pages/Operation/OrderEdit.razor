@page "/admin/Operation/OrderEdit/{OrderId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.operation")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Admin.Services

<PageTitle>编辑订单</PageTitle>

@if (_loaded)
{
    @if (_order == null)
    {
        <div class="error-state"><i class="fas fa-exclamation-triangle"></i> 订单不存在或已被删除</div>
        <div style="margin-top:20px;"><a href="/admin/Operation/Orders" class="btn btn-outline"><i class="fas fa-arrow-left"></i> 返回订单列表</a></div>
    }
    else
    {
        <div class="page-header">
            <h2 class="page-title"><i class="fas fa-edit" style="color:#00bcd4;"></i> 编辑订单 #@_order.OrderNo</h2>
            <div class="breadcrumb">
                <a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> /
                <a href="/admin/Operation/Orders" style="color:#00bcd4;text-decoration:none;">订单管理</a> /
                <span>编辑订单</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMsg))
        {
            <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> @_errorMsg</div>
        }
        @if (!string.IsNullOrEmpty(_successMsg))
        {
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> @_successMsg</div>
        }

        <div class="form-container">
            <EditForm Model="@_editModel" OnValidSubmit="HandleSubmit" FormName="orderEditForm">
                <!-- 只读信息区域 -->
                <div class="info-section">
                    <h3><i class="fas fa-info-circle"></i> 订单基本信息（只读）</h3>
                    <div class="form-row">
                        <div class="info-row"><span class="info-label">订单号:</span><span class="info-value">@_order.OrderNo</span></div>
                        <div class="info-row"><span class="info-label">下单时间:</span><span class="info-value">@(_order.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span></div>
                    </div>
                    <div class="form-row">
                        <div class="info-row"><span class="info-label">客户账号:</span><span class="info-value">@GetCustomerName() (@GetCustomerEmail())</span></div>
                        <div class="info-row"><span class="info-label">订单金额:</span><span class="info-value" style="font-size:18px;font-weight:600;">¥@_order.TotalAmount.ToString("N2")</span></div>
                    </div>
                </div>

                <!-- 可编辑区域 -->
                <div class="form-group">
                    <label>订单状态 <span class="required">*</span></label>
                    <select class="form-control" @bind="_editModel.Status" required>
                        <option value="Pending">待支付</option>
                        <option value="Paid">已支付</option>
                        <option value="Processing">处理中</option>
                        <option value="Shipped">已发货</option>
                        <option value="Delivered">已送达</option>
                        <option value="Cancelled">已取消</option>
                        <option value="Refunded">已退款</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex:1;">
                        <label>收货人姓名 <span class="required">*</span></label>
                        <input type="text" class="form-control" @bind="_editModel.ShippingName" required />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>收货电话 <span class="required">*</span></label>
                        <input type="text" class="form-control" @bind="_editModel.ShippingPhone" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>收货地址 <span class="required">*</span></label>
                    <textarea class="form-control" @bind="_editModel.ShippingAddress" required rows="2"></textarea>
                </div>

                <div class="form-group">
                    <label>订单备注</label>
                    <textarea class="form-control" @bind="_editModel.Notes" placeholder="请输入订单备注（可选）" rows="3"></textarea>
                </div>

                <!-- 订单商品列表（只读） -->
                <div class="info-section" style="margin-top:30px;">
                    <h3><i class="fas fa-shopping-bag"></i> 订单商品（只读）</h3>
                    @if (_orderDetails.Any())
                    {
                        @foreach (var d in _orderDetails)
                        {
                            <div class="product-card">
                                <div class="product-header">
                                    <span class="product-name">@(d.ProductName ?? "-")</span>
                                    <span>数量: <strong>@d.Quantity</strong> | 单价: ¥@d.UnitPrice.ToString("N2")</span>
                                </div>
                                <div class="product-info">
                                    <div>前调: @(d.TopNoteName ?? "-")</div>
                                    <div>中调: @(d.MiddleNoteName ?? "-")</div>
                                    <div>后调: @(d.BaseNoteName ?? "-")</div>
                                    <div>容量: @(d.VolumeName ?? "-")</div>
                                    <div>瓶身: @(d.BottleName ?? "-")</div>
                                    <div>刻字: @(d.CustomLabel ?? "-")</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted">此订单无详细商品数据</div>
                    }
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" disabled="@_saving"><i class="fas fa-save"></i> @(_saving ? "保存中..." : "保存修改")</button>
                    <a href="/admin/Operation/OrderDetail/@(_order.OrderId)" class="btn btn-outline"><i class="fas fa-times"></i> 取消</a>
                </div>
            </EditForm>
        </div>
    }
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

<style>

.form-container{max-width:900px;background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:30px;border-radius:14px;border:1px solid rgba(255,255,255,0.05);}.form-group{margin-bottom:20px;}.form-group label{display:block;margin-bottom:8px;font-weight:500;color:#e0e0e0;font-size:14px;}.form-group label .required{color:#e74c3c;margin-left:4px;}.form-control{width:100%;padding:12px 15px;border:1px solid rgba(255,255,255,0.08);border-radius:8px;font-size:14px;box-sizing:border-box;background:rgba(255,255,255,0.04);color:#e0e0e0;}.form-control:focus{outline:none;border-color:#00bcd4;box-shadow:0 0 0 2px rgba(0,188,212,0.2);}textarea.form-control{min-height:80px;resize:vertical;}.form-control option{background:#2d2d44;color:#e0e0e0;}.form-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;}.form-actions{display:flex;gap:15px;margin-top:30px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.08);}
.info-section{background:rgba(255,255,255,0.04);padding:18px;border-radius:10px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.08);}.info-section h3{margin:0 0 15px;font-size:16px;color:#e0e0e0;border-bottom:1px solid rgba(255,255,255,0.08);padding-bottom:10px;}.info-section h3 i{color:#00bcd4;margin-right:6px;}.info-row{display:flex;margin-bottom:10px;font-size:14px;}.info-label{width:100px;color:#888;font-weight:bold;flex-shrink:0;}.info-value{flex:1;color:#e0e0e0;}
.btn{padding:10px 20px;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.3s;text-decoration:none;}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}.btn-primary:hover{background:linear-gradient(135deg,#00bcd4,#0097a7);}.btn-primary[disabled]{opacity:0.5;cursor:not-allowed;}.btn-outline{background:rgba(255,255,255,0.05);color:#b0b0b0;border:1px solid rgba(255,255,255,0.1);}.btn-outline:hover{background:rgba(255,255,255,0.1);color:#fff;}
.alert{padding:15px;border-radius:8px;margin-bottom:20px;font-size:14px;}.alert-error{background:rgba(198,40,40,0.2);color:#c62828;border:1px solid rgba(198,40,40,0.3);}.alert-success{background:rgba(46,125,50,0.2);color:#4caf50;border:1px solid rgba(46,125,50,0.3);}
.product-card{border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:15px;margin-bottom:12px;background:linear-gradient(135deg,#2d2d44,#1e1e32);}.product-header{display:flex;justify-content:space-between;align-items:center;border-bottom:1px dashed rgba(255,255,255,0.08);padding-bottom:10px;margin-bottom:10px;}.product-name{font-weight:bold;font-size:15px;color:#00bcd4;}.product-info{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;font-size:13px;color:#b0b0b0;}
.text-muted{color:#888;font-size:13px;}
.error-state{text-align:center;color:#c62828;padding:40px;font-size:16px;background:rgba(198,40,40,0.1);border:1px solid rgba(198,40,40,0.3);border-radius:10px;}
@@media(max-width:768px){.form-row{grid-template-columns:1fr;}.product-info{grid-template-columns:1fr;}}
</style>

@code {
    [Parameter] public int OrderId { get; set; }

    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IAdminAuditor Auditor { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;

    private bool _loaded, _saving;
    private int _adminId; private string _adminName = "";
    private Order? _order;
    private User? _customer;
    private List<PerfumeShop.Data.Models.OrderDetail> _orderDetails = new();
    private OrderEditModel _editModel = new();
    private string? _errorMsg, _successMsg;

    class OrderEditModel
    {
        public string Status { get; set; } = "";
        public string ShippingName { get; set; } = "";
        public string ShippingPhone { get; set; } = "";
        public string ShippingAddress { get; set; } = "";
        public string Notes { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var st = await AuthState.GetAuthenticationStateAsync();
            int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _adminId);
            _adminName = st.User.FindFirst(ClaimTypes.Name)?.Value ?? "";
            _order = await Db.Orders.FirstOrDefaultAsync(o => o.OrderId == OrderId);
            if (_order != null)
            {
                _customer = await Db.Users.FirstOrDefaultAsync(u => u.UserId == _order.UserId);
                _orderDetails = await Db.OrderDetails.Where(d => d.OrderId == OrderId).ToListAsync();

                _editModel = new OrderEditModel
                {
                    Status = _order.Status ?? "Pending",
                    ShippingName = _order.ShippingName ?? "",
                    ShippingPhone = _order.ShippingPhone ?? "",
                    ShippingAddress = _order.ShippingAddress ?? "",
                    Notes = _order.Notes ?? ""
                };
            }
            _loaded = true;
        }
        catch { _loaded = true; }
    }

    async Task HandleSubmit()
    {
        _errorMsg = null;
        _successMsg = null;

        if (string.IsNullOrWhiteSpace(_editModel.Status))
        {
            _errorMsg = "请选择订单状态";
            return;
        }
        if (string.IsNullOrWhiteSpace(_editModel.ShippingName))
        {
            _errorMsg = "请输入收货人姓名";
            return;
        }
        if (string.IsNullOrWhiteSpace(_editModel.ShippingPhone))
        {
            _errorMsg = "请输入收货电话";
            return;
        }
        if (string.IsNullOrWhiteSpace(_editModel.ShippingAddress))
        {
            _errorMsg = "请输入收货地址";
            return;
        }

        try
        {
            _saving = true;
            await Db.Orders.Where(o => o.OrderId == OrderId)
                .ExecuteUpdateAsync(s => s
                    .SetProperty(o => o.Status, _editModel.Status)
                    .SetProperty(o => o.ShippingName, _editModel.ShippingName)
                    .SetProperty(o => o.ShippingPhone, _editModel.ShippingPhone)
                    .SetProperty(o => o.ShippingAddress, _editModel.ShippingAddress)
                    .SetProperty(o => o.Notes, _editModel.Notes)
                    .SetProperty(o => o.UpdatedAt, DateTime.Now));

            await Auditor.LogAsync(_adminId, _adminName, "编辑订单", "Order", OrderId, _order?.OrderNo, $"状态={_editModel.Status}");
            _successMsg = "订单信息已成功更新";
            // Navigate to detail page after short delay
            Navigation.NavigateTo($"/admin/Operation/OrderDetail/{OrderId}");
        }
        catch (Exception ex)
        {
            _errorMsg = "保存失败: " + ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    string GetCustomerName() => _customer?.FullName ?? _customer?.Username ?? $"(ID:{_order?.UserId})";
    string GetCustomerEmail() => _customer?.Email ?? "-";
}
