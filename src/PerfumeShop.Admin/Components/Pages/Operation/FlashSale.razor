@page "/admin/Operation/FlashSale"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.operation")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Admin.Services
@using FSModel = PerfumeShop.Data.Models.FlashSale

<PageTitle>秒杀管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-bolt" style="color:#f44336;"></i> 秒杀活动管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>秒杀管理</span></div></div>

@if (_error != null) { <div class="alert alert-error">@_error<button class="btn btn-outline btn-sm" @onclick="RetryLoad">重试</button></div> }
else if (!_loaded) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }
else
{
    @if (!string.IsNullOrEmpty(_msg)) { <div class="alert @(_msgErr?"alert-error":"alert-success")"><i class="fas fa-@(_msgErr?"exclamation":"check")-circle"></i> @_msg</div> }
    <div class="stats-row"><div class="stat-card"><div class="stat-value" style="color:#f44336;">@_totalCount</div><div class="stat-label">全部秒杀</div></div><div class="stat-card"><div class="stat-value" style="color:#4CAF50;">@_activeCount</div><div class="stat-label">进行中</div></div><div class="stat-card"><div class="stat-value" style="color:#2196F3;">@_upcomingCount</div><div class="stat-label">即将开始</div></div><div class="stat-card"><div class="stat-value" style="color:#9e9e9e;">@_endedCount</div><div class="stat-label">已结束</div></div></div>
    <div class="tier-wheel-panel" style="margin-bottom:20px;"><div class="wheel" style="background:@WheelGradient();"><div class="wheel-center"><div class="wheel-total">@_totalCount</div><div class="wheel-label">秒杀总数</div></div></div><div class="wheel-legend"><div class="legend-item"><span class="legend-dot" style="background:#4CAF50;"></span><span class="legend-name">进行中</span><span class="legend-count">@_activeCount 个 (@(_totalCount>0?(int)((double)_activeCount/_totalCount*100):0)%)</span></div><div class="legend-item"><span class="legend-dot" style="background:#2196F3;"></span><span class="legend-name">即将开始</span><span class="legend-count">@_upcomingCount 个</span></div><div class="legend-item"><span class="legend-dot" style="background:#9e9e9e;"></span><span class="legend-name">已结束</span><span class="legend-count">@_endedCount 个</span></div></div></div>

    <div style="margin-bottom:20px;display:flex;gap:12px;align-items:center;">
        <button class="btn btn-primary" @onclick="ToggleForm"><i class="fas fa-plus"></i> 创建秒杀活动</button>
        <select class="filter-select" @bind="_statusFilter">
            <option value="">全部状态</option>
            <option value="active">进行中</option>
            <option value="upcoming">即将开始</option>
            <option value="ended">已结束</option>
        </select>
    </div>

    @if (_showForm)
    {
        <div class="panel"><h3><i class="fas fa-@(_editId>0?"edit":"plus-circle")"></i> @(_editId>0?"编辑":"创建")秒杀活动</h3>
            <form @onsubmit="SaveForm"><div class="form-row"><div class="form-group"><label>商品选择 *</label><select class="form-input" @bind="_fProductId" required><option value="">-- 请选择商品 --</option>@foreach(var p in _productList){<option value="@p.ProductId">@p.ProductName (@p.BasePrice.ToString("C2"))</option>}</select></div><div class="form-group"><label>秒杀价 *</label><input class="form-input" type="number" step="0.01" @bind="_fPrice" required/></div><div class="form-group"><label>秒杀库存 *</label><input class="form-input" type="number" @bind="_fStock" required/></div><div class="form-group"><label>每人限购</label><input class="form-input" type="number" @bind="_fLimit"/></div></div>
            <div class="form-row"><div class="form-group"><label>开始时间 *</label><input class="form-input" type="datetime-local" @bind-value="_fStart" @bind-value:format="yyyy-MM-ddTHH:mm" required/></div><div class="form-group"><label>结束时间 *</label><input class="form-input" type="datetime-local" @bind-value="_fEnd" @bind-value:format="yyyy-MM-ddTHH:mm" required/></div><div class="form-group"><label>排序</label><input class="form-input" type="number" @bind="_fSort"/></div></div>
            <div style="display:flex;gap:8px;margin-top:12px;"><button type="submit" class="btn btn-primary" disabled="@_saving"><i class="fas fa-save"></i> @(_saving?"保存中...":(_editId>0?"更新":"创建"))</button><button type="button" class="btn btn-outline" @onclick="()=>_showForm=false">取消</button></div></form></div>
    }

    <div class="panel"><h3><i class="fas fa-list"></i> 秒杀活动列表</h3>
    <table class="data-table"><thead><tr><th>ID</th><th>商品</th><th>原价</th><th>秒杀价</th><th>库存(剩余/总量)</th><th>已售</th><th>限购</th><th>时间</th><th>状态</th><th>操作</th></tr></thead>
    <tbody>@if (_filteredItems.Any()) { @foreach (var f in _filteredItems) { var pn = GetProdName(f.ProductId); var bp = GetBasePrice(f.ProductId); var remain = f.Stock - f.SoldCount; if (remain < 0) remain = 0; var pct = f.Stock > 0 ? (int)((double)f.SoldCount / f.Stock * 100) : 0;
    <tr><td>#@f.FlashSaleId</td><td style="color:#00bcd4;font-weight:500;">@pn</td><td>@bp.ToString("C2")</td><td style="color:#f44336;font-weight:700;">@f.FlashPrice.ToString("C2")</td><td>@remain/@f.Stock</td><td>@f.SoldCount<div class="stock-bar"><div class="stock-fill" style="width:@pct%;"></div></div></td><td>@f.LimitPerUser</td><td style="font-size:11px;">@f.StartTime.ToString("MM-dd HH:mm")~@f.EndTime.ToString("MM-dd HH:mm")</td><td><span class="badge @GetBadgeClass(f)">@GetStatusText(f)</span></td><td><button class="btn btn-sm" style="background:#f44336;color:#fff;" @onclick="()=>Edit(f)"><i class="fas fa-edit"></i></button><button class="btn btn-sm btn-outline" @onclick="()=>ToggleActive(f)"><i class="fas fa-power-off"></i></button><button class="btn btn-sm" style="background:#c62828;color:#fff;" @onclick="()=>Delete(f)"><i class="fas fa-trash"></i></button></td></tr>}} else { <tr><td colspan="10" class="empty-cell">暂无秒杀活动</td></tr> }</tbody></table></div>
}

<style>

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:18px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}.stat-value{font-size:26px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}
.panel{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:24px;border:1px solid rgba(255,255,255,0.05);margin-bottom:24px;}.panel h3{color:#fff;margin:0 0 16px;font-size:18px;display:flex;align-items:center;gap:8px;}.panel h3 i{color:#f44336;}
.form-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:12px;margin-bottom:12px;}.form-group{display:flex;flex-direction:column;gap:4px;}.form-group label{font-size:12px;color:#888;}.form-input{padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;font-size:13px;}.form-input:focus{border-color:#f44336;outline:none;}.form-input option{background:#2d2d44;color:#e0e0e0;}
.filter-select{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;padding:8px 12px;font-size:13px;min-width:120px;cursor:pointer;}.filter-select:focus{border-color:#f44336;outline:none;}.filter-select option{background:#2d2d44;color:#e0e0e0;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.2s;text-decoration:none;}.btn-primary{background:linear-gradient(135deg,#f44336,#c62828);color:#fff;}.btn-primary[disabled]{opacity:0.5;}.btn-outline{background:transparent;border:1px solid #555;color:#ccc;}.btn-sm{padding:4px 12px;font-size:11px;}
.data-table{width:100%;border-collapse:collapse;}.data-table th{text-align:left;padding:10px 12px;background:rgba(0,0,0,0.2);color:#888;font-size:11px;text-transform:uppercase;}.data-table td{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;color:#ccc;}.data-table tr:hover td{background:rgba(255,255,255,0.02);}.empty-cell{text-align:center;color:#666;padding:40px;}
.stock-bar{height:4px;background:rgba(255,255,255,0.1);border-radius:2px;margin-top:3px;overflow:hidden;width:60px;}.stock-fill{height:100%;background:linear-gradient(90deg,#f44336,#ff7043);border-radius:2px;}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;}.badge-active{background:rgba(76,175,80,0.2);color:#4CAF50;}.badge-inactive{background:rgba(158,158,158,0.2);color:#9e9e9e;}.badge-upcoming{background:rgba(33,150,243,0.2);color:#64B5F6;}.badge-ended{background:rgba(244,67,54,0.2);color:#ef9a9a;}
.alert{padding:12px 16px;border-radius:8px;margin-bottom:16px;display:flex;align-items:center;gap:8px;}.alert-success{background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-error{background:rgba(244,67,54,0.15);color:#ef9a9a;border:1px solid rgba(244,67,54,0.3);}
.tier-wheel-panel{display:flex;align-items:center;gap:30px;background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:20px 24px;border:1px solid rgba(255,255,255,0.05);}.wheel{width:120px;height:120px;border-radius:50%;position:relative;flex-shrink:0;}.wheel-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:76px;height:76px;background:#1a1a2e;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;}.wheel-total{font-size:24px;font-weight:700;color:#fff;}.wheel-label{font-size:11px;color:#888;}.wheel-legend{display:flex;flex-direction:column;gap:8px;flex:1;}.legend-item{display:flex;align-items:center;gap:8px;}.legend-dot{width:12px;height:12px;border-radius:3px;flex-shrink:0;}.legend-name{font-size:13px;color:#e0e0e0;min-width:80px;}.legend-count{font-size:12px;color:#888;}
@@media(max-width:768px){.stats-row{grid-template-columns:repeat(2,1fr);}}
</style>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private IAdminAuditor Auditor { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = default!;
    private bool _loaded, _showForm, _saving, _msgErr;
    private int _adminId; private string _adminName = "";
    private string? _error, _msg;
    private string? _statusFilter;
    private List<FSModel> _items = new();
    private List<Product> _productList = new();
    private Dictionary<int, string> _pn = new();
    private Dictionary<int, decimal> _bp = new();
    private int _totalCount, _activeCount, _upcomingCount, _endedCount;
    private int _editId;
    private string _fProductId = "", _fPrice = "", _fStock = "", _fLimit = "1", _fSort = "0";
    private DateTime _fStart = DateTime.Now, _fEnd = DateTime.Now.AddDays(1);

    IEnumerable<FSModel> _filteredItems
    {
        get
        {
            var n = DateTime.Now;
            return _statusFilter switch
            {
                "active" => _items.Where(f => f.IsActive && n >= f.StartTime && n <= f.EndTime),
                "upcoming" => _items.Where(f => f.IsActive && f.StartTime > n),
                "ended" => _items.Where(f => f.EndTime < n || !f.IsActive),
                _ => _items
            };
        }
    }

    protected override async Task OnInitializedAsync() { var st = await AuthState.GetAuthenticationStateAsync(); int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _adminId); _adminName = st.User.FindFirst(ClaimTypes.Name)?.Value ?? ""; await LoadData(); }

    async Task LoadData()
    {
        try { _error = null;
            _items = await Db.FlashSales.OrderByDescending(f => f.CreatedAt).ToListAsync();
            var n = DateTime.Now;
            _totalCount = _items.Count;
            _activeCount = _items.Count(f => f.IsActive && n >= f.StartTime && n <= f.EndTime);
            _upcomingCount = _items.Count(f => f.IsActive && f.StartTime > n);
            _endedCount = _items.Count(f => f.EndTime < n || !f.IsActive);
            _productList = await Db.Products.AsNoTracking().Where(p => p.IsActive == true).OrderBy(p => p.ProductName).ToListAsync();
            _pn = _productList.ToDictionary(p => p.ProductId, p => p.ProductName ?? "");
            _bp = _productList.ToDictionary(p => p.ProductId, p => p.BasePrice);
            _loaded = true;
        } catch (Exception ex) { _error = ex.Message; _loaded = true; }
    }

    async Task RetryLoad() { _loaded = false; _error = null; await LoadData(); }

    void ToggleForm() { _showForm = !_showForm; if (_showForm) { _editId = 0; ResetForm(); } }

    void ResetForm() { _fProductId = ""; _fPrice = ""; _fStock = ""; _fLimit = "1"; _fSort = "0"; _fStart = DateTime.Now; _fEnd = DateTime.Now.AddDays(1); }

    void Edit(FSModel f)
    {
        _editId = f.FlashSaleId; _fProductId = f.ProductId.ToString(); _fPrice = f.FlashPrice.ToString("F2");
        _fStock = f.Stock.ToString(); _fLimit = f.LimitPerUser.ToString(); _fSort = f.SortOrder.ToString();
        _fStart = f.StartTime; _fEnd = f.EndTime; _showForm = true;
    }

    async Task SaveForm()
    {
        _msg = null; _saving = true;
        try
        {
            var pid = int.TryParse(_fProductId, out var v) ? v : 0;
            var pr = decimal.TryParse(_fPrice, out var pv) ? pv : 0;
            var st = int.TryParse(_fStock, out var sv) ? sv : 0;
            var limit = int.TryParse(_fLimit, out var lv) ? lv : 1;
            var sort = int.TryParse(_fSort, out var so) ? so : 0;
            if (pid <= 0 || pr <= 0 || st <= 0) { _msg = "请完整填写必填字段"; _msgErr = true; return; }
            if (_fEnd <= _fStart) { _msg = "结束时间必须晚于开始时间"; _msgErr = true; return; }
            if (_editId > 0)
            {
                await Db.FlashSales.Where(f => f.FlashSaleId == _editId).ExecuteUpdateAsync(s =>
                    s.SetProperty(f => f.ProductId, pid).SetProperty(f => f.FlashPrice, pr)
                     .SetProperty(f => f.Stock, st).SetProperty(f => f.LimitPerUser, limit)
                     .SetProperty(f => f.StartTime, _fStart).SetProperty(f => f.EndTime, _fEnd)
                     .SetProperty(f => f.SortOrder, sort));
                _msg = "更新成功";
            }
            else
            {
                Db.FlashSales.Add(new FSModel { ProductId = pid, FlashPrice = pr, Stock = st, LimitPerUser = limit, StartTime = _fStart, EndTime = _fEnd, SortOrder = sort, IsActive = true, SoldCount = 0, CreatedAt = DateTime.Now });
                await Db.SaveChangesAsync();
                _msg = "创建成功";
            }
            await Auditor.LogAsync(_adminId, _adminName, _editId > 0 ? "编辑秒杀活动" : "创建秒杀活动", "FlashSale", _editId > 0 ? _editId : (int?)null, GetProdName(int.TryParse(_fProductId, out var apid) ? apid : 0));
            _msgErr = false; _showForm = false; await LoadData();
        }
        catch (Exception ex) { _msg = "保存失败: " + ex.Message; _msgErr = true; }
        _saving = false;
    }

    async Task ToggleActive(FSModel f) { var nv = !f.IsActive; await Db.FlashSales.Where(x => x.FlashSaleId == f.FlashSaleId).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, nv)); await Auditor.LogAsync(_adminId, _adminName, nv ? "启用秒杀活动" : "暂停秒杀活动", "FlashSale", f.FlashSaleId, GetProdName(f.ProductId)); f.IsActive = nv;await InvokeAsync(StateHasChanged); _msg = $"秒杀已{(nv ? "启用" : "暂停")}"; _msgErr = false; ComputeStats(); }

    async Task Delete(FSModel f) { try { await Db.FlashSales.Where(x => x.FlashSaleId == f.FlashSaleId).ExecuteDeleteAsync(); await Auditor.LogAsync(_adminId, _adminName, "删除秒杀活动", "FlashSale", f.FlashSaleId, GetProdName(f.ProductId)); _msg = "已删除"; _msgErr = false; _items.Remove(f); ComputeStats();await InvokeAsync(StateHasChanged); } catch (Exception ex) { _msg = ex.Message; _msgErr = true; } }

    void ComputeStats() { var n = DateTime.Now; _totalCount = _items.Count; _activeCount = _items.Count(f => f.IsActive && n >= f.StartTime && n <= f.EndTime); _upcomingCount = _items.Count(f => f.IsActive && f.StartTime > n); _endedCount = _items.Count(f => f.EndTime < n || !f.IsActive); }
    
        string WheelGradient(){if(_totalCount==0)return"conic-gradient(#3a3a4a 0turn 1turn)";var a=$"{(double)_activeCount/_totalCount*100:0.##}%";var u=$"{(double)_upcomingCount/_totalCount*100:0.##}%";var e=$"{(double)_endedCount/_totalCount*100:0.##}%";return$"conic-gradient(#4CAF50 0 {a},#2196F3 0 {u},#9e9e9e 0 {e})";}

    string GetProdName(int pid) => _pn.TryGetValue(pid, out var n) ? n : $"#{pid}";
    decimal GetBasePrice(int pid) => _bp.TryGetValue(pid, out var p) ? p : 0;

    static string GetStatusText(FSModel f) { var n = DateTime.Now; if (!f.IsActive) return "已暂停"; if (n >= f.StartTime && n <= f.EndTime) return "进行中"; if (f.StartTime > n) return "即将开始"; return "已结束"; }
    static string GetBadgeClass(FSModel f) { var n = DateTime.Now; if (!f.IsActive) return "badge-inactive"; if (n >= f.StartTime && n <= f.EndTime) return "badge-active"; if (f.StartTime > n) return "badge-upcoming"; return "badge-ended"; }
}
