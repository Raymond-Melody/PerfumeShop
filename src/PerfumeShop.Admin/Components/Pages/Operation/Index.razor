@page "/admin/Operation/Index"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
<PageTitle>运营概览</PageTitle>
<div class="page-header"><h2 class="page-title">运营概览</h2><div class="breadcrumb"><a href="/admin/Operation/Index">运营中心</a> / <span>概览</span></div></div>
@if(_loaded){<div class="stats-grid"><div class="stat-card orders"><div class="stat-icon"><i class="fas fa-shopping-cart"></i></div><div class="stat-value">@_todayOrders</div><div class="stat-label">今日订单</div><div class="stat-change @OrdersChange.Cls">@OrdersChange.Text @OrdersChange.Arrow</div></div><div class="stat-card revenue"><div class="stat-icon"><i class="fas fa-yen-sign"></i></div><div class="stat-value">@_todayRevenue.ToString("N0")</div><div class="stat-label">今日营收</div><div class="stat-change @RevenueChange.Cls">@RevenueChange.Text @RevenueChange.Arrow</div></div><div class="stat-card customers"><div class="stat-icon"><i class="fas fa-users"></i></div><div class="stat-value">@_todayNewUsers</div><div class="stat-label">今日新客</div><div style="margin-top:5px;color:#999;font-size:12px;">累计 @_totalCustomers 人</div></div><div class="stat-card products"><div class="stat-icon"><i class="fas fa-box"></i></div><div class="stat-value">@_activeProducts</div><div class="stat-label">在售商品</div><div style="margin-top:5px;color:#999;font-size:12px;">累计 @_totalProducts 款</div></div></div>
<div class="dashboard-grid"><div class="dashboard-card"><h3>订单状态分布</h3><div class="order-status-grid"><div class="status-item pending"><div class="status-number">@_pendingOrders</div><div class="status-label">待付款</div></div><div class="status-item processing"><div class="status-number">@_processingOrders</div><div class="status-label">处理中</div></div><div class="status-item completed"><div class="status-number">@_completedOrders</div><div class="status-label">已完成</div></div></div></div><div class="dashboard-card"><h3>快捷操作</h3><div class="quick-actions"><a href="/admin/Operation/Orders" class="action-btn"><i class="fas fa-shopping-cart"></i><span>订单管理</span></a><a href="/admin/Operation/Customers" class="action-btn"><i class="fas fa-users"></i><span>客户管理</span></a><a href="/admin/Operation/TierManagement" class="action-btn"><i class="fas fa-layer-group"></i><span>会员等级</span></a><a href="/admin/Operation/Points" class="action-btn"><i class="fas fa-coins"></i><span>积分管理</span></a></div></div></div>
<div class="dashboard-card"><h3>最近订单</h3><table class="recent-orders"><thead><tr><th>订单号</th><th>客户</th><th>金额</th><th>状态</th><th>时间</th></tr></thead><tbody>@foreach(var o in _recentOrders){<tr><td><a href="/admin/Operation/OrderDetail/@o.OrderId" style="color:#00bcd4;text-decoration:none;">@o.OrderNo</a></td><td>@o.CustomerName</td><td>@o.TotalAmount.ToString("N2")</td><td><span class="order-status @GetStatusClass(o.Status)">@GetStatusLabel(o.Status)</span></td><td>@(o.CreatedAt?.ToString("yyyy-MM-dd HH:mm"))</td></tr>}</tbody></table><div style="text-align:center;margin-top:15px;"><a href="/admin/Operation/Orders" class="btn-view-all">查看全部订单</a></div></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:30px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:25px;border-radius:12px;border:1px solid rgba(255,255,255,0.05);text-align:center;transition:transform 0.3s;}.stat-card:hover{transform:translateY(-5px);border-color:rgba(0,188,212,0.2);}.stat-icon{width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 15px;font-size:24px;color:white;}.orders .stat-icon{background:linear-gradient(135deg,#667eea,#764ba2);}.revenue .stat-icon{background:linear-gradient(135deg,#f093fb,#f5576c);}.customers .stat-icon{background:linear-gradient(135deg,#4facfe,#00f2fe);}.products .stat-icon{background:linear-gradient(135deg,#43e97b,#38f9d7);}.stat-value{font-size:32px;font-weight:bold;color:#fff;margin-bottom:5px;}.stat-label{color:#aaa;font-size:14px;}.stat-change{font-size:12px;margin-top:8px;}.stat-change.up{color:#4CAF50;}.stat-change.down{color:#f44336;}.stat-change.flat{color:#999;}.dashboard-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:25px;margin-bottom:30px;}.dashboard-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:25px;border:1px solid rgba(255,255,255,0.05);}.dashboard-card h3{font-size:18px;color:#fff;margin-bottom:20px;}.order-status-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;}.status-item{background:rgba(0,0,0,0.2);padding:20px;border-radius:10px;text-align:center;}.status-item.pending{border-left:4px solid #ff9800;}.status-item.processing{border-left:4px solid #2196F3;}.status-item.completed{border-left:4px solid #4CAF50;}.status-number{font-size:28px;font-weight:bold;margin-bottom:5px;}.pending .status-number{color:#ff9800;}.processing .status-number{color:#2196F3;}.completed .status-number{color:#4CAF50;}.status-label{color:#888;font-size:13px;}.quick-actions{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}.action-btn{display:flex;flex-direction:column;align-items:center;padding:16px;background:rgba(0,188,212,0.08);border-radius:10px;text-decoration:none;color:#ccc;transition:all 0.3s;border:1px solid rgba(255,255,255,0.05);}.action-btn:hover{background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;transform:translateY(-3px);}.action-btn i{font-size:22px;margin-bottom:8px;}.recent-orders{width:100%;border-collapse:collapse;}.recent-orders th{text-align:left;padding:12px;background:rgba(0,0,0,0.2);font-weight:600;color:#888;font-size:12px;text-transform:uppercase;}.recent-orders td{padding:12px;border-bottom:1px solid rgba(255,255,255,0.05);color:#e0e0e0;}.order-status{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}.status-paid{background:rgba(76,175,80,0.2);color:#4caf50;}.status-pending{background:rgba(255,152,0,0.2);color:#ff9800;}.status-processing{background:rgba(33,150,243,0.2);color:#2196f3;}.status-shipped{background:rgba(156,39,176,0.2);color:#9C27B0;}.status-completed{background:rgba(76,175,80,0.2);color:#4caf50;}.status-cancelled{background:rgba(244,67,54,0.2);color:#c62828;}.btn-view-all{display:inline-block;padding:10px 30px;background:linear-gradient(135deg,#00bcd4,#00838f);color:white;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;transition:all 0.3s;}.btn-view-all:hover{background:linear-gradient(135deg,#00bcd4,#0097a7);transform:translateY(-2px);}@@media(max-width:1200px){.stats-grid{grid-template-columns:repeat(2,1fr);}.dashboard-grid{grid-template-columns:1fr;}}@@media(max-width:768px){.stats-grid{grid-template-columns:1fr;}.order-status-grid{grid-template-columns:1fr;}}</style>
@code{[Inject] private PerfumeShopContext Db{get;set;}=default!;private bool _loaded;private int _todayOrders,_yesterdayOrders,_todayNewUsers,_totalCustomers,_activeProducts,_totalProducts,_pendingOrders,_processingOrders,_completedOrders;private decimal _todayRevenue,_yesterdayRevenue;private List<RecentOrderRow> _recentOrders=new();
class RecentOrderRow{public int OrderId;public string OrderNo="",CustomerName="",Status="";public decimal TotalAmount;public DateTime? CreatedAt;}
protected override async Task OnInitializedAsync(){try{var today=DateTime.Today;_todayOrders=await Db.Orders.CountAsync(o=>o.CreatedAt>=today);_todayRevenue=await Db.Orders.Where(o=>o.CreatedAt>=today&&o.Status=="Paid").SumAsync(o=>(decimal?)o.TotalAmount)??0;var yesterday=today.AddDays(-1);_yesterdayOrders=await Db.Orders.CountAsync(o=>o.CreatedAt>=yesterday&&o.CreatedAt<today);_yesterdayRevenue=await Db.Orders.Where(o=>o.CreatedAt>=yesterday&&o.CreatedAt<today&&o.Status=="Paid").SumAsync(o=>(decimal?)o.TotalAmount)??0;_todayNewUsers=await Db.Users.CountAsync(u=>u.CreatedAt>=today);_totalCustomers=await Db.Users.CountAsync();_activeProducts=await Db.Products.CountAsync(p=>p.IsActive==true);_totalProducts=await Db.Products.CountAsync();_pendingOrders=await Db.Orders.CountAsync(o=>o.Status=="Pending");_processingOrders=await Db.Orders.CountAsync(o=>o.Status=="Processing");_completedOrders=await Db.Orders.CountAsync(o=>o.Status=="Paid");var ro=await Db.Orders.OrderByDescending(o=>o.CreatedAt).Take(5).ToListAsync();var uids=ro.Select(o=>o.UserId).Distinct().ToList();var us=await Db.Users.Where(u=>uids.Contains(u.UserId)).ToDictionaryAsync(u=>u.UserId,u=>u.FullName??u.Username??"");_recentOrders=ro.Select(o=>new RecentOrderRow{OrderId=o.OrderId,OrderNo=o.OrderNo??"",CustomerName=us.TryGetValue(o.UserId,out var n)?n:$"#{o.UserId}",TotalAmount=o.TotalAmount,Status=o.Status??"",CreatedAt=o.CreatedAt}).ToList();_loaded=true;}catch{_loaded=true;}}
static string GetStatusClass(string? s)=>s switch{"Pending"=>"status-pending","Paid"=>"status-paid","Processing"=>"status-processing","Shipped"=>"status-shipped","Completed"=>"status-completed","Cancelled"=>"status-cancelled",_=>""};
static string GetStatusLabel(string? s)=>s switch{"Pending"=>"待付款","Paid"=>"已支付","Processing"=>"处理中","Shipped"=>"已发货","Completed"=>"已完成","Cancelled"=>"已取消",_=>s??"-"};
(string Cls,string Arrow,string Text) OrdersChange=>CalcChange(_todayOrders,_yesterdayOrders);
(string Cls,string Arrow,string Text) RevenueChange=>CalcChange((double)_todayRevenue,(double)_yesterdayRevenue);
static (string Cls,string Arrow,string Text) CalcChange(double today,double yest){if(yest<=0)return today>0?("up","↑","较上日 +100%"):("flat","—","较上日 0%");var pct=(today-yest)/yest*100;string cls=pct>0?"up":(pct<0?"down":"flat");string arrow=pct>0?"↑":(pct<0?"↓":"—");return(cls,arrow,$"较上日 {(pct>=0?"+":"")}{pct:F0}%");}}