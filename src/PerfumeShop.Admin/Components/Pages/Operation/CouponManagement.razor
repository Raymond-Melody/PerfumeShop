@page "/admin/Operation/CouponManagement"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.operation")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Admin.Services

<PageTitle>优惠券管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-ticket-alt" style="color:#00bcd4;"></i> 优惠券管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>优惠券管理</span></div></div>
@if(_error!=null){<div class="alert alert-error">@_error<button class="btn btn-outline btn-sm" @onclick="RetryLoad">重试</button></div>}
else if(!_loaded){<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
else{
@if(!string.IsNullOrEmpty(_msg)){<div class="alert @(_msgErr?"alert-error":"alert-success")"><i class="fas fa-@(_msgErr?"exclamation":"check")-circle"></i> @_msg</div>}

<div class="stats-row"><div class="stat-card"><div class="stat-value" style="color:#00bcd4;">@_totalCoupons</div><div class="stat-label">总券模板</div></div><div class="stat-card"><div class="stat-value" style="color:#4CAF50;">@_activeCoupons</div><div class="stat-label">生效中</div></div><div class="stat-card"><div class="stat-value" style="color:#FF9800;">@_totalIssued</div><div class="stat-label">总发放</div></div><div class="stat-card"><div class="stat-value" style="color:#9C27B0;">@_totalUsed</div><div class="stat-label">已使用</div></div></div>

<button class="btn btn-primary" style="margin-bottom:20px;" @onclick="ShowForm"><i class="fas fa-plus"></i> 创建优惠券</button>

@if(_showForm){<div class="panel"><h3><i class="fas fa-@(_editId>0?"edit":"plus-circle")"></i> @(_editId>0?"编辑":"创建")优惠券</h3>
<form @onsubmit="HandleSave"><div class="form-row"><div class="form-group"><label>优惠码 *</label><input class="form-input" @bind="_fCode" required placeholder="如: SUMMER20" style="text-transform:uppercase;" readonly="@(_editId>0)"/></div><div class="form-group"><label>券名称 *</label><input class="form-input" @bind="_fName" required placeholder="如: 夏日大促券"/></div><div class="form-group"><label>券类型 *</label><select class="form-input" @bind="_fType" required><option value="fixed">满减券</option><option value="percentage">折扣券</option><option value="free_shipping">免邮券</option><option value="gift">礼品券</option></select></div><div class="form-group"><label>券面额 *</label><input class="form-input" type="number" step="0.01" @bind="_fValue" required/></div></div>
<div class="form-row"><div class="form-group"><label>最低消费</label><input class="form-input" type="number" step="0.01" @bind="_fMinSpend"/></div><div class="form-group"><label>最大优惠(折扣券用)</label><input class="form-input" type="number" step="0.01" @bind="_fMaxDiscount"/></div><div class="form-group"><label>发行总量(0=不限)</label><input class="form-input" type="number" @bind="_fTotalQty"/></div><div class="form-group"><label>&nbsp;</label><label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#b0b0b0;"><input type="checkbox" @bind="_fIsActive"/> 启用 &nbsp; <input type="checkbox" @bind="_fFirstOrder"/> 仅首单</label></div></div>
<div class="form-row"><div class="form-group"><label>生效日期</label><input class="form-input" type="date" @bind-value="_fValidFrom" @bind-value:format="yyyy-MM-dd" required/></div><div class="form-group"><label>失效日期</label><input class="form-input" type="date" @bind-value="_fValidTo" @bind-value:format="yyyy-MM-dd" required/></div><div class="form-group"><label>限定品类</label><input class="form-input" @bind="_fCategory" placeholder="留空=全场通用"/></div><div class="form-group"><label>限定产品ID</label><input class="form-input" type="number" @bind="_fProductId" placeholder="留空=全场通用"/></div></div>
<div class="form-row"><div class="form-group" style="grid-column:span 2;"><label>描述</label><input class="form-input" @bind="_fDesc" placeholder="简短描述"/></div><div class="form-group" style="grid-column:span 2;"><label>使用条款</label><input class="form-input" @bind="_fTerms" placeholder="详细条款"/></div></div>
<div style="display:flex;gap:8px;margin-top:12px;"><button type="submit" class="btn btn-primary" disabled="@_saving"><i class="fas fa-save"></i> @(_saving?"保存中...":(_editId>0?"更新":"创建"))</button><button type="button" class="btn btn-outline" @onclick="()=>_showForm=false">取消</button></div></form></div>}

<div class="panel"><h3><i class="fas fa-list"></i> 优惠券列表</h3>
<table class="data-table"><thead><tr><th>ID</th><th>优惠码</th><th>名称</th><th>类型</th><th>面额</th><th>门槛</th><th>发行/已用</th><th>有效期</th><th>状态</th><th>操作</th></tr></thead>
<tbody>@if(_coupons.Any()){@foreach(var c in _coupons){var usedQty=c.UsedQty;var totalQty=c.TotalQty;<tr><td>@c.CouponId</td><td><strong style="color:#00bcd4;">@(c.CouponCode??"-")</strong></td><td>@(c.CouponName??"-")</td><td><span class="badge @GetTypeBadge(c.CouponType)">@GetTypeLabel(c.CouponType)</span></td><td>@FormatValue(c)</td><td>@(c.MinSpend>0?$"¥{c.MinSpend:F0}":"无门槛")</td><td>@usedQty/@(totalQty==0?"∞":totalQty.ToString())</td><td style="font-size:11px;">@c.ValidFrom.ToString("yyyy-MM-dd")<br>~@c.ValidTo.ToString("yyyy-MM-dd")</td><td><span class="badge @(c.IsActive==true&&DateTime.Now>=c.ValidFrom&&DateTime.Now<=c.ValidTo?"badge-active":"badge-inactive")">@(c.IsActive==true&&DateTime.Now>=c.ValidFrom&&DateTime.Now<=c.ValidTo?"启用":"禁用")</span></td><td><button class="btn btn-sm" style="background:#00bcd4;color:#fff;" @onclick="()=>Edit(c)"><i class="fas fa-edit"></i></button><button class="btn btn-sm" style="background:#c62828;color:#fff;" @onclick="()=>Delete(c.CouponId)"><i class="fas fa-trash"></i></button></td></tr>}}else{<tr><td colspan="10" class="empty-cell">暂无优惠券</td></tr>}</tbody></table></div>}

<style>
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:18px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}.stat-value{font-size:26px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}
.panel{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:24px;border:1px solid rgba(255,255,255,0.05);margin-bottom:24px;}.panel h3{color:#fff;margin:0 0 16px;font-size:18px;display:flex;align-items:center;gap:8px;}.panel h3 i{color:#00bcd4;}
.form-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:12px;}.form-group{display:flex;flex-direction:column;gap:4px;}.form-group label{font-size:12px;color:#888;font-weight:500;}.form-input{padding:9px 12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:6px;color:#e0e0e0;font-size:13px;}.form-input:focus{border-color:#00bcd4;outline:none;}.form-input option{background:#2d2d44;color:#e0e0e0;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.2s;text-decoration:none;}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;}.btn-primary[disabled]{opacity:0.5;cursor:not-allowed;}.btn-outline{background:transparent;border:1px solid #555;color:#ccc;}.btn-sm{padding:4px 12px;font-size:11px;}
.data-table{width:100%;border-collapse:collapse;}.data-table th{text-align:left;padding:10px 12px;background:rgba(0,0,0,0.2);color:#888;font-size:11px;text-transform:uppercase;}.data-table td{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:13px;color:#ccc;}.data-table tr:hover td{background:rgba(255,255,255,0.02);}.empty-cell{text-align:center;color:#666;padding:40px;}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;}.badge-active{background:rgba(76,175,80,0.2);color:#4CAF50;}.badge-inactive{background:rgba(158,158,158,0.2);color:#9e9e9e;}.badge-fixed{background:rgba(255,87,34,0.2);color:#FF5722;}.badge-percentage{background:rgba(156,39,176,0.2);color:#CE93D8;}.badge-freeship{background:rgba(33,150,243,0.2);color:#64B5F6;}.badge-gift{background:rgba(255,152,0,0.2);color:#FFB74D;}
.alert{padding:12px 20px;border-radius:8px;margin-bottom:20px;display:flex;align-items:center;gap:8px;}.alert-success{background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-error{background:rgba(244,67,54,0.15);color:#ef9a9a;border:1px solid rgba(244,67,54,0.3);}
@@media(max-width:768px){.stats-row{grid-template-columns:repeat(2,1fr);}.form-row{grid-template-columns:1fr;}}</style>

@code{
[Inject] private PerfumeShopContext Db{get;set;}=default!;
[Inject] private IAdminAuditor Auditor{get;set;}=default!;
[Inject] private AuthenticationStateProvider AuthState{get;set;}=default!;
private bool _loaded,_showForm,_saving,_msgErr;
private int _adminId;private string _adminName="";
private string? _error,_msg;
private List<Coupon> _coupons=new();
private int _totalCoupons,_activeCoupons,_totalIssued,_totalUsed;
private int _editId;
private string _fCode="",_fName="",_fType="fixed",_fValue="",_fMinSpend="0",_fMaxDiscount="0",_fTotalQty="0",_fCategory="",_fProductId="",_fDesc="",_fTerms="";
private DateTime _fValidFrom=DateTime.Today,_fValidTo=DateTime.Today.AddMonths(1);
private bool _fIsActive=true,_fFirstOrder;

protected override async Task OnInitializedAsync(){try{var st=await AuthState.GetAuthenticationStateAsync();int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value,out _adminId);_adminName=st.User.FindFirst(ClaimTypes.Name)?.Value??"";await Load();_loaded=true;}catch(Exception ex){_error=ex.Message;_loaded=true;}}

async Task Load(){
_coupons=await Db.Coupons.AsNoTracking().OrderByDescending(c=>c.CouponId).ToListAsync();
_totalCoupons=_coupons.Count;
var now=DateTime.Now;
_activeCoupons=_coupons.Count(c=>c.IsActive==true&&now>=c.ValidFrom&&now<=c.ValidTo);
_totalIssued=await Db.UserCoupons.CountAsync();
_totalUsed=await Db.UserCoupons.CountAsync(uc=>uc.Status=="used");
}

async Task RetryLoad(){_loaded=false;_error=null;await Load();}

void ShowForm(){_editId=0;_fCode=$"CPN{DateTime.Now:yyMMddHHmm}";_fName="";_fType="fixed";_fValue="";_fMinSpend="0";_fMaxDiscount="0";_fTotalQty="100";_fCategory="";_fProductId="";_fDesc="";_fTerms="";_fValidFrom=DateTime.Today;_fValidTo=DateTime.Today.AddMonths(1);_fIsActive=true;_fFirstOrder=false;_showForm=true;}

void Edit(Coupon c){_editId=c.CouponId;_fCode=c.CouponCode??"";_fName=c.CouponName??"";_fType=c.CouponType??"fixed";_fValue=(c.DiscountValue??0).ToString("F2");_fMinSpend=c.MinSpend.ToString("F2");_fMaxDiscount=c.MaxDiscount.ToString("F2");_fTotalQty=c.TotalQty.ToString();_fCategory=c.ApplicableCategory??"";_fProductId=(c.ApplicableProductId?.ToString())??"";_fDesc=c.Description??"";_fTerms=c.Terms??"";_fValidFrom=c.ValidFrom;_fValidTo=c.ValidTo;_fIsActive=c.IsActive==true;_fFirstOrder=c.FirstOrderOnly;_showForm=true;}

async Task HandleSave(){
_msg=null;_saving=true;
try{
if(string.IsNullOrWhiteSpace(_fCode)||string.IsNullOrWhiteSpace(_fName)||string.IsNullOrWhiteSpace(_fType)){_msg="请填写优惠码、名称和类型";_msgErr=true;_saving=false;return;}
var val=decimal.TryParse(_fValue,out var dv)?dv:0;
var min=decimal.TryParse(_fMinSpend,out var mn)?mn:0;
var max=decimal.TryParse(_fMaxDiscount,out var mx)?mx:0;
var qty=int.TryParse(_fTotalQty,out var tq)?tq:0;
int? pid=null;if(int.TryParse(_fProductId,out var pv)&&pv>0)pid=pv;
if(_editId>0){
await Db.Coupons.Where(c=>c.CouponId==_editId).ExecuteUpdateAsync(s=>s
.SetProperty(c=>c.CouponName,_fName).SetProperty(c=>c.CouponType,_fType)
.SetProperty(c=>c.DiscountValue,val).SetProperty(c=>c.MinSpend,min)
.SetProperty(c=>c.MaxDiscount,max).SetProperty(c=>c.TotalQty,qty)
.SetProperty(c=>c.ValidFrom,_fValidFrom).SetProperty(c=>c.ValidTo,_fValidTo)
.SetProperty(c=>c.ApplicableCategory,_fCategory).SetProperty(c=>c.ApplicableProductId,pid)
.SetProperty(c=>c.Description,_fDesc).SetProperty(c=>c.Terms,_fTerms)
.SetProperty(c=>c.IsActive,_fIsActive).SetProperty(c=>c.FirstOrderOnly,_fFirstOrder)
.SetProperty(c=>c.UpdatedAt,DateTime.Now));
_msg="更新成功";
}else{
Db.Coupons.Add(new Coupon{CouponCode=_fCode.ToUpper(),CouponName=_fName,CouponType=_fType,DiscountValue=val,MinSpend=min,MaxDiscount=max,TotalQty=qty,ValidFrom=_fValidFrom,ValidTo=_fValidTo,ApplicableCategory=_fCategory,ApplicableProductId=pid,Description=_fDesc,Terms=_fTerms,IsActive=_fIsActive,FirstOrderOnly=_fFirstOrder,IsPublic=true,UsedQty=0,CreatedAt=DateTime.Now,UpdatedAt=DateTime.Now});
await Db.SaveChangesAsync();
_msg="创建成功";
}
_msgErr=false;_showForm=false;await Load();
await Auditor.LogAsync(_adminId,_adminName,_editId>0?"编辑优惠券":"创建优惠券","Coupon",_editId>0?_editId:(int?)null,_fName);
await InvokeAsync(StateHasChanged);
}catch(Exception ex){_msg="操作失败: "+ex.Message;_msgErr=true;}
_saving=false;
}

async Task Delete(int id){await Db.Coupons.Where(c=>c.CouponId==id).ExecuteDeleteAsync();await Auditor.LogAsync(_adminId,_adminName,"删除优惠券","Coupon",id,null);_coupons=_coupons.Where(c=>c.CouponId!=id).ToList();_totalCoupons--;_msg="已删除";_msgErr=false;await InvokeAsync(StateHasChanged);}

static string GetTypeLabel(string? t)=>t?.ToLower() switch{"fixed"=>"满减券","percentage"=>"折扣券","free_shipping"=>"免邮券","gift"=>"礼品券",_=>t??"-"};
static string GetTypeBadge(string? t)=>t?.ToLower() switch{"fixed"=>"badge-fixed","percentage"=>"badge-percentage","free_shipping"=>"badge-freeship","gift"=>"badge-gift",_=>"badge-inactive"};
static string FormatValue(Coupon c)=>c.CouponType?.ToLower() switch{"percentage"=>$"{c.DiscountValue??0:F0}% OFF","fixed"=>$"¥{c.DiscountValue??0:F0}","free_shipping"=>"免邮","gift"=>"赠品",_=>$"¥{c.DiscountValue??0:F0}"};
}