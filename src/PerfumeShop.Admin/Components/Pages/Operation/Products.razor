@page "/admin/Operation/Products"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.Extensions.Configuration
<PageTitle>商品上下架管理</PageTitle>
<div class="page-header"><div><h2 class="page-title"><i class="fas fa-box" style="color:#00bcd4;"></i> 商品上下架管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index" style="color:#00bcd4;text-decoration:none;">运营中心</a> / <span>商品上下架</span></div></div><a href="/admin/TechCenter/ProductSettings" class="btn btn-outline"><i class="fas fa-external-link-alt"></i> 产品技术管理中心</a></div>
@if(_loaded){<div class="info-banner"><i class="fas fa-info-circle"></i><strong>提示：</strong>运营后台仅管理产品上下架状态</div>
<div class="stats-row"><div class="stat-card"><div class="stat-value" style="color:#00bcd4;">@_totalProducts</div><div class="stat-label">全部商品</div></div><div class="stat-card"><div class="stat-value" style="color:#4CAF50;">@_showingCount</div><div class="stat-label">展示中</div></div><div class="stat-card"><div class="stat-value" style="color:#f44336;">@_inactiveCount</div><div class="stat-label">已下架</div></div><div class="stat-card"><div class="stat-value" style="color:#FF9800;">@_pendingCount</div><div class="stat-label">待审核</div></div></div>
<div class="filter-bar"><span class="filter-label"><i class="fas fa-filter"></i> 前台状态筛选：</span><select class="filter-select" @bind="_frontStatusFilter"><option value="">全部商品</option><option value="showing">展示中</option><option value="inactive">已下架</option><option value="typeDisabled">类型已关闭</option><option value="pending">待审核</option></select><span class="filter-label" style="margin-left:16px;">类型：</span><select class="filter-select" @bind="_typeFilter"><option value="">全部类型</option>@foreach(var t in _productTypes){<option value="@t.TypeCode">@t.DisplayName</option>}</select></div>
<div class="product-grid">@if(_filteredProducts.Any()){@foreach(var p in _filteredProducts){var imgSrc=ResolveImg(p.ImageUrl);var tc=p.ProductType?.ToLower();var typeClass=tc switch{"fixed"=>"fixed","custom"=>"custom","kol"=>"kol",_=>""};var typeLabel=tc switch{"fixed"=>"品牌定香","custom"=>"用户定制","kol"=>"KOL推荐",_=>p.ProductType??"未知"};var typeIcon=tc switch{"fixed"=>"fa-box","custom"=>"fa-paint-brush","kol"=>"fa-star",_=>"fa-tag"};var fs=GetFrontStatus(p);var ia=p.IsActive==true;<div class="product-card"><div class="product-card-image"><img src="@imgSrc" alt="@p.ProductName" loading="lazy" onerror="this.onerror=null;this.src='/images/default-product.svg';"/></div><div class="product-header"><div class="product-title"><i class="fas fa-box-open"></i><span title="@p.ProductName">@p.ProductName</span></div><span class="product-id">#@p.ProductId</span></div><div class="product-meta"><span class="product-type-badge @typeClass"><i class="fas @typeIcon"></i>@typeLabel</span>@if(NeedsReview(p)){<span class="status-badge @GetReviewStatusClass(p.ReviewStatus)"><i class="fas @(p.ReviewStatus switch{"Pending"=>"fa-clock","Approved"=>"fa-check","Rejected"=>"fa-times",_=>"fa-clock"})"></i>@GetReviewStatusText(p.ReviewStatus)</span>}<span class="status-badge @(ia?"status-active":"status-inactive")"><i class="fas fa-@(ia?"check-circle":"ban")"></i>@(ia?"上架":"下架")</span><span class="status-badge @fs.Class"><i class="fas @fs.Icon"></i>@fs.Text</span></div><div class="product-price">@p.BasePrice.ToString("C2")</div>@if(!string.IsNullOrEmpty(p.Description)){<div class="product-desc">@(p.Description.Length>80?p.Description[..80]+"...":p.Description)</div>}<div class="product-footer"><div class="action-btns"><button class="btn btn-outline btn-sm" @onclick="()=>ShowDetail(p)">详情</button>@if(p.ProductType?.ToLower()=="fixed"){<a href="/admin/Purchase/FixedBrand" class="btn btn-outline btn-sm">采购管理</a>}</div><button class="btn @(ia?"btn-danger":"btn-primary") btn-sm" @onclick="()=>ToggleActive(p)">@(ia?"下架":"上架")</button></div></div>}}else{<div class="empty-state"><i class="fas fa-box"></i><h3>暂无商品</h3></div>}</div>
@if(_showDetail){<div class="modal-overlay show" @onclick="()=>_showDetail=false"><div class="modal" @onclick:stopPropagation="true"><div class="modal-header"><h3>商品详情 #@_detailProduct.ProductId</h3><button class="modal-close" @onclick="()=>_showDetail=false">&times;</button></div><div class="modal-body"><div class="detail-row"><label>商品名称</label><p>@_detailProduct.ProductName</p></div><div class="detail-row"><label>描述</label><p>@(_detailProduct.Description??"（无描述）")</p></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;"><div class="detail-row"><label>类型</label><p>@GetTypeDisplayName(_detailProduct.ProductType)</p></div><div class="detail-row"><label>价格</label><p>@_detailProduct.BasePrice.ToString("C2")</p></div><div class="detail-row"><label>状态</label><p style="color:@(_detailProduct.IsActive==true?"#4caf50":"#f44336")">@(_detailProduct.IsActive==true?"上架中":"已下架")</p></div><div class="detail-row"><label>商品ID</label><p>@_detailProduct.ProductId</p></div></div></div><div class="modal-footer"><button class="btn btn-outline" @onclick="()=>_showDetail=false">关闭</button></div></div></div>}}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.btn{padding:8px 18px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:6px;transition:all 0.3s;text-decoration:none;}.btn-outline{background:rgba(255,255,255,0.05);color:#b0b0b0;border:1px solid rgba(255,255,255,0.1);}.btn-outline:hover{background:rgba(255,255,255,0.1);color:#fff;}.btn-primary{background:linear-gradient(135deg,#00bcd4,#00838f);color:white;}.btn-danger{background:#c62828;color:white;}.btn-sm{padding:5px 12px;font-size:11px;}.info-banner{background:rgba(0,188,212,0.1);border-left:4px solid #00bcd4;color:#80deea;padding:12px 18px;border-radius:6px;margin-bottom:20px;font-size:14px;}.filter-bar{display:flex;align-items:center;gap:15px;margin-bottom:25px;flex-wrap:wrap;padding:15px 20px;background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;border:1px solid rgba(255,255,255,0.05);}.filter-label{color:#888;font-size:13px;font-weight:600;white-space:nowrap;}.filter-select{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#e0e0e0;padding:8px 12px;font-size:13px;cursor:pointer;min-width:140px;}.filter-select:focus{border-color:#00bcd4;outline:none;}.filter-select option{background:#2d2d44;color:#e0e0e0;}.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;transition:transform 0.2s;}.stat-card:hover{transform:translateY(-3px);}.stat-value{font-size:28px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}.product-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}.product-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:20px;border:1px solid rgba(255,255,255,0.05);transition:all 0.3s ease;display:flex;flex-direction:column;}.product-card:hover{transform:translateY(-3px);box-shadow:0 8px 25px rgba(0,0,0,0.3);}.product-card-image{position:relative;width:100%;padding-top:100%;border-radius:8px;overflow:hidden;margin-bottom:15px;background:rgba(0,0,0,0.3);}.product-card-image img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;}.product-card-image .no-image{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#666;font-size:36px;}.product-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}.product-title{font-size:15px;font-weight:600;color:#fff;display:flex;align-items:center;gap:8px;flex:1;min-width:0;}.product-title span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}.product-title i{color:#00bcd4;flex-shrink:0;}.product-id{font-size:11px;color:#999;background:rgba(0,0,0,0.3);padding:2px 8px;border-radius:4px;flex-shrink:0;}.product-meta{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;}.product-type-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:4px;font-size:10px;font-weight:600;text-transform:uppercase;}.product-type-badge.fixed{background:rgba(33,150,243,0.2);color:#2196f3;}.product-type-badge.custom{background:rgba(76,175,80,0.2);color:#4caf50;}.product-type-badge.kol{background:rgba(156,39,176,0.2);color:#9c27b0;}.status-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:500;}.status-active{background:rgba(76,175,80,0.2);color:#4caf50;}.status-inactive{background:rgba(244,67,54,0.2);color:#ef5350;}.status-pending{background:rgba(255,152,0,0.2);color:#ff9800;}.status-approved{background:rgba(76,175,80,0.2);color:#4caf50;}.status-disabled{background:rgba(158,158,158,0.2);color:#9e9e9e;}.product-price{font-size:18px;font-weight:700;color:#00bcd4;margin-bottom:10px;}.product-desc{font-size:12px;color:#888;line-height:1.5;margin-bottom:10px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}.product-footer{display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1px solid rgba(255,255,255,0.05);margin-top:auto;gap:8px;}.action-btns{display:flex;gap:8px;}.empty-state{grid-column:1/-1;text-align:center;padding:60px 20px;color:#666;}.empty-state i{font-size:48px;margin-bottom:15px;color:#555;}.empty-state h3{color:#888;margin-bottom:10px;}.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;justify-content:center;align-items:center;}.modal{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:16px;border:1px solid rgba(255,255,255,0.1);padding:30px;width:90%;max-width:600px;max-height:90vh;overflow-y:auto;}.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}.modal-header h3{color:#fff;margin:0;font-size:18px;}.modal-close{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.detail-row{margin-bottom:12px;}.detail-row label{display:block;color:#999;font-size:12px;margin-bottom:4px;}.detail-row p{background:rgba(255,255,255,0.05);color:#e0e0e0;padding:10px;border-radius:6px;margin:0;border:1px solid rgba(255,255,255,0.08);}.modal-footer{margin-top:20px;display:flex;justify-content:flex-end;}@@media(max-width:1200px){.product-grid{grid-template-columns:repeat(2,1fr);}}@@media(max-width:768px){.product-grid{grid-template-columns:1fr;}.filter-bar{flex-direction:column;align-items:stretch;}}</style>
@code{[Inject] private PerfumeShopContext Db{get;set;}=default!;[Inject] private IConfiguration Config{get;set;}=default!;private string _storefrontBase="";private bool _loaded;private List<Product> _products=new();private List<ProductTypeConfig> _productTypes=new();private string? _frontStatusFilter;private string? _typeFilter;private bool _showDetail;private Product _detailProduct=new();private int _totalProducts,_showingCount,_inactiveCount,_pendingCount;
IEnumerable<Product> _filteredProducts{get{var dt=_productTypes.Where(t=>t.IsActive!=true).Select(t=>t.TypeCode).ToHashSet();var rt=_productTypes.Where(t=>t.RequiresReview==true).Select(t=>t.TypeCode).ToHashSet();var r=_frontStatusFilter switch{"showing"=>_products.Where(p=>p.IsActive==true&&!dt.Contains(p.ProductType??"")&&(!rt.Contains(p.ProductType??"")||p.ReviewStatus=="Approved")),"inactive"=>_products.Where(p=>p.IsActive!=true),"typeDisabled"=>_products.Where(p=>dt.Contains(p.ProductType??"")),"pending"=>_products.Where(p=>rt.Contains(p.ProductType??"")&&p.ReviewStatus=="Pending"),_=>_products.AsEnumerable()};if(!string.IsNullOrEmpty(_typeFilter))r=r.Where(p=>p.ProductType==_typeFilter);return r;}}
protected override async Task OnInitializedAsync(){_storefrontBase=Config["Storefront:BaseUrl"]??"";_productTypes=await Db.ProductTypeConfigs.AsNoTracking().OrderBy(t=>t.DisplayOrder).ToListAsync();_products=await Db.Products.OrderByDescending(p=>p.ProductId).ToListAsync();ComputeStats();_loaded=true;}
void ComputeStats(){var dt=_productTypes.Where(t=>t.IsActive!=true).Select(t=>t.TypeCode).ToHashSet();var rt=_productTypes.Where(t=>t.RequiresReview==true).Select(t=>t.TypeCode).ToHashSet();_totalProducts=_products.Count;_showingCount=_products.Count(p=>p.IsActive==true&&!dt.Contains(p.ProductType??"")&&(!rt.Contains(p.ProductType??"")||p.ReviewStatus=="Approved"));_inactiveCount=_products.Count(p=>p.IsActive!=true);_pendingCount=_products.Count(p=>rt.Contains(p.ProductType??"")&&p.ReviewStatus=="Pending");}
async Task ToggleActive(Product p){var nv=!(p.IsActive??false);await Db.Products.Where(x=>x.ProductId==p.ProductId).ExecuteUpdateAsync(s=>s.SetProperty(x=>x.IsActive,nv));p.IsActive=nv;await InvokeAsync(StateHasChanged);}
void ShowDetail(Product p){_detailProduct=p;_showDetail=true;}
(string Text,string Class,string Title,string Icon) GetFrontStatus(Product p){var tc=_productTypes.FirstOrDefault(t=>t.TypeCode==p.ProductType);var ta=tc?.IsActive!=false;var tr=tc?.RequiresReview==true;var ia=p.IsActive==true;var rs=p.ReviewStatus??"";if(!ta)return("类型已关闭","status-disabled","","fa-minus-circle");if(!ia)return("已下架","status-inactive","","fa-ban");if(tr)return rs switch{"Pending"=>("待审核","status-pending","","fa-clock"),"Rejected"=>("已驳回","status-inactive","","fa-ban"),"Approved"=>("展示中","status-active","","fa-eye"),_=>("待审核","status-pending","","fa-clock")};return("展示中","status-active","","fa-eye");}
bool NeedsReview(Product p){var tc=_productTypes.FirstOrDefault(t=>t.TypeCode==p.ProductType);return tc?.RequiresReview==true;}
string GetReviewStatusText(string? rs)=>rs switch{"Pending"=>"待审核","Approved"=>"已通过","Rejected"=>"已驳回",_=>"待审核"};
string GetReviewStatusClass(string? rs)=>rs switch{"Pending"=>"status-pending","Approved"=>"status-approved","Rejected"=>"status-inactive",_=>"status-pending"};
string GetTypeDisplayName(string? t)=>t?.ToLower() switch{"fixed"=>"品牌定香","custom"=>"用户定制","kol"=>"KOL推荐",_=>t??"未知"};
string ResolveImg(string? url){if(string.IsNullOrWhiteSpace(url))return "/images/default-product.svg";if(url.StartsWith("http://")||url.StartsWith("https://")||url.StartsWith("//"))return url;if(string.IsNullOrWhiteSpace(_storefrontBase))return url;var b=_storefrontBase.TrimEnd('/');return url.StartsWith("/")?b+url:b+"/"+url;}}
