@page "/admin/Operation/TierManagement"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.operation")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Admin.Services
<PageTitle>会员等级管理</PageTitle>
<div class="page-header"><h2 class="page-title">会员等级折扣管理</h2><div class="breadcrumb"><a href="/admin/Operation/Index">运营中心</a> / <span>会员等级</span></div></div>
@if(_error!=null){<div class="alert alert-error">@_error<button class="btn btn-outline btn-sm" @onclick="RetryLoad">重试</button></div>}
else if(!_loaded){<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
else{<div class="tier-wheel-panel"><div class="wheel" style="background:@WheelGradient();"><div class="wheel-center"><div class="wheel-total">@_totalMembers</div><div class="wheel-label">会员总数</div></div></div><div class="wheel-legend">@foreach(var t in _tiers){var cnt=_tierCounts.TryGetValue(t.TierCode,out var c)?c:0;var pct=_totalMembers>0?(double)cnt/_totalMembers*100:0;<div class="legend-item"><span class="legend-dot" style="background:@(string.IsNullOrEmpty(t.Color)?"#00bcd4":t.Color);"></span><span class="legend-name">@t.TierName</span><span class="legend-count">@cnt 人 (@pct.ToString("F0")%)</span></div>}</div></div><div class="tier-grid">@foreach(var t in _tiers){var dc=GetDiscountLabel(t.DiscountRate);var sc=t.Color??"#00bcd4";<div class="tier-panel"><div class="tier-panel-header"><div class="tier-icon" style="background:@sc;"><i class="fas @(t.IconClass??"fa-layer-group")"></i></div><div><div class="tier-title">@t.TierName</div><div class="tier-code">@t.TierCode</div></div><div class="tier-discount-badge">@dc</div></div><div class="tier-panel-body"><form @onsubmit="(e)=>SaveTier(t,e)"><div class="form-row"><label>折扣率</label><input type="number" step="0.001" min="0.001" max="1.000" value="@t.DiscountRate.ToString("F3")" @onchange="(e)=>UpdateTierVal(t,e,nameof(t.DiscountRate))"/><span>@((t.DiscountRate*100).ToString("N0"))%</span></div><div class="form-row"><label>门槛</label><input type="number" step="100" min="0" value="@t.MinSpent" @onchange="(e)=>UpdateTierVal(t,e,nameof(t.MinSpent))"/>元起</div><div class="form-row"><label>启用</label><div class="switch-group"><label class="switch-label @(t.IsActive?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.IsActive),true)">是</label><label class="switch-label @(!t.IsActive?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.IsActive),false)">否</label></div></div><div class="form-row"><label>免运费</label><div class="switch-group"><label class="switch-label @(t.FreeShipping?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.FreeShipping),true)">是</label><label class="switch-label @(!t.FreeShipping?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.FreeShipping),false)">否</label></div></div><div class="form-row"><label>优先发货</label><div class="switch-group"><label class="switch-label @(t.PriorityShipping?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.PriorityShipping),true)">是</label><label class="switch-label @(!t.PriorityShipping?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.PriorityShipping),false)">否</label></div></div><div class="form-row"><label>生日礼</label><div class="switch-group"><label class="switch-label @(t.BirthdayGift?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.BirthdayGift),true)">是</label><label class="switch-label @(!t.BirthdayGift?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.BirthdayGift),false)">否</label></div></div><div class="form-row"><label>专属客服</label><div class="switch-group"><label class="switch-label @(t.DedicatedSupport?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.DedicatedSupport),true)">是</label><label class="switch-label @(!t.DedicatedSupport?"active":"inactive")" @onclick="()=>SetTierFlag(t,nameof(t.DedicatedSupport),false)">否</label></div></div><button type="submit" class="btn-save">保存设置</button></form><div class="benefit-row"><span class="benefit-tag @(t.FreeShipping?"active":"")">免运费</span><span class="benefit-tag @(t.PriorityShipping?"active":"")">优先发货</span><span class="benefit-tag @(t.BirthdayGift?"active":"")">生日礼</span><span class="benefit-tag @(t.DedicatedSupport?"active":"")">专属客服</span></div></div></div>}</div><div class="log-panel"><h3><i class="fas fa-history"></i> 配置变更日志（最近 20 条）</h3><table class="log-table"><thead><tr><th>时间</th><th>等级编码</th><th>字段</th><th>变更内容</th><th>操作人</th></tr></thead><tbody>@if(_tierLogs.Any()){@foreach(var l in _tierLogs){<tr><td>@l.ChangedAt.ToString("yyyy-MM-dd HH:mm")</td><td style="color:#00bcd4;font-weight:500;">@l.TierCode</td><td>@l.FieldName</td><td>@if(!string.IsNullOrEmpty(l.OldValue)){<span class="log-old">@l.OldValue</span><span class="log-arrow">→</span>}<span class="log-new">@l.NewValue</span></td><td>@l.ChangedBy</td></tr>}}else{<tr><td colspan="5" class="empty-cell">暂无变更记录</td></tr>}</tbody></table></div>}
<style>.tier-wheel-panel{display:flex;align-items:center;gap:40px;background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:24px;border:1px solid rgba(255,255,255,0.05);margin-bottom:20px;flex-wrap:wrap;}.wheel{width:160px;height:160px;border-radius:50%;position:relative;flex-shrink:0;}.wheel-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:100px;height:100px;background:#1a1a2e;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;}.wheel-total{font-size:28px;font-weight:700;color:#fff;}.wheel-label{font-size:12px;color:#888;}.wheel-legend{display:flex;flex-direction:column;gap:10px;flex:1;min-width:200px;}.legend-item{display:flex;align-items:center;gap:10px;}.legend-dot{width:14px;height:14px;border-radius:3px;flex-shrink:0;}.legend-name{font-size:14px;color:#e0e0e0;min-width:90px;}.legend-count{font-size:13px;color:#888;}.tier-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(420px,1fr));gap:20px;}.tier-panel{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;border:1px solid rgba(255,255,255,0.05);overflow:hidden;}.tier-panel-header{padding:16px 20px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(255,255,255,0.08);}.tier-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;flex-shrink:0;}.tier-title{font-size:18px;font-weight:700;color:#fff;}.tier-code{font-size:12px;color:#888;margin-top:2px;}.tier-discount-badge{margin-left:auto;padding:5px 14px;border-radius:20px;font-size:14px;font-weight:700;background:rgba(0,188,212,0.2);color:#00bcd4;}.tier-panel-body{padding:16px 20px;}.form-row{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:8px;}.form-row>label{font-size:13px;color:#b0b0b0;font-weight:600;min-width:60px;}.form-row input{padding:8px 12px;border:1px solid #3a3a4a;border-radius:6px;font-size:14px;width:100px;background:#1a1a2e;color:#e0e0e0;}.form-row input:focus{border-color:#00bcd4;outline:none;}.form-row span{font-size:13px;color:#888;}.switch-group{display:flex;gap:4px;}.switch-label{display:inline-flex;align-items:center;gap:4px;padding:5px 12px;border-radius:4px;font-size:12px;cursor:pointer;border:1px solid #3a3a4a;background:#1a1a2e;color:#888;}.switch-label.active{background:rgba(76,175,80,0.15);border-color:#4CAF50;color:#66bb6a;}.switch-label.inactive{background:rgba(244,67,54,0.15);border-color:#e53935;color:#ef5350;}.btn-save{padding:8px 20px;background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;border:none;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer;margin-top:8px;}.benefit-row{display:flex;gap:6px;flex-wrap:wrap;padding:10px 0 0;border-top:1px solid rgba(255,255,255,0.06);margin-top:8px;}.benefit-tag{padding:3px 10px;border-radius:4px;font-size:11px;background:rgba(255,255,255,0.05);color:#888;}.benefit-tag.active{background:rgba(76,175,80,0.15);color:#66bb6a;}.alert{padding:12px 20px;border-radius:8px;margin-bottom:20px;}.alert-error{background:rgba(244,67,54,0.15);color:#ef9a9a;border:1px solid rgba(244,67,54,0.3);}.log-panel{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:24px;border:1px solid rgba(255,255,255,0.05);margin-top:20px;}.log-panel h3{color:#fff;margin:0 0 16px;font-size:18px;display:flex;align-items:center;gap:8px;}.log-panel h3 i{color:#00bcd4;}.log-table{width:100%;border-collapse:collapse;font-size:13px;}.log-table th{text-align:left;padding:10px 14px;background:rgba(0,0,0,0.2);color:#888;font-size:11px;text-transform:uppercase;}.log-table td{padding:10px 14px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;}.log-table tr:hover td{background:rgba(255,255,255,0.02);}.log-old{color:#ef5350;text-decoration:line-through;margin-right:4px;}.log-new{color:#66bb6a;font-weight:600;}.log-arrow{color:#666;margin:0 4px;}.empty-cell{text-align:center;color:#666;padding:40px;}@@media(max-width:768px){.tier-grid{grid-template-columns:1fr;}}</style>
@code{[Inject] private PerfumeShopContext Db{get;set;}=default!;[Inject] private AuthenticationStateProvider AuthState{get;set;}=default!;[Inject] private IAdminAuditor Auditor{get;set;}=default!;private bool _loaded;private string? _error;private int _adminId;private string _adminName="";private List<MemberTier> _tiers=new();private Dictionary<string,int> _tierCounts=new();private int _totalMembers;private List<TierConfigLog> _tierLogs=new();
protected override async Task OnInitializedAsync(){try{var st=await AuthState.GetAuthenticationStateAsync();int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value,out _adminId);_adminName=st.User.FindFirst(ClaimTypes.Name)?.Value??"";_tiers=await Db.MemberTiers.OrderBy(t=>t.SortOrder).ToListAsync();_tierLogs=await Db.TierConfigLogs.OrderByDescending(l=>l.ChangedAt).Take(20).ToListAsync();await ComputeDistribution();_loaded=true;}catch(Exception ex){_error=ex.Message;_loaded=true;}}
async Task ComputeDistribution(){var paid=new[]{"Paid","paid","shipped","delivered"};var spentDict=await Db.Orders.Where(o=>paid.Contains(o.Status!)).GroupBy(o=>o.UserId).Select(g=>new{Uid=g.Key,Spent=g.Sum(x=>x.TotalAmount)}).ToDictionaryAsync(x=>x.Uid,x=>x.Spent);var allUsers=await Db.Users.Select(u=>u.UserId).ToListAsync();_tierCounts=_tiers.ToDictionary(t=>t.TierCode,t=>0);foreach(var uid in allUsers){var spent=spentDict.TryGetValue(uid,out var s)?s:0;var tier=_tiers.FirstOrDefault(t=>spent>=t.MinSpent&&(t.MaxSpent==null||spent<t.MaxSpent));if(tier!=null)_tierCounts[tier.TierCode]++;}_totalMembers=allUsers.Count;}
string WheelGradient(){var segs=new List<string>();double acc=0;foreach(var t in _tiers){var cnt=_tierCounts.TryGetValue(t.TierCode,out var c)?c:0;if(cnt==0||_totalMembers==0)continue;var frac=(double)cnt/_totalMembers;var col=string.IsNullOrEmpty(t.Color)?"#00bcd4":t.Color;segs.Add($"{col} {acc.ToString("0.####",System.Globalization.CultureInfo.InvariantCulture)}turn {(acc+frac).ToString("0.####",System.Globalization.CultureInfo.InvariantCulture)}turn");acc+=frac;}return segs.Count==0?"conic-gradient(#3a3a4a 0turn 1turn)":$"conic-gradient({string.Join(",",segs)})";}
async Task RetryLoad(){_loaded=false;_error=null;await OnInitializedAsync();}
void UpdateTierVal(MemberTier t,ChangeEventArgs e,string f){var v=e.Value?.ToString()??"";if(f==nameof(t.DiscountRate)&&decimal.TryParse(v,out var dr))t.DiscountRate=dr;else if(f==nameof(t.MinSpent)&&decimal.TryParse(v,out var mn))t.MinSpent=mn;else if(f==nameof(t.MaxSpent)){if(string.IsNullOrWhiteSpace(v))t.MaxSpent=null;else if(decimal.TryParse(v,out var mx))t.MaxSpent=mx;}}
void SetTierFlag(MemberTier t,string f,bool v){switch(f){case nameof(t.FreeShipping):t.FreeShipping=v;break;case nameof(t.PriorityShipping):t.PriorityShipping=v;break;case nameof(t.BirthdayGift):t.BirthdayGift=v;break;case nameof(t.DedicatedSupport):t.DedicatedSupport=v;break;case nameof(t.IsActive):t.IsActive=v;break;}}
async Task SaveTier(MemberTier t,EventArgs e){try{var old=await Db.MemberTiers.AsNoTracking().FirstOrDefaultAsync(x=>x.TierId==t.TierId);t.UpdatedAt=DateTime.Now;Db.MemberTiers.Update(t);if(old!=null){var who=string.IsNullOrEmpty(_adminName)?"管理员":_adminName;void Log(string fn,string ov,string nv){if(ov!=nv)Db.TierConfigLogs.Add(new TierConfigLog{TierCode=t.TierCode,FieldName=fn,OldValue=ov,NewValue=nv,ChangedBy=who,ChangedAt=DateTime.Now});}Log("折扣率",old.DiscountRate.ToString("F3"),t.DiscountRate.ToString("F3"));Log("消费门槛",old.MinSpent.ToString(),t.MinSpent.ToString());Log("免运费",(old.FreeShipping?"是":"否"),(t.FreeShipping?"是":"否"));Log("优先发货",(old.PriorityShipping?"是":"否"),(t.PriorityShipping?"是":"否"));Log("生日礼",(old.BirthdayGift?"是":"否"),(t.BirthdayGift?"是":"否"));Log("专属客服",(old.DedicatedSupport?"是":"否"),(t.DedicatedSupport?"是":"否"));Log("启用状态",(old.IsActive?"是":"否"),(t.IsActive?"是":"否"));}await Db.SaveChangesAsync();await Auditor.LogAsync(_adminId,_adminName,"修改会员等级","MemberTier",t.TierId,t.TierName);}catch(Exception ex){_error="保存失败: "+ex.Message;}}
static string GetDiscountLabel(decimal r)=>r>=1m?"原价":((int)((1-r)*100))+"% OFF";}
