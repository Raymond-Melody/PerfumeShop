@page "/admin/inventory/alerts"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>库存预警</PageTitle>
<div class="ph"><h2><i class="fas fa-exclamation-triangle" style="color:#F44336;"></i> 全品类库存预警</h2><div class="br"><a href="/admin/inventory" style="text-decoration:none;color:#00BCD4;">返回库存中心</a></div></div>
@if(_l){<div class="tc"><table class="ot"><thead><tr><th>类型</th><th>名称</th><th>当前库存</th><th>安全库存</th><th>缺口</th></tr></thead><tbody>@foreach(var r in _raw){<tr><td>原料</td><td>@(r.ItemName??"-")</td><td style="color:#F44336;">@(r.StockQty?.ToString()??"0")</td><td>@(r.SafetyStock?.ToString()??"0")</td><td style="color:#FF9800;">@(((r.SafetyStock??0)-(r.StockQty??0)).ToString("N0"))</td></tr>}@foreach(var b in _bottles){<tr><td>瓶子</td><td>@b.BottleName</td><td style="color:#F44336;">@(b.StockQty?.ToString()??"0")</td><td>@(b.SafetyStock?.ToString()??"0")</td><td style="color:#FF9800;">@(((b.SafetyStock??0)-(b.StockQty??0)).ToString("N0"))</td></tr>}@if(!_raw.Any()&&!_bottles.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:30px;">库存充足，无预警</td></tr>}</tbody></table></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;color:#888;}.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}.ot th{background:rgba(244,67,54,0.1);color:#F44336;padding:14px 16px;font-size:13px;text-align:left;}.ot td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}</style>
@code{bool _l;List<RawMaterialInventory> _raw=new();List<BottleStyle> _bottles=new();protected override async Task OnInitializedAsync(){try{_raw=await Db.RawMaterialInventories.AsNoTracking().Where(r=>(r.StockQty??0)<(r.SafetyStock??999)).Take(50).ToListAsync();_bottles=await Db.BottleStyles.AsNoTracking().Where(b=>(b.StockQty??0)<(b.SafetyStock??999)).Take(50).ToListAsync();_l=true;}catch{_l=true;}}}
