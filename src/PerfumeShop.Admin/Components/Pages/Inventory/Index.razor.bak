<!-- V19库存管理中心 · 首页仪表盘 -->
@page "/admin/inventory"
@page "/admin/Inventory"
@page "/admin/inventory/index"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>库存管理中心</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-warehouse" style="color:#00BCD4;"></i> 库存管理中心</MudText>

@if (_loaded)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
                <div style="font-size:12px;color:#888;">成品库存</div>
                <div style="font-size:32px;font-weight:700;color:#4CAF50;">@_productCount</div>
                <div style="font-size:12px;color:#666;">种类</div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
                <div style="font-size:12px;color:#888;">瓶子库存</div>
                <div style="font-size:32px;font-weight:700;color:#9C27B0;">@_bottleCount</div>
                <div style="font-size:12px;color:#666;">种类</div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
                <div style="font-size:12px;color:#888;">包装物库存</div>
                <div style="font-size:32px;font-weight:700;color:#FF9800;">@_packagingCount</div>
                <div style="font-size:12px;color:#666;">种类</div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
                <div style="font-size:12px;color:#888;">原料库存</div>
                <div style="font-size:32px;font-weight:700;color:#2196F3;">@_rawCount</div>
                <div style="font-size:12px;color:#666;">种类</div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_lowStockProducts.Any())
    {
        <MudAlert Severity="Severity.Warning" Class="mt-4 mb-4">
            <i class="fas fa-exclamation-triangle"></i> @_lowStockProducts.Count 个成品库存低于阈值（≤10）
        </MudAlert>
    }
    @if (_lowStockMaterials.Any())
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <i class="fas fa-exclamation-triangle"></i> @_lowStockMaterials.Count 个原料库存低于阈值（≤50）
        </MudAlert>
    }

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">成品库存总览</MudText>
    <MudTable Items="@_products.Take(15)" Hover="true" Dense="true" Striped="true">
        <HeaderContent>
            <MudTh>产品ID</MudTh><MudTh>产品名称</MudTh><MudTh>当前库存</MudTh><MudTh>单位</MudTh><MudTh>最后更新</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProductId</MudTd>
            <MudTd Style="font-weight:600;">@context.Product?.ProductName</MudTd>
            <MudTd>
                <span style="color:@(context.StockQty <= 10 ? "#F44336" : "#4CAF50");font-weight:600;">@context.StockQty</span>
            </MudTd>
            <MudTd>@context.Unit</MudTd>
            <MudTd>@context.UpdatedAt?.ToString("yyyy-MM-dd")</MudTd>
        </RowTemplate>
    </MudTable>

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">最近库存变动</MudText>
    <MudTable Items="@_recentMovements.Take(10)" Hover="true" Dense="true" Striped="true">
        <HeaderContent>
            <MudTh>类型</MudTh><MudTh>物品</MudTh><MudTh>变动</MudTh><MudTh>变动前</MudTh><MudTh>变动后</MudTh><MudTh>参考号</MudTh><MudTh>时间</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetMovementColor(context.MovementType)">@context.MovementType</MudChip></MudTd>
            <MudTd>@context.ItemName</MudTd>
            <MudTd Style="@GetQtyStyle(context)" class="font-weight-bold">@(context.Quantity >= 0 ? "+" : "")@context.Quantity</MudTd>
            <MudTd>@context.BeforeQty</MudTd>
            <MudTd>@context.AfterQty</MudTd>
            <MudTd>@context.ReferenceNo</MudTd>
            <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private bool _loaded;
    private int _productCount, _bottleCount, _packagingCount, _rawCount;
    private List<ProductInventory> _products = new();
    private List<BottleInventory> _bottles = new();
    private List<PackagingInventory> _packagings = new();
    private List<RawMaterialInventory> _rawMaterials = new();
    private List<ProductInventory> _lowStockProducts = new();
    private List<RawMaterialInventory> _lowStockMaterials = new();
    private List<StockMovement> _recentMovements = new();

    protected override async Task OnInitializedAsync()
    {
        _products = await Db.ProductInventories.Include(p => p.Product).AsNoTracking().ToListAsync();
        _bottles = await Db.BottleInventories.AsNoTracking().ToListAsync();
        _packagings = await Db.PackagingInventories.AsNoTracking().ToListAsync();
        _rawMaterials = await Db.RawMaterialInventories.AsNoTracking().ToListAsync();
        _lowStockProducts = _products.Where(p => p.StockQty <= 10).ToList();
        _lowStockMaterials = _rawMaterials.Where(m => m.StockQty <= 50).ToList();
        _recentMovements = await Db.StockMovements.AsNoTracking().OrderByDescending(m => m.MovementId).Take(20).ToListAsync();

        _productCount = _products.Count;
        _bottleCount = _bottles.Count;
        _packagingCount = _packagings.Count;
        _rawCount = _rawMaterials.Count;
        _loaded = true;
    }

    private static Color GetMovementColor(string? type) => type switch
    {
        "入库" or "收货" => Color.Success, "出库" or "发货" => Color.Error,
        "调拨" => Color.Info, "退货" => Color.Warning, _ => Color.Default
    };
    private static string GetQtyStyle(StockMovement m) => $"font-weight:600;color:{(m.Quantity >= 0 ? "#4CAF50" : "#F44336")}";
}
