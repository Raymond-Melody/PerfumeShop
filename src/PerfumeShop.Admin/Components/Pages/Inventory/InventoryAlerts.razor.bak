<!-- V19库存管理 · 库存预警 -->
@page "/admin/inventory/alerts"
@page "/admin/inventory/inventory-alerts"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>库存预警</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-exclamation-triangle" style="color:#F44336;"></i> 库存预警</MudText>

@if (_loaded)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="3">
            <MudNumericField @bind-Value="_productThreshold" Label="成品低库存阈值" Min="0" Max="9999" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudNumericField @bind-Value="_materialThreshold" Label="原料低库存阈值" Min="0" Max="99999" Variant="Variant.Outlined" />
        </MudItem>
    </MudGrid>

    @if (!_lowStockProducts.Any() && !_lowStockMaterials.Any())
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">所有库存充足，无需预警</MudAlert>
    }

    @if (_lowStockProducts.Any())
    {
        <MudText Typo="Typo.h6" Class="mb-3" Style="color:#F44336;">低库存成品 (@_lowStockProducts.Count)</MudText>
        <MudTable Items="@_lowStockProducts" Hover="true" Dense="true" Striped="true">
            <HeaderContent>
                <MudTh>产品ID</MudTh><MudTh>产品名称</MudTh><MudTh>当前库存</MudTh><MudTh>安全阈值</MudTh><MudTh>单位</MudTh><MudTh>最后更新</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ProductId</MudTd>
                <MudTd Style="font-weight:600;">@context.Product?.ProductName</MudTd>
                <MudTd Style="color:#F44336;font-weight:700;">@context.StockQty</MudTd>
                <MudTd>@_productThreshold</MudTd>
                <MudTd>@context.Unit</MudTd>
                <MudTd>@context.UpdatedAt?.ToString("yyyy-MM-dd")</MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (_lowStockMaterials.Any())
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-3" Style="color:#F44336;">低库存原料 (@_lowStockMaterials.Count)</MudText>
        <MudTable Items="@_lowStockMaterials" Hover="true" Dense="true" Striped="true">
            <HeaderContent>
                <MudTh>原料ID</MudTh><MudTh>原料代码</MudTh><MudTh>当前库存</MudTh><MudTh>安全阈值</MudTh><MudTh>最后更新</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.MaterialId</MudTd>
                <MudTd>@context.MaterialCode</MudTd>
                <MudTd Style="color:#F44336;font-weight:700;">@context.StockQty</MudTd>
                <MudTd>@_materialThreshold</MudTd>
                <MudTd>@context.UpdatedAt?.ToString("yyyy-MM-dd")</MudTd>
            </RowTemplate>
        </MudTable>
    }
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private bool _loaded;
    private int _productThreshold = 10;
    private int _materialThreshold = 50;
    private List<ProductInventory> _lowStockProducts = new();
    private List<RawMaterialInventory> _lowStockMaterials = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAlerts();
        _loaded = true;
    }

    private async Task LoadAlerts()
    {
        _lowStockProducts = await Db.ProductInventories
            .Include(p => p.Product).AsNoTracking()
            .Where(p => p.StockQty <= _productThreshold).ToListAsync();
        _lowStockMaterials = await Db.RawMaterialInventories.AsNoTracking()
            .Where(m => m.StockQty <= _materialThreshold).ToListAsync();
    }
}
