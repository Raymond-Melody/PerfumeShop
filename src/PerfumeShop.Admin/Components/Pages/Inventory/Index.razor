@page "/admin/inventory"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>库存中心</PageTitle>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);"><h2 style="font-size:24px;color:#fff;margin:0;"><i class="fas fa-warehouse" style="color:#00BCD4;"></i> 库存管理中心</h2><span style="color:#888;">全品类统一管控</span></div>
@if(_l){<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;"><div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;"><div style="font-size:26px;font-weight:bold;color:#e0e0e0;">@_c1</div><div style="font-size:13px;color:#888;">库存品类</div></div><div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;"><div style="font-size:26px;font-weight:bold;color:#00BCD4;">@_c2</div><div style="font-size:13px;color:#888;">库存条目</div></div><div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;"><div style="font-size:26px;font-weight:bold;color:#4CAF50;">@_c3</div><div style="font-size:13px;color:#888;">变动记录</div></div></div>
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;"><a href="/admin/inventory/stock-movements" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #00BCD4;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-list" style="color:#00BCD4;margin-right:8px;"></i>库存变动</div><div style="font-size:12px;color:#888;margin-top:6px;">出入库流水记录</div></div></a><a href="/admin/inventory/alerts" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #F44336;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-exclamation-triangle" style="color:#F44336;margin-right:8px;"></i>库存预警</div><div style="font-size:12px;color:#888;margin-top:6px;">全品类低库存预警</div></div></a></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
@code{bool _l;int _c1,_c2,_c3;protected override async Task OnInitializedAsync(){try{_c1=6;_c2=await Db.ProductInventories.CountAsync()+await Db.BottleStyles.CountAsync()+await Db.PackagingInventories.CountAsync()+await Db.RawMaterialInventories.CountAsync();_c3=await Db.StockMovements.CountAsync();_l=true;}catch{_l=true;}}}
