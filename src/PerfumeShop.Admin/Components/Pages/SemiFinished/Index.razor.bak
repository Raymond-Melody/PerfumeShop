@page "/admin/semifinished"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using AccordModel = PerfumeShop.Data.Models.AccordProduction

<PageTitle>半成品管理</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">半成品管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">调配记录</MudText><MudText Typo="Typo.h4">@_accordCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">转移记录</MudText><MudText Typo="Typo.h4">@_transferCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption" Color="Color.Error">库存预警</MudText><MudText Typo="Typo.h4" Color="Color.Error">@_alertCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">原料种类</MudText><MudText Typo="Typo.h4">@_rawCount</MudText></MudPaper></MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">快捷操作</MudText>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/semifinished/accord-production">调配记录</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" Href="/admin/semifinished/new-blend">新增调配</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/admin/semifinished/workshop-transfer">车间转移</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Href="/admin/semifinished/inventory-alerts">库存预警</MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">最近调配</MudText>
            <MudTable Items="@_recentAccords" Hover="true" Dense="true" RowsPerPage="5">
                <HeaderContent><MudTh>批次号</MudTh><MudTh>香料</MudTh><MudTh>状态</MudTh></HeaderContent>
                <RowTemplate>
                    <MudTd>@(context.BatchNo ?? "-")</MudTd>
                    <MudTd>@(context.NoteName ?? "-")</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small">@(context.Status ?? "-")</MudChip></MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private int _accordCount, _transferCount, _alertCount, _rawCount;
    private List<AccordModel> _recentAccords = new();

    protected override async Task OnInitializedAsync()
    {
        _accordCount = await Db.AccordProductions.CountAsync();
        _transferCount = await Db.WorkshopTransfers.CountAsync();
        _rawCount = await Db.RawMaterialInventories.CountAsync();
        _recentAccords = await Db.AccordProductions.AsNoTracking().OrderByDescending(a => a.CreatedAt).Take(5).ToListAsync();
        var noteAlerts = await Db.NoteInventories.CountAsync(n => n.StockQuantity < n.MinStockLevel);
        var rawAlerts = await Db.RawMaterialInventories.CountAsync(r => r.StockQty < r.SafetyStock);
        _alertCount = noteAlerts + rawAlerts;
    }
}
