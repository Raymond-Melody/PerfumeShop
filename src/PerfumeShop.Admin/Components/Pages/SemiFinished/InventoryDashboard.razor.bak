@page "/admin/semifinished/inventory-dashboard"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>库存总览仪表盘</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">库存总览仪表盘</MudText>

@* 统计卡片 *@
<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2" Style="border-left:4px solid #4361ee">
            <MudText Typo="Typo.caption">香料种类</MudText>
            <MudText Typo="Typo.h4">@_noteCount</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2" Style="border-left:4px solid #00bcd4">
            <MudText Typo="Typo.caption">原料种类</MudText>
            <MudText Typo="Typo.h4">@_rawCount</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2" Style="border-left:4px solid #F44336">
            <MudText Typo="Typo.caption" Color="Color.Error">低库存预警</MudText>
            <MudText Typo="Typo.h4" Color="Color.Error">@_alertCount</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2" Style="border-left:4px solid #4caf50">
            <MudText Typo="Typo.caption">基础香料</MudText>
            <MudText Typo="Typo.h4">@_baseNoteCount</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@* 香料库存表 *@
<MudText Typo="Typo.h6" Class="mb-2">香料库存</MudText>
<MudTable Items="@_noteInventories" Hover="true" Dense="true" Striped="true" Class="mb-4" RowsPerPage="10">
    <HeaderContent>
        <MudTh>NoteID</MudTh><MudTh>当前库存</MudTh><MudTh>安全库存</MudTh><MudTh>状态</MudTh><MudTh>更新时间</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.NoteId</MudTd>
        <MudTd>@(context.StockQuantity ?? 0)</MudTd>
        <MudTd>@(context.MinStockLevel ?? 0)</MudTd>
        <MudTd>
            @if ((context.StockQuantity ?? 0) < (context.MinStockLevel ?? 0))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error">低库存</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success">正常</MudChip>
            }
        </MudTd>
        <MudTd>@context.UpdatedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
    </RowTemplate>
</MudTable>

@* 原料库存表 *@
<MudText Typo="Typo.h6" Class="mb-2">原料库存</MudText>
<MudTable Items="@_rawInventories" Hover="true" Dense="true" Striped="true" RowsPerPage="10">
    <HeaderContent>
        <MudTh>ID</MudTh><MudTh>编码</MudTh><MudTh>名称</MudTh><MudTh>库存量</MudTh><MudTh>安全库存</MudTh><MudTh>单价</MudTh><MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.MaterialId</MudTd>
        <MudTd><code>@(context.ItemCode ?? "-")</code></MudTd>
        <MudTd>@(context.ItemName ?? "-")</MudTd>
        <MudTd>@(context.StockQty?.ToString("F2") ?? "0") @(context.Unit ?? "")</MudTd>
        <MudTd>@(context.SafetyStock?.ToString("F2") ?? "0")</MudTd>
        <MudTd>@(context.UnitPrice?.ToString("F2") ?? "-")</MudTd>
        <MudTd>
            @if ((context.StockQty ?? 0) < (context.SafetyStock ?? 0))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error">低库存</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success">正常</MudChip>
            }
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private int _noteCount, _rawCount, _alertCount, _baseNoteCount;
    private List<NoteInventory> _noteInventories = new();
    private List<RawMaterialInventory> _rawInventories = new();

    protected override async Task OnInitializedAsync()
    {
        _noteInventories = await Db.NoteInventories.AsNoTracking().OrderBy(n => n.NoteId).ToListAsync();
        _rawInventories = await Db.RawMaterialInventories.AsNoTracking().OrderBy(r => r.MaterialId).ToListAsync();
        _noteCount = _noteInventories.Count;
        _rawCount = _rawInventories.Count;
        _baseNoteCount = await Db.BaseNotes.CountAsync();

        var noteAlerts = _noteInventories.Count(n => (n.StockQuantity ?? 0) < (n.MinStockLevel ?? 0));
        var rawAlerts = _rawInventories.Count(r => (r.StockQty ?? 0) < (r.SafetyStock ?? 0));
        _alertCount = noteAlerts + rawAlerts;
    }
}
