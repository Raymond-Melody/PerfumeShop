@page "/admin/semifinished"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>生产概览 - 半成品生产中心</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-flask" style="color:#2196F3;"></i> 半成品生产概览</h2><div class="breadcrumb"><a href="/" style="color:#2196F3;text-decoration:none;">管理中心</a> / <span>半成品生产</span></div></div>

@if(_loaded){
<div class="stats-grid">
    <div class="stat-card stat-raw">
        <div class="stat-label"><i class="fas fa-boxes"></i> 原料种类</div>
        <div class="stat-value">@_rawCount</div>
        <div class="stat-sub">@if(_rawLowStock>0){<span class="alert-badge">@_rawLowStock 低库存</span>}else{<span>库存正常</span>}</div>
    </div>
    <div class="stat-card stat-base">
        <div class="stat-label"><i class="fas fa-database"></i> 基香</div>
        <div class="stat-value">@_baseActive</div>
        <div class="stat-sub">总计 @_baseTotal 种</div>
    </div>
    <div class="stat-card stat-note">
        <div class="stat-label"><i class="fas fa-layer-group"></i> 香调库存</div>
        <div class="stat-value">@_noteTotalQty</div>
        <div class="stat-sub">@_noteCount 种香调 @if (_noteLowStock > 0){<span class="alert-badge">@_noteLowStock 低库存</span>}</div>
    </div>
    <div class="stat-card stat-accord">
        <div class="stat-label"><i class="fas fa-cogs"></i> Accord生产</div>
        <div class="stat-value">@_accordProcessing</div>
        <div class="stat-sub">待处理 @_accordPending | 已完成 @_accordCompleted</div>
    </div>
</div>

<div style="margin-top:25px;">
    <h3 class="section-title"><i class="fas fa-clock" style="color:#2196F3;"></i> 近期Accord生产</h3>
    <div class="card"><div class="card-body">
    <table class="data-table"><thead><tr><th>生产批号</th><th>香调名称</th><th>计划产量</th><th>状态</th><th>创建时间</th></tr></thead><tbody>
    @if(_recentAccords.Any()){@foreach(var a in _recentAccords){<tr>
        <td>@a.BatchNo</td><td><strong>@a.NoteName</strong></td><td>@a.PlannedQty</td>
        <td><span class="status-badge @GetAccordStatusClass(a.Status)">@GetAccordStatusLabel(a.Status)</span></td>
        <td style="color:#888;">@(a.CreatedAt?.ToString("yyyy-MM-dd HH:mm"))</td>
    </tr>}}else{<tr><td colspan="5" class="text-center text-muted" style="padding:40px;">暂无生产记录</td></tr>}
    </tbody></table>
    </div></div>
</div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded;int _rawCount,_rawLowStock,_baseTotal,_baseActive,_noteCount,_noteLowStock,_noteTotalQty,_accordPending,_accordProcessing,_accordCompleted;
List<AccordProduction> _recentAccords=new();

protected override async Task OnInitializedAsync(){
    try{
        _rawCount=await Db.RawMaterialInventories.CountAsync();
        _rawLowStock=await Db.RawMaterialInventories.CountAsync(r=>r.StockQty<=r.SafetyStock&&r.SafetyStock>0);
        _baseTotal=await Db.BaseNotes.CountAsync();
        _baseActive=await Db.BaseNotes.CountAsync(b=>b.IsActive==true);
        var notes=await Db.NoteInventories.ToListAsync();
        _noteCount=notes.Count;
        _noteLowStock=notes.Count(n=>(n.StockQuantity??0)<=(n.MinStockLevel??0)&&(n.MinStockLevel??0)>0);
        _noteTotalQty=notes.Sum(n=>n.StockQuantity??0);
        _accordPending=await Db.AccordProductions.CountAsync(a=>a.Status=="Pending");
        _accordProcessing=await Db.AccordProductions.CountAsync(a=>a.Status=="InProgress");
        _accordCompleted=await Db.AccordProductions.CountAsync(a=>a.Status=="Completed"||a.Status=="QC");
        _recentAccords=await Db.AccordProductions.OrderByDescending(a=>a.CreatedAt).Take(5).ToListAsync();
    }catch(Exception ex){System.Console.WriteLine($"SF Index error: {ex.Message}");}
    _loaded=true;
}

string GetAccordStatusClass(string? s)=>s switch{"Pending"=>"status-pending","InProgress"=>"status-progress","Completed"=>"status-completed","QC"=>"status-qc",_=>"status-fail"};
string GetAccordStatusLabel(string? s)=>s switch{"Pending"=>"待生产","InProgress"=>"生产中","Completed"=>"已完成","QC"=>"已质检",_=>s??"-"};
}

<style>
.page-header{margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}
.page-title{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}
.breadcrumb{font-size:13px;color:#888;margin-top:5px;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:15px;margin-bottom:30px;}
.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:20px;border:1px solid rgba(255,255,255,0.06);}
.stat-card .stat-label{font-size:12px;color:#888;margin-bottom:8px;}
.stat-card .stat-value{font-size:28px;font-weight:700;}
.stat-card .stat-sub{font-size:12px;color:#888;margin-top:5px;}
.stat-raw .stat-value{color:#4CAF50;}.stat-base .stat-value{color:#2196F3;}.stat-note .stat-value{color:#FF9800;}.stat-accord .stat-value{color:#9C27B0;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}
.card-body{padding:16px 20px;overflow-x:auto;}
.data-table{width:100%;border-collapse:collapse;}
.data-table th{background:rgba(33,150,243,0.15);color:#64b5f6;font-weight:600;padding:12px 15px;text-align:left;font-size:13px;}
.data-table td{padding:12px 15px;color:#e0e0e0;font-size:14px;border-bottom:1px solid rgba(255,255,255,0.04);}
.data-table tr:hover td{background:rgba(255,255,255,0.03);}
.section-title{font-size:18px;color:#e0e0e0;margin-bottom:15px;display:flex;align-items:center;gap:10px;}
.status-badge{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}
.status-pending{background:rgba(255,152,0,0.15);color:#ffb74d;}
.status-progress{background:rgba(33,150,243,0.15);color:#64b5f6;}
.status-completed{background:rgba(76,175,80,0.15);color:#81c784;}
.status-qc{background:rgba(156,39,176,0.15);color:#ce93d8;}
.status-fail{background:rgba(244,67,54,0.15);color:#e57373;}
.alert-badge{background:rgba(244,67,54,0.15);color:#e57373;padding:2px 8px;border-radius:10px;font-size:11px;}
.text-center{text-align:center;}.text-muted{color:#888;font-size:13px;}
</style>
