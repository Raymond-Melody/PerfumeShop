@page "/admin/semifinished/new-blend"
@using PerfumeShop.Data.Models
@using AccordModel = PerfumeShop.Data.Models.AccordProduction

<PageTitle>新增调配</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">新增调配记录</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_form.BatchNo" Label="批次号" Required="true" /></MudItem>
        <MudItem xs="12" sm="6"><MudTextField @bind-Value="_form.NoteName" Label="香料名称" /></MudItem>
        <MudItem xs="12" sm="4"><MudNumericField @bind-Value="_form.PlannedQty" Label="计划量 (ml)" /></MudItem>
        <MudItem xs="12" sm="4"><MudTextField @bind-Value="_form.WorkCenter" Label="工作中心" /></MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect @bind-Value="_form.Status" Label="状态">
                <MudSelectItem Value="@("Pending")">待开始</MudSelectItem>
                <MudSelectItem Value="@("InProgress")">生产中</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12"><MudTextField @bind-Value="_form.Notes" Label="备注" Lines="3" /></MudItem>
    </MudGrid>
    <MudStack Row="true" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" StartIcon="@Icons.Material.Filled.Save">保存</MudButton>
        <MudButton Variant="Variant.Outlined" Href="/admin/semifinished/accord-production">取消</MudButton>
    </MudStack>
</MudPaper>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    private AccordModel _form = new() { Status = "Pending", BatchNo = $"BP-{DateTime.Now:yyyyMMddHHmm}" };

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.BatchNo)) { Snackbar.Add("批次号必填", Severity.Error); return; }
        _form.CreatedAt = DateTime.Now; _form.UpdatedAt = DateTime.Now;
        Db.AccordProductions.Add(_form); await Db.SaveChangesAsync();
        Snackbar.Add("调配记录已创建", Severity.Success);
        Nav.NavigateTo("/admin/semifinished/accord-production");
    }
}
