@page "/admin/semifinished/base-note-inventory"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>基础香料库存</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">基础香料库存</MudText>

<MudTable Items="@_items" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent><MudTh>NoteID</MudTh><MudTh>库存量</MudTh><MudTh>安全库存</MudTh><MudTh>状态</MudTh><MudTh>更新时间</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.NoteId</MudTd><MudTd>@(context.StockQuantity ?? 0)</MudTd><MudTd>@(context.MinStockLevel ?? 0)</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@((context.StockQuantity ?? 0) < (context.MinStockLevel ?? 0) ? Color.Error : Color.Success)">@((context.StockQuantity ?? 0) < (context.MinStockLevel ?? 0) ? "低库存" : "正常")</MudChip></MudTd>
        <MudTd>@context.UpdatedAt?.ToString("yyyy-MM-dd")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private List<NoteInventory> _items = new();
    protected override async Task OnInitializedAsync() => _items = await Db.NoteInventories.AsNoTracking().OrderBy(n => n.NoteId).ToListAsync();
}
