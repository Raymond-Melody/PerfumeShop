@page "/admin/semifinished/base-note-production"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using AccordModel = PerfumeShop.Data.Models.AccordProduction

<PageTitle>基础香料生产</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">基础香料生产</MudText>

<MudTable ServerData="@(new Func<TableState, Task<TableData<AccordModel>>>(ServerReload))" Hover="true" Dense="true" Striped="true" RowsPerPage="15">
    <HeaderContent><MudTh>批次号</MudTh><MudTh>香料</MudTh><MudTh>计划量</MudTh><MudTh>实际量</MudTh><MudTh>状态</MudTh><MudTh>时间</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@(context.BatchNo ?? "-")</MudTd><MudTd>@(context.NoteName ?? "-")</MudTd>
        <MudTd>@(context.PlannedQty ?? 0)</MudTd><MudTd>@(context.ActualQty ?? 0)</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Status == "Completed" ? Color.Success : Color.Info)">@(context.Status ?? "-")</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("MM-dd HH:mm")</MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private async Task<TableData<AccordModel>> ServerReload(TableState state)
    {
        var q = Db.AccordProductions.AsNoTracking().AsQueryable();
        var total = await q.CountAsync();
        var items = await q.OrderByDescending(a => a.CreatedAt).Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        return new TableData<AccordModel> { TotalItems = total, Items = items };
    }
}
