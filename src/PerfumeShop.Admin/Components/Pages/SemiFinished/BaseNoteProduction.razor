@page "/admin/semifinished/base-note-production"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>基香生产</PageTitle>
<div class="ph"><h2 class="pt"><i class="fas fa-vial" style="color:#2196F3;"></i> 基香生产管理</h2><div class="br"><a href="/admin/semifinished" style="color:#2196F3;text-decoration:none;">半成品中心</a> / 基香生产</div></div>

@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="@(_msgErr?"alert-err":"alert-ok")">@_msg</div>}

<div class="sg"><div class="sc"><span class="n c-blue">@_bnTotal</span><span class="l">基香总数</span></div><div class="sc"><span class="n c-green">@_bnActive</span><span class="l">已激活</span></div><div class="sc"><span class="n c-gray">@(_bnTotal-_bnActive)</span><span class="l">已停用</span></div><div class="sc"><span class="n c-orange">@_bnNoteCount</span><span class="l">关联香调</span></div></div>

<div class="card"><div class="ch">基香列表</div><div class="cb"><table class="dt"><thead><tr><th>基香名称</th><th>成分</th><th>关联香调数</th><th>状态</th><th>操作</th></tr></thead><tbody>
@foreach(var b in _baseNotes){var isActive=b.IsActive==true;<tr><td><strong>@b.Name</strong></td><td><div class="it">@foreach(var ing in (b.Ingredients??"").Split(',')){if(!string.IsNullOrWhiteSpace(ing)){<span class="ing-tag">@ing.Trim()</span>}}</div></td><td>@b.NoteCount</td><td><span class="@(isActive?"sa":"si")">@(isActive?"激活":"停用")</span></td><td><button class="btn @(isActive?"btn-warning":"btn-success") btn-sm" @onclick="()=>ToggleActive(b)">@(isActive?"停用":"激活")</button><button class="btn btn-primary btn-sm" @onclick="()=>OpenEditModal(b)">编辑成分</button></td></tr>}
@if(!_baseNotes.Any()){<tr><td colspan="5" class="tac tm" style="padding:40px;">暂无基香数据</td></tr>}
</tbody></table></div></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@if(_showEdit){<div class="mo" @onclick="()=>_showEdit=false"><div class="mc" @onclick:stopPropagation="true"><div class="mh"><h3>编辑基香成分 - @_editName</h3><button class="mcl" @onclick="()=>_showEdit=false">&times;</button></div>
<div class="fg"><label>成分列表（逗号分隔）</label><textarea @bind="_editIngredients" class="fi" rows="5"></textarea></div>
<div class="mft"><button class="btn btn--neutral" @onclick="()=>_showEdit=false">取消</button><button class="btn btn-primary" @onclick="SaveIngredients" disabled="@_saving">保存</button></div>
</div></div>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded,_msgErr,_showEdit,_saving;string? _msg;int _bnTotal,_bnActive,_bnNoteCount;
List<BnVm> _baseNotes=new();string _editName="";int _editId;string _editIngredients="";

record BnVm(int Id,string? Name,string? Ingredients,bool? IsActive,int NoteCount);

protected override async Task OnInitializedAsync(){await LoadData();}
async Task LoadData(){
    try{
        _bnTotal=await Db.BaseNotes.CountAsync();
        _bnActive=await Db.BaseNotes.CountAsync(b=>b.IsActive==true);
        _bnNoteCount=await Db.FragranceNotes.Select(n=>n.BaseNoteId).Distinct().CountAsync();
        var all=await Db.BaseNotes.OrderByDescending(b=>b.IsActive).ThenBy(b=>b.BaseNoteName).ToListAsync();
        _baseNotes=all.Select(b=>new BnVm(b.BaseNoteId,b.BaseNoteName,b.Ingredients,b.IsActive,Db.FragranceNotes.Count(n=>n.BaseNoteId==b.BaseNoteId))).ToList();
    }catch(Exception ex){_msg="加载失败: "+ex.Message;_msgErr=true;}
    _loaded=true;
}

async Task ToggleActive(BnVm b){
    var nv=!(b.IsActive??false);
    await Db.BaseNotes.Where(x=>x.BaseNoteId==b.Id).ExecuteUpdateAsync(s=>s.SetProperty(x=>x.IsActive,nv));
    _msg=nv?"基香已激活":"基香已停用";_msgErr=false;
    await LoadData();await InvokeAsync(StateHasChanged);
}

void OpenEditModal(BnVm b){_editId=b.Id;_editName=b.Name??"";_editIngredients=b.Ingredients??"";_showEdit=true;}

async Task SaveIngredients(){
    if(_editId<=0||string.IsNullOrEmpty(_editIngredients))return;_saving=true;
    try{await Db.BaseNotes.Where(b=>b.BaseNoteId==_editId).ExecuteUpdateAsync(s=>s.SetProperty(b=>b.Ingredients,_editIngredients));_msg="成分已更新";_msgErr=false;_showEdit=false;await LoadData();}
    catch(Exception ex){_msg="保存失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}
}

<style>
.ph{margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;margin-top:5px;}
.sg{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;display:block;}.sc .l{font-size:12px;color:#888;display:block;margin-top:5px;}.c-blue{color:#2196F3;}.c-green{color:#4CAF50;}.c-gray{color:#888;}.c-orange{color:#FF9800;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.ch{padding:14px 20px;background:rgba(33,150,243,0.08);border-bottom:1px solid rgba(255,255,255,0.06);font-weight:600;font-size:15px;color:#e0e0e0;}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(33,150,243,0.15);color:#64b5f6;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}
.it{display:flex;flex-wrap:wrap;gap:4px;}.ing-tag{background:rgba(33,150,243,0.12);color:#64b5f6;padding:2px 10px;border-radius:10px;font-size:12px;}
.sa{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;background:rgba(76,175,80,0.15);color:#81c784;}.si{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;background:rgba(244,67,54,0.15);color:#e57373;}
.alert-ok{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-err{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.mo{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}.mc{background:linear-gradient(135deg,#2d2d44,#1e1e32);width:90%;max-width:550px;padding:30px;border-radius:15px;border:1px solid rgba(255,255,255,0.06);}.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.06);}.mh h3{margin:0;font-size:18px;color:#e0e0e0;}.mcl{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.mft{display:flex;justify-content:flex-end;gap:10px;margin-top:25px;}
.fg{margin-bottom:18px;}.fg label{display:block;margin-bottom:6px;font-weight:600;color:#e0e0e0;font-size:13px;}.fi{width:100%;padding:10px 12px;background:#2d2d44;border:1px solid rgba(255,255,255,0.12);border-radius:6px;color:#e0e0e0;font-size:14px;}.fi:focus{outline:none;border-color:#2196F3;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:#fff;}.btn-primary{background:#2196F3;}.btn-success{background:#4CAF50;}.btn-warning{background:#FF9800;}.btn--neutral{background:#555;}.btn-sm{padding:6px 12px;font-size:12px;}.btn:disabled{opacity:0.6;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
