@page "/admin/semifinished/inventory-alerts"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>库存预警</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">库存预警</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4"><MudPaper Class="pa-4" Elevation="2" Style="border-left:4px solid #F44336"><MudText Typo="Typo.caption">香料低库存</MudText><MudText Typo="Typo.h4" Color="Color.Error">@_noteAlertCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="4"><MudPaper Class="pa-4" Elevation="2" Style="border-left:4px solid #FF9800"><MudText Typo="Typo.caption">原料低库存</MudText><MudText Typo="Typo.h4" Color="Color.Warning">@_rawAlertCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="4"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">总预警数</MudText><MudText Typo="Typo.h4">@(_noteAlertCount + _rawAlertCount)</MudText></MudPaper></MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mb-2">香料库存预警</MudText>
<MudTable Items="@_noteAlerts" Hover="true" Dense="true" Class="mb-4">
    <HeaderContent><MudTh>NoteID</MudTh><MudTh>当前库存</MudTh><MudTh>安全库存</MudTh><MudTh>缺口</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.NoteId</MudTd><MudTd>@(context.StockQuantity ?? 0)</MudTd><MudTd>@(context.MinStockLevel ?? 0)</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Error">-@((context.MinStockLevel ?? 0) - (context.StockQuantity ?? 0))</MudChip></MudTd>
    </RowTemplate>
</MudTable>

<MudText Typo="Typo.h6" Class="mb-2">原料库存预警</MudText>
<MudTable Items="@_rawAlerts" Hover="true" Dense="true">
    <HeaderContent><MudTh>原料ID</MudTh><MudTh>名称</MudTh><MudTh>当前库存</MudTh><MudTh>安全库存</MudTh><MudTh>缺口</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.MaterialId</MudTd><MudTd>@(context.ItemName ?? "-")</MudTd><MudTd>@(context.StockQty ?? 0) @(context.Unit ?? "")</MudTd>
        <MudTd>@(context.SafetyStock ?? 0)</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Error">-@((context.SafetyStock ?? 0) - (context.StockQty ?? 0))</MudChip></MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private List<NoteInventory> _noteAlerts = new();
    private List<RawMaterialInventory> _rawAlerts = new();
    private int _noteAlertCount, _rawAlertCount;

    protected override async Task OnInitializedAsync()
    {
        _noteAlerts = await Db.NoteInventories.AsNoTracking().Where(n => n.StockQuantity < n.MinStockLevel).ToListAsync();
        _rawAlerts = await Db.RawMaterialInventories.AsNoTracking().Where(r => r.StockQty < r.SafetyStock).ToListAsync();
        _noteAlertCount = _noteAlerts.Count; _rawAlertCount = _rawAlerts.Count;
    }
}
