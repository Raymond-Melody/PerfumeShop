@page "/admin/semifinished/inventory-dashboard"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>库存仪表盘</PageTitle>
<div class="ph"><h2 class="pt"><i class="fas fa-chart-pie" style="color:#2196F3;"></i> 库存仪表盘</h2><div class="br"><a href="/admin/semifinished" style="color:#2196F3;text-decoration:none;">半成品中心</a> / 库存仪表盘</div></div>

@if(_loaded){
<div class="sg">
    <div class="sc"><div class="si raw"><i class="fas fa-boxes"></i></div><div class="info"><div class="num" style="color:#4CAF50;">@_rawTotal</div><div class="label">原料种类 | 总值 ¥@(((decimal)_rawTotalValue).ToString("N0"))</div>@if(_rawLow>0){<div class="ab">@_rawLow 低库存</div>}</div></div>
    <div class="sc"><div class="si base"><i class="fas fa-database"></i></div><div class="info"><div class="num" style="color:#2196F3;">@_bnActive</div><div class="label">激活基香 / 共 @_bnTotal 种</div></div></div>
    <div class="sc"><div class="si note"><i class="fas fa-layer-group"></i></div><div class="info"><div class="num" style="color:#FF9800;">@_noteTotalQty</div><div class="label">香调库存总量 | @_noteTotal 种</div>@if(_noteLow>0){<div class="ab">@_noteLow 低库存</div>}</div></div>
    <div class="sc"><div class="si accord"><i class="fas fa-cogs"></i></div><div class="info"><div class="num" style="color:#9C27B0;">@_accordProgress</div><div class="label">Accord生产中 | 本月完成 @_accordMonth</div></div></div>
</div>

<div class="ic">
    <div class="icc"><div class="ich raw"><i class="fas fa-exclamation-triangle"></i> 原料低库存预警</div><div class="icb"><table class="dt"><thead><tr><th>编码</th><th>名称</th><th>库存</th><th>安全</th><th>单位</th></tr></thead><tbody>
    @foreach(var r in _lowRaw){<tr><td style="color:#888;">@r.ItemCode</td><td>@r.ItemName</td><td style="color:#f44336;">@string.Format("{0:F1}",r.StockQty??0)</td><td>@string.Format("{0:F1}",r.SafetyStock??0)</td><td>@r.Unit</td></tr>}
    @if(!_lowRaw.Any()){<tr><td colspan="5" class="tac tm" style="padding:20px;color:#81c784;">✓ 所有原料库存正常</td></tr>}
    </tbody></table></div></div>
    <div class="icc"><div class="ich note"><i class="fas fa-bell"></i> 香调低库存预警</div><div class="icb"><table class="dt"><thead><tr><th>香调</th><th>类型</th><th>库存</th><th>最低</th></tr></thead><tbody>
    @foreach(var n in _lowNote){<tr><td>@n.NoteName</td><td>@n.NoteType</td><td style="color:#f44336;">@n.StockQuantity</td><td>@n.MinStockLevel</td></tr>}
    @if(!_lowNote.Any()){<tr><td colspan="4" class="tac tm" style="padding:20px;color:#81c784;">✓ 所有香调库存正常</td></tr>}
    </tbody></table></div></div>
</div>

<div class="st"><i class="fas fa-calendar-day" style="color:#2196F3;"></i> 今日运营概览</div>
<div class="sg">
    <div class="sc"><div class="si" style="background:rgba(156,39,176,0.15);color:#9C27B0;"><i class="fas fa-truck-loading"></i></div><div class="info"><div class="num" style="color:#9C27B0;">@_moToday</div><div class="label">今日出库单</div></div></div>
    <div class="sc"><div class="si" style="background:rgba(33,150,243,0.15);color:#2196F3;"><i class="fas fa-calendar-check"></i></div><div class="info"><div class="num" style="color:#2196F3;">@_moMonth</div><div class="label">本月出库单</div></div></div>
    <div class="sc"><div class="si" style="background:rgba(76,175,80,0.15);color:#4CAF50;"><i class="fas fa-check-circle"></i></div><div class="info"><div class="num" style="color:#4CAF50;">@_accordCompleted</div><div class="label">已完成Accord</div></div></div>
</div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded;int _rawTotal,_rawLow,_rawZero,_bnTotal,_bnActive,_noteTotal,_noteLow,_noteTotalQty,_accordProgress,_accordCompleted,_accordMonth,_moToday,_moMonth;double _rawTotalValue;
List<RawMaterialInventory> _lowRaw=new();List<NoteVm> _lowNote=new();

record NoteVm(string? NoteName,string? NoteType,int StockQuantity,int? MinStockLevel);

protected override async Task OnInitializedAsync(){
    try{
        // 原料统计
        var raw=await Db.RawMaterialInventories.ToListAsync();
        _rawTotal=raw.Count;_rawLow=raw.Count(r=>(r.StockQty??0)<=(r.SafetyStock??0)&&(r.SafetyStock??0)>0);_rawZero=raw.Count(r=>(r.StockQty??0)<=0);
        _rawTotalValue=raw.Sum(r=>(r.StockQty??0)*(double)(r.UnitPrice??0));
        _lowRaw=raw.Where(r=>(r.StockQty??0)<=(r.SafetyStock??0)&&(r.SafetyStock??0)>0).OrderBy(r=>r.StockQty).Take(5).ToList();
        // 基香统计
        _bnTotal=await Db.BaseNotes.CountAsync();_bnActive=await Db.BaseNotes.CountAsync(b=>b.IsActive==true);
        // 香调统计
        var notes=await Db.NoteInventories.ToListAsync();_noteTotal=notes.Count;_noteTotalQty=notes.Sum(n=>n.StockQuantity??0);_noteLow=notes.Count(n=>(n.StockQuantity??0)<=(n.MinStockLevel??0)&&(n.MinStockLevel??0)>0);
        _lowNote=await (from ni in Db.NoteInventories join fn in Db.FragranceNotes on ni.NoteId equals fn.NoteId where (ni.StockQuantity??0)<=(ni.MinStockLevel??0)&&(ni.MinStockLevel??0)>0 orderby ni.StockQuantity select new NoteVm(fn.NoteName,fn.NoteType,ni.StockQuantity??0,ni.MinStockLevel)).Take(5).ToListAsync();
        // Accord统计
        _accordProgress=await Db.AccordProductions.CountAsync(a=>a.Status=="InProgress");
        _accordCompleted=await Db.AccordProductions.CountAsync(a=>a.Status=="Completed"||a.Status=="QC");
        _accordMonth=await Db.AccordProductions.CountAsync(a=>(a.Status=="Completed"||a.Status=="QC")&&a.CompletedAt>=DateTime.Now.AddMonths(-1));
        // 出库统计
        _moToday=await Db.MaterialOutbounds.CountAsync(m=>m.CreatedAt!=null&&m.CreatedAt>=DateTime.Today);
        _moMonth=await Db.MaterialOutbounds.CountAsync(m=>m.CreatedAt!=null&&m.CreatedAt>=DateTime.Now.AddMonths(-1));
    }catch{}
    _loaded=true;
}
}

<style>
.ph{margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;margin-top:5px;}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;border:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:15px;}
.si{width:50px;height:50px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}.si.raw{background:rgba(76,175,80,0.15);color:#4CAF50;}.si.base{background:rgba(33,150,243,0.15);color:#2196F3;}.si.note{background:rgba(255,152,0,0.15);color:#FF9800;}.si.accord{background:rgba(156,39,176,0.15);color:#9C27B0;}
.info .num{font-size:24px;font-weight:bold;}.info .label{font-size:12px;color:#888;}.ab{background:rgba(244,67,54,0.15);color:#e57373;padding:2px 8px;border-radius:10px;font-size:11px;margin-top:4px;}
.ic{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-bottom:25px;}.icc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;border:1px solid rgba(255,255,255,0.06);overflow:hidden;}.ich{padding:14px 20px;font-weight:600;font-size:15px;color:#e0e0e0;border-bottom:1px solid rgba(255,255,255,0.06);}.ich.raw{background:rgba(76,175,80,0.08);}.ich.note{background:rgba(255,152,0,0.08);}.icb{padding:16px 20px;}
.dt{width:100%;border-collapse:collapse;}.dt th{padding:10px 12px;text-align:left;font-weight:600;font-size:12px;color:#888;border-bottom:1px solid rgba(255,255,255,0.04);}.dt td{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,0.03);color:#e0e0e0;font-size:13px;}
.st{font-size:16px;color:#e0e0e0;margin:25px 0 15px;display:flex;align-items:center;gap:8px;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
