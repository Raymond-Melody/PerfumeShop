    {
        "alipay" => "alipay", "wechat" => "wechat", "bank" => "bank", "paypal" => "paypal", "cash" => "cash", _ => "other"
    };
    static string GetIconFa(string? t) => t?.ToLower() switch
    {
        "alipay" => "fa-alipay", "wechat" => "fa-weixin", "bank" => "fa-university", "paypal" => "fa-paypal", _ => "fa-wallet"
    };
    static string GetTypeLabel(string? t) => t?.ToLower() switch
    {
        "alipay" => "支付宝", "wechat" => "微信支付", "bank" => "银行账户", "paypal" => "PayPal", "cash" => "现金", _ => "其他"
    };

    // ===== CRUD =====
    void CloseAllModals() { _showAccountModal = _showBalanceModal = _showThresholdModal = _showDetailModal = false; _editingAccount = null; }

    async Task ReloadData()
    {
        _accounts = await FinRepo.GetFundAccountsAsync();
        _recentPayments = await Db.PaymentRecords.AsNoTracking().OrderByDescending(p => p.RecordId).Take(20).ToListAsync();
        _penetration = await FinRepo.GetPendingPenetrationAsync();
        _alerts = await FinRepo.GetFundAlertsDetailAsync();
        _totalBalance = _accounts.Sum(a => a.TotalBalance ?? 0);
        _totalAvailable = _accounts.Sum(a => a.AvailableBalance ?? 0);
        _totalFrozen = _accounts.Sum(a => a.FrozenAmount ?? 0);
        _pendingTotal = _penetration.Total;
        _alertCount = _alerts.Count;
    }

    void OpenAddModal() { _editingAccount = new FundAccount(); _editTotalBalance = 0; _editThreshold = 1000; _showAccountModal = true; }
    void OpenEditModal(FundAccount a) { _editingAccount = new FundAccount { AccountId = a.AccountId, AccountName = a.AccountName, AccountType = a.AccountType }; _showAccountModal = true; }
    void OpenBalanceModal(FundAccount a) { _editingAccount = a; _editTotalBalance = a.TotalBalance ?? 0; _showBalanceModal = true; }
    void OpenThresholdModal(FundAccount a) { _editingAccount = a; _editThreshold = a.AlertThreshold ?? 0; _showThresholdModal = true; }

    async Task SaveAccount()
    {
        if (string.IsNullOrWhiteSpace(_editingAccount?.AccountName)) return;
        if (_editingAccount!.AccountId == 0) _editingAccount.TotalBalance = _editTotalBalance;
        _editingAccount.AlertThreshold = _editThreshold;
        var isNew = _editingAccount.AccountId == 0;
        await FinRepo.SaveFundAccountAsync(_editingAccount);
        await Auditor.LogAsync(_adminId, _adminName, isNew ? "新增资金账户" : "编辑资金账户", "FundAccount", _editingAccount.AccountId, _editingAccount.AccountName);
        _msg = isNew ? "账户已添加" : "账户已更新"; _msgType = "ok";
        CloseAllModals();
        await ReloadData();
    }

    async Task UpdateBalance()
    {
        if (_editingAccount == null) return;
        await FinRepo.UpdateFundBalanceAsync(_editingAccount.AccountId, _editTotalBalance);
        await Auditor.LogAsync(_adminId, _adminName, "更新账户余额", "FundAccount", _editingAccount.AccountId, _editingAccount.AccountName, $"新余额{_editTotalBalance:F2}");
        _msg = "余额已更新"; _msgType = "ok";
        CloseAllModals();
        await ReloadData();
    }

    async Task SetThreshold()
    {
        if (_editingAccount == null) return;
        await FinRepo.UpdateFundThresholdAsync(_editingAccount.AccountId, _editThreshold);
        await Auditor.LogAsync(_adminId, _adminName, "设置预警阈值", "FundAccount", _editingAccount.AccountId, _editingAccount.AccountName, $"阈值{_editThreshold:F2}");
        _msg = "阈值已设置"; _msgType = "ok";
        CloseAllModals();
        await ReloadData();
    }

    async Task ToggleAccount(FundAccount a)
    {
        var newState = a.IsActive == false;
        if (!newState && !await JS.InvokeAsync<bool>("confirm", $"确定要停用「{a.AccountName}」吗？")) return;
        await FinRepo.ToggleFundStatusAsync(a.AccountId, newState);
        await Auditor.LogAsync(_adminId, _adminName, newState ? "启用资金账户" : "停用资金账户", "FundAccount", a.AccountId, a.AccountName);
        _msg = newState ? "账户已启用" : "账户已停用"; _msgType = "ok";
        await ReloadData();
    }

    // ===== 待结算穿透明细 =====
    async Task ShowPendingDetail(string type)
    {
        _detailTitle = type switch { "orders" => "交易在途明细", "withdraw" => "提现中明细", "frozen" => "不可用保证金明细", _ => "明细" };
        _detailItems = new();
        _detailLoading = true;
        _showDetailModal = true;
        try { _detailItems = await FinRepo.GetPendingDetailAsync(type); }
        finally { _detailLoading = false; }
    }
}
