@page "/admin/finance/gl-report"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.finance")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>总账报表</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-book" style="color:#00bcd4;"></i> 总账报表</h2><div class="breadcrumb"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>总账报表</span></div></div>
@if(_loaded){
<div class="stats-row"><div class="stat-card"><div class="stat-value">@_totalCount</div><div class="stat-label">总账条目</div></div><div class="stat-card"><div class="stat-value" style="color:#4CAF50;">¥@_debitTotal.ToString("N0")</div><div class="stat-label">借方总额</div></div><div class="stat-card"><div class="stat-value" style="color:#F44336;">¥@_creditTotal.ToString("N0")</div><div class="stat-label">贷方总额</div></div></div>
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>科目</th><th>借方金额</th><th>贷方金额</th><th>摘要</th><th>日期</th></tr></thead><tbody>
@foreach(var g in _items){<tr><td>#@g.Glid</td><td>@(g.AccountCode??"-")</td><td class="cost-value">¥@((g.DebitAmount??0).ToString("N2"))</td><td class="cost-value">¥@((g.CreditAmount??0).ToString("N2"))</td><td>@(g.Description??"-")</td><td>@(g.TransactionDate?.ToString("yyyy-MM-dd")??"-")</td></tr>}
@if(!_items.Any()){<tr><td colspan="6" style="text-align:center;color:#666;padding:40px;">暂无总账记录</td></tr>}</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}.stat-value{font-size:26px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}.orders-table{width:100%;border-collapse:collapse;}.orders-table th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:14px 16px;font-size:13px;}.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;}.cost-value{font-family:'Courier New',monospace;font-weight:600;}</style>
@code{private bool _loaded;private int _totalCount;private decimal _debitTotal,_creditTotal;private List<Gltransaction> _items=new();
protected override async Task OnInitializedAsync(){try{_items=await Db.Gltransactions.AsNoTracking().OrderByDescending(g=>g.Glid).Take(50).ToListAsync();_totalCount=_items.Count;_debitTotal=_items.Sum(g=>g.DebitAmount??0);_creditTotal=_items.Sum(g=>g.CreditAmount??0);_loaded=true;}catch{_loaded=true;}}}
