@page "/admin/finance/purchase-review"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.finance")]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories
@inject PerfumeShopContext Db
@inject FinanceRepository FinRepo
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState
@inject PerfumeShop.Admin.Services.IAdminAuditor Auditor

<PageTitle>采购审核</PageTitle>
<div class="page-header">
    <h2 class="page-title"><i class="fas fa-clipboard-check" style="color:#00bcd4;"></i> 采购审核</h2>
    <div class="breadcrumb"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>采购审核</span></div>
</div>

@if (_loaded)
{
    @if (!_canReview)
    {
    <div class="alert alert-error"><i class="fas fa-lock"></i> 权限不足：采购审核仅限财务经理（FIN_MANAGER）或超级管理员访问。</div>
    }
    else
    {
    @if (!string.IsNullOrEmpty(_msg))
    {
    <div class="alert @(_msgType=="err"?"alert-error":"alert-success")">@_msg</div>
    }

    <!-- 统计卡 -->
    <div class="stats-row">
        <div class="stat-card"><div class="stat-value" style="color:#FFB74D;">@_pendingCount</div><div class="stat-label">待审核</div></div>
        <div class="stat-card"><div class="stat-value" style="color:#4CAF50;">@_approvedCount</div><div class="stat-label">已通过</div></div>
        <div class="stat-card"><div class="stat-value" style="color:#F44336;">@_rejectedCount</div><div class="stat-label">已驳回</div></div>
    </div>

    <!-- Tab -->
    <div class="tab-nav">
        <a class="tab-link @(_tab=="pending"?"active":"")" @onclick='()=>SwitchTab("pending")' @onclick:preventDefault><i class="fas fa-hourglass-half"></i> 待审核</a>
        <a class="tab-link @(_tab=="approved"?"active":"")" @onclick='()=>SwitchTab("approved")' @onclick:preventDefault><i class="fas fa-check-circle"></i> 已通过</a>
        <a class="tab-link @(_tab=="rejected"?"active":"")" @onclick='()=>SwitchTab("rejected")' @onclick:preventDefault><i class="fas fa-times-circle"></i> 已驳回</a>
    </div>

    <div class="table-container">
        <table class="orders-table">
            <thead><tr><th>采购单号</th><th>供应商</th><th>品类</th><th>金额</th><th>下单日期</th><th>审核状态</th><th>审核时间</th>@if(_tab=="pending"){<th style="width:150px;">操作</th>}</tr></thead>
            <tbody>
                @foreach (var o in _orders)
                {
                <tr>
                    <td>@o.PurchaseNo</td>
                    <td>@o.SupplierName</td>
                    <td>@o.CategoryCode</td>
                    <td class="cost-value">¥@o.TotalAmount.ToString("N2")</td>
                    <td style="color:#888;">@(o.OrderDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td><span class="status-badge @GetReviewClass(o.Status)">@GetReviewLabel(o.Status)</span></td>
                    <td style="color:#888;">@(o.ApprovedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    @if (_tab == "pending")
                    {
                    <td>
                        <button class="btn-approve" @onclick="()=>OpenApprove(o)"><i class="fas fa-check"></i> 通过</button>
                        <button class="btn-reject" @onclick="()=>OpenReject(o)"><i class="fas fa-times"></i> 驳回</button>
                    </td>
                    }
                </tr>
                }
                @if (!_orders.Any())
                {
                <tr><td colspan="@(_tab=="pending"?8:7)" style="text-align:center;color:#666;padding:40px;">暂无采购单</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 审核通过弹窗 -->
    @if (_showApprove && _current != null)
    {
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header"><h3><i class="fas fa-check-circle" style="color:#4CAF50;"></i> 审核通过 - @_current.PurchaseNo</h3><button class="modal-close" @onclick="CloseModal"><i class="fas fa-times"></i></button></div>
            <div class="modal-body">
                <div class="form-group"><label>供应商</label><input value="@_current.SupplierName" disabled /></div>
                <div class="form-group"><label>审核金额</label><input type="number" step="0.01" @bind="_reviewAmount" /></div>
                <div class="form-group"><label>成本归类</label>
                    <select @bind="_costAllocation">
                        <option value="">请选择成本归类</option>
                        <option value="RawMaterial">原材料</option>
                        <option value="Packaging">包装物</option>
                        <option value="Bottle">瓶子</option>
                        <option value="Printing">印刷品</option>
                        <option value="Nozzle">喷头</option>
                        <option value="Other">其他</option>
                    </select>
                </div>
                <div class="form-group"><label>审核意见</label><input @bind="_reviewComments" placeholder="选填" /></div>
            </div>
            <div class="modal-footer"><button class="btn-secondary" @onclick="CloseModal">取消</button><button class="btn-save" @onclick="DoApprove">确认通过</button></div>
        </div>
    </div>
    }

    <!-- 审核驳回弹窗 -->
    @if (_showReject && _current != null)
    {
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header"><h3><i class="fas fa-times-circle" style="color:#F44336;"></i> 审核驳回 - @_current.PurchaseNo</h3><button class="modal-close" @onclick="CloseModal"><i class="fas fa-times"></i></button></div>
            <div class="modal-body">
                <div class="form-group"><label>驳回原因 <span style="color:#F44336;">*</span></label><input @bind="_rejectReason" placeholder="请填写驳回原因" /></div>
            </div>
            <div class="modal-footer"><button class="btn-secondary" @onclick="CloseModal">取消</button><button class="btn-save" style="background:#c62828;" @onclick="DoReject">确认驳回</button></div>
        </div>
    </div>
    }
    }
}
else { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }

<style>

.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}
.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}
.stat-value{font-size:26px;font-weight:bold;color:#e0e0e0;}.stat-label{font-size:13px;color:#888;margin-top:4px;}
.tab-nav{display:flex;border-bottom:2px solid #3a3a4a;margin-bottom:25px;}
.tab-link{padding:14px 28px;color:#888;font-size:15px;border-bottom:3px solid transparent;cursor:pointer;display:flex;align-items:center;gap:8px;}
.tab-link:hover{color:#e0e0e0;}.tab-link.active{color:#00bcd4;border-bottom-color:#00bcd4;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}
.orders-table{width:100%;border-collapse:collapse;}.orders-table th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:14px 16px;font-size:13px;text-align:left;}
.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.orders-table tr:hover{background:rgba(255,255,255,0.03);}
.cost-value{font-family:'Courier New',monospace;font-weight:600;}
.status-badge{padding:4px 12px;border-radius:12px;font-size:12px;}.s-approved{background:rgba(76,175,80,0.2);color:#81c784;}.s-pending{background:rgba(255,152,0,0.15);color:#FFB74D;}.s-rejected{background:rgba(244,67,54,0.2);color:#e57373;}
.btn-approve{background:rgba(76,175,80,0.2);color:#4CAF50;border:none;padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px;margin-right:6px;}
.btn-approve:hover{background:#4CAF50;color:#fff;}
.btn-reject{background:rgba(244,67,54,0.2);color:#F44336;border:none;padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px;}
.btn-reject:hover{background:#F44336;color:#fff;}
.alert{padding:15px 20px;border-radius:8px;margin-bottom:20px;display:flex;align-items:center;gap:10px;}
.alert-success{background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}
.alert-error{background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}
.modal-content{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;width:90%;max-width:500px;border:1px solid rgba(255,255,255,0.06);}
.modal-header{padding:20px 25px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;align-items:center;}
.modal-header h3{margin:0;color:#e0e0e0;font-size:18px;}.modal-close{background:none;border:none;color:#888;font-size:20px;cursor:pointer;}
.modal-body{padding:25px;}.modal-footer{padding:20px 25px;border-top:1px solid rgba(255,255,255,0.06);display:flex;justify-content:flex-end;gap:10px;}
.form-group{margin-bottom:15px;}.form-group label{display:block;margin-bottom:6px;color:#b0b0b0;font-size:13px;}
.form-group input,.form-group select{width:100%;padding:10px 14px;border:2px solid #3a3a4a;border-radius:8px;font-size:14px;background:#1a1a2e;color:#e0e0e0;box-sizing:border-box;}
.form-group input:focus,.form-group select:focus{border-color:#00bcd4;outline:none;}
.form-group input:disabled{opacity:0.6;}
.btn-save{background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;border:none;padding:10px 24px;border-radius:8px;font-size:14px;cursor:pointer;}
.btn-secondary{background:#3a3a4a;color:#e0e0e0;border:none;padding:10px 24px;border-radius:8px;font-size:14px;cursor:pointer;}
@@media(max-width:768px){.stats-row{grid-template-columns:1fr;}}
</style>

@code {
    private bool _loaded, _canReview;
    private int _adminId;
    private string _adminName = "";
    private string _tab = "pending";
    private string? _msg, _msgType;
    private int _pendingCount, _approvedCount, _rejectedCount;
    private List<FinanceRepository.PurchaseReviewRow> _orders = new();

    // 弹窗状态
    private bool _showApprove, _showReject;
    private FinanceRepository.PurchaseReviewRow? _current;
    private decimal _reviewAmount;
    private string _costAllocation = "", _reviewComments = "", _rejectReason = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var rc = auth.User.FindFirst("RoleCode")?.Value;
            _canReview = rc == "FIN_MANAGER" || rc == "SUPER_ADMIN";
            int.TryParse(auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _adminId);
            _adminName = auth.User.FindFirst(ClaimTypes.Name)?.Value ?? "";
            if (_canReview) await LoadData();
            _loaded = true;
        }
        catch { _loaded = true; }
    }

    async Task LoadData()
    {
        var counts = await FinRepo.GetPurchaseReviewCountsAsync();
        _pendingCount = counts.Pending; _approvedCount = counts.Approved; _rejectedCount = counts.Rejected;
        _orders = await FinRepo.GetPurchaseReviewListAsync(_tab);
    }

    async Task SwitchTab(string t) { _tab = t; await LoadData(); }

    string GetReviewClass(string? s) => s switch { "FinanceApproved" or "Approved" or "Ordered" => "s-approved", "Rejected" => "s-rejected", _ => "s-pending" };
    string GetReviewLabel(string? s) => s switch { "FinanceApproved" => "财务已审", "Approved" => "已通过", "Ordered" => "已下单", "Rejected" => "已驳回", "Submitted" => "待审核", "Pending" => "待审核", _ => s ?? "待审核" };

    void OpenApprove(FinanceRepository.PurchaseReviewRow o) { _current = o; _reviewAmount = o.TotalAmount; _costAllocation = ""; _reviewComments = ""; _showApprove = true; }
    void OpenReject(FinanceRepository.PurchaseReviewRow o) { _current = o; _rejectReason = ""; _showReject = true; }
    void CloseModal() { _showApprove = _showReject = false; _current = null; }

    async Task DoApprove()
    {
        if (_current == null) return;
        if (_reviewAmount <= 0) { _msg = "审核金额必须大于0"; _msgType = "err"; return; }
        if (string.IsNullOrEmpty(_costAllocation)) { _msg = "请选择成本归类"; _msgType = "err"; return; }
        var ok = await FinRepo.ApprovePurchaseAsync(_current.PurchaseId, _adminId, _reviewAmount, _costAllocation, _reviewComments);
        _msg = ok ? "审核通过成功" : "操作失败：采购单不存在"; _msgType = ok ? "ok" : "err";
        if (ok) await Auditor.LogAsync(_adminId, _adminName, "采购审核通过", "PurchaseOrder", _current.PurchaseId, _current.PurchaseNo, $"金额{_reviewAmount:F2} 归类{_costAllocation}");
        CloseModal();
        await LoadData();
    }

    async Task DoReject()
    {
        if (_current == null) return;
        if (string.IsNullOrWhiteSpace(_rejectReason)) { _msg = "请填写驳回原因"; _msgType = "err"; return; }
        var ok = await FinRepo.RejectPurchaseAsync(_current.PurchaseId, _adminId, _rejectReason);
        _msg = ok ? "审核驳回成功" : "操作失败：采购单不存在"; _msgType = ok ? "ok" : "err";
        if (ok) await Auditor.LogAsync(_adminId, _adminName, "采购审核驳回", "PurchaseOrder", _current.PurchaseId, _current.PurchaseNo, _rejectReason);
        CloseModal();
        await LoadData();
    }
}
