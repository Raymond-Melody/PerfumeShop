@page "/admin/finance/reports"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.finance")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>财务报表</PageTitle>
<div class="ph"><h2><i class="fas fa-file-alt" style="color:#00bcd4;"></i> 财务报表</h2><div class="br"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>财务报表</span></div></div>
@if(_l){
<div class="sr"><div class="sc"><div class="sv">@_rev.ToString("N0")</div><div class="sl">总营收</div></div><div class="sc"><div class="sv" style="color:#F44336;">@_cost.ToString("N0")</div><div class="sl">总成本</div></div><div class="sc"><div class="sv" style="color:#4CAF50;">@_profit.ToString("N0")</div><div class="sl">毛利润</div></div><div class="sc"><div class="sv">@_margin.ToString("F1")%</div><div class="sl">毛利率</div></div></div>
<div class="tc"><table class="ot"><thead><tr><th>费用名称</th><th>类型</th><th>金额</th><th>期间</th></tr></thead><tbody>@foreach(var e in _expenses.Take(10)){<tr><td>@(e.ExpenseName??"-")</td><td>@(e.ExpenseType??"-")</td><td>@((e.Amount??0).ToString("N0"))</td><td>@(e.Period??"-")</td></tr>}@if(!_expenses.Any()){<tr><td colspan="4" style="text-align:center;color:#666;padding:30px;">暂无费用记录</td></tr>}</tbody></table></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;color:#888;}.sr{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;}.sv{font-size:26px;font-weight:bold;color:#e0e0e0;}.sl{font-size:13px;color:#888;}.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}.ot th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:14px 16px;font-size:13px;text-align:left;}.ot td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}</style>
@code{bool _l;decimal _rev,_cost,_profit,_margin;List<ExpenseRecord> _expenses=new();protected override async Task OnInitializedAsync(){try{var done=new[]{"Completed","completed","shipped","delivered","Paid","paid"};_rev=await Db.Orders.Where(o=>done.Contains(o.Status!)).SumAsync(o=>o.TotalAmount);_cost=await Db.Orders.Where(o=>done.Contains(o.Status!)).SumAsync(o=>(decimal?)o.CostAmount)??0;_profit=_rev-_cost;_margin=_rev>0?_profit/_rev*100:0;_expenses=await Db.ExpenseRecords.AsNoTracking().OrderByDescending(e=>e.ExpenseId).Take(20).ToListAsync();_l=true;}catch{_l=true;}}}
