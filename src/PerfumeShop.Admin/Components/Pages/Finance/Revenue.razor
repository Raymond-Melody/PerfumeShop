@page "/admin/finance/revenue"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.finance")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>收入统计</PageTitle>
<div class="ph"><h2><i class="fas fa-chart-bar" style="color:#00bcd4;"></i> 收入统计</h2><div class="br"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>收入统计</span></div></div>
@if(_l){
<div class="sr"><div class="sc"><div class="sv">@_rev.ToString("N0")</div><div class="sl">已确认收入</div></div><div class="sc"><div class="sv" style="color:#FF9800;">@_pending.ToString("N0")</div><div class="sl">待收款</div></div><div class="sc"><div class="sv">@_ordCnt</div><div class="sl">已交付订单</div></div></div>
<div class="tc"><table class="ot"><thead><tr><th>订单号</th><th>客户</th><th>金额</th><th>状态</th><th>日期</th></tr></thead><tbody>@foreach(var o in _orders.Take(20)){<tr><td>@o.OrderNo</td><td>@(o.ShippingName??"-")</td><td>@((o.TotalAmount).ToString("N2"))</td><td>@(o.Status??"-")</td><td>@(o.CreatedAt?.ToString("MM-dd")??"-")</td></tr>}@if(!_orders.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:30px;">暂无订单</td></tr>}</tbody></table></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;color:#888;}.sr{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;}.sv{font-size:26px;font-weight:bold;color:#e0e0e0;}.sl{font-size:13px;color:#888;}.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}.ot th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:14px 16px;font-size:13px;text-align:left;}.ot td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}</style>
@code{bool _l;decimal _rev,_pending;int _ordCnt;List<Order> _orders=new();protected override async Task OnInitializedAsync(){try{var done=new[]{"Completed","completed","shipped","delivered","Paid","paid"};_rev=await Db.Orders.Where(o=>done.Contains(o.Status!)).SumAsync(o=>o.TotalAmount);_pending=await Db.Orders.Where(o=>o.Status=="paid"||o.Status=="Paid").SumAsync(o=>o.TotalAmount);_ordCnt=await Db.Orders.CountAsync(o=>done.Contains(o.Status!));_orders=await Db.Orders.AsNoTracking().Where(o=>done.Contains(o.Status!)).OrderByDescending(o=>o.OrderId).Take(30).ToListAsync();_l=true;}catch{_l=true;}}}
