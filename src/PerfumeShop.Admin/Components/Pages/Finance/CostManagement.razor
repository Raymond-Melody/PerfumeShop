@page "/admin/finance/cost-management"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories
@using PerfumeShop.Core.Interfaces
@inject PerfumeShopContext Db
@inject FinanceRepository FinRepo
@inject ICostEngine CostEngine
@inject AuthenticationStateProvider AuthState

<PageTitle>成本管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-coins" style="color:#00bcd4;"></i> 成本管理</h2><div class="breadcrumb"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>成本管理</span></div></div>

@if(_loaded){
<!-- 计价方式选择区 -->
<div class="cost-method-banner">
<div class="method-info"><i class="fas fa-calculator"></i><div><h4>出库成本计价规则</h4><p>当前: <strong>@GetMethodLabel(_costMethod)</strong></p></div></div>
@if(_canEdit){
<div class="cost-method-selector"><select @bind="_costMethod"><option value="FIFO">FIFO 先进先出</option><option value="WEIGHTED">移动加权平均</option><option value="STANDARD">标准成本法</option></select><button class="btn-save" @onclick="SaveCostMethod">保存</button></div>
}
</div>
@if(!string.IsNullOrEmpty(_msg)){<div class="alert @(_msgType=="err"?"alert-error":"alert-success")">@_msg</div>}
<!-- Tab导航 -->
<div class="tab-nav">
<a class="tab-link @(_tab=="products"?"active":"")" @onclick='()=>SwitchTab("products")' @onclick:preventDefault><i class="fas fa-boxes"></i> 商品成本维护</a>
<a class="tab-link @(_tab=="variance"?"active":"")" @onclick='()=>SwitchTab("variance")' @onclick:preventDefault><i class="fas fa-exclamation-triangle"></i> 成本异动监控</a>
<a class="tab-link @(_tab=="history"?"active":"")" @onclick='()=>SwitchTab("history")' @onclick:preventDefault><i class="fas fa-history"></i> 成本变更历史</a>
<a class="tab-link @(_tab=="chain"?"active":"")" @onclick='()=>SwitchTab("chain")' @onclick:preventDefault><i class="fas fa-project-diagram"></i> 成本传导链</a>
</div>
<!-- Tab内容 -->
@switch(_tab){
case "products":
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>商品名称</th><th>类型</th><th>单位成本</th><th>BOM成本</th><th>成本项数</th><th>操作</th></tr></thead><tbody>
@foreach(var p in _productItems){<tr><td>#@p.ProductId</td><td>@p.ProductName</td><td>@p.ProductType</td><td class="cost-value">¥@p.UnitCost.ToString("N2")</td><td class="cost-value">¥@p.BomCost.ToString("N2")</td><td>@p.CostItemCount</td><td>@if(_canEdit){<button class="btn-primary" style="padding:6px 16px;font-size:12px;" @onclick='()=>OpenCostModal(p.ProductId,p.ProductName)'>编辑</button>}</td></tr>}
</tbody></table></div>
@RenderPagination(_productTotalPages);
break;
case "variance":
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>商品名称</th><th>上月成本</th><th>本月成本</th><th>变动额</th><th>变动率</th><th>状态</th><th>归因备注</th></tr></thead><tbody>
@foreach(var v in _varianceItems){var cls=Math.Abs(v.VarianceRate)>5?"warning-row":"";var dirIcon=v.VarianceRate>0?"fa-arrow-up":v.VarianceRate<0?"fa-arrow-down":"fa-minus";var dirCls=v.VarianceRate>0?"variance-up":v.VarianceRate<0?"variance-down":"";<tr class="@cls"><td>#@v.ProductId</td><td>@v.ProductName</td><td class="cost-value">¥@v.PreviousCost.ToString("N2")</td><td class="cost-value">¥@v.CurrentCost.ToString("N2")</td><td class="cost-value @dirCls"><i class="fas @dirIcon"></i> ¥@Math.Abs(v.Variance).ToString("N2")</td><td class="cost-value @dirCls">@(v.VarianceRate>=0?"+":"")@v.VarianceRate.ToString("F1")%</td><td><span class="status-badge @(Math.Abs(v.VarianceRate)>5?"status-warning":"status-normal")">@(Math.Abs(v.VarianceRate)>5?"异动":"正常")</span></td><td>@if(_canEdit){<div style="display:flex;gap:6px;align-items:center;"><input class="note-input" @bind="v.Note" placeholder="如:采购涨价/物流涨价" /><button class="btn-note" title="保存" @onclick="()=>SaveVarianceNote(v)"><i class="fas fa-save"></i></button></div>}else{<span style="color:#888;">@(string.IsNullOrEmpty(v.Note)?"-":v.Note)</span>}</td></tr>}
</tbody></table></div>
@RenderPagination(10);
break;
case "history":
<div class="table-container"><table class="orders-table"><thead><tr><th>时间</th><th>商品</th><th>成本类型</th><th>成本项</th><th>单价</th><th>数量</th><th>金额</th><th>操作人</th></tr></thead><tbody>
@foreach(var l in _historyItems){<tr><td>@(l.CreatedAt?.ToString("yyyy-MM-dd HH:mm")??"-")</td><td>@l.ProductName</td><td><span class="status-badge status-normal">@GetCostTypeLabel(l.CostType)</span></td><td>@(l.CostName??"-")</td><td class="cost-value">¥@l.UnitCost.ToString("N2")</td><td>@l.Quantity</td><td class="cost-value" style="color:#00bcd4;">¥@l.TotalCost.ToString("N2")</td><td>@(string.IsNullOrEmpty(l.CreatedBy)?"系统":l.CreatedBy)</td></tr>}
@if(!_historyItems.Any()){<tr><td colspan="8" style="text-align:center;color:#666;padding:40px;">暂无成本变更记录</td></tr>}
</tbody></table></div>
@RenderPagination(_historyTotalPages);
break;
case "chain":
@if(_canEdit){
<div style="display:flex;gap:15px;margin-bottom:25px;flex-wrap:wrap;align-items:center;">
<button class="btn-primary" disabled="@_chainBusy" @onclick="RunAutoCalcProducts"><i class="fas fa-calculator"></i> 自动计算全部产品成本</button>
<button class="btn-primary" disabled="@_chainBusy" @onclick="RunAutoCalcOrders"><i class="fas fa-receipt"></i> 自动更新全部订单利润</button>
@if(_chainBusy){<span style="color:#ffa726;"><i class="fas fa-spinner fa-spin"></i> 处理中...</span>}
</div>
}
<div class="chain-panel">
<h4 class="chain-title"><i class="fas fa-project-diagram"></i> 成本自动传导链路</h4>
<div class="chain-flow">
<div class="chain-node" style="border-top-color:#4CAF50;"><i class="fas fa-truck-loading" style="color:#4CAF50;"></i><h5>① 采购原料</h5><p>RawMaterialInventory</p><div class="chain-note-box">原料单价 → 加权成本</div></div>
<div class="chain-arrow"><i class="fas fa-arrow-right"></i></div>
<div class="chain-node" style="border-top-color:#2196F3;"><i class="fas fa-flask" style="color:#2196F3;"></i><h5>② 香调/基香</h5><p>RecipeAccords/NoteIngredients</p><div class="chain-note-box">配比 × 单价</div></div>
<div class="chain-arrow"><i class="fas fa-arrow-right"></i></div>
<div class="chain-node" style="border-top-color:#FF9800;"><i class="fas fa-box" style="color:#FF9800;"></i><h5>③ 产品BOM</h5><p>ProductNoteRatios</p><div class="chain-note-box">香调成本 × 配比 + 瓶身</div></div>
<div class="chain-arrow"><i class="fas fa-arrow-right"></i></div>
<div class="chain-node" style="border-top-color:#9C27B0;"><i class="fas fa-shopping-cart" style="color:#9C27B0;"></i><h5>④ 销售订单</h5><p>Orders.CostAmount</p><div class="chain-note-box">售价 − 成本 − 运费</div></div>
</div>
</div>
@if(_costSummary!=null){
<div class="stat-grid">
<div class="stat-card"><div class="stat-label">产品总数</div><div class="stat-value">@_costSummary.TotalProducts</div><div class="stat-sub" style="color:#4CAF50;">已更新成本: @_costSummary.UpdatedProducts</div></div>
<div class="stat-card"><div class="stat-label">有效订单</div><div class="stat-value">@_costSummary.TotalOrders</div><div class="stat-sub" style="color:#9C27B0;">已算利润: @_costSummary.UpdatedOrders</div></div>
<div class="stat-card"><div class="stat-label">原料缓存</div><div class="stat-value">@_costSummary.CachedMaterials</div><div class="stat-sub">加权批次: @_costSummary.CachedBatchCosts</div></div>
<div class="stat-card"><div class="stat-label">上次刷新</div><div class="stat-value" style="font-size:16px;">@(_costSummary.LastUpdate?.ToString("MM-dd HH:mm")??"—")</div><div class="stat-sub">点击上方按钮触发</div></div>
</div>
}
<h4 class="section-h"><i class="fas fa-list"></i> 香调(Note)成本明细</h4>
<div class="table-container"><table class="orders-table"><thead><tr><th>NoteID</th><th>香调名称</th><th>类型</th><th>自动计算成本</th><th>状态</th></tr></thead><tbody>
@foreach(var n in _chainNotes){var nc=_noteCosts.GetValueOrDefault(n.NoteId,0m);<tr><td>@n.NoteId</td><td><strong>@n.NoteName</strong></td><td><span style="color:#888;">@n.NoteType</span></td><td class="cost-value">¥@nc.ToString("N4")</td><td><span class="status-badge @(nc>0?"status-normal":"status-warning")">@(nc>0?"已传导":"待核算")</span></td></tr>}
@if(!_chainNotes.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:30px;">暂无启用香调</td></tr>}
</tbody></table></div>
<h4 class="section-h"><i class="fas fa-boxes"></i> 产品成本构成</h4>
<div class="table-container"><table class="orders-table"><thead><tr><th>商品</th><th>类型</th><th>BOM成本</th><th>采购成本</th><th>包装成本</th><th>其他</th><th>单位总成本</th></tr></thead><tbody>
@foreach(var c in _chainItems){<tr><td>@c.ProductName</td><td>@c.ProductType</td><td class="cost-value">¥@c.BomItems.ToString("N2")</td><td class="cost-value">¥@c.PurchaseItems.ToString("N2")</td><td class="cost-value">¥@c.PackagingItems.ToString("N2")</td><td class="cost-value">¥@c.OtherItems.ToString("N2")</td><td class="cost-value" style="color:#00bcd4;">¥@c.UnitCost.ToString("N2")</td></tr>}
</tbody></table></div>
break;
}
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@if(_showModal){
<div class="modal-overlay" @onclick="CloseModal"><div class="modal-content" @onclick:stopPropagation="true"><div class="modal-header"><h3>编辑成本 - @_editProductName</h3><button class="modal-close" @onclick="CloseModal"><i class="fas fa-times"></i></button></div><div class="modal-body">
@foreach(var item in _editItems){
var idx = _editItems.IndexOf(item);
<div class="cost-item" style="background:#1a1a2e;border:1px solid #3a3a4a;border-radius:8px;padding:15px;margin-bottom:15px;"><div class="cost-item-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;"><span class="cost-item-title" style="font-weight:600;color:#00bcd4;">成本项 #@(idx+1)</span><button class="btn-danger" @onclick='()=>RemoveCostItem(idx)'>移除</button></div>
<div class="form-row" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;"><div class="form-group"><label>类型</label><select @bind="item.CostType"><option value="BOM">BOM材料</option><option value="Purchase">采购</option><option value="Packaging">包装</option><option value="Other">其他</option></select></div><div class="form-group"><label>名称</label><input @bind="item.CostName" /></div><div class="form-group"><label>单价</label><input type="number" step="0.01" @bind="item.UnitCost" /></div><div class="form-group"><label>数量</label><input type="number" step="0.01" @bind="item.Quantity" /></div></div></div>
}
<button class="btn-primary" style="width:100%;" @onclick="AddCostItem">+ 添加成本项</button>
</div><div class="modal-footer"><button class="btn-secondary" @onclick="CloseModal">取消</button><button class="btn-save" @onclick="SaveProductCosts">保存</button></div></div></div>
}

<style>
.page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}
.page-title{font-size:24px;color:#fff;margin:0;display:flex;align-items:center;gap:10px;}
.breadcrumb{font-size:13px;color:#888;}
.cost-method-banner{background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:20px;margin-bottom:25px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px;}
.method-info{display:flex;align-items:center;gap:15px;}
.method-info i{font-size:28px;color:#ffa726;}
.method-info h4{margin:0;color:#e0e0e0;font-size:16px;}
