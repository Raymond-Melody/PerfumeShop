@@media(max-width:768px){.form-row{grid-template-columns:repeat(2,1fr);}.cost-method-banner{flex-direction:column;}}
</style>

@code {
    private bool _loaded, _canEdit;
    private string _tab = "products", _costMethod = "FIFO", _msg = "", _msgType = "";
    private int _page = 1; private const int PageSize = 20;
    private int _productTotalPages = 1;
    private List<FinanceRepository.ProductCostSummary> _productItems = new();
    private List<FinanceRepository.CostVarianceRow> _varianceItems = new();
    private List<FinanceRepository.CostHistoryRow> _historyItems = new();
    private int _historyTotalPages = 1;
    private List<FinanceRepository.CostChainRow> _chainItems = new();
    private CostSummaryDto? _costSummary;
    private List<FragranceNote> _chainNotes = new();
    private Dictionary<int,decimal> _noteCosts = new();
    private bool _chainBusy;

    protected override async Task OnInitializedAsync() {
        try{
            var auth = await AuthState.GetAuthenticationStateAsync();
            var rc = auth.User.FindFirst("RoleCode")?.Value;
            _canEdit = rc == "FIN_MANAGER" || rc == "SUPER_ADMIN";
            _costMethod = await FinRepo.GetCostMethodAsync();
            await LoadTabData();
            _loaded = true;
        }catch{_loaded=true;}
    }

    string GetMethodLabel(string m) => m switch { "FIFO" => "先进先出法", "WEIGHTED" => "移动加权平均法", "STANDARD" => "标准成本法", _ => m };

    string GetCostTypeLabel(string? t) => t switch { "BOM" => "BOM材料", "Purchase" => "采购", "Packaging" => "包装", "Other" => "其他", _ => t ?? "-" };

    async Task GoToPage(int p) { if(p < 1) p = 1; _page = p; await LoadTabData(); }

    async Task SwitchTab(string t) { _tab = t; _page = 1; await LoadTabData(); }

    async Task LoadTabData() {
        try {
            switch(_tab) {
                case "products":
                    var total = await FinRepo.GetProductCountAsync();
                    _productTotalPages = (int)Math.Ceiling(total / (double)PageSize);
                    if(_page > _productTotalPages) _page = _productTotalPages;
                    if(_page < 1) _page = 1;
                    _productItems = await FinRepo.GetProductCostSummariesAsync(_page, PageSize);
                    break;
                case "variance":
                    _varianceItems = await FinRepo.GetCostVarianceAsync(_page, PageSize);
                    break;
                case "history":
                    var htotal = await FinRepo.GetCostHistoryCountAsync();
                    _historyTotalPages = (int)Math.Ceiling(htotal / (double)PageSize);
                    if(_page > _historyTotalPages) _page = _historyTotalPages;
                    if(_page < 1) _page = 1;
                    _historyItems = await FinRepo.GetCostChangeHistoryAsync(_page, PageSize);
                    break;
                case "chain":
                    await LoadChainData();
                    break;
            }
        } catch { }
    }

    async Task SaveCostMethod() {
        try{ await FinRepo.SaveCostMethodAsync(_costMethod); _msg="计价规则已保存"; _msgType="ok"; }
        catch{ _msg="保存失败"; _msgType="err"; }
    }

    // ===== 成本传导链（引擎） =====
    async Task LoadChainData() {
        _chainItems = await FinRepo.GetCostChainAsync();
        try { _chainNotes = await FinRepo.GetActiveFragranceNotesAsync(); } catch { _chainNotes = new(); }
        try { _costSummary = await CostEngine.GetCostSummaryAsync(); } catch { _costSummary = null; }
        try { await CostEngine.PreloadAllCostDataAsync(); } catch { }
        _noteCosts = new();
        foreach(var n in _chainNotes){ try { _noteCosts[n.NoteId] = await CostEngine.GetCachedNoteCostAsync(n.NoteId); } catch { _noteCosts[n.NoteId] = 0m; } }
    }

    async Task RunAutoCalcProducts() {
        if(_chainBusy) return; _chainBusy=true; _msg="";
        try { var n = await CostEngine.UpdateAllProductCostsAsync(); CostEngine.ClearCache(); await LoadChainData(); _msg=$"已自动计算 {n} 个产品的 BOM/单位成本"; _msgType="ok"; }
        catch(Exception ex){ _msg="计算失败: "+ex.Message; _msgType="err"; }
        finally { _chainBusy=false; }
    }

    async Task RunAutoCalcOrders() {
        if(_chainBusy) return; _chainBusy=true; _msg="";
        try { await CostEngine.UpdateAllOrderCostsAsync(); CostEngine.ClearCache(); await LoadChainData(); _msg="已自动更新全部有效订单的成本与利润"; _msgType="ok"; }
        catch(Exception ex){ _msg="更新失败: "+ex.Message; _msgType="err"; }
        finally { _chainBusy=false; }
    }

    async Task SaveVarianceNote(FinanceRepository.CostVarianceRow v) {
        try { await FinRepo.SaveVarianceNoteAsync(v.ProductId, v.Note ?? ""); _msg="归因备注已保存"; _msgType="ok"; }
        catch { _msg="备注保存失败"; _msgType="err"; }
    }

    RenderFragment RenderPagination(int totalPages) => builder => {
        if(totalPages <= 1) return;
        builder.OpenElement(0,"div"); builder.AddAttribute(1,"class","pagination");
        builder.OpenElement(2,"button"); builder.AddAttribute(3,"disabled",_page<=1); builder.AddAttribute(4,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(1))); builder.AddContent(5,"首页"); builder.CloseElement();
        builder.OpenElement(6,"button"); builder.AddAttribute(7,"disabled",_page<=1); builder.AddAttribute(8,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(_page-1))); builder.AddContent(9,"上一页"); builder.CloseElement();
        builder.OpenElement(10,"button"); builder.AddAttribute(11,"class","current"); builder.AddContent(12,$"{_page}/{totalPages}"); builder.CloseElement();
        builder.OpenElement(13,"button"); builder.AddAttribute(14,"disabled",_page>=totalPages); builder.AddAttribute(15,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(_page+1))); builder.AddContent(16,"下一页"); builder.CloseElement();
        builder.OpenElement(17,"button"); builder.AddAttribute(18,"disabled",_page>=totalPages); builder.AddAttribute(19,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(totalPages))); builder.AddContent(20,"末页"); builder.CloseElement();
        builder.CloseElement();
    };

    // ===== 成本编辑弹窗 =====
    bool _showModal; int _editProductId; string _editProductName=""; List<CostEditItem> _editItems=new();
    class CostEditItem { public string CostType="BOM",CostName=""; public decimal UnitCost; public double Quantity=1; public string EffectiveDate=DateTime.Today.ToString("yyyy-MM-dd"); }

    async Task OpenCostModal(int pid, string pname) {
        _editProductId = pid; _editProductName = pname; _showModal = true;
        var existing = await FinRepo.GetProductCostItemsAsync(pid);
        _editItems = existing.Select(e => new CostEditItem{CostType=e.CostType??"BOM",CostName=e.CostName??"",UnitCost=e.UnitCost??0,Quantity=e.Quantity??1,EffectiveDate=e.EffectiveDate?.ToString("yyyy-MM-dd")??DateTime.Today.ToString("yyyy-MM-dd")}).ToList();
        if(!_editItems.Any()) AddCostItem();
    }
    void AddCostItem() => _editItems.Add(new());
    void RemoveCostItem(int i) => _editItems.RemoveAt(i);
    void CloseModal() { _showModal = false; }

    async Task SaveProductCosts() {
        var costs = _editItems.Where(x=>!string.IsNullOrWhiteSpace(x.CostName)).Select(x=>new ProductCost{
            CostType=x.CostType,CostName=x.CostName,UnitCost=x.UnitCost,Quantity=x.Quantity,
            TotalCost=(decimal)(x.UnitCost * (decimal)x.Quantity),EffectiveDate=DateTime.TryParse(x.EffectiveDate,out var d)?d:DateTime.Today
        }).ToList();
        try { await FinRepo.SaveProductCostsAsync(_editProductId, costs); _msg="成本已保存"; _msgType="ok"; _showModal=false; }
        catch { _msg="保存失败"; _msgType="err"; }
    }
}
