.cost-method-selector select{padding:10px 15px;border:2px solid #3a3a4a;border-radius:8px;background:#1a1a2e;color:#e0e0e0;font-size:14px;min-width:180px;}
.cost-method-selector select:focus{border-color:#00bcd4;outline:none;}
.btn-save{background:linear-gradient(135deg,#00bcd4,#00838f);color:#fff;border:none;padding:10px 24px;border-radius:8px;font-size:14px;cursor:pointer;}
.btn-save:hover{opacity:0.9;}
.tab-nav{display:flex;border-bottom:2px solid #3a3a4a;margin-bottom:25px;}
