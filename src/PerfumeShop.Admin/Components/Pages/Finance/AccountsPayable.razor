@page "/admin/finance/accounts-payable"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.finance")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories
@inject PerfumeShopContext Db
@inject FinanceRepository FinRepo

<PageTitle>应付账款</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-file-invoice-dollar" style="color:#00bcd4;"></i> 应付账款</h2><div class="breadcrumb"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>应付账款</span></div></div>
@if(_loaded){
<div class="stats-row"><div class="stat-card"><div class="stat-value">@_totalCount</div><div class="stat-label">应付总数</div></div>
<div class="stat-card"><div class="stat-value" style="color:#F44336;">¥@_totalAmount.ToString("N0")</div><div class="stat-label">未付金额</div></div>
<div class="stat-card"><div class="stat-value" style="color:#4CAF50;">¥@_paidAmount.ToString("N0")</div><div class="stat-label">已付金额</div></div></div>
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>供应商</th><th>金额</th><th>已付</th><th>余额</th><th>到期日</th><th>状态</th></tr></thead><tbody>
@foreach(var a in _items){<tr class="@(a.DueDate<DateTime.Today&&a.Status!="Paid"?"warning-row":"")"><td>#@a.PayableId</td><td>@(a.SupplierName??"-")</td><td>¥@((a.Amount??0).ToString("N2"))</td><td>¥@((a.PaidAmount??0).ToString("N2"))</td><td>¥@(((a.Amount??0)-(a.PaidAmount??0)).ToString("N2"))</td><td>@(a.DueDate?.ToString("yyyy-MM-dd")??"-")</td><td>@(a.Status??"-")</td></tr>}
@if(!_items.Any()){<tr><td colspan="7" style="text-align:center;color:#666;padding:40px;">暂无应付记录</td></tr>}
</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

<style>

.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}.stat-value{font-size:26px;font-weight:bold;}.stat-label{font-size:13px;color:#888;margin-top:4px;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}.orders-table{width:100%;border-collapse:collapse;}.orders-table th{background:rgba(0,188,212,0.1);color:#00bcd4;padding:14px 16px;font-size:13px;}.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;}.warning-row{background:rgba(244,67,54,0.1)!important;}
</style>

@code{
private bool _loaded; private int _totalCount; private decimal _totalAmount,_paidAmount; private List<PerfumeShop.Data.Models.AccountsPayable> _items=new();
protected override async Task OnInitializedAsync(){try{
_items=await Db.AccountsPayables.AsNoTracking().OrderByDescending(a=>a.PayableId).Take(50).ToListAsync();
_totalCount=_items.Count;_totalAmount=_items.Where(a=>a.Status!="Paid").Sum(a=>(a.Amount??0)-(a.PaidAmount??0));_paidAmount=_items.Where(a=>a.Status=="Paid").Sum(a=>a.PaidAmount??0);
_loaded=true;}catch{_loaded=true;}}
}
