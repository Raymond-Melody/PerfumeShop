@page "/admin/finance"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories
@inject PerfumeShopContext Db
@inject FinanceRepository FinRepo
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState

<PageTitle>财务概览</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-chart-line" style="color:#00bcd4;"></i> 财务概览</h2><div class="breadcrumb"><a href="/admin/finance" style="color:#00bcd4;text-decoration:none;">财务中心</a> / <span>概览</span></div></div>
@if(_loaded){
<!-- KPI卡片 -->
<div class="kpi-section"><div class="kpi-grid">
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon revenue"><i class="fas fa-yen-sign"></i></div><div class="kpi-label">总营收</div></div><div class="kpi-value">¥@_totalRevenue.ToString("N0")</div><div class="kpi-sub">已付款订单总额</div></div>
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon profit"><i class="fas fa-wallet"></i></div><div class="kpi-label">总利润</div></div><div class="kpi-value">¥@_totalProfit.ToString("N0")</div><div class="kpi-sub">营收 - 成本 - 退款</div></div>
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon margin"><i class="fas fa-percentage"></i></div><div class="kpi-label">利润率</div></div><div class="kpi-value @_marginClass">@_profitMargin.ToString("F1")%</div><div class="kpi-sub"><i class="fas @_marginIcon" style="color:@_marginColor;"></i> @_marginText</div></div>
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon recon"><i class="fas fa-balance-scale"></i></div><div class="kpi-label">待对账</div></div><div class="kpi-value">@_pendingRecon</div><div class="kpi-sub">未匹配/未解决记录</div></div>
</div></div>
<!-- 图表区域 -->
<div class="chart-section" style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:30px;">
<div class="kpi-card"><div class="section-title" style="margin-bottom:15px;font-size:18px;color:#fff;"><i class="fas fa-chart-line" style="color:#4CAF50;"></i> 月度营收趋势</div><div style="position:relative;height:300px;"><canvas id="revenueChart"></canvas></div></div>
<div class="kpi-card"><div class="section-title" style="margin-bottom:15px;font-size:18px;color:#fff;"><i class="fas fa-chart-pie" style="color:#FF9800;"></i> 品类销售占比</div><div style="position:relative;height:300px;"><canvas id="categoryChart"></canvas></div></div></div>
<!-- 供应链对接：库存价值 -->
<div class="kpi-section"><div class="section-title" style="font-size:18px;color:#fff;margin-bottom:20px;"><i class="fas fa-link" style="color:#00bcd4;"></i> 供应链对接</div><div class="kpi-grid">
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon" style="background:linear-gradient(135deg,#FF9800,#F57C00);"><i class="fas fa-cubes"></i></div><div class="kpi-label">原材料库存价值</div></div><div class="kpi-value">¥@_invRawValue.ToString("N0")</div><div class="kpi-sub">RawMaterialInventory</div></div>
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon" style="background:linear-gradient(135deg,#9C27B0,#7B1FA2);"><i class="fas fa-wine-bottle"></i></div><div class="kpi-label">香调库存价值</div></div><div class="kpi-value">¥@_invNoteValue.ToString("N0")</div><div class="kpi-sub">NoteInventory</div></div>
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon" style="background:linear-gradient(135deg,#2196F3,#1976D2);"><i class="fas fa-box"></i></div><div class="kpi-label">成品库存价值</div></div><div class="kpi-value">¥@_invProductValue.ToString("N0")</div><div class="kpi-sub">ProductInventory</div></div>
<div class="kpi-card"><div class="kpi-header"><div class="kpi-icon" style="background:linear-gradient(135deg,#4CAF50,#388E3C);"><i class="fas fa-chart-pie"></i></div><div class="kpi-label">库存总价值</div></div><div class="kpi-value">¥@_totalInvValue.ToString("N0")</div><div class="kpi-sub">应付款 @_pendingPayable 单 | 应收款 @_pendingReceivable 单</div></div>
</div></div>
<!-- 快捷入口 -->
<div class="quick-section" style="margin-bottom:30px;"><div class="section-title" style="font-size:18px;color:#fff;margin-bottom:20px;"><i class="fas fa-th-large" style="color:#00bcd4;"></i> 快捷入口</div><div class="quick-grid">
<div class="quick-column"><div class="column-header"><i class="fas fa-cogs" style="color:#2196F3;"></i> 财务中台</div>
<a href="/admin/finance/cost-management" class="quick-item"><div class="quick-item-icon blue"><i class="fas fa-coins"></i></div><div class="quick-item-content"><div class="quick-item-title">成本管理</div><div class="quick-item-desc">商品成本录入与核算</div></div></a>
<a href="/admin/finance/expense-allocation" class="quick-item"><div class="quick-item-icon green"><i class="fas fa-calculator"></i></div><div class="quick-item-content"><div class="quick-item-title">费用分摊</div><div class="quick-item-desc">间接费用分摊计算</div></div></a>
<a href="/admin/finance/reconciliation" class="quick-item"><div class="quick-item-icon purple"><i class="fas fa-balance-scale"></i></div><div class="quick-item-content"><div class="quick-item-title">对账中心</div><div class="quick-item-desc">收支对账与差异处理</div></div></a></div>
<div class="quick-column"><div class="column-header"><i class="fas fa-wallet" style="color:#4CAF50;"></i> 资金台账</div>
<a href="/admin/finance/fund-dashboard" class="quick-item"><div class="quick-item-icon green"><i class="fas fa-wallet"></i></div><div class="quick-item-content"><div class="quick-item-title">资金看板</div><div class="quick-item-desc">账户余额与资金流向</div></div></a>
<a href="/admin/finance/transactions" class="quick-item"><div class="quick-item-icon blue"><i class="fas fa-exchange-alt"></i></div><div class="quick-item-content"><div class="quick-item-title">流水管理</div><div class="quick-item-desc">资金流水查询与导出</div></div></a></div>
<div class="quick-column"><div class="column-header"><i class="fas fa-chart-pie" style="color:#FF9800;"></i> 报表分析</div>
<a href="/admin/finance/profit-report" class="quick-item"><div class="quick-item-icon orange"><i class="fas fa-chart-line"></i></div><div class="quick-item-content"><div class="quick-item-title">经营利润表</div><div class="quick-item-desc">月度/季度利润分析</div></div></a>
<a href="/admin/finance/product-analysis" class="quick-item"><div class="quick-item-icon teal"><i class="fas fa-box-open"></i></div><div class="quick-item-content"><div class="quick-item-title">单品分析</div><div class="quick-item-desc">单品盈利与成本分析</div></div></a>
<a href="/admin/finance/marketing-stats" class="quick-item"><div class="quick-item-icon purple"><i class="fas fa-bullhorn"></i></div><div class="quick-item-content"><div class="quick-item-title">营销统计</div><div class="quick-item-desc">营销投入产出分析</div></div></a>
<a href="/admin/finance/budget-management" class="quick-item"><div class="quick-item-icon red"><i class="fas fa-chart-pie"></i></div><div class="quick-item-content"><div class="quick-item-title">预算管理</div><div class="quick-item-desc">预算编制与执行监控</div></div></a></div>
@if(_isFinanceManager){<div class="quick-column"><div class="column-header"><i class="fas fa-shield-alt" style="color:#F44336;"></i> 管理配置</div><a href="/admin/finance/purchase-review" class="quick-item"><div class="quick-item-icon red"><i class="fas fa-clipboard-check"></i></div><div class="quick-item-content"><div class="quick-item-title">采购审核</div><div class="quick-item-desc">采购订单审核与审批</div></div></a><a href="/admin/finance/payment-config" class="quick-item"><div class="quick-item-icon blue"><i class="fas fa-credit-card"></i></div><div class="quick-item-content"><div class="quick-item-title">支付配置</div><div class="quick-item-desc">支付渠道与费率配置</div></div></a></div>}
</div></div>
<!-- 异常预警 -->
<div class="alert-section"><div class="section-title" style="font-size:18px;color:#fff;margin-bottom:20px;"><i class="fas fa-bell" style="color:#FF9800;"></i> 异常预警汇总</div><div class="alert-grid">
<div class="alert-item @(_costAlertCount>0?"warning":"normal")"><div class="alert-icon @(_costAlertCount>0?"warning":"normal")"><i class="fas fa-coins"></i></div><div class="alert-content"><div class="alert-label">成本异动预警</div><div class="alert-value @(_costAlertCount>0?"warning":"normal")">@_costAlertCount</div></div></div>
<div class="alert-item @(_reconAlertCount>0?"warning":"normal")"><div class="alert-icon @(_reconAlertCount>0?"warning":"normal")"><i class="fas fa-balance-scale"></i></div><div class="alert-content"><div class="alert-label">对账异常</div><div class="alert-value @(_reconAlertCount>0?"warning":"normal")">@_reconAlertCount</div></div></div>
<div class="alert-item @(_budgetAlertCount>0?"warning":"normal")"><div class="alert-icon @(_budgetAlertCount>0?"warning":"normal")"><i class="fas fa-chart-pie"></i></div><div class="alert-content"><div class="alert-label">预算超支预警</div><div class="alert-value @(_budgetAlertCount>0?"warning":"normal")">@_budgetAlertCount</div></div></div>
<div class="alert-item @(_fundAlertCount>0?"warning":"normal")"><div class="alert-icon @(_fundAlertCount>0?"warning":"normal")"><i class="fas fa-wallet"></i></div><div class="alert-content"><div class="alert-label">资金预警</div><div class="alert-value @(_fundAlertCount>0?"warning":"normal")">@_fundAlertCount</div></div></div>
</div></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

<style>
/* 本页特有KPI/快捷/预警样式，通用样式见 wwwroot/css/finance-dark.css */
/* KPI卡片 */
.kpi-section{margin-bottom:30px;}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.kpi-card{background:linear-gradient(135deg,#2d2d44 0%,#1e1e32 100%);border-radius:12px;padding:25px;box-shadow:0 4px 20px rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.05);transition:transform 0.2s ease,box-shadow 0.2s ease;}
.kpi-card:hover{transform:translateY(-3px);box-shadow:0 6px 25px rgba(0,0,0,0.4);}
.kpi-header{display:flex;align-items:center;margin-bottom:15px;}
.kpi-icon{width:48px;height:48px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-right:12px;}
.kpi-icon.revenue{background:linear-gradient(135deg,#4CAF50 0%,#2e7d32 100%);}
.kpi-icon.profit{background:linear-gradient(135deg,#2196F3 0%,#1565c0 100%);}
.kpi-icon.margin{background:linear-gradient(135deg,#FF9800 0%,#e65100 100%);}
.kpi-icon.recon{background:linear-gradient(135deg,#9C27B0 0%,#6a1b9a 100%);}
.kpi-label{font-size:13px;color:#888;text-transform:uppercase;letter-spacing:0.5px;}
.kpi-value{font-size:28px;font-weight:700;color:#fff;margin-top:5px;}
.kpi-sub{font-size:12px;color:#888;margin-top:8px;}
.margin-green{color:#4CAF50!important;}
.margin-yellow{color:#FFC107!important;}
.margin-red{color:#F44336!important;}
/* 快捷入口 */
.quick-section{margin-bottom:30px;}
.quick-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.quick-column{background:linear-gradient(135deg,#2d2d44 0%,#1e1e32 100%);border-radius:12px;padding:20px;border:1px solid rgba(255,255,255,0.05);}
.column-header{font-size:14px;font-weight:600;color:#fff;margin-bottom:15px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;}
.column-header i{margin-right:8px;width:20px;text-align:center;}
.quick-item{display:flex;align-items:flex-start;padding:12px;border-radius:8px;transition:all 0.2s ease;text-decoration:none;color:inherit;margin-bottom:8px;}
.quick-item:hover{background:rgba(255,255,255,0.05);}
.quick-item-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-right:12px;font-size:14px;flex-shrink:0;}
.quick-item-icon.blue{background:rgba(33,150,243,0.2);color:#2196F3;}
.quick-item-icon.green{background:rgba(76,175,80,0.2);color:#4CAF50;}
.quick-item-icon.orange{background:rgba(255,152,0,0.2);color:#FF9800;}
.quick-item-icon.purple{background:rgba(156,39,176,0.2);color:#9C27B0;}
.quick-item-icon.red{background:rgba(244,67,54,0.2);color:#F44336;}
.quick-item-icon.teal{background:rgba(0,150,136,0.2);color:#009688;}
.quick-item-content{flex:1;}
.quick-item-title{font-size:14px;font-weight:500;color:#fff;margin-bottom:3px;}
.quick-item-desc{font-size:11px;color:#888;}
/* 预警 */
.alert-section{background:linear-gradient(135deg,#2d2d44 0%,#1e1e32 100%);border-radius:12px;padding:20px;border:1px solid rgba(255,255,255,0.05);}
.alert-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:15px;}
.alert-item{display:flex;align-items:center;padding:15px;background:rgba(0,0,0,0.2);border-radius:8px;border-left:3px solid;}
.alert-item.normal{border-left-color:#4CAF50;}
.alert-item.warning{border-left-color:#F44336;animation:pulse 2s infinite;}
@@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(244,67,54,0.4);}50%{box-shadow:0 0 0 8px rgba(244,67,54,0);}}
.alert-icon{width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-right:12px;font-size:16px;}
.alert-icon.normal{background:rgba(76,175,80,0.2);color:#4CAF50;}
.alert-icon.warning{background:rgba(244,67,54,0.2);color:#F44336;}
.alert-content{flex:1;}
.alert-label{font-size:12px;color:#888;}
.alert-value{font-size:20px;font-weight:700;color:#fff;}
.alert-value.normal{color:#4CAF50;}
.alert-value.warning{color:#F44336;}
/* 响应式 */
@@media(max-width:1200px){.kpi-grid{grid-template-columns:repeat(2,1fr);}.quick-grid{grid-template-columns:1fr;}.alert-grid{grid-template-columns:repeat(2,1fr);}.chart-section{grid-template-columns:1fr!important;}}
@@media(max-width:768px){.kpi-grid{grid-template-columns:1fr;}.alert-grid{grid-template-columns:1fr;}}
</style>

@code {
    private bool _loaded;
    private decimal _totalRevenue, _totalCost, _totalRefund, _totalProfit, _profitMargin;
    private string _marginColor = "", _marginClass = "", _marginIcon = "", _marginText = "";
    private int _pendingRecon, _costAlertCount, _reconAlertCount, _budgetAlertCount, _fundAlertCount;
    private decimal _invRawValue, _invNoteValue, _invProductValue, _totalInvValue;
    private int _pendingPayable, _pendingReceivable;
    private List<FinanceRepository.MonthRevenueRow> _trendData = new();
    private List<FinanceRepository.CategorySalesRow> _categoryData = new();
    private bool _chartsRendering;
    private bool _isFinanceManager;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var roleCode = authState.User.FindFirst("RoleCode")?.Value;
            _isFinanceManager = roleCode == "FIN_MANAGER" || roleCode == "SUPER_ADMIN";
        }
        catch { }
        try
        {
            _totalRevenue = await FinRepo.GetTotalRevenueAsync();
            _totalCost = await FinRepo.GetTotalCostAsync();
            _totalRefund = await FinRepo.GetTotalRefundAsync();
            _totalProfit = _totalRevenue - _totalCost - _totalRefund;
            if (_totalRevenue > 0) _profitMargin = _totalProfit / _totalRevenue * 100;
            if (_profitMargin >= 20) { _marginColor = "#4CAF50"; _marginClass = "margin-green"; _marginIcon = "fa-check-circle"; _marginText = "健康"; }
            else if (_profitMargin >= 10) { _marginColor = "#FFC107"; _marginClass = "margin-yellow"; _marginIcon = "fa-exclamation-circle"; _marginText = "一般"; }
            else { _marginColor = "#F44336"; _marginClass = "margin-red"; _marginIcon = "fa-times-circle"; _marginText = "需关注"; }
            _pendingRecon = await FinRepo.GetPendingReconCountAsync();
            _costAlertCount = await FinRepo.GetCostAlertCountAsync();
            _reconAlertCount = await FinRepo.GetReconAlertCountAsync();
            _budgetAlertCount = await FinRepo.GetBudgetAlertCountAsync();
            _fundAlertCount = await FinRepo.GetFundAlertCountAsync();
            _invRawValue = await FinRepo.GetInventoryValueAsync("raw");
            _invNoteValue = await FinRepo.GetInventoryValueAsync("note");
            _invProductValue = await FinRepo.GetInventoryValueAsync("product");
            _totalInvValue = _invRawValue + _invNoteValue + _invProductValue;
            _pendingPayable = await FinRepo.GetPendingPayableCountAsync();
            _pendingReceivable = await FinRepo.GetPendingReceivableCountAsync();
            _trendData = await FinRepo.GetMonthlyRevenueTrendAsync();
            _categoryData = await FinRepo.GetCategorySalesAsync();
            _loaded = true;
        }
        catch { _loaded = true; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loaded && !_chartsRendering)
        {
            _chartsRendering = true;
            try
            {
                await JS.InvokeVoidAsync("financeCharts.ready");
                var labels = _trendData.Select(t => t.Label).ToArray();
                var revData = _trendData.Select(t => (double)t.RevenueWan).ToArray();
                var profData = _trendData.Select(t => (double)t.ProfitWan).ToArray();
                var catLabels = _categoryData.Select(c => c.CategoryName).ToArray();
                var catData = _categoryData.Select(c => (double)c.SalesAmount).ToArray();
                await JS.InvokeVoidAsync("financeCharts.renderBarLine", "revenueChart", labels, revData, "营收(万元)", profData, "利润(万元)");
                await JS.InvokeVoidAsync("financeCharts.renderDoughnut", "categoryChart", catLabels, catData);
            }
            catch { /* 图表渲染容错 */ }
            finally { _chartsRendering = false; }
        }
    }
}
