@page "/admin/prodcenter/prod-qc"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>质量检验</PageTitle>

<div class="ph"><h2 class="pt"><i class="fas fa-check-circle" style="color:#9C27B0;"></i> 质量检验</h2><div class="br"><a href="/admin/prodcenter" style="color:#4CAF50;text-decoration:none;">生产中心</a> / 质量检验</div></div>

@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="@(_msgErr?"alert-err":"alert-ok")">@_msg</div>}

<div class="sg"><div class="sc"><span class="n" style="color:#FF9800;">@_qcPending</span><span class="l">待检验</span></div><div class="sc"><span class="n" style="color:#4CAF50;">@_qcPassed</span><span class="l">今日通过</span></div><div class="sc"><span class="n" style="color:#f44336;">@_qcFailed</span><span class="l">未通过</span></div></div>

<div class="card"><div class="ch">检验列表</div><div class="cb"><table class="dt"><thead><tr><th>工单号</th><th>订单号</th><th>配方</th><th>计划量</th><th>状态</th><th>完成时间</th><th>操作</th></tr></thead><tbody>
@foreach(var po in _items){<tr><td><strong>@(po.WorkOrderNo??po.ProductionId.ToString())</strong></td><td>@(po.OrderId>0?"#"+po.OrderId:"-")</td><td>@(po.RecipeName??"-")</td><td>@po.PlannedQty</td><td><span class="sb @GetSCls(po.Status)">@GetSLbl(po.Status)</span></td><td style="color:#888;">@(po.CompletedAt?.ToString("yyyy-MM-dd"))</td><td>
@if(po.Status=="Completed"){<button class="btn btn-success btn-sm" @onclick="()=>OpenQCModal(po)">检验</button>}
</td></tr>}
@if(!_items.Any()){<tr><td colspan="7" class="tac tm" style="padding:40px;">暂无待检验工单</td></tr>}
</tbody></table></div></div>

}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@if(_showQC){<div class="mo" @onclick="()=>_showQC=false"><div class="mc" @onclick:stopPropagation="true"><div class="mh"><h3>质量检验 - @(_qcPo?.WorkOrderNo)</h3><button class="mcl" @onclick="()=>_showQC=false">&times;</button></div>
<div class="fg"><label>检验结果</label><select @bind="_qcResult"><option value="Pass">合格</option><option value="Fail">不合格</option></select></div>
<div class="fg"><label>备注</label><input type="text" @bind="_qcNotes" /></div>
<div class="mft"><button class="btn btn--neutral" @onclick="()=>_showQC=false">取消</button><button class="btn btn-success" @onclick="SubmitQC" disabled="@_saving">提交</button></div>
</div></div>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded,_msgErr,_saving,_showQC;string? _msg,_qcResult="Pass",_qcNotes="";ProductionOrder? _qcPo;
int _qcPending,_qcPassed,_qcFailed;List<ProductionOrder> _items=new();

protected override async Task OnInitializedAsync(){await LoadData();}

async Task LoadData(){
    try{
        _qcPending=await Db.ProductionOrders.CountAsync(p=>p.Status=="Completed");
        _qcPassed=await Db.ProductionOrders.CountAsync(p=>p.Status=="QC_Passed"&&p.QcpassedAt!=null&&p.QcpassedAt>=DateTime.Today);
        _qcFailed=await Db.ProductionOrders.CountAsync(p=>p.Status=="QC_Fail");
        _items=await Db.ProductionOrders.AsNoTracking().Where(p=>p.Status=="Completed"||p.Status=="QC_Passed"||p.Status=="QC_Fail").OrderByDescending(p=>p.UpdatedAt).Take(50).ToListAsync();
    }catch(Exception ex){_msg="加载失败: "+ex.Message;_msgErr=true;}
    _loaded=true;
}

void OpenQCModal(ProductionOrder po){_qcPo=po;_qcResult="Pass";_qcNotes="";_showQC=true;}

async Task SubmitQC(){
    if(_qcPo==null)return;_saving=true;
    try{
        var newStatus=_qcResult=="Pass"?"QC_Passed":"QC_Fail";
        await Db.Database.ExecuteSqlInterpolatedAsync($@"UPDATE ProductionOrders SET Status={newStatus},QCNotes={_qcNotes},QCPassedAt=GETDATE(),UpdatedAt=GETDATE() WHERE ProductionId={_qcPo.ProductionId}");
        await Db.Database.ExecuteSqlInterpolatedAsync($@"INSERT INTO ProductionLogs (ProductionID,Status,CreatedBy,Notes,CreatedAt) VALUES ({_qcPo.ProductionId},{newStatus},{System.Environment.UserName},{("质检"+(_qcResult=="Pass"?"通过":"不通过")+" - "+_qcNotes)},GETDATE())");
        _msg=_qcResult=="Pass"?"质检通过":"质检未通过，需返工";_msgErr=_qcResult!="Pass";
        _showQC=false;await LoadData();
    }catch(Exception ex){_msg="提交失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}

string GetSCls(string? s)=>s switch{"Completed"=>"sb-completed","QC_Passed"=>"sb-qc","QC_Fail"=>"sb-fail",_=>"sb-default"};
string GetSLbl(string? s)=>s switch{"Completed"=>"待检验","QC_Passed"=>"已通过","QC_Fail"=>"未通过",_=>s??"-"};
}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;}.sc .l{font-size:12px;color:#888;margin-top:5px;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.ch{padding:14px 20px;background:rgba(156,39,176,0.08);border-bottom:1px solid rgba(255,255,255,0.06);font-weight:600;font-size:15px;color:#e0e0e0;}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(156,39,176,0.15);color:#ce93d8;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}
.sb{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}.sb-completed{background:rgba(76,175,80,0.15);color:#81c784;}.sb-qc{background:rgba(33,150,243,0.15);color:#64b5f6;}.sb-fail{background:rgba(244,67,54,0.15);color:#e57373;}.sb-default{background:rgba(158,158,158,0.15);color:#9e9e9e;}
.alert-ok{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-err{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.mo{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}.mc{background:linear-gradient(135deg,#2d2d44,#1e1e32);width:90%;max-width:500px;padding:30px;border-radius:15px;border:1px solid rgba(255,255,255,0.06);}.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.06);}.mh h3{margin:0;font-size:18px;color:#e0e0e0;}.mcl{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.mft{display:flex;justify-content:flex-end;gap:10px;margin-top:25px;}
.fg{margin-bottom:18px;}.fg label{display:block;margin-bottom:6px;font-weight:600;color:#e0e0e0;font-size:13px;}.fg input,.fg select{width:100%;padding:10px 12px;background:#2d2d44;border:1px solid rgba(255,255,255,0.12);border-radius:6px;color:#e0e0e0;font-size:14px;}.fg input:focus,.fg select:focus{outline:none;border-color:#9C27B0;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:#fff;}.btn-success{background:#4CAF50;}.btn--neutral{background:#555;}.btn-sm{padding:6px 12px;font-size:12px;}.btn:disabled{opacity:0.6;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
