@page "/admin/prodcenter/order-production"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>订单生产</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">订单生产</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_search" Placeholder="搜索订单号..." Immediate="true" DebounceInterval="300"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect @bind-Value="_statusFilter" Placeholder="状态" Clearable="true">
            <MudSelectItem Value="@("Paid")">已付款</MudSelectItem>
            <MudSelectItem Value="@("Processing")">处理中</MudSelectItem>
            <MudSelectItem Value="@("Shipped")">已发货</MudSelectItem>
        </MudSelect>
    </MudItem>
</MudGrid>

<MudTable ServerData="@(new Func<TableState, Task<TableData<Order>>>(ServerReload))" Hover="true" Dense="true" Striped="true" RowsPerPage="15">
    <HeaderContent>
        <MudTh>订单号</MudTh><MudTh>金额</MudTh><MudTh>状态</MudTh>
        <MudTh>创建时间</MudTh><MudTh>工单数</MudTh><MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.OrderNo</MudTd>
        <MudTd>¥@context.TotalAmount.ToString("F2")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Status == "Paid" ? Color.Warning : Color.Info)">@(context.Status ?? "-")</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
        <MudTd>@_orderProdCounts.GetValueOrDefault(context.OrderId, 0)</MudTd>
        <MudTd><MudButton Size="Size.Small" Variant="Variant.Outlined" Href="@($"/admin/prodcenter/production-management?orderId={context.OrderId}")">查看工单</MudButton></MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private string _search = "", _statusFilter = "Paid";
    private Dictionary<int, int> _orderProdCounts = new();

    private async Task<TableData<Order>> ServerReload(TableState state)
    {
        var query = Db.Orders.AsNoTracking().Where(o => o.Status == "Paid" || o.Status == "Processing" || o.Status == "Shipped");
        if (!string.IsNullOrWhiteSpace(_search)) { var s = _search.Trim(); query = query.Where(o => o.OrderNo.Contains(s)); }
        if (!string.IsNullOrWhiteSpace(_statusFilter)) query = query.Where(o => o.Status == _statusFilter);
        var total = await query.CountAsync();
        var items = await query.OrderByDescending(o => o.CreatedAt).Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        var orderIds = items.Select(o => o.OrderId).ToList();
        _orderProdCounts = await Db.ProductionOrders.AsNoTracking().Where(p => orderIds.Contains(p.OrderId))
            .GroupBy(p => p.OrderId).Select(g => new { Id = g.Key, Cnt = g.Count() }).ToDictionaryAsync(x => x.Id, x => x.Cnt);
        return new TableData<Order> { TotalItems = total, Items = items };
    }
}
