@page "/admin/prodcenter/prod-reports"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>生产报表</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">生产报表</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3"><MudDatePicker @bind-Date="_startDate" Label="开始日期" DateFormat="yyyy-MM-dd" /></MudItem>
    <MudItem xs="12" sm="3"><MudDatePicker @bind-Date="_endDate" Label="结束日期" DateFormat="yyyy-MM-dd" /></MudItem>
    <MudItem xs="12" sm="2"><MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="LoadReport">生成报表</MudButton></MudItem>
</MudGrid>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">总工单</MudText><MudText Typo="Typo.h4">@_totalCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">已完成</MudText><MudText Typo="Typo.h4" Color="Color.Success">@_completedCount</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">良品率</MudText><MudText Typo="Typo.h4">@(_totalCount > 0 ? $"{_completedCount * 100.0 / _totalCount:F1}%" : "N/A")</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="3"><MudPaper Class="pa-4" Elevation="2"><MudText Typo="Typo.caption">已取消</MudText><MudText Typo="Typo.h4" Color="Color.Error">@_cancelledCount</MudText></MudPaper></MudItem>
</MudGrid>

<MudPaper Class="pa-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">产量趋势</MudText>
    <MudChart ChartType="ChartType.Line" Height="300px" InputData="@_chartData" InputLabels="@_chartLabels" />
</MudPaper>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private DateTime? _startDate = DateTime.Today.AddMonths(-1);
    private DateTime? _endDate = DateTime.Today;
    private int _totalCount, _completedCount, _cancelledCount;
    private double[] _chartData = Array.Empty<double>();
    private string[] _chartLabels = Array.Empty<string>();

    private async Task LoadReport()
    {
        var start = _startDate ?? DateTime.Today.AddMonths(-1);
        var end = (_endDate ?? DateTime.Today).AddDays(1);
        var items = await Db.ProductionOrders.AsNoTracking()
            .Where(p => p.CreatedAt >= start && p.CreatedAt < end).ToListAsync();

        _totalCount = items.Count;
        _completedCount = items.Count(p => p.Status == "Completed");
        _cancelledCount = items.Count(p => p.Status == "Cancelled");

        var grouped = items.GroupBy(p => p.CreatedAt!.Value.Date).OrderBy(g => g.Key).ToList();
        _chartLabels = grouped.Select(g => g.Key.ToString("MM-dd")).ToArray();
        _chartData = grouped.Select(g => (double)g.Count()).ToArray();
    }
}
