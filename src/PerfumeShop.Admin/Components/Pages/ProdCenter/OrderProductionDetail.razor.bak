@page "/admin/prodcenter/order-production-detail/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>工单详情</PageTitle>

@if (_po == null) { <MudProgressLinear Indeterminate="true" /> }
else
{
    <MudText Typo="Typo.h4" Class="mb-4">工单详情 #@_po.ProductionId</MudText>

    <MudGrid Class="mb-4">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-2">基本信息</MudText>
                <MudSimpleTable Dense="true">
                    <tbody>
                        <tr><td><b>工单号</b></td><td>@_po.WorkOrderNo</td></tr>
                        <tr><td><b>订单ID</b></td><td>@_po.OrderId</td></tr>
                        <tr><td><b>配方</b></td><td>@(_po.RecipeName ?? "-")</td></tr>
                        <tr><td><b>进度</b></td><td>@(_po.BottleIndex)/@(_po.TotalBottles)</td></tr>
                        <tr><td><b>状态</b></td><td><MudChip T="string" Color="@GetStatusColor(_po.Status ?? "")">@( _po.Status ?? "-")</MudChip></td></tr>
                        <tr><td><b>分配</b></td><td>@(_po.AssignedTo ?? "未分配")</td></tr>
                        <tr><td><b>优先级</b></td><td>@(_po.Priority ?? 0)</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-2">时间线</MudText>
                <MudSimpleTable Dense="true">
                    <tbody>
                        <tr><td><b>创建</b></td><td>@_po.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss")</td></tr>
                        <tr><td><b>开始</b></td><td>@(_po.StartedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                        <tr><td><b>完成</b></td><td>@(_po.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                        <tr><td><b>质检</b></td><td>@(_po.QcpassedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                        <tr><td><b>出库</b></td><td>@(_po.ShippedOutAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                        <tr><td><b>入库</b></td><td>@(_po.WarehouseInAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-2">操作日志</MudText>
        <MudTable Items="@_logs" Hover="true" Dense="true" RowsPerPage="10">
            <HeaderContent><MudTh>时间</MudTh><MudTh>状态</MudTh><MudTh>操作人</MudTh><MudTh>备注</MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.CreatedAt?.ToString("MM-dd HH:mm")</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small">@(context.Status ?? "-")</MudChip></MudTd>
                <MudTd>@(context.CreatedBy ?? "-")</MudTd>
                <MudTd>@(context.Notes ?? "-")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudStack Row="true" Class="mt-4">
        <MudButton Variant="Variant.Outlined" Href="/admin/prodcenter/production-management">返回列表</MudButton>
    </MudStack>
}

@code {
    [Parameter] public int Id { get; set; }
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private ProductionOrder? _po;
    private List<ProductionLog> _logs = new();

    protected override async Task OnParametersSetAsync()
    {
        _po = await Db.ProductionOrders.AsNoTracking().FirstOrDefaultAsync(p => p.ProductionId == Id);
        if (_po != null) _logs = await Db.ProductionLogs.AsNoTracking().Where(l => l.ProductionId == Id).OrderByDescending(l => l.CreatedAt).ToListAsync();
    }

    private Color GetStatusColor(string s) => s switch
    {
        "Pending" => Color.Warning, "InProgress" => Color.Info, "Completed" => Color.Success, "Cancelled" => Color.Error, _ => Color.Default
    };
}
