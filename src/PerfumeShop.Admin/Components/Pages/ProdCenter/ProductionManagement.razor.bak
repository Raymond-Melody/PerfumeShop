@page "/admin/prodcenter/production-management"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>生产工单管理</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">生产工单管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_search" Placeholder="搜索工单号/订单ID..." Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect @bind-Value="_statusFilter" Placeholder="状态筛选" Clearable="true">
            <MudSelectItem Value="@("Pending")">待生产</MudSelectItem>
            <MudSelectItem Value="@("InProgress")">生产中</MudSelectItem>
            <MudSelectItem Value="@("Completed")">已完成</MudSelectItem>
            <MudSelectItem Value="@("Cancelled")">已取消</MudSelectItem>
            <MudSelectItem Value="@("QC_Review")">质检中</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/prodcenter/sync-orders"
                   StartIcon="@Icons.Material.Filled.Sync">同步订单</MudButton>
    </MudItem>
</MudGrid>

<MudTable ServerData="@(new Func<TableState, Task<TableData<ProductionOrder>>>(ServerReload))"
          @ref="_table" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>工单号</MudTh>
        <MudTh>订单ID</MudTh>
        <MudTh>配方</MudTh>
        <MudTh>进度</MudTh>
        <MudTh>状态</MudTh>
        <MudTh SortBy="new SortDefinition<ProductionOrder>(nameof(ProductionOrder.CreatedAt), p => p.CreatedAt)">创建时间</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.WorkOrderNo</MudTd>
        <MudTd>@context.OrderId</MudTd>
        <MudTd>@(context.RecipeName ?? "-")</MudTd>
        <MudTd>@(context.BottleIndex)/@(context.TotalBottles)</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status ?? "")">@(context.Status ?? "-")</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                           Href="@($"/admin/prodcenter/order-production-detail/{context.ProductionId}")" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning"
                           OnClick="@(() => OpenStatusDialog(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

<MudDialog @bind-Visible="_showStatusDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small }">
    <TitleContent><MudText Typo="Typo.h6">更新状态</MudText></TitleContent>
    <DialogContent>
        <MudSelect @bind-Value="_newStatus" Label="新状态">
            <MudSelectItem Value="@("Pending")">待生产</MudSelectItem>
            <MudSelectItem Value="@("InProgress")">生产中</MudSelectItem>
            <MudSelectItem Value="@("Completed")">已完成</MudSelectItem>
            <MudSelectItem Value="@("Cancelled")">已取消</MudSelectItem>
            <MudSelectItem Value="@("QC_Review")">质检中</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showStatusDialog = false)">取消</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveStatus">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudTable<ProductionOrder>? _table;
    private string _search = "", _statusFilter = "", _newStatus = "InProgress";
    private bool _showStatusDialog;
    private ProductionOrder? _editingOrder;

    private async Task<TableData<ProductionOrder>> ServerReload(TableState state)
    {
        var query = Db.ProductionOrders.AsNoTracking().AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
        { var s = _search.Trim(); query = query.Where(p => (p.WorkOrderNo != null && p.WorkOrderNo.Contains(s)) || p.OrderId.ToString().Contains(s)); }
        if (!string.IsNullOrWhiteSpace(_statusFilter)) query = query.Where(p => p.Status == _statusFilter);
        var total = await query.CountAsync();
        var items = await query.OrderByDescending(p => p.CreatedAt).Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        return new TableData<ProductionOrder> { TotalItems = total, Items = items };
    }

    private void OpenStatusDialog(ProductionOrder po) { _editingOrder = po; _newStatus = po.Status ?? "Pending"; _showStatusDialog = true; }

    private async Task SaveStatus()
    {
        if (_editingOrder == null) return;
        var po = await Db.ProductionOrders.FirstOrDefaultAsync(p => p.ProductionId == _editingOrder.ProductionId);
        if (po != null)
        {
            po.Status = _newStatus; po.UpdatedAt = DateTime.Now;
            if (_newStatus == "InProgress") po.StartedAt = DateTime.Now;
            if (_newStatus == "Completed") po.CompletedAt = DateTime.Now;
            Db.ProductionLogs.Add(new ProductionLog { ProductionId = po.ProductionId, Status = _newStatus, Notes = "状态更新", CreatedBy = "Admin", CreatedAt = DateTime.Now });
            await Db.SaveChangesAsync();
            Snackbar.Add("状态已更新", Severity.Success);
        }
        _showStatusDialog = false;
        await _table!.ReloadServerData();
    }

    private Color GetStatusColor(string s) => s switch
    {
        "Pending" => Color.Warning, "InProgress" => Color.Info, "Completed" => Color.Success, "Cancelled" => Color.Error, "QC_Review" => Color.Secondary, _ => Color.Default
    };
}
