@page "/admin/prodcenter/packaging-inventory"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>包装物库存</PageTitle>

<div class="ph"><h2 class="pt"><i class="fas fa-box-open" style="color:#607D8B;"></i> 包装物库存</h2><div class="br"><a href="/admin/prodcenter" style="color:#4CAF50;text-decoration:none;">生产中心</a> / 包材库存</div></div>

@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="@(_msgErr?"alert-err":"alert-ok")">@_msg</div>}

<div class="sg"><div class="sc"><span class="n" style="color:#2196F3;">@_total</span><span class="l">包材种类</span></div><div class="sc"><span class="n" style="color:#f44336;">@_lowStock</span><span class="l">低库存预警</span></div><div class="sc"><span class="n" style="color:#4CAF50;">@_totalValue.ToString("N2")</span><span class="l">库存总值</span></div></div>

<div class="card"><div class="ch">包材清单</div><div class="cb"><table class="dt"><thead><tr><th>ID</th><th>编码</th><th>名称</th><th>库存量</th><th>安全库存</th><th>单价</th><th>操作</th></tr></thead><tbody>
@foreach(var p in _items){var qty=p.StockQty??0;var safety=p.SafetyStock??0;<tr class="@(qty<=0?"low":qty<=safety?"warn":"")"><td>#@p.PackagingId</td><td>@(p.ItemCode??"-")</td><td><strong>@(p.ItemName??"-")</strong></td><td>@qty.ToString("F0")<div class="sbar"><div class="sbar-f @(qty<=0?"d":qty<=safety?"w":"s")" style="width:@(safety>0?Math.Min(100,qty*100/safety):100)%;"></div></div></td><td>@safety.ToString("F0")</td><td>¥@((p.UnitPrice??0).ToString("N2"))</td><td><button class="btn btn-primary btn-sm" @onclick="()=>OpenRestock(p)">入库</button></td></tr>}
@if(!_items.Any()){<tr><td colspan="7" class="tac tm" style="padding:40px;">暂无包材数据</td></tr>}
</tbody></table></div></div>

}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@if(_showRestock){<div class="mo" @onclick="()=>_showRestock=false"><div class="mc" @onclick:stopPropagation="true"><div class="mh"><h3>包材入库 - @(_editItem?.ItemName)</h3><button class="mcl" @onclick="()=>_showRestock=false">&times;</button></div>
<div class="fg"><label>入库数量</label><input type="number" @bind="_rQty" step="1" min="1" /></div>
<div class="mft"><button class="btn btn--neutral" @onclick="()=>_showRestock=false">取消</button><button class="btn btn-primary" @onclick="DoRestock" disabled="@_saving">确认入库</button></div>
</div></div>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded,_msgErr,_saving,_showRestock;string? _msg;
int _total,_lowStock;decimal _totalValue;List<PackagingInventory> _items=new();
PackagingInventory? _editItem;decimal _rQty;

protected override async Task OnInitializedAsync(){await LoadData();}

async Task LoadData(){
    try{
        _items=await Db.PackagingInventories.AsNoTracking().OrderByDescending(p=>p.PackagingId).Take(100).ToListAsync();
        _total=await Db.PackagingInventories.CountAsync();
        _lowStock=await Db.PackagingInventories.CountAsync(p=>(p.StockQty??0)<=0||((p.StockQty??0)<=(p.SafetyStock??0)&&(p.SafetyStock??0)>0));
        _totalValue=(decimal)await Db.PackagingInventories.SumAsync(p=>(double)(p.StockQty??0)*(double)(p.UnitPrice??0));
    }catch{}
    _loaded=true;
}

void OpenRestock(PackagingInventory p){_editItem=p;_rQty=0;_showRestock=true;}

async Task DoRestock(){
    if(_editItem==null||_rQty<=0)return;_saving=true;
    try{
        await Db.PackagingInventories.Where(p=>p.PackagingId==_editItem.PackagingId).ExecuteUpdateAsync(s=>s.SetProperty(p=>p.StockQty,p=>(p.StockQty??0)+_rQty).SetProperty(p=>p.LastReplenishDate,DateTime.Now).SetProperty(p=>p.UpdatedAt,DateTime.Now));
        _msg="入库成功";_msgErr=false;_showRestock=false;await LoadData();
    }catch(Exception ex){_msg="入库失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}
}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;}.sc .l{font-size:12px;color:#888;margin-top:5px;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.ch{padding:14px 20px;background:rgba(96,125,139,0.08);border-bottom:1px solid rgba(255,255,255,0.06);font-weight:600;font-size:15px;color:#e0e0e0;}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(96,125,139,0.15);color:#b0bec5;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}tr.low td{background:rgba(244,67,54,0.06);}tr.warn td{background:rgba(255,152,0,0.04);}
.sbar{height:6px;background:rgba(255,255,255,0.1);border-radius:3px;margin-top:4px;}.sbar-f{height:100%;border-radius:3px;}.sbar-f.s{background:#4CAF50;}.sbar-f.w{background:#FF9800;}.sbar-f.d{background:#f44336;}
.alert-ok{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-err{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.mo{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}.mc{background:linear-gradient(135deg,#2d2d44,#1e1e32);width:90%;max-width:450px;padding:30px;border-radius:15px;border:1px solid rgba(255,255,255,0.06);}.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.06);}.mh h3{margin:0;font-size:18px;color:#e0e0e0;}.mcl{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.mft{display:flex;justify-content:flex-end;gap:10px;margin-top:25px;}
.fg{margin-bottom:18px;}.fg label{display:block;margin-bottom:6px;font-weight:600;color:#e0e0e0;font-size:13px;}.fg input{width:100%;padding:10px 12px;background:#2d2d44;border:1px solid rgba(255,255,255,0.12);border-radius:6px;color:#e0e0e0;font-size:14px;}.fg input:focus{outline:none;border-color:#607D8B;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:#fff;}.btn-primary{background:#2196F3;}.btn--neutral{background:#555;}.btn-sm{padding:6px 12px;font-size:12px;}.btn:disabled{opacity:0.6;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
