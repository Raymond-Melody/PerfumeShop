@page "/admin/prodcenter"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>生产中心</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">生产中心</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">总工单数</MudText>
            <MudText Typo="Typo.h4">@_totalOrders</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Warning">待生产</MudText>
            <MudText Typo="Typo.h4">@_pendingOrders</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Info">生产中</MudText>
            <MudText Typo="Typo.h4">@_inProgressOrders</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.caption" Color="Color.Success">已完成</MudText>
            <MudText Typo="Typo.h4">@_completedOrders</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">快捷操作</MudText>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/prodcenter/production-management"
                           StartIcon="@Icons.Material.Filled.List">工单管理</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" Href="/admin/prodcenter/sync-orders"
                           StartIcon="@Icons.Material.Filled.Sync">同步订单</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/admin/prodcenter/prod-scheduling"
                           StartIcon="@Icons.Material.Filled.CalendarMonth">排程</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="/admin/prodcenter/prod-reports"
                           StartIcon="@Icons.Material.Filled.Assessment">报表</MudButton>
            </MudStack>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">最近工单</MudText>
            <MudTable Items="@_recentOrders" Hover="true" Dense="true" RowsPerPage="5">
                <HeaderContent>
                    <MudTh>工单号</MudTh>
                    <MudTh>状态</MudTh>
                    <MudTh>创建时间</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.WorkOrderNo</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status ?? "")">@(context.Status ?? "-")</MudChip></MudTd>
                    <MudTd>@context.CreatedAt?.ToString("MM-dd HH:mm")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private int _totalOrders, _pendingOrders, _inProgressOrders, _completedOrders;
    private List<ProductionOrder> _recentOrders = new();

    protected override async Task OnInitializedAsync()
    {
        _totalOrders = await Db.ProductionOrders.CountAsync();
        _pendingOrders = await Db.ProductionOrders.CountAsync(p => p.Status == "Pending");
        _inProgressOrders = await Db.ProductionOrders.CountAsync(p => p.Status == "InProgress");
        _completedOrders = await Db.ProductionOrders.CountAsync(p => p.Status == "Completed");
        _recentOrders = await Db.ProductionOrders.AsNoTracking()
            .OrderByDescending(p => p.CreatedAt).Take(5).ToListAsync();
    }

    private Color GetStatusColor(string s) => s switch
    {
        "Pending" => Color.Warning, "InProgress" => Color.Info,
        "Completed" => Color.Success, "Cancelled" => Color.Error,
        "QC_Review" => Color.Secondary, _ => Color.Default
    };
}
