@page "/admin/prodcenter/product-inventory"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using ProductInvModel = PerfumeShop.Data.Models.ProductInventory

<PageTitle>成品库存</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">成品库存</MudText>

<MudTable Items="@_items" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>产品ID</MudTh><MudTh>类型</MudTh><MudTh>库存数量</MudTh>
        <MudTh>安全库存</MudTh><MudTh>单位成本</MudTh><MudTh>状态</MudTh><MudTh>更新时间</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ProductId</MudTd>
        <MudTd>@(context.StockType ?? "-")</MudTd>
        <MudTd>@(context.StockQty ?? 0)</MudTd>
        <MudTd>@(context.SafetyStock ?? 0)</MudTd>
        <MudTd>¥@((context.UnitCost ?? 0).ToString("F2"))</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@((context.StockQty ?? 0) < (context.SafetyStock ?? 0) ? Color.Error : Color.Success)">@((context.StockQty ?? 0) < (context.SafetyStock ?? 0) ? "低库存" : "正常")</MudChip></MudTd>
        <MudTd>@context.UpdatedAt?.ToString("yyyy-MM-dd")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private List<ProductInvModel> _items = new();
    protected override async Task OnInitializedAsync()
    {
        _items = await Db.ProductInventories.AsNoTracking().OrderBy(p => p.ProductId).ToListAsync();
    }
}
