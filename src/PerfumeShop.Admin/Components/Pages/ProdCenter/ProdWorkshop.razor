@page "/admin/prodcenter/prod-workshop"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>车间作业</PageTitle>

<div class="ph"><h2 class="pt"><i class="fas fa-cogs" style="color:#FF9800;"></i> 车间作业</h2><div class="br"><a href="/admin/prodcenter" style="color:#4CAF50;text-decoration:none;">生产中心</a> / 车间作业</div></div>

@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="@(_msgErr?"alert-err":"alert-ok")">@_msg</div>}

<div class="sg"><div class="sc"><span class="n" style="color:#2196F3;">@_inProgress</span><span class="l">进行中作业</span></div><div class="sc"><span class="n" style="color:#FF9800;">@_pending</span><span class="l">待开始</span></div><div class="sc"><span class="n" style="color:#4CAF50;">@_todayDone</span><span class="l">今日完成</span></div></div>

<div class="card"><div class="cb"><table class="dt"><thead><tr><th>工单号</th><th>订单号</th><th>配方</th><th>计划量</th><th>负责人</th><th>状态</th><th>开始时间</th><th>操作</th></tr></thead><tbody>
@foreach(var po in _items){<tr><td><strong>@(po.WorkOrderNo??po.ProductionId.ToString())</strong></td><td>@(po.OrderId>0?"#"+po.OrderId:"-")</td><td>@(po.RecipeName??"-")</td><td>@po.PlannedQty</td><td>@(po.AssignedTo??"-")</td><td><span class="sb @GetSCls(po.Status)">@GetSLbl(po.Status)</span></td><td style="color:#888;">@(po.StartedAt?.ToString("yyyy-MM-dd HH:mm"))</td><td>
@if(po.Status=="Pending"){<button class="btn btn-primary btn-sm" @onclick="()=>StartJob(po.ProductionId)">开始作业</button>}
else if(po.Status=="InProgress"){<button class="btn btn-success btn-sm" @onclick="()=>CompleteJob(po.ProductionId)">完成作业</button>}
</td></tr>}
@if(!_items.Any()){<tr><td colspan="8" class="tac tm" style="padding:40px;">暂无进行中作业</td></tr>}
</tbody></table></div></div>

}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded,_msgErr,_saving;string? _msg;
int _inProgress,_pending,_todayDone;List<ProductionOrder> _items=new();

protected override async Task OnInitializedAsync(){await LoadData();}

async Task LoadData(){
    try{
        _inProgress=await Db.ProductionOrders.CountAsync(p=>p.Status=="InProgress");
        _pending=await Db.ProductionOrders.CountAsync(p=>p.Status=="Pending");
        _todayDone=await Db.ProductionOrders.CountAsync(p=>p.Status=="Completed"&&p.CompletedAt!=null&&p.CompletedAt>=DateTime.Today);
        _items=await Db.ProductionOrders.AsNoTracking().Where(p=>p.Status=="Pending"||p.Status=="InProgress").OrderByDescending(p=>p.Priority).ThenBy(p=>p.CreatedAt).Take(50).ToListAsync();
    }catch(Exception ex){_msg="加载失败: "+ex.Message;_msgErr=true;}
    _loaded=true;
}

async Task UpdateStatus(int poId,string newStatus){
    _saving=true;
    try{
        string sql;if(newStatus=="InProgress")sql=$"UPDATE ProductionOrders SET Status='{newStatus}',StartedAt=GETDATE(),UpdatedAt=GETDATE() WHERE ProductionId={poId}";else if(newStatus=="Completed")sql=$"UPDATE ProductionOrders SET Status='{newStatus}',CompletedAt=GETDATE(),UpdatedAt=GETDATE() WHERE ProductionId={poId}";else sql=$"UPDATE ProductionOrders SET Status='{newStatus}',UpdatedAt=GETDATE() WHERE ProductionId={poId}";
        await Db.Database.ExecuteSqlRawAsync(sql);
        await Db.Database.ExecuteSqlInterpolatedAsync($@"INSERT INTO ProductionLogs (ProductionID,Status,CreatedBy,Notes,CreatedAt) VALUES ({poId},{newStatus},{System.Environment.UserName},{("车间作业: "+newStatus)},GETDATE())");
        _msg="操作成功";_msgErr=false;await LoadData();
    }catch(Exception ex){_msg="操作失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}

async Task StartJob(int id)=>await UpdateStatus(id,"InProgress");
async Task CompleteJob(int id)=>await UpdateStatus(id,"Completed");

string GetSCls(string? s)=>s switch{"Pending"=>"sb-pending","InProgress"=>"sb-progress","Completed"=>"sb-completed",_=>"sb-default"};
string GetSLbl(string? s)=>s switch{"Pending"=>"待开始","InProgress"=>"作业中","Completed"=>"已完成",_=>s??"-"};
}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;}.sc .l{font-size:12px;color:#888;margin-top:5px;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(255,152,0,0.15);color:#ffb74d;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}
.sb{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}.sb-pending{background:rgba(255,152,0,0.15);color:#ffb74d;}.sb-progress{background:rgba(33,150,243,0.15);color:#64b5f6;}.sb-completed{background:rgba(76,175,80,0.15);color:#81c784;}.sb-default{background:rgba(158,158,158,0.15);color:#9e9e9e;}
.alert-ok{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-err{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:#fff;}.btn-primary{background:#2196F3;}.btn-success{background:#4CAF50;}.btn-sm{padding:6px 12px;font-size:12px;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
