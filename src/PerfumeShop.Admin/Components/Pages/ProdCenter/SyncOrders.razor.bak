@page "/admin/prodcenter/sync-orders"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>订单同步</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">订单→生产工单同步</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">同步统计</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td><b>已付款待同步订单</b></td><td><MudChip T="string" Color="Color.Warning">@_pendingCount</MudChip></td></tr>
                    <tr><td><b>已有工单数</b></td><td>@_existingProdCount</td></tr>
                    <tr><td><b>上次同步</b></td><td>@(_lastSync?.ToString("yyyy-MM-dd HH:mm") ?? "无")</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">执行同步</MudText>
            <MudText Class="mb-3">将已付款但未生成工单的订单同步为生产工单（幂等操作，重复执行安全）</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Disabled="@_syncing"
                       StartIcon="@Icons.Material.Filled.Sync" OnClick="DoSync">
                @(_syncing ? "同步中..." : "开始同步")
            </MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (_result != null)
{
    <MudAlert Severity="@(_result.Success ? Severity.Success : Severity.Error)" Class="mb-4">@_result.Message</MudAlert>
}

<MudText Typo="Typo.h6" Class="mb-2">待同步订单</MudText>
<MudTable Items="@_pendingOrders" Hover="true" Dense="true" RowsPerPage="10">
    <HeaderContent><MudTh>订单号</MudTh><MudTh>金额</MudTh><MudTh>状态</MudTh><MudTh>创建时间</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.OrderNo</MudTd>
        <MudTd>¥@context.TotalAmount.ToString("F2")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Warning">@(context.Status ?? "-")</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private int _pendingCount, _existingProdCount;
    private DateTime? _lastSync;
    private bool _syncing;
    private SyncResult? _result;
    private List<Order> _pendingOrders = new();

    protected override async Task OnInitializedAsync() => await LoadStats();

    private async Task LoadStats()
    {
        var syncedIds = await Db.ProductionOrders.AsNoTracking().Where(p => p.Status != "Cancelled")
            .Select(p => p.OrderId).Distinct().ToListAsync();
        _pendingOrders = await Db.Orders.AsNoTracking()
            .Where(o => (o.Status == "Paid" || o.Status == "Processing") && !syncedIds.Contains(o.OrderId))
            .OrderBy(o => o.CreatedAt).ToListAsync();
        _pendingCount = _pendingOrders.Count;
        _existingProdCount = await Db.ProductionOrders.CountAsync();
        _lastSync = await Db.ProductionLogs.AsNoTracking().Where(l => l.CreatedBy == "SYSTEM_SYNC")
            .MaxAsync(l => (DateTime?)l.CreatedAt);
    }

    private async Task DoSync()
    {
        _syncing = true; _result = null; StateHasChanged();
        try
        {
            var syncedIds = await Db.ProductionOrders.AsNoTracking().Where(p => p.Status != "Cancelled")
                .Select(p => p.OrderId).Distinct().ToListAsync();
            var orders = await Db.Orders.Where(o => (o.Status == "Paid" || o.Status == "Processing") && !syncedIds.Contains(o.OrderId))
                .OrderBy(o => o.OrderId).ToListAsync();

            int synced = 0;
            foreach (var order in orders)
            {
                var details = await Db.OrderDetails.AsNoTracking().Where(d => d.OrderId == order.OrderId).ToListAsync();
                int idx = 0;
                foreach (var detail in details)
                {
                    for (int i = 1; i <= detail.Quantity; i++)
                    {
                        idx++;
                        var woNo = $"WO-{DateTime.Now:yyyyMMdd}-{idx:D4}";
                        bool exists = await Db.ProductionOrders.AnyAsync(p => p.WorkOrderNo == woNo && p.OrderId == order.OrderId);
                        if (!exists)
                        {
                            var po = new ProductionOrder
                            {
                                OrderId = order.OrderId, DetailId = detail.DetailId, WorkOrderNo = woNo,
                                BottleIndex = idx, TotalBottles = details.Sum(d => d.Quantity),
                                Status = "Pending", Priority = 0, CreatedAt = DateTime.Now, UpdatedAt = DateTime.Now
                            };
                            Db.ProductionOrders.Add(po); await Db.SaveChangesAsync();
                            Db.ProductionLogs.Add(new ProductionLog { ProductionId = po.ProductionId, Status = "Pending", Notes = $"同步创建 (订单{order.OrderNo})", CreatedBy = "SYSTEM_SYNC", CreatedAt = DateTime.Now });
                        }
                        synced++;
                    }
                }
                if (order.Status == "Paid") { order.Status = "Processing"; order.UpdatedAt = DateTime.Now; }
                await Db.SaveChangesAsync();
            }
            _result = new SyncResult { Success = true, Message = $"成功同步 {synced} 个工单" };
            Snackbar.Add(_result.Message, Severity.Success);
            await LoadStats();
        }
        catch (Exception ex) { _result = new SyncResult { Success = false, Message = $"同步失败: {ex.Message}" }; }
        finally { _syncing = false; }
    }

    private class SyncResult { public bool Success { get; set; } public string Message { get; set; } = ""; }
}
