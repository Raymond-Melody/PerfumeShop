@page "/admin/prodcenter/prod-warehouse"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>成品入库</PageTitle>

<div class="ph"><h2 class="pt"><i class="fas fa-warehouse" style="color:#00BCD4;"></i> 成品入库</h2><div class="br"><a href="/admin/prodcenter" style="color:#4CAF50;text-decoration:none;">生产中心</a> / 成品入库</div></div>

@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="@(_msgErr?"alert-err":"alert-ok")">@_msg</div>}

<div class="sg"><div class="sc"><span class="n" style="color:#2196F3;">@_whPending</span><span class="l">待入库</span></div><div class="sc"><span class="n" style="color:#4CAF50;">@_whCompleted</span><span class="l">已入库</span></div><div class="sc"><span class="n" style="color:#00BCD4;">@_whToday</span><span class="l">今日入库</span></div></div>

<div class="card"><div class="ch">入库管理列表</div><div class="cb"><table class="dt"><thead><tr><th>工单号</th><th>订单号</th><th>配方</th><th>计划量</th><th>状态</th><th>操作</th></tr></thead><tbody>
@foreach(var po in _items){<tr><td><strong>@(po.WorkOrderNo??po.ProductionId.ToString())</strong></td><td>@(po.OrderId>0?"#"+po.OrderId:"-")</td><td>@(po.RecipeName??"-")</td><td>@po.PlannedQty</td><td><span class="sb @GetSCls(po.Status)">@GetSLbl(po.Status)</span></td><td>
@if(po.Status=="QC_Passed"){<button class="btn btn-primary btn-sm" @onclick="()=>DoWarehouseIn(po.ProductionId)">入库</button>}
</td></tr>}
@if(!_items.Any()){<tr><td colspan="6" class="tac tm" style="padding:40px;">暂无待入库工单</td></tr>}
</tbody></table></div></div>

}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded,_msgErr,_saving;string? _msg;
int _whPending,_whCompleted,_whToday;List<ProductionOrder> _items=new();

protected override async Task OnInitializedAsync(){await LoadData();}

async Task LoadData(){
    try{
        _whPending=await Db.ProductionOrders.CountAsync(p=>p.Status=="QC_Passed");
        _whCompleted=await Db.ProductionOrders.CountAsync(p=>p.Status=="WarehouseIn"||p.Status=="ShippedOut");
        _whToday=await Db.ProductionOrders.CountAsync(p=>p.Status=="WarehouseIn"&&p.WarehouseInAt!=null&&p.WarehouseInAt>=DateTime.Today);
        _items=await Db.ProductionOrders.AsNoTracking().Where(p=>p.Status=="QC_Passed"||p.Status=="WarehouseIn"||p.Status=="ShippedOut").OrderByDescending(p=>p.UpdatedAt).Take(50).ToListAsync();
    }catch(Exception ex){_msg="加载失败: "+ex.Message;_msgErr=true;}
    _loaded=true;
}

async Task DoWarehouseIn(int poId){
    _saving=true;
    try{
        await Db.Database.ExecuteSqlInterpolatedAsync($@"UPDATE ProductionOrders SET Status={"WarehouseIn"},WarehouseInAt=GETDATE(),UpdatedAt=GETDATE() WHERE ProductionId={poId}");
        await Db.Database.ExecuteSqlInterpolatedAsync($@"INSERT INTO ProductionLogs (ProductionID,Status,CreatedBy,Notes,CreatedAt) VALUES ({poId},{"WarehouseIn"},{System.Environment.UserName},{"成品入库"},GETDATE())");
        _msg="入库成功";_msgErr=false;await LoadData();
    }catch(Exception ex){_msg="入库失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}

string GetSCls(string? s)=>s switch{"QC_Passed"=>"sb-qc","WarehouseIn"=>"sb-warehouse","ShippedOut"=>"sb-shipped",_=>"sb-default"};
string GetSLbl(string? s)=>s switch{"QC_Passed"=>"待入库","WarehouseIn"=>"已入库","ShippedOut"=>"已发货",_=>s??"-"};
}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;}
.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;}.sc .l{font-size:12px;color:#888;margin-top:5px;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.ch{padding:14px 20px;background:rgba(0,188,212,0.08);border-bottom:1px solid rgba(255,255,255,0.06);font-weight:600;font-size:15px;color:#e0e0e0;}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(0,188,212,0.15);color:#80deea;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}
.sb{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}.sb-qc{background:rgba(33,150,243,0.15);color:#64b5f6;}.sb-warehouse{background:rgba(76,175,80,0.15);color:#81c784;}.sb-shipped{background:rgba(0,188,212,0.15);color:#80deea;}.sb-default{background:rgba(158,158,158,0.15);color:#9e9e9e;}
.alert-ok{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-err{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:#fff;}.btn-primary{background:#2196F3;}.btn-sm{padding:6px 12px;font-size:12px;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
