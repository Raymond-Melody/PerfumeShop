@page "/admin/prodcenter/production-management"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.prodcenter")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PerfumeShop.Admin.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<PageTitle>生产工单管理</PageTitle>

<div class="ph"><h2 class="pt"><i class="fas fa-clipboard-list" style="color:#4CAF50;"></i> 生产工单管理</h2><div class="br"><a href="/admin/prodcenter" style="color:#4CAF50;text-decoration:none;">生产中心</a> / 工单管理</div></div>

@if(_loaded){
@if(!string.IsNullOrEmpty(_msg)){<div class="@(_msgErr?"alert-err":"alert-ok")">@_msg</div>}

<div class="sg"><div class="sc"><span class="n" style="color:#4CAF50;">@_poTotal</span><span class="l">总工单</span></div><div class="sc"><span class="n" style="color:#FF9800;">@_poPending</span><span class="l">待生产</span></div><div class="sc"><span class="n" style="color:#2196F3;">@_poProgress</span><span class="l">生产中</span></div><div class="sc"><span class="n" style="color:#888;">@_poCompleted</span><span class="l">已完成</span></div></div>

<div class="ft"><a href="/admin/prodcenter/production-management" class="ftab @(string.IsNullOrEmpty(_filterStatus)?"active":"")">全部</a><a href="/admin/prodcenter/production-management?status=Pending" class="ftab @(_filterStatus=="Pending"?"active":"")">待生产</a><a href="/admin/prodcenter/production-management?status=InProgress" class="ftab @(_filterStatus=="InProgress"?"active":"")">生产中</a><a href="/admin/prodcenter/production-management?status=Completed" class="ftab @(_filterStatus=="Completed"?"active":"")">已完成</a><button class="btn btn-primary" @onclick="OpenCreateModal" style="margin-left:auto;">+ 新建工单</button></div>

<div class="card"><div class="cb"><table class="dt"><thead><tr><th>工单号</th><th>订单号</th><th>配方名</th><th>计划量</th><th>优先级</th><th>状态</th><th>负责人</th><th>创建时间</th><th>操作</th></tr></thead><tbody>
@foreach(var po in _items){<tr><td><strong>@(po.WorkOrderNo??po.ProductionId.ToString())</strong></td><td>@(po.OrderId>0?"#"+po.OrderId:"-")</td><td>@(po.RecipeName??"-")</td><td>@po.PlannedQty</td><td>@(po.PriorityText??(po.Priority?.ToString()??"-"))</td><td><span class="sb @GetSCls(po.Status)">@GetSLbl(po.Status)</span></td><td>@(po.AssignedTo??"-")</td><td style="color:#888;">@(po.CreatedAt?.ToString("yyyy-MM-dd"))</td><td>
@if(po.Status=="Pending"){<button class="btn btn-primary btn-sm" @onclick="()=>StartProduction(po.ProductionId)">开始生产</button>}
else if(po.Status=="InProgress"){<button class="btn btn-warning btn-sm" @onclick="()=>CompleteProduction(po.ProductionId)">完成生产</button>}
</td></tr>}
@if(!_items.Any()){<tr><td colspan="9" class="tac tm" style="padding:40px;">暂无生产工单</td></tr>}
</tbody></table></div></div>

}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@if(_showCreate){<div class="mo" @onclick="()=>_showCreate=false"><div class="mc" @onclick:stopPropagation="true"><div class="mh"><h3>新建生产工单</h3><button class="mcl" @onclick="()=>_showCreate=false">&times;</button></div>
<div class="fg"><label>关联订单</label><select @bind="_cOrderId" @bind:after="()=>OnOrderChanged()"><option value="0">-- 不关联订单（独立工单）--</option>@foreach(var o in _orderOptions){<option value="@o.OrderId">@o.OrderNo - @(o.ProductName??"-")</option>}</select></div>
<div class="fg"><label>配方ID</label><input type="number" @bind="_cRecipeId" /></div>
<div class="fg"><label>产品名称</label><input type="text" @bind="_cProductName" readonly style="background:#1a1a2e;color:#888;" /></div>
<div class="fg"><label>计划产量</label><input type="number" @bind="_cQty" min="1" /></div>
<div class="fg"><label>负责人</label><input type="text" @bind="_cAssigned" placeholder="可选填负责人姓名" /></div>
<div class="fg"><label>优先级</label><select @bind="_cPriority"><option value="1">普通</option><option value="2">优先</option><option value="3">紧急</option></select></div>
<div class="fg"><label>备注</label><input type="text" @bind="_cNotes" /></div>
<div class="mft"><button class="btn btn--neutral" @onclick="()=>_showCreate=false">取消</button><button class="btn btn-primary" @onclick="HandleCreate" disabled="@_saving">创建工单</button></div>
</div></div>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
[Inject] IAdminAuditor Auditor{get;set;}=default!;
[Inject] AuthenticationStateProvider AuthState{get;set;}=default!;
[SupplyParameterFromQuery] string? status{get;set;}
bool _loaded,_msgErr,_saving,_showCreate;string? _msg,_filterStatus;
int _adminId;string _adminName="";
int _poTotal,_poPending,_poProgress,_poCompleted;
List<ProductionOrder> _items=new();
List<OrderOption> _orderOptions=new();

int _cOrderId,_cRecipeId=0,_cQty=1,_cPriority=2;string _cProductName="",_cAssigned="",_cNotes="";

protected override async Task OnInitializedAsync(){
    var st=await AuthState.GetAuthenticationStateAsync();int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value,out _adminId);_adminName=st.User.FindFirst(ClaimTypes.Name)?.Value??"";
    _filterStatus=string.IsNullOrEmpty(status)?null:status;
    await LoadData();
}

async Task LoadData(){
    try{
        var q=Db.ProductionOrders.AsQueryable();
        if(!string.IsNullOrEmpty(_filterStatus))q=q.Where(p=>p.Status==_filterStatus);
        _items=await q.AsNoTracking().OrderByDescending(p=>p.CreatedAt).Take(100).ToListAsync();
        _poTotal=await Db.ProductionOrders.CountAsync();
        _poPending=await Db.ProductionOrders.CountAsync(p=>p.Status=="Pending");
        _poProgress=await Db.ProductionOrders.CountAsync(p=>p.Status=="InProgress");
        _poCompleted=await Db.ProductionOrders.CountAsync(p=>p.Status=="Completed"||p.Status=="QC_Passed"||p.Status=="WarehouseIn");
        _orderOptions=await (from o in Db.Orders
            join oi in Db.OrderItems on o.OrderId equals oi.OrderId into oij
            from oi in oij.DefaultIfEmpty()
            join p in Db.Products on (oi!=null?oi.ProductId:null) equals p.ProductId into pj
            from p in pj.DefaultIfEmpty()
            where (o.Status=="Paid"||o.Status=="Processing")&&!Db.ProductionOrders.Any(po=>po.OrderId==o.OrderId&&po.Status!="Cancelled")
            orderby o.CreatedAt
            select new OrderOption{OrderId=o.OrderId,OrderNo=o.OrderNo??"",ProductName=p!=null?p.ProductName:null}).Take(50).ToListAsync();
    }catch(Exception ex){_msg="加载失败: "+ex.Message;_msgErr=true;}
    _loaded=true;
}

async Task UpdateStatus(int poId,string newStatus){
    _saving=true;
    try{
        string sql;if(newStatus=="InProgress")sql=$"UPDATE ProductionOrders SET Status='{newStatus}',StartedAt=GETDATE(),UpdatedAt=GETDATE() WHERE ProductionId={poId}";else if(newStatus=="Completed")sql=$"UPDATE ProductionOrders SET Status='{newStatus}',CompletedAt=GETDATE(),UpdatedAt=GETDATE() WHERE ProductionId={poId}";else sql=$"UPDATE ProductionOrders SET Status='{newStatus}',UpdatedAt=GETDATE() WHERE ProductionId={poId}";
        await Db.Database.ExecuteSqlRawAsync(sql);
        await Db.Database.ExecuteSqlInterpolatedAsync($@"INSERT INTO ProductionLogs (ProductionID,Status,CreatedBy,Notes,CreatedAt) VALUES ({poId},{newStatus},{System.Environment.UserName},{("状态更新为: "+newStatus)},GETDATE())");
        await Auditor.LogAsync(_adminId,_adminName,"生产工单状态变更","ProductionOrder",poId,null,newStatus);
        _msg="状态已更新";_msgErr=false;await LoadData();
    }catch(Exception ex){_msg="更新失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}

async Task StartProduction(int id)=>await UpdateStatus(id,"InProgress");
async Task CompleteProduction(int id)=>await UpdateStatus(id,"Completed");

void OpenCreateModal(){_cOrderId=0;_cRecipeId=0;_cProductName="";_cQty=1;_cAssigned="";_cNotes="";_cPriority=2;_showCreate=true;}
async Task OnOrderChanged(){
    if(_cOrderId==0){_cRecipeId=0;_cProductName="";_cQty=1;return;}
    try{
        var info=await (from oi in Db.OrderItems join p in Db.Products on oi.ProductId equals p.ProductId where oi.OrderId==_cOrderId select new{p.RecipeId,p.ProductName,oi.Quantity}).FirstOrDefaultAsync();
        if(info!=null){_cRecipeId=info.RecipeId??0;_cProductName=info.ProductName??"";_cQty=info.Quantity??1;}
    }catch{}
}

async Task HandleCreate(){
    if(_cQty<=0){_msg="产量必须大于0";_msgErr=true;return;}
    _saving=true;
    try{
        var workNo="PO"+DateTime.Now.ToString("yyyyMMddHHmmss");
        await Db.Database.ExecuteSqlInterpolatedAsync($@"INSERT INTO ProductionOrders (WorkOrderNo,OrderID,RecipeID,RecipeName,PlannedQty,Priority,Status,Notes,AssignedTo,CreatedAt,UpdatedAt) VALUES ({workNo},{(_cOrderId>0?_cOrderId:null)},{(_cRecipeId>0?_cRecipeId:null)},{_cProductName},{_cQty},{_cPriority},{("Pending")},{_cNotes},{_cAssigned},GETDATE(),GETDATE())");
        var newId=await Db.ProductionOrders.Where(p=>p.WorkOrderNo==workNo).Select(p=>p.ProductionId).FirstOrDefaultAsync();
        if(newId>0)await Db.Database.ExecuteSqlInterpolatedAsync($@"INSERT INTO ProductionLogs (ProductionID,Status,CreatedBy,Notes,CreatedAt) VALUES ({newId},{("Pending")},{System.Environment.UserName},{("手动创建工单")},GETDATE())");
        if(_cOrderId>0)await Db.Orders.Where(o=>o.OrderId==_cOrderId).ExecuteUpdateAsync(s=>s.SetProperty(o=>o.Status,"Processing").SetProperty(o=>o.UpdatedAt,DateTime.Now));
        await Auditor.LogAsync(_adminId,_adminName,"创建生产工单","ProductionOrder",null,workNo,$"产量{_cQty}");
        _msg="工单已创建："+workNo;_msgErr=false;_showCreate=false;await LoadData();
    }catch(Exception ex){_msg="创建失败: "+ex.Message;_msgErr=true;}
    _saving=false;await InvokeAsync(StateHasChanged);
}

string GetSCls(string? s)=>s switch{"Pending"=>"sb-pending","InProgress"=>"sb-progress","Completed"=>"sb-completed","QC_Passed"=>"sb-qc","QC_Fail"=>"sb-fail","WarehouseIn"=>"sb-warehouse",_=>"sb-default"};
string GetSLbl(string? s)=>s switch{"Pending"=>"待生产","InProgress"=>"生产中","Completed"=>"待质检","QC_Passed"=>"已质检","QC_Fail"=>"未通过","WarehouseIn"=>"已入库",_=>s??"-"};

class OrderOption{public int OrderId{get;set;}public string OrderNo{get;set;}="";public string? ProductName{get;set;}}
}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#e0e0e0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;}
.sg{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-bottom:25px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;}.sc .l{font-size:12px;color:#888;margin-top:5px;}
.ft{display:flex;gap:8px;margin-bottom:15px;align-items:center;}.ftab{padding:6px 16px;border-radius:16px;font-size:13px;text-decoration:none;color:#888;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);}.ftab:hover,.ftab.active{color:#fff;background:#4CAF50;border-color:#4CAF50;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(76,175,80,0.15);color:#81c784;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}
.sb{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}.sb-pending{background:rgba(255,152,0,0.15);color:#ffb74d;}.sb-progress{background:rgba(33,150,243,0.15);color:#64b5f6;}.sb-completed{background:rgba(76,175,80,0.15);color:#81c784;}.sb-qc{background:rgba(156,39,176,0.15);color:#ce93d8;}.sb-fail{background:rgba(244,67,54,0.15);color:#e57373;}.sb-warehouse{background:rgba(0,188,212,0.15);color:#80deea;}.sb-default{background:rgba(158,158,158,0.15);color:#9e9e9e;}
.alert-ok{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(76,175,80,0.15);color:#81c784;border:1px solid rgba(76,175,80,0.3);}.alert-err{padding:15px 20px;border-radius:8px;margin-bottom:20px;background:rgba(244,67,54,0.15);color:#e57373;border:1px solid rgba(244,67,54,0.3);}
.mo{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}.mc{background:linear-gradient(135deg,#2d2d44,#1e1e32);width:90%;max-width:550px;padding:30px;border-radius:15px;border:1px solid rgba(255,255,255,0.06);}.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.06);}.mh h3{margin:0;font-size:18px;color:#e0e0e0;}.mcl{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.mft{display:flex;justify-content:flex-end;gap:10px;margin-top:25px;}
.fg{margin-bottom:18px;}.fg label{display:block;margin-bottom:6px;font-weight:600;color:#e0e0e0;font-size:13px;}.fg input,.fg select{width:100%;padding:10px 12px;background:#2d2d44;border:1px solid rgba(255,255,255,0.12);border-radius:6px;color:#e0e0e0;font-size:14px;}.fg input:focus,.fg select:focus{outline:none;border-color:#4CAF50;}
.btn{padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:#fff;}.btn-primary{background:#2196F3;}.btn-warning{background:#FF9800;}.btn--neutral{background:#555;}.btn-sm{padding:6px 12px;font-size:12px;}.btn:disabled{opacity:0.6;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
</style>
