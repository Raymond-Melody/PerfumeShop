@page "/admin/prodcenter"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>生产概览 - 产品生产管理中心</PageTitle>

<div class="ph"><h2 class="pt"><i class="fas fa-industry" style="color:#4CAF50;"></i> 产品生产概览</h2><div class="br">工单 · 排产 · 质检 · 入库</div></div>

@if(_loaded){

<div class="stats-grid">
    <div class="sc stat-prod"><div class="n">@_poTotal</div><div class="l">生产工单</div><div class="s">待生产 @_poPending | 进行中 @_poInProgress | 已完成 @_poCompleted</div></div>
    <div class="sc stat-order"><div class="n">@_orderPending</div><div class="l">待生产订单</div><div class="s">已付款待排产</div></div>
    <div class="sc stat-warehouse"><div class="n">@_productActive</div><div class="l">在售产品</div><div class="s">总计 @_productTotal 个</div></div>
    <div class="sc stat-bottle"><div class="n">@_bottleActive</div><div class="l">瓶子款式</div><div class="s">总计 @_bottleTotal 种</div></div>
</div>

<div class="quick-section"><h3 class="section-title"><i class="fas fa-th-large" style="color:#4CAF50;"></i> 快捷入口</h3>
<div class="quick-grid">
    <a href="/admin/prodcenter/prod-scheduling" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#4CAF50,#1B5E20);"><i class="fas fa-calendar-alt"></i></div><div class="qc-title">排产调度</div><div class="qc-desc">生产计划与排期</div></a>
    <a href="/admin/prodcenter/production-management" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#2196F3,#1565C0);"><i class="fas fa-clipboard-list"></i></div><div class="qc-title">工单管理</div><div class="qc-desc">创建与跟踪工单</div></a>
    <a href="/admin/prodcenter/prod-workshop" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#FF9800,#E65100);"><i class="fas fa-cogs"></i></div><div class="qc-title">车间作业</div><div class="qc-desc">工单执行进度</div></a>
    <a href="/admin/prodcenter/prod-qc" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#9C27B0,#6A1B9A);"><i class="fas fa-clipboard-check"></i></div><div class="qc-title">质量检验</div><div class="qc-desc">QC质检记录</div></a>
    <a href="/admin/prodcenter/prod-warehouse" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#00BCD4,#00838F);"><i class="fas fa-warehouse"></i></div><div class="qc-title">成品入库</div><div class="qc-desc">入库记录</div></a>
    <a href="/admin/prodcenter/sync-orders" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#E91E63,#AD1457);"><i class="fas fa-sync"></i></div><div class="qc-title">订单追踪</div><div class="qc-desc">订单生产状态</div></a>
    <a href="/admin/prodcenter/product-inventory" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#607D8B,#37474F);"><i class="fas fa-boxes"></i></div><div class="qc-title">成品库存</div><div class="qc-desc">产品库存量</div></a>
    <a href="/admin/prodcenter/bottle-inventory" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#795548,#4E342E);"><i class="fas fa-wine-bottle"></i></div><div class="qc-title">瓶子库存</div><div class="qc-desc">瓶身备料</div></a>
    <a href="/admin/prodcenter/packaging-inventory" class="qc"><div class="qc-icon" style="background:linear-gradient(135deg,#455A64,#263238);"><i class="fas fa-box"></i></div><div class="qc-title">包材库存</div><div class="qc-desc">包装材料</div></a>
</div></div>

<div class="card"><div class="ch"><i class="fas fa-clock" style="color:#4CAF50;"></i> 近期生产工单</div><div class="cb"><table class="dt">
<thead><tr><th>工单号</th><th>订单号</th><th>产品</th><th>计划量</th><th>状态</th><th>创建时间</th></tr></thead>
<tbody>
@if(_recentPOs.Any()){@foreach(var po in _recentPOs){<tr><td><strong>#@po.WorkOrderNo</strong></td><td>@(po.OrderId>0?"#"+po.OrderId:"-")</td><td>@(po.RecipeName??"-")</td><td>@po.PlannedQty</td><td><span class="sb @GetStatusClass(po.Status)">@GetStatusLabel(po.Status)</span></td><td style="color:#888;">@(po.CreatedAt?.ToString("yyyy-MM-dd"))</td></tr>}}else{<tr><td colspan="6" class="tac tm" style="padding:40px;">暂无生产工单</td></tr>}
</tbody></table></div></div>

}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@code{
[Inject] PerfumeShopContext Db{get;set;}=default!;
bool _loaded;int _poTotal,_poPending,_poInProgress,_poCompleted,_orderPending,_productTotal,_productActive,_bottleTotal,_bottleActive;
List<ProductionOrder> _recentPOs=new();

protected override async Task OnInitializedAsync(){
    try{
        _poTotal=await Db.ProductionOrders.CountAsync();
        _poPending=await Db.ProductionOrders.CountAsync(o=>o.Status=="Pending");
        _poInProgress=await Db.ProductionOrders.CountAsync(o=>o.Status=="InProgress");
        _poCompleted=await Db.ProductionOrders.CountAsync(o=>o.Status=="Completed"||o.Status=="QC_Passed"||o.Status=="WarehouseIn");
        _orderPending=await Db.Orders.CountAsync(o=>o.Status=="Paid"||o.Status=="Processing");
        _productTotal=await Db.Products.CountAsync();
        _productActive=await Db.Products.CountAsync(p=>p.IsActive==true);
        _bottleTotal=await Db.BottleStyles.CountAsync();
        _bottleActive=await Db.BottleStyles.CountAsync(b=>b.IsActive==true);
        _recentPOs=await Db.ProductionOrders.AsNoTracking().OrderByDescending(o=>o.CreatedAt).Take(8).ToListAsync();
    }catch{}
    _loaded=true;
}

string GetStatusClass(string? s)=>s switch{"Pending"=>"sb-pending","InProgress"=>"sb-progress","Completed"=>"sb-completed","QC_Passed"=>"sb-qc","QC_Fail"=>"sb-fail","WarehouseIn"=>"sb-warehouse",_=>"sb-default"};
string GetStatusLabel(string? s)=>s switch{"Pending"=>"待生产","InProgress"=>"生产中","Completed"=>"待质检","QC_Passed"=>"已质检","QC_Fail"=>"未通过","WarehouseIn"=>"已入库",_=>s??"-"};
}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.pt{font-size:24px;color:#fff;margin:0;display:flex;align-items:center;gap:10px;}.br{font-size:13px;color:#888;}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-bottom:30px;}.sc{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:12px;text-align:center;border:1px solid rgba(255,255,255,0.06);}.sc .n{font-size:28px;font-weight:bold;}.sc .l{font-size:12px;color:#888;margin-top:5px;}.sc .s{font-size:11px;color:#666;margin-top:4px;}
.stat-prod .n{color:#4CAF50;}.stat-order .n{color:#2196F3;}.stat-warehouse .n{color:#FF9800;}.stat-bottle .n{color:#9C27B0;}
.section-title{font-size:18px;color:#e0e0e0;margin-bottom:15px;display:flex;align-items:center;gap:10px;}
.quick-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-bottom:30px;}
.qc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;padding:24px 18px;text-align:center;border:1px solid rgba(255,255,255,0.05);text-decoration:none;color:inherit;display:block;transition:all 0.3s;}.qc:hover{transform:translateY(-3px);border-color:rgba(76,175,80,0.3);}
.qc-icon{width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;color:#fff;font-size:20px;}
.qc-title{font-size:15px;color:#fff;font-weight:600;margin-bottom:5px;}.qc-desc{font-size:11px;color:#888;}
.card{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;margin-bottom:25px;border:1px solid rgba(255,255,255,0.06);}.ch{padding:14px 20px;background:rgba(76,175,80,0.08);border-bottom:1px solid rgba(255,255,255,0.06);font-weight:600;font-size:15px;color:#e0e0e0;}.cb{padding:16px 20px;overflow-x:auto;}
.dt{width:100%;border-collapse:collapse;}.dt th{background:rgba(76,175,80,0.15);color:#81c784;padding:12px 15px;text-align:left;font-weight:600;font-size:13px;}.dt td{padding:12px 15px;border-bottom:1px solid rgba(255,255,255,0.04);color:#e0e0e0;font-size:14px;}.dt tr:hover td{background:rgba(255,255,255,0.03);}
.sb{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}
.sb-pending{background:rgba(255,152,0,0.15);color:#ffb74d;}.sb-progress{background:rgba(33,150,243,0.15);color:#64b5f6;}.sb-completed{background:rgba(76,175,80,0.15);color:#81c784;}.sb-qc{background:rgba(156,39,176,0.15);color:#ce93d8;}.sb-fail{background:rgba(244,67,54,0.15);color:#e57373;}.sb-warehouse{background:rgba(0,188,212,0.15);color:#80deea;}.sb-default{background:rgba(158,158,158,0.15);color:#9e9e9e;}
.tac{text-align:center;}.tm{color:#888;font-size:13px;}
@@media(max-width:768px){.stats-grid{grid-template-columns:repeat(2,1fr);}}
</style>
