@page "/admin/prodcenter/packaging-inventory"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PackagingModel = PerfumeShop.Data.Models.PackagingInventory

<PageTitle>包装库存</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">包装材料库存</MudText>

<MudTable Items="@_items" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>ID</MudTh><MudTh>名称</MudTh><MudTh>编码</MudTh><MudTh>库存量</MudTh>
        <MudTh>安全库存</MudTh><MudTh>单位</MudTh><MudTh>单价</MudTh><MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PackagingId</MudTd>
        <MudTd>@(context.ItemName ?? "-")</MudTd>
        <MudTd>@(context.ItemCode ?? "-")</MudTd>
        <MudTd>@(context.StockQty ?? 0)</MudTd>
        <MudTd>@(context.SafetyStock ?? 0)</MudTd>
        <MudTd>@(context.Unit ?? "-")</MudTd>
        <MudTd>¥@((context.UnitPrice ?? 0).ToString("F2"))</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@((context.StockQty ?? 0) < (context.SafetyStock ?? 0) ? Color.Error : Color.Success)">@((context.StockQty ?? 0) < (context.SafetyStock ?? 0) ? "低库存" : "正常")</MudChip></MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private List<PackagingModel> _items = new();
    protected override async Task OnInitializedAsync() => _items = await Db.PackagingInventories.AsNoTracking().OrderBy(p => p.PackagingId).ToListAsync();
}
