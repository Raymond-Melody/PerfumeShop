@page "/admin/prodcenter/prod-scheduling"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>生产排程</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">生产排程</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudDatePicker @bind-Date="_selectedDate" Label="选择日期" DateFormat="yyyy-MM-dd" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="LoadSchedule">加载排程</MudButton>
    </MudItem>
</MudGrid>

<MudGrid>
    @foreach (var group in _scheduleGroups)
    {
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-3" Elevation="2">
                <MudText Typo="Typo.subtitle1"><b>@group.Key</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@group.Count() 个工单</MudText>
                <MudDivider Class="my-2" />
                @foreach (var po in group)
                {
                    <MudStack Row="true" Spacing="1" Class="mb-1">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(po.Status ?? "")">@(po.Status ?? "-")</MudChip>
                        <MudText Typo="Typo.caption">@po.WorkOrderNo — @(po.RecipeName ?? "无配方")</MudText>
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@if (!_scheduleGroups.Any())
{
    <MudAlert Severity="Severity.Info" Class="mt-4">当日无排程数据</MudAlert>
}

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private DateTime? _selectedDate = DateTime.Today;
    private IEnumerable<IGrouping<string, ProductionOrder>> _scheduleGroups = Enumerable.Empty<IGrouping<string, ProductionOrder>>();

    private async Task LoadSchedule()
    {
        var date = _selectedDate ?? DateTime.Today;
        var start = date.Date; var end = start.AddDays(1);
        var items = await Db.ProductionOrders.AsNoTracking()
            .Where(p => p.EstimatedDate >= start && p.EstimatedDate < end || p.CreatedAt >= start && p.CreatedAt < end)
            .OrderBy(p => p.Priority).ToListAsync();
        _scheduleGroups = items.GroupBy(p => p.AssignedTo ?? "未分配");
    }

    private Color GetStatusColor(string s) => s switch { "Pending" => Color.Warning, "InProgress" => Color.Info, "Completed" => Color.Success, _ => Color.Default };
}
