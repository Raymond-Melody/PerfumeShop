@page "/reset-password"
@using global::System.Security.Cryptography
@using global::System.Text
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
@inject NavigationManager Navigation
@layout PerfumeShop.Admin.Components.Layout.LoginLayout

@* V19 密码重置页 — 对应 V18 admin/reset_pwd.asp *@

<PageTitle>重置密码 - 管理后台</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center" Style="min-height:100vh;">
    <MudItem xs="12">
        <MudPaper Elevation="8" Class="pa-8" Style="border-radius:12px;">
            <div class="text-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.Password" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5" Class="mt-2">设置新密码</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">请输入您的新密码</MudText>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">@_success</MudAlert>
            }

            @if (_isValidToken)
            {
                <form method="post" action="/reset-password" @formname="resetForm">
                    <AntiforgeryToken />
                    <input type="hidden" name="token" value="@_token" />
                    <MudTextField T="string" name="new_password" Label="新密码" InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Required="true" RequiredError="请输入新密码" Class="mb-3" />

                    <MudTextField T="string" name="confirm_password" Label="确认新密码" InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                                  Required="true" RequiredError="请确认新密码" Class="mb-4" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               ButtonType="ButtonType.Submit" Size="Size.Large" Class="mb-3">
                        重置密码
                    </MudButton>
                </form>
            }

            <div class="text-center mt-3">
                <MudLink Href="/login" Typo="Typo.caption" Color="Color.Primary">&larr; 返回登录页面</MudLink>
            </div>
        </MudPaper>
    </MudItem>
</MudContainer>

@code {
    private string? _error;
    private string? _success;
    private string _token = "";
    private bool _isValidToken;

    // V18 PASSWORD_PEPPER
    private const string PasswordPepper = "P3rfum3Sh0p_S@lt_2026!";

    [SupplyParameterFromQuery] private string? token { get; set; }
    [SupplyParameterFromForm] private string? new_password { get; set; }
    [SupplyParameterFromForm] private string? confirm_password { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _token = token ?? "";
        if (!string.IsNullOrEmpty(_token))
            await ValidateToken();
        else if (!string.IsNullOrEmpty(new_password))
            await ProcessReset();
        else
            _error = "无效的重置链接，缺少令牌。";
    }

    private async Task ValidateToken()
    {
        if (string.IsNullOrEmpty(_token))
        {
            _isValidToken = false;
            _error = "无效的重置链接。";
            return;
        }

        try
        {
            var tokenHash = HashTokenForStorage(_token);
            var admin = await Db.AdminUsers
                .FirstOrDefaultAsync(a => a.ResetToken == tokenHash
                    && a.ResetTokenExpiry > DateTime.Now);

            if (admin == null)
            {
                _isValidToken = false;
                _error = "重置链接已过期或无效，请重新申请。";
                return;
            }

            _isValidToken = true;
        }
        catch (Exception ex)
        {
            _isValidToken = false;
            _error = $"系统错误: {ex.Message}";
        }
    }

    private async Task ProcessReset()
    {
        if (string.IsNullOrEmpty(_token))
        {
            _error = "无效的重置令牌。";
            return;
        }

        if (string.IsNullOrEmpty(new_password) || new_password.Length < 6)
        {
            _error = "密码长度至少6位。";
            return;
        }

        if (new_password != confirm_password)
        {
            _error = "两次输入的密码不一致。";
            return;
        }

        try
        {
            var tokenHash = HashTokenForStorage(_token);
            var admin = await Db.AdminUsers
                .FirstOrDefaultAsync(a => a.ResetToken == tokenHash
                    && a.ResetTokenExpiry > DateTime.Now);

            if (admin == null)
            {
                _error = "重置链接已过期或无效。";
                _isValidToken = false;
                return;
            }

            // 更新密码为 V3 哈希
            var newHash = HashPasswordV3(new_password);
            admin.PasswordHash = newHash;
            admin.ResetToken = null;
            admin.ResetTokenExpiry = null;
            await Db.SaveChangesAsync();

            _success = "密码重置成功！";
            _isValidToken = false;
        }
        catch (Exception ex)
        {
            _error = $"密码重置失败: {ex.Message}";
        }
    }

    // ===== V19 统一口令散列 — 委托共享 PasswordHasher（单一真源） =====
    private static string HashPasswordV3(string password)
    {
        return global::PerfumeShop.Shared.Security.PasswordHasher.Hash(password);
    }

    private static string GenerateSalt(int length)
    {
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
        return new string(Enumerable.Range(0, length).Select(_ => chars[Random.Shared.Next(chars.Length)]).ToArray());
    }

    private static string HashTokenForStorage(string token)
    {
        using var sha = SHA256.Create();
        var hash = sha.ComputeHash(Encoding.UTF8.GetBytes(token));
        return Convert.ToHexString(hash).ToLowerInvariant();
    }
}
