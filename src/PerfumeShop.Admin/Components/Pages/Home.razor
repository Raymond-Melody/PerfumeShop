@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using PerfumeShop.Data.Models
@using PerfumeShop.Admin.Services
@inject PerfumeShopContext Db
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation
@inject IPermissionService Perms

<PageTitle>管理中心 - 香氛电商系统</PageTitle>

<style>
/* ===== V18 门户卡片样式（从 portal.asp 复刻） ===== */
.portal-container { max-width: 1400px; margin: 0 auto; padding: 0 16px; }
.portal-header { text-align: center; margin-bottom: 30px; padding-top: 16px; }
.portal-header h1 { font-size: 32px; color: #e0e0e0; margin-bottom: 8px; font-weight: 700; }
.portal-header h1 span { color: #00bcd4; }
.portal-header p { font-size: 15px; color: #888; }

.portal-user-info {
    background: linear-gradient(135deg, #2d2d44, #1e1e32);
    border-radius: 16px;
    padding: 20px 30px;
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 25px;
    color: #e0e0e0;
    border: 1px solid rgba(255,255,255,0.06);
}
.portal-user-avatar {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, #00bcd4, #00838f);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; color: #fff;
}
.portal-user-details h3 { font-size: 18px; margin-bottom: 4px; color: #fff; }
.portal-user-details p { font-size: 13px; color: #888; }

.portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}
.portal-card {
    background: linear-gradient(135deg, #2d2d44, #1e1e32);
    border-radius: 16px;
    padding: 28px 25px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
}
.portal-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    transition: all 0.3s ease;
}
.portal-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    border-color: rgba(0,188,212,0.3);
}
.portal-card:hover::before { width: 6px; }

/* 各模块左边框颜色 */
.portal-card.operation::before { background: #667eea; }
.portal-card.semifinished::before { background: #FF9800; }
.portal-card.prodcenter::before { background: #4CAF50; }
.portal-card.finance::before { background: #00bcd4; }
.portal-card.system::before { background: #E91E63; }
.portal-card.techcenter::before { background: #9C27B0; }
.portal-card.purchase::before { background: #FF5722; }
.portal-card.logistics::before { background: #2196F3; }
.portal-card.inventory::before { background: #00BCD4; }
.portal-card.analytics::before { background: #2196F3; }
.portal-card.logout::before { background: #f44336; }

.card-top { display: flex; align-items: center; gap: 16px; margin-bottom: 15px; }
.portal-icon {
    width: 64px; height: 64px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: white; flex-shrink: 0;
}
.portal-card.operation .portal-icon { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.portal-card.semifinished .portal-icon { background: linear-gradient(135deg, #FF9800 0%, #E65100 100%); }
.portal-card.prodcenter .portal-icon { background: linear-gradient(135deg, #4CAF50 0%, #1B5E20 100%); }
.portal-card.finance .portal-icon { background: linear-gradient(135deg, #00bcd4 0%, #00838f 100%); }
.portal-card.system .portal-icon { background: linear-gradient(135deg, #E91E63 0%, #880E4F 100%); }
.portal-card.techcenter .portal-icon { background: linear-gradient(135deg, #9C27B0 0%, #4A148C 100%); }
.portal-card.purchase .portal-icon { background: linear-gradient(135deg, #FF5722 0%, #BF360C 100%); }
.portal-card.logistics .portal-icon { background: linear-gradient(135deg, #2196F3 0%, #0D47A1 100%); }
.portal-card.inventory .portal-icon { background: linear-gradient(135deg, #00BCD4 0%, #006064 100%); }
.portal-card.analytics .portal-icon { background: linear-gradient(135deg, #2196F3 0%, #0D47A1 100%); }
.portal-card.logout .portal-icon { background: linear-gradient(135deg, #f44336 0%, #b71c1c 100%); }

.card-title h3 { font-size: 20px; color: #fff; margin-bottom: 4px; }
.card-title .badge-new {
    display: inline-block; padding: 2px 8px;
    background: rgba(76,175,80,0.3); color: #4CAF50;
    border-radius: 10px; font-size: 10px; font-weight: 700; margin-left: 6px;
}
.card-title p { color: #888; font-size: 13px; }

.portal-features {
    padding-top: 15px;
    border-top: 1px solid rgba(255,255,255,0.06);
    display: grid; grid-template-columns: 1fr 1fr; gap: 4px;
    list-style: none; margin: 0; padding-left: 0;
}
.portal-features li {
    padding: 3px 0; color: #999; font-size: 12px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.portal-features li::before { content: "✓ "; color: #4CAF50; margin-right: 5px; font-size: 10px; }

.logout-card { background: rgba(244,67,54,0.08); border: 1px solid rgba(244,67,54,0.15); text-align: center; }
.logout-card .card-top { justify-content: center; }
.logout-card h3 { color: #EF9A9A; }
.logout-card p { color: #888; font-size: 13px; }

.portal-footer { text-align: center; color: #555; font-size: 12px; padding: 20px 0; }
.portal-footer span { color: #00bcd4; }

@@media (max-width: 1200px) {
    .portal-grid { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 768px) {
    .portal-header h1 { font-size: 24px; }
    .portal-user-info { flex-direction: column; text-align: center; }
    .portal-grid { grid-template-columns: 1fr; }
    .portal-features { grid-template-columns: 1fr; }
}

/* 确保 Material Icons 字体不被 MudBlazor 覆盖 */
.portal-icon span.material-icons {
    font-family: 'Material Icons' !important;
    font-weight: normal !important;
    font-style: normal !important;
    font-size: 28px !important;
    line-height: 1 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    word-wrap: normal !important;
    white-space: nowrap !important;
    direction: ltr !important;
    -webkit-font-smoothing: antialiased !important;
}
</style>

<div class="portal-container">
    <div class="portal-header">
        <h1><span style="color:#00bcd4;">管理中心</span></h1>
        <p>V19 全模块统一入口 · 请选择要进入的管理后台</p>
    </div>

    <div class="portal-user-info">
        <div class="portal-user-avatar">
            <span class="material-icons" style="font-size:26px;">person</span>
        </div>
        <div class="portal-user-details">
            <h3>@_userDisplayName</h3>
            <p>@_userRole</p>
        </div>
    </div>

    <div class="portal-grid">
        @foreach (var c in _cards)
        {
            @if (Can(c.Module))
            {
                <MudElement HtmlTag="a" href="@c.Url" class="@($"portal-card {c.Css}")">
                    <div class="card-top">
                        <div class="portal-icon"><span class="material-icons" style="font-size:28px;">@c.Icon</span></div>
                        <div class="card-title">
                            <h3>@c.Title@if (!string.IsNullOrEmpty(c.Badge)){<span class="badge-new">@c.Badge</span>}</h3>
                            <p>@c.Sub</p>
                        </div>
                    </div>
                    <ul class="portal-features">
                        @foreach (var f in c.Features){<li>@f</li>}
                    </ul>
                </MudElement>
            }
        }

        <MudElement HtmlTag="a" href="/logout" class="portal-card logout logout-card">
            <div class="card-top">
                <div class="portal-icon"><span class="material-icons" style="font-size:28px;">logout</span></div>
                <div class="card-title">
                    <h3>安全退出</h3>
                    <p>结束本次管理会话</p>
                </div>
            </div>
        </MudElement>
    </div>

    <div class="portal-footer">
        香氛电商系统 <span>V19.0</span> · 全模块统一管理平台
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string _userDisplayName = "管理员";
    private string _userRole = "系统管理员";
    private HashSet<string> _modules = new();

    protected override async Task OnInitializedAsync()
    {
        // 统一使用注入的 AuthenticationStateProvider（与全站一致）；
        // 早先依赖级联参数 AuthStateTask 在本页为 null，导致门户卡片恒不显示。
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userDisplayName = user.FindFirst(ClaimTypes.Name)?.Value ?? "管理员";
            _userRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "系统管理员";
            var roleCode = user.FindFirst("RoleCode")?.Value;
            try { _modules = await Perms.GetAccessibleModulesAsync(roleCode); } catch { }
        }
    }

    private bool Can(string module) => _modules.Contains(module);

    private record PortalCard(string Module, string Url, string Css, string Icon, string Title, string Sub, string? Badge, string[] Features);

    private static readonly PortalCard[] _cards =
    {
        new("operation", "/admin/Operation/Index", "operation", "bar_chart", "运营管理中心", "订单、客户、商品、评价", null, new[]{"订单管理","客户CRM画像","售后管理","评价审核"}),
        new("semifinished", "/admin/semifinished", "semifinished", "science", "半成品生产中心", "原料、基香、香调生产", "NEW", new[]{"Accord生产","原料库存","基香&香调库存","车间调拨"}),
        new("prodcenter", "/admin/prodcenter", "prodcenter", "factory", "产品生产管理中心", "工单、排产、质检、入库", "NEW", new[]{"生产工单","排产调度","质量检验","成品库存"}),
        new("logistics", "/admin/logistics", "logistics", "local_shipping", "物流管理中心", "发货、在途、签收、退货", "NEW", new[]{"发货单管理","在途跟踪","签收确认","退货入库"}),
        new("purchase", "/admin/Purchase/Dashboard", "purchase", "shopping_cart", "采购管理中心", "品牌定香采购、供应商、价格管理", null, new[]{"采购订单","供应商管理","价格管理","采购分析"}),
        new("finance", "/admin/finance", "finance", "account_balance", "财务管理中心", "应收应付、成本、总账", null, new[]{"应收应付","付款凭证","总账报表","现金流预测"}),
        new("techcenter", "/admin/TechCenter", "techcenter", "science", "产品技术管理中心", "配方、基香、规格设置", null, new[]{"配方工艺","基香管理","香调调整","产品规格"}),
        new("system", "/admin/system/users", "system", "shield", "站点技术管理", "权限、安全、备份、日志", null, new[]{"管理员&角色","安全审计","备份中心","站点设置"}),
        new("inventory", "/admin/inventory", "inventory", "warehouse", "库存管理中心", "全品类统一库存管控", "NEW", new[]{"库存仪表盘","全品类预警","库存流水","快捷入口"}),
        new("analytics", "/admin/analytics", "analytics", "analytics", "数据分析仪表盘", "营收趋势、转化漏斗、热门产品", "V19", new[]{"实时数据概览","转化漏斗分析","热门产品排行","营收趋势图"}),
    };
}
