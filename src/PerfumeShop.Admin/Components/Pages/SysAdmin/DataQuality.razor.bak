<!-- V19系统管理 · 数据质量检查 -->
@page "/admin/system/data-quality"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>数据质量</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-check-double" style="color:#E91E63;"></i> 数据质量检查</MudText>
@if (_loaded)
{
    <MudPaper Class="pa-6" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
        <MudText Typo="Typo.h6" Class="mb-4">数据完整性检查</MudText>
        <MudTable Items="@_checks" Hover="true" Dense="true">
            <HeaderContent><MudTh>检查项</MudTh><MudTh>状态</MudTh><MudTh>详情</MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd><MudIcon Icon="@(context.Pass ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)" Color="@(context.Pass ? Color.Success : Color.Warning)" /></MudTd>
                <MudTd>@context.Detail</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}
else { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }
@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private bool _loaded;
    private List<(string Name, bool Pass, string Detail)> _checks = new();
    protected override async Task OnInitializedAsync()
    {
        var productCnt = await Db.Products.CountAsync();
        var userCnt = await Db.Users.CountAsync();
        var orderCnt = await Db.Orders.CountAsync();
        var orphanItems = await Db.OrderItems.CountAsync(oi => !oi.Order!.OrderId.Equals(0));
        _checks = new() {
            ("产品数据", productCnt > 0, $"{productCnt} 个产品"),
            ("用户数据", userCnt > 0, $"{userCnt} 个用户"),
            ("订单数据", orderCnt > 0, $"{orderCnt} 个订单"),
            ("订单明细完整性", orphanItems >= 0, $"{orphanItems} 条有主明细"),
            ("数据库连接", true, "正常")
        };
        _loaded = true;
    }
}
