@page "/admin/system/ip-blacklist"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject ISnackbar Snackbar

<PageTitle>IP黑名单</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-ban" style="color:#E91E63;"></i> IP黑名单管理</MudText>
@if (_items is not null)
{
    @if (_editing)
    {
        <MudPaper Class="pa-6 mb-4" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(233,30,99,0.2);border-radius:12px;max-width:600px;">
            <MudText Typo="Typo.h6" Class="mb-3" Style="color:#E91E63;">添加IP黑名单</MudText>
            <MudTextField @bind-Value="_newIp" Label="IP地址" Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_newReason" Label="封禁原因" Variant="Variant.Outlined" Lines="2" Class="mb-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveNew">保存</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="CancelEdit" Class="ml-2">取消</MudButton>
        </MudPaper>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="StartAdd" Class="mb-4">添加IP</MudButton>
    <MudTable Items="@_items" Hover="true" Dense="true" Striped="true">
        <HeaderContent><MudTh>IP地址</MudTh><MudTh>原因</MudTh><MudTh>状态</MudTh><MudTh>封禁时间</MudTh><MudTh>操作</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd Style="font-weight:600;color:#F44336;">@context.Ipaddress</MudTd><MudTd>@context.Reason</MudTd>
            <MudTd><MudChip Size="Size.Small" Color="@(context.IsActive == true ? Color.Error : Color.Default)">@(context.IsActive == true ? "封禁中" : "已解除")</MudChip></MudTd>
            <MudTd>@context.BlockedAt?.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.ToggleOff" Size="Size.Small" Color="Color.Success" OnClick="@(() => ToggleBan(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveIp(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }
@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private bool _editing; private string _newIp = "", _newReason = "";
    private List<Ipblacklist>? _items;

    protected override async Task OnInitializedAsync() { _items = await Db.Ipblacklists.AsNoTracking().OrderByDescending(i => i.BlockedAt).ToListAsync(); }
    private void StartAdd() { _newIp = ""; _newReason = ""; _editing = true; }
    private void CancelEdit() { _editing = false; }
    private async Task SaveNew()
    {
        if (string.IsNullOrWhiteSpace(_newIp)) { Snackbar.Add("请输入IP地址", Severity.Warning); return; }
        Db.Ipblacklists.Add(new Ipblacklist { Ipaddress = _newIp, Reason = _newReason, IsActive = true, BlockedAt = DateTime.Now });
        await Db.SaveChangesAsync(); Snackbar.Add("已添加", Severity.Success);
        _editing = false; _items = await Db.Ipblacklists.AsNoTracking().OrderByDescending(i => i.BlockedAt).ToListAsync();
    }
    private async Task ToggleBan(Ipblacklist item) { var b = await Db.Ipblacklists.FindAsync(item.Ipid); if (b != null) { b.IsActive = !(b.IsActive ?? true); await Db.SaveChangesAsync(); Snackbar.Add(b.IsActive == true ? "已封禁" : "已解除", Severity.Success); _items = await Db.Ipblacklists.AsNoTracking().OrderByDescending(i => i.BlockedAt).ToListAsync(); } }
    private async Task RemoveIp(Ipblacklist item) { var b = await Db.Ipblacklists.FindAsync(item.Ipid); if (b != null) { Db.Ipblacklists.Remove(b); await Db.SaveChangesAsync(); Snackbar.Add("已删除", Severity.Success); _items!.Remove(item); } }
}
