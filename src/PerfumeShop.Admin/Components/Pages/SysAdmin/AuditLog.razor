@page "/admin/system/audit-log"
@page "/admin/system/operation-log"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.system")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories
@inject PerfumeShopContext Db
@inject SystemRepository SysRepo

<PageTitle>审计日志</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-history" style="color:#E91E63;"></i> 操作日志 & 审计日志</h2><div class="breadcrumb"><a href="/admin/system/users" style="color:#E91E63;text-decoration:none;">系统管理</a> / <span>审计日志</span></div></div>
@if(_loaded){
<div class="stats-row"><div class="stat-card"><div class="stat-value">@_totalAuditLogs</div><div class="stat-label">审计日志</div></div><div class="stat-card"><div class="stat-value" style="color:#00bcd4;">@_totalAppLogs</div><div class="stat-label">应用日志</div></div></div>
<div class="tab-nav"><a class="tab-link @(_tab=="audit"?"active":"")" @onclick='()=>SwitchTab("audit")' @onclick:preventDefault>审计日志</a><a class="tab-link @(_tab=="app"?"active":"")" @onclick='()=>SwitchTab("app")' @onclick:preventDefault>应用日志</a></div>
<div class="toolbar"><select @bind="_filterType" style="padding:10px 14px;border:1px solid #3a3a4a;border-radius:8px;background:#1a1a2e;color:#e0e0e0;font-size:14px;"><option value="">全部类型</option><option value="LOGIN">登录</option><option value="OPERATION">操作</option><option value="SECURITY">安全</option></select><button class="btn-search" @onclick="Refresh">筛选</button></div>
@if(_tab=="audit"){
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>类型</th><th>描述</th><th>IP</th><th>时间</th></tr></thead><tbody>
@foreach(var l in _auditLogs){<tr><td>#@l.LogId</td><td><span class="status-badge status-normal">@(l.ActionType??"-")</span></td><td>@(l.Details??"-")</td><td>@(l.Ipaddress??"-")</td><td>@(l.CreatedAt?.ToString("yyyy-MM-dd HH:mm")??"-")</td></tr>}
@if(!_auditLogs.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:40px;">暂无审计日志</td></tr>}
</tbody></table></div>
@RenderPagination(_auditTotalPages)
}else{
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>级别</th><th>类型</th><th>消息</th><th>时间</th></tr></thead><tbody>
@foreach(var l in _appLogs){<tr><td>#@l.LogId</td><td><span class="status-badge @(l.LogLevel=="ERROR"?"status-warning":"status-normal")">@(l.LogLevel??"-")</span></td><td>@(l.LogType??"-")</td><td>@(l.LogMessage??"-")</td><td>@(l.CreatedAt?.ToString("yyyy-MM-dd HH:mm")??"-")</td></tr>}
@if(!_appLogs.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:40px;">暂无应用日志</td></tr>}
</tbody></table></div>
@RenderPagination(_appTotalPages)
}
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

<style>



.stats-row{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:24px;}
.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;border:1px solid rgba(255,255,255,0.05);text-align:center;}
.stat-value{font-size:26px;font-weight:bold;color:#e0e0e0;}
.stat-label{font-size:13px;color:#888;margin-top:4px;}
.tab-nav{display:flex;border-bottom:2px solid #3a3a4a;margin-bottom:20px;}
.tab-link{padding:12px 24px;color:#888;text-decoration:none;font-size:14px;border-bottom:3px solid transparent;cursor:pointer;}
.tab-link:hover{color:#e0e0e0;}
.tab-link.active{color:#E91E63;border-bottom-color:#E91E63;}
.toolbar{display:flex;gap:12px;margin-bottom:20px;}
.btn-search{background:#3a3a4a;color:#e0e0e0;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;font-size:14px;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);margin-bottom:20px;}
.orders-table{width:100%;border-collapse:collapse;}
.orders-table th{background:rgba(233,30,99,0.1);color:#E91E63;padding:14px 16px;font-size:13px;text-align:left;}
.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.orders-table tr:hover{background:rgba(255,255,255,0.03);}
.status-badge{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;font-weight:500;}
.status-normal{background:rgba(76,175,80,0.2);color:#81c784;}
.status-warning{background:rgba(244,67,54,0.2);color:#e57373;}
.pagination{display:flex;justify-content:center;align-items:center;gap:10px;margin-top:25px;}
.pagination button{padding:8px 14px;border-radius:6px;border:none;font-size:14px;cursor:pointer;background:#3a3a4a;color:#e0e0e0;}
.pagination button.current{background:#E91E63;color:#fff;}
.pagination button:disabled{background:#2a2a3a;color:#666;cursor:not-allowed;}
</style>

@code {
    private bool _loaded;
    private string _tab="audit",_filterType="";
    private int _totalAuditLogs,_totalAppLogs,_page=1,_auditTotalPages=1,_appTotalPages=1; const int PageSize=20;
    private List<AdminAuditLog> _auditLogs=new();
    private List<AppLog> _appLogs=new();

    protected override async Task OnInitializedAsync(){
        try{
            var(aItems,aTotal)=await SysRepo.GetAuditLogsAsync(1,PageSize);
            _auditLogs=aItems;_totalAuditLogs=aTotal;_auditTotalPages=(int)Math.Ceiling(aTotal/(double)PageSize);
            var(pItems,pTotal)=await SysRepo.GetAppLogsAsync(1,PageSize);
            _appLogs=pItems;_totalAppLogs=pTotal;_appTotalPages=(int)Math.Ceiling(pTotal/(double)PageSize);
            _loaded=true;
        }catch{_loaded=true;}
    }
    async Task SwitchTab(string t){_tab=t;_page=1;await LoadTabData();}
    async Task Refresh(){_page=1;await LoadTabData();}
    async Task LoadTabData(){
        try{
            if(_tab=="audit"){var(items,total)=await SysRepo.GetAuditLogsAsync(_page,PageSize,_filterType);_auditLogs=items;_totalAuditLogs=total;_auditTotalPages=(int)Math.Ceiling(total/(double)PageSize);}
            else{var(items,total)=await SysRepo.GetAppLogsAsync(_page,PageSize);_appLogs=items;_totalAppLogs=total;_appTotalPages=(int)Math.Ceiling(total/(double)PageSize);}
        }catch{}
    }
    async Task GoToPage(int p){_page=p;await LoadTabData();}
    RenderFragment RenderPagination(int totalPages)=>builder=>{
        if(totalPages<=1)return;
        builder.OpenElement(0,"div");builder.AddAttribute(1,"class","pagination");
        builder.OpenElement(2,"button");builder.AddAttribute(3,"disabled",_page<=1);builder.AddAttribute(4,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(1)));builder.AddContent(5,"首页");builder.CloseElement();
        builder.OpenElement(6,"button");builder.AddAttribute(7,"disabled",_page<=1);builder.AddAttribute(8,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(_page-1)));builder.AddContent(9,"上一页");builder.CloseElement();
        builder.OpenElement(10,"button");builder.AddAttribute(11,"class","current");builder.AddContent(12,$"{_page}/{totalPages}");builder.CloseElement();
        builder.OpenElement(13,"button");builder.AddAttribute(14,"disabled",_page>=totalPages);builder.AddAttribute(15,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(_page+1)));builder.AddContent(16,"下一页");builder.CloseElement();
        builder.OpenElement(17,"button");builder.AddAttribute(18,"disabled",_page>=totalPages);builder.AddAttribute(19,"onclick",EventCallback.Factory.Create(this,()=>GoToPage(totalPages)));builder.AddContent(20,"末页");builder.CloseElement();
        builder.CloseElement();
    };
}
