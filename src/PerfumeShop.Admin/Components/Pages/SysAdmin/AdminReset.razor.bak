<!-- V19系统管理 · 管理员密码重置 -->
@page "/admin/system/admin-reset"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using Microsoft.AspNetCore.Identity
@inject ISnackbar Snackbar

<PageTitle>管理员密码重置</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-key" style="color:#E91E63;"></i> 管理员密码重置</MudText>

@if (_loaded)
{
    <MudPaper Class="pa-6" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;max-width:600px;">
        <MudSelect @bind-Value="_selectedAdminId" Label="选择管理员" Required="true">
            @foreach (var a in _admins)
            {
                <MudSelectItem Value="@a.AdminId">@a.FullName (@a.Username) - @a.Role?.RoleName</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_newPassword" Label="新密码" Variant="Variant.Outlined" Class="mt-4" InputType="InputType.Password" Required="true" />
        <MudTextField @bind-Value="_confirmPassword" Label="确认密码" Variant="Variant.Outlined" Class="mt-4" InputType="InputType.Password" Required="true" />
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ResetPassword" Class="mt-4" Disabled="@(_resetting)">重置密码</MudButton>
    </MudPaper>
}
else { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private bool _loaded, _resetting;
    private int _selectedAdminId;
    private string _newPassword = "", _confirmPassword = "";
    private List<AdminUser> _admins = new();

    protected override async Task OnInitializedAsync()
    {
        _admins = await Db.AdminUsers.Include(a => a.Role).AsNoTracking().OrderBy(a => a.AdminId).ToListAsync();
        _loaded = true;
    }

    private async Task ResetPassword()
    {
        if (_selectedAdminId == 0) { Snackbar.Add("请选择管理员", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 6) { Snackbar.Add("密码至少6位", Severity.Warning); return; }
        if (_newPassword != _confirmPassword) { Snackbar.Add("两次密码不一致", Severity.Warning); return; }

        _resetting = true; StateHasChanged();
        try
        {
            var hasher = new PasswordHasher<object>();
            var hash = hasher.HashPassword(null!, _newPassword);
            await Db.AdminUsers.Where(a => a.AdminId == _selectedAdminId)
                .ExecuteUpdateAsync(s => s.SetProperty(a => a.PasswordHash, hash));
            Snackbar.Add("密码已重置", Severity.Success);
            _newPassword = ""; _confirmPassword = "";
        }
        catch (Exception ex) { Snackbar.Add($"重置失败：{ex.Message}", Severity.Error); }
        finally { _resetting = false; }
    }
}
