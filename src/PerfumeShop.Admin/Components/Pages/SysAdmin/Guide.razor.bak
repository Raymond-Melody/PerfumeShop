<!-- V19系统管理 · 使用流程指南 -->
@page "/admin/system/guide"
@page "/admin/system/operation-log"

<PageTitle>使用流程指南</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-book-open" style="color:#E91E63;"></i> 使用流程指南</MudText>

<div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:22px;margin-bottom:18px;">
    <h3 style="color:#80deea;font-size:16px;margin-bottom:10px;">V19 Blazor MudBlazor 平台 · 模块导航</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));gap:16px;margin-top:12px;">
        <div style="background:rgba(0,188,212,0.04);border:1px solid rgba(0,188,212,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#00bcd4;margin-bottom:6px;"><i class="fas fa-chart-line"></i> 运营中心</h4>
            <p style="font-size:13px;color:#90a4ae;">订单处理、客户管理、售后、商品上下架、秒杀/拼团/订阅</p>
        </div>
        <div style="background:rgba(0,188,212,0.04);border:1px solid rgba(0,188,212,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#00bcd4;margin-bottom:6px;"><i class="fas fa-dollar-sign"></i> 财务中心</h4>
            <p style="font-size:13px;color:#90a4ae;">应收应付、付款凭证、利润表、成本中心、对账</p>
        </div>
        <div style="background:rgba(255,152,0,0.04);border:1px solid rgba(255,152,0,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#FF9800;margin-bottom:6px;"><i class="fas fa-shopping-cart"></i> 采购管理</h4>
            <p style="font-size:13px;color:#90a4ae;">采购订单、收货入库、品牌定香、供应商管理</p>
        </div>
        <div style="background:rgba(76,175,80,0.04);border:1px solid rgba(76,175,80,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#4CAF50;margin-bottom:6px;"><i class="fas fa-industry"></i> 生产中心</h4>
            <p style="font-size:13px;color:#90a4ae;">生产排程、质量控制、成品入库、物料需求</p>
        </div>
        <div style="background:rgba(156,39,176,0.04);border:1px solid rgba(156,39,176,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#9C27B0;margin-bottom:6px;"><i class="fas fa-flask"></i> 技术中心</h4>
            <p style="font-size:13px;color:#90a4ae;">配方管理、工艺参数、质量标准</p>
        </div>
        <div style="background:rgba(33,150,243,0.04);border:1px solid rgba(33,150,243,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#2196F3;margin-bottom:6px;"><i class="fas fa-vial"></i> 半成品管理</h4>
            <p style="font-size:13px;color:#90a4ae;">半成品库存、流转、质检</p>
        </div>
        <div style="background:rgba(255,152,0,0.04);border:1px solid rgba(255,152,0,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#FF9800;margin-bottom:6px;"><i class="fas fa-truck"></i> 物流管理</h4>
            <p style="font-size:13px;color:#90a4ae;">发货、配送、物流跟踪、退换货</p>
        </div>
        <div style="background:rgba(0,188,212,0.04);border:1px solid rgba(0,188,212,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#00BCD4;margin-bottom:6px;"><i class="fas fa-warehouse"></i> 库存管理</h4>
            <p style="font-size:13px;color:#90a4ae;">库存盘点、调拨、预警</p>
        </div>
        <div style="background:rgba(233,30,99,0.04);border:1px solid rgba(233,30,99,0.1);border-radius:10px;padding:16px;">
            <h4 style="color:#E91E63;margin-bottom:6px;"><i class="fas fa-shield-alt"></i> 系统管理</h4>
            <p style="font-size:13px;color:#90a4ae;">用户管理、权限配置、安全审计、备份</p>
        </div>
    </div>
</div>
