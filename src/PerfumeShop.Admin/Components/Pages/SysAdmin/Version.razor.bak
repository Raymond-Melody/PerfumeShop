<!-- V19系统管理 · 版本信息 -->
@page "/admin/system/version-info"
@page "/admin/system/health"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>版本信息</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-code-branch" style="color:#E91E63;"></i> 版本信息</MudText>

@if (_loaded)
{
    <div style="background:linear-gradient(135deg,#1e2a3a,#162231);border:1px solid rgba(0,188,212,0.2);border-radius:16px;padding:30px 35px;margin-bottom:25px;display:flex;align-items:center;gap:30px;">
        <div style="width:80px;height:80px;background:linear-gradient(135deg,#00bcd4,#00838f);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;color:#fff;">V19</div>
        <div>
            <h2 style="color:#fff;font-size:24px;margin-bottom:5px;">Custom Fragrance · 香氛定制系统</h2>
            <p style="color:#78909c;font-size:14px;">PerfumeShop V19.0 · Blazor + .NET 8</p>
            <div style="display:flex;gap:20px;margin-top:12px;flex-wrap:wrap;">
                <span style="background:rgba(0,188,212,0.08);padding:6px 14px;border-radius:20px;font-size:13px;color:#80deea;"><i class="fas fa-database"></i> SQL Server 2017+</span>
                <span style="background:rgba(0,188,212,0.08);padding:6px 14px;border-radius:20px;font-size:13px;color:#80deea;"><i class="fas fa-server"></i> IIS / MudBlazor Blazor Server</span>
                <span style="background:rgba(0,188,212,0.08);padding:6px 14px;border-radius:20px;font-size:13px;color:#80deea;"><i class="fas fa-table"></i> @_tableCount 张数据表</span>
            </div>
        </div>
    </div>

    <MudPaper Class="pa-6" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
        <MudText Typo="Typo.h6" Class="mb-4">V19架构组件</MudText>
        <MudTable Items="@_components" Hover="true" Dense="true">
            <HeaderContent><MudTh>组件</MudTh><MudTh>技术栈</MudTh></HeaderContent>
            <RowTemplate><MudTd>@context.Item1</MudTd><MudTd>@context.Item2</MudTd></RowTemplate>
        </MudTable>
    </MudPaper>
}
else { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private bool _loaded; private int _tableCount;
    private List<(string, string)> _components = new() {
        ("后端框架", ".NET 8 Blazor Server (InteractiveServer)"),
        ("前端UI", "MudBlazor 8.x + Font Awesome 6"),
        ("数据库", "SQL Server 2017+ via EF Core 8"),
        ("认证", "Cookie Auth + AuthBridge Middleware"),
        ("API层", "ASP.NET Core Web API (OpenAPI/Swagger)"),
        ("安全", "速率限制 + API Key + CSRF防护"),
        ("前端增强", "PWA Service Worker + 离线缓存 + 骨架屏"),
        ("国际化", "内置中/英双语言 i18n")
    };
    protected override async Task OnInitializedAsync() { _tableCount = await Db.Database.SqlQuery<int>($"SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE='BASE TABLE'").FirstOrDefaultAsync(); _loaded = true; }
}
