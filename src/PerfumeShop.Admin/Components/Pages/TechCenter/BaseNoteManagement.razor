@page "/admin/TechCenter/BaseNoteManagement"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Module.techcenter")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories
@using PerfumeShop.Core.Interfaces
@using PerfumeShop.Admin.Services
@inject PerfumeShopContext Db
@inject IAdminAuditor Auditor
@inject ICostEngine CostEngine
@inject AuthenticationStateProvider AuthState

<PageTitle>基香管理</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-wine-bottle" style="color:#FF9800;"></i> 基香管理</h2><div class="breadcrumb"><a href="/admin/TechCenter" style="color:#00bcd4;text-decoration:none;">技术中心</a> / <span>基香管理</span></div></div>
@if(_loaded){
<div class="stats-row"><div class="stat-card"><div class="stat-value">@_total</div><div class="stat-label">基香总数</div></div><div class="stat-card" style="border-left:3px solid #4CAF50;"><div class="stat-value" style="color:#4CAF50;">@_active</div><div class="stat-label">已启用</div></div><div class="stat-card" style="border-left:3px solid #f44336;"><div class="stat-value" style="color:#f44336;">@(_total-_active)</div><div class="stat-label">已禁用</div></div></div>
@if(!string.IsNullOrEmpty(_msg)){<div class="alert @(_msgType=="err"?"alert-error":"alert-success")">@_msg</div>}
<div class="filter-bar"><input class="filter-input" @bind="_search" placeholder="搜索基香名称..." /><button class="btn-search" @onclick="DoSearch"><i class="fas fa-search"></i> 搜索</button>@if(!string.IsNullOrEmpty(_search)){<button class="btn-clear" @onclick="ClearSearch"><i class="fas fa-times"></i> 清除</button>}<button class="btn-add" @onclick="OpenAddModal" style="margin-left:auto;">+ 新建基香</button></div>
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>基香名称</th><th>描述</th><th>成分数</th><th style="text-align:right;">单价(¥/ml)</th><th>状态</th><th>操作</th></tr></thead><tbody>
@foreach(var n in _items){var ingCount=n.Ingredients?.Split(',').Count(s=>!string.IsNullOrWhiteSpace(s))??0;<tr><td>#@n.BaseNoteId</td><td>@n.BaseNoteName</td><td>@(n.Description??"-")</td><td style="text-align:center;">@ingCount</td><td style="text-align:right;">@(n.UnitPrice.HasValue?n.UnitPrice.Value.ToString("F4"):"-")</td><td><span class="status-badge @(n.IsActive==true?"status-normal":"status-warning")">@(n.IsActive==true?"启用":"禁用")</span></td><td><button class="btn-edit" @onclick='()=>OpenEditModal(n)'>编辑</button></td></tr>}
@if(!_items.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:40px;">暂无基香</td></tr>}
</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@if(_showModal){
<div class="modal-overlay" @onclick="CloseModal"><div class="modal-content" @onclick:stopPropagation="true"><div class="modal-header"><h3>@(_editing?"编辑基香":"新建基香")</h3><button class="modal-close" @onclick="CloseModal"><i class="fas fa-times"></i></button></div><div class="modal-body">
<div class="form-group"><label>基香名称 <span style="color:#f44336;">*</span></label><input @bind="_edit.BaseNoteName" /></div>
<div class="form-group"><label>描述</label><textarea @bind="_edit.Description" rows="3" class="input-full"></textarea></div>
<div class="form-group"><label>成分列表 <span style="color:#f44336;">*</span></label><textarea @bind="_editIngredients" rows="5" class="input-full" placeholder="支持逗号分隔或每行一个成分，用于过敏源追溯&#10;例如：&#10;乙醇,蒸馏水,香精油"></textarea><div style="font-size:12px;color:#666;margin-top:4px;"><i class="fas fa-info-circle"></i> 支持逗号分隔或每行一个成分</div></div>
<div class="form-group"><label>单价 (¥/ml)</label><input type="number" @bind="_edit.UnitPrice" step="0.0001" min="0" placeholder="如: 0.0250" /></div>
<div class="form-group"><label>状态</label><select @bind="_edit.IsActive"><option value="true">启用</option><option value="false">禁用</option></select></div>
</div><div class="modal-footer"><button class="btn-secondary" @onclick="CloseModal">取消</button><button class="btn-save" @onclick="SaveItem">保存</button></div></div></div>
}

<style>



.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}
.stat-card{background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;}
.stat-value{font-size:26px;font-weight:bold;color:#e0e0e0;}.stat-label{font-size:13px;color:#888;}
.filter-bar{display:flex;gap:10px;align-items:center;margin-bottom:20px;flex-wrap:wrap;}
.filter-input{flex:1;min-width:200px;padding:10px 14px;background:#1a1a2e;border:2px solid #3a3a4a;border-radius:8px;color:#e0e0e0;font-size:14px;}
.filter-input:focus{border-color:#FF9800;outline:none;}
.btn-search{background:rgba(255,152,0,0.15);color:#FF9800;border:1px solid rgba(255,152,0,0.3);padding:8px 16px;border-radius:6px;cursor:pointer;}
.btn-clear{background:rgba(158,158,158,0.15);color:#9e9e9e;border:1px solid rgba(158,158,158,0.3);padding:8px 16px;border-radius:6px;cursor:pointer;}
.input-full{width:100% !important;padding:10px 14px;border:2px solid #3a3a4a;border-radius:8px;font-size:14px;background:#1a1a2e;color:#e0e0e0;resize:vertical;min-height:60px;box-sizing:border-box;}
.input-full:focus{border-color:#FF9800;outline:none;}
.btn-add{background:linear-gradient(135deg,#FF9800,#E65100);color:#fff;border:none;padding:10px 20px;border-radius:8px;cursor:pointer;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}
.orders-table{width:100%;border-collapse:collapse;}
.orders-table th{background:rgba(255,152,0,0.1);color:#FF9800;padding:14px 16px;font-size:13px;text-align:left;}
.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.status-badge{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;}
.status-normal{background:rgba(76,175,80,0.2);color:#81c784;}.status-warning{background:rgba(244,67,54,0.2);color:#e57373;}
.btn-edit{background:rgba(255,152,0,0.15);color:#FF9800;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;}
.alert{padding:15px 20px;border-radius:8px;margin-bottom:20px;}
.alert-success{background:rgba(76,175,80,0.15);color:#81c784;}.alert-error{background:rgba(244,67,54,0.15);color:#e57373;}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}
.modal-content{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;width:90%;max-width:500px;border:1px solid rgba(255,255,255,0.06);}
.modal-header{padding:20px 25px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;}
.modal-header h3{margin:0;color:#e0e0e0;font-size:18px;}
.modal-close{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}
.modal-body{padding:25px;max-height:55vh;overflow-y:auto;}
.modal-footer{padding:20px 25px;border-top:1px solid rgba(255,255,255,0.06);display:flex;justify-content:flex-end;gap:10px;}
.form-group{margin-bottom:15px;}.form-group label{display:block;margin-bottom:6px;color:#b0b0b0;font-size:13px;}
.form-group input,.form-group select{width:100%;padding:10px 14px;border:2px solid #3a3a4a;border-radius:8px;font-size:14px;background:#1a1a2e;color:#e0e0e0;box-sizing:border-box;}
.form-group input:focus,.form-group select:focus{border-color:#FF9800;outline:none;}
.btn-save{background:linear-gradient(135deg,#FF9800,#E65100);color:#fff;border:none;padding:10px 24px;border-radius:8px;cursor:pointer;}
.btn-secondary{background:#3a3a4a;color:#e0e0e0;border:none;padding:10px 24px;border-radius:8px;cursor:pointer;}
</style>

@code {
    private bool _loaded,_editing,_showModal;private int _total,_active;private string _msg="",_msgType="",_search="",_editIngredients="";
    private List<BaseNote> _items=new();private BaseNote _edit=new();
    private int _adminId;private string _adminName="";
    protected override async Task OnInitializedAsync(){var st=await AuthState.GetAuthenticationStateAsync();int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value,out _adminId);_adminName=st.User.FindFirst(ClaimTypes.Name)?.Value??"";await LoadItems();}
    async Task LoadItems(){
        try{_items=await Db.BaseNotes.AsNoTracking().OrderByDescending(b=>b.BaseNoteId).ToListAsync();_total=_items.Count;_active=_items.Count(b=>b.IsActive==true);_loaded=true;}catch{_loaded=true;}
    }
    async Task DoSearch(){if(!string.IsNullOrWhiteSpace(_search)){_items=await Db.BaseNotes.AsNoTracking().Where(b=>b.BaseNoteName.Contains(_search)).OrderByDescending(b=>b.BaseNoteId).ToListAsync();}else await LoadItems();}
    void ClearSearch(){_search="";StateHasChanged();}
    void OpenAddModal(){_editing=false;_edit=new(){IsActive=true};_editIngredients="";_showModal=true;}
    void OpenEditModal(BaseNote b){_editing=true;_edit=new(){BaseNoteId=b.BaseNoteId,BaseNoteName=b.BaseNoteName,Description=b.Description,Ingredients=b.Ingredients,UnitPrice=b.UnitPrice,IsActive=b.IsActive};_editIngredients=b.Ingredients??"";_showModal=true;}
    void CloseModal(){_showModal=false;}
    async Task SaveItem(){
        if(string.IsNullOrWhiteSpace(_edit.BaseNoteName)){_msg="名称不能为空";_msgType="err";return;}
        // Convert newlines to commas for ingredients
        if(!string.IsNullOrWhiteSpace(_editIngredients)){
            var ing=_editIngredients.Replace("\r\n","\n").Replace("\r","\n");
            var lines=ing.Split('\n').Select(s=>s.Trim()).Where(s=>!string.IsNullOrEmpty(s));
            _edit.Ingredients=string.Join(",",lines);
        }else _edit.Ingredients=null;
        try{if(!_editing){_edit.CreatedAt=DateTime.Now;Db.BaseNotes.Add(_edit);}else Db.BaseNotes.Update(_edit);await Db.SaveChangesAsync();await Auditor.LogAsync(_adminId,_adminName,_editing?"编辑基香":"新建基香","BaseNote",_edit.BaseNoteId,_edit.BaseNoteName);
        // V21: 基香单价变更会影响香调与产品成本，触发全量产品成本重算
        if(_editing){try{await CostEngine.PreloadAllCostDataAsync();await CostEngine.UpdateAllProductCostsAsync();CostEngine.ClearCache();}catch{}}
        _msg=_editing?"已更新，产品成本已同步刷新":"已创建";_msgType="ok";_showModal=false;await LoadItems();}catch(Exception ex){_msg="失败: "+ex.Message;_msgType="err";}
    }
}
