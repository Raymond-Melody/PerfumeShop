@page "/admin/TechCenter/ProductSettingsRatio"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>规格定价管理</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">规格定价管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudSelect @bind-Value="_productId" Label="选择产品" OnSelectedValuesChanged="LoadData">
            @foreach (var p in _products)
            {
                <MudSelectItem Value="@p.ProductId">@p.ProductName</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

@if (_productId > 0)
{
    <MudText Typo="Typo.h5" Class="mb-3">容量规格</MudText>
    <MudTable Items="_volumes" Dense="true" Hover="true" Striped="true" Elevation="1" Class="mb-4">
        <HeaderContent><MudTh>VolumeID</MudTh><MudTh>规格名</MudTh><MudTh>容量(ml)</MudTh><MudTh>价格倍率</MudTh><MudTh>状态</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd>@context.VolumeId</MudTd><MudTd>@context.VolumeName</MudTd><MudTd>@context.VolumeMl</MudTd>
            <MudTd>@context.PriceMultiplier?.ToString("F2")x</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "启用" : "停用")</MudChip></MudTd>
        </RowTemplate>
    </MudTable>

    <MudText Typo="Typo.h5" Class="mb-3">当前产品定价</MudText>
    <MudTable Items="_volumePrices" Dense="true" Hover="true" Striped="true" Elevation="1">
        <HeaderContent><MudTh>规格</MudTh><MudTh>价格</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd>@(_volumes.FirstOrDefault(v => v.VolumeId == context.VolumeId)?.VolumeName ?? $"Vol#{context.VolumeId}")</MudTd>
            <MudTd>¥@context.Price.ToString("F2")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private List<Product> _products = new();
    private List<Volume> _volumes = new();
    private List<ProductVolumePrice> _volumePrices = new();
    private int _productId;

    protected override async Task OnInitializedAsync()
    {
        _products = await Db.Products.OrderBy(p => p.ProductName).ToListAsync();
        _volumes = await Db.Volumes.OrderBy(v => v.VolumeMl).ToListAsync();
    }

    private async Task LoadData(int productId)
    {
        _productId = productId;
        _volumePrices = productId > 0 ? await Db.ProductVolumePrices.Where(v => v.ProductId == productId).ToListAsync() : new();
    }
}
