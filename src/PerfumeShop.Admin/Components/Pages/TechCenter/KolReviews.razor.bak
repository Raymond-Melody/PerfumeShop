@page "/admin/TechCenter/KolReviews"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>KOL评审</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">KOL评审管理</MudText>

<MudGrid Class="mb-3">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_search" Placeholder="搜索评审..." Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect @bind-Value="_statusFilter" Placeholder="评审状态" Clearable="true">
            <MudSelectItem Value="@("Pending")">待审</MudSelectItem>
            <MudSelectItem Value="@("Approved")">已通过</MudSelectItem>
            <MudSelectItem Value="@("Rejected")">已拒绝</MudSelectItem>
        </MudSelect>
    </MudItem>
</MudGrid>

<MudTable ServerData="@(new Func<TableState, Task<TableData<ProductReview>>>(ServerReload))"
          @ref="_table" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>ID</MudTh><MudTh>产品</MudTh><MudTh>用户</MudTh><MudTh>评分</MudTh>
        <MudTh>标题</MudTh><MudTh>评论</MudTh><MudTh>时间</MudTh><MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ReviewId</MudTd>
        <MudTd>Product #@context.ProductId</MudTd>
        <MudTd>User #@context.UserId</MudTd>
        <MudTd>
            <MudRating ReadOnly="true" Value="@(context.Rating ?? 0)" Size="Size.Small" Color="Color.Warning" />
        </MudTd>
        <MudTd>@(context.Title ?? "-")</MudTd>
        <MudTd><MudText Typo="Typo.body2">@(context.Comment?.Length > 50 ? context.Comment[..50] + "..." : context.Comment ?? "-")</MudText></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" OnClick="@(() => ViewReview(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

<MudDialog @bind-Visible="_showDetail" Options="new DialogOptions { MaxWidth = MaxWidth.Medium }">
    <TitleContent><MudText Typo="Typo.h6">评审详情 #@_selectedReview?.ReviewId</MudText></TitleContent>
    <DialogContent>
        @if (_selectedReview != null)
        {
            <MudStack Spacing="2">
                <MudText><strong>产品ID:</strong> @_selectedReview.ProductId</MudText>
                <MudText><strong>用户:</strong> User #@_selectedReview.UserId</MudText>
                <MudRating ReadOnly="true" Value="@(_selectedReview.Rating ?? 0)" Color="Color.Warning" />
                @if (!string.IsNullOrEmpty(_selectedReview.Title))
                {
                    <MudText Typo="Typo.h6">@_selectedReview.Title</MudText>
                }
                <MudText>@_selectedReview.Comment</MudText>
                @if (_selectedReview.IsVerifiedPurchase)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">已验证购买</MudChip>
                }
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_selectedReview.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss")</MudText>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDetail = false)" Variant="Variant.Text">关闭</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private MudTable<ProductReview>? _table;
    private string _search = "";
    private string? _statusFilter;
    private bool _showDetail;
    private ProductReview? _selectedReview;

    private async Task<TableData<ProductReview>> ServerReload(TableState state)
    {
        var q = Db.ProductReviews.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(r => (r.Comment != null && r.Comment.Contains(s)) || (r.Title != null && r.Title.Contains(s)));
        }
        if (!string.IsNullOrWhiteSpace(_statusFilter))
            q = q.Where(r => r.Status == _statusFilter);

        var total = await q.CountAsync();
        var items = await q.OrderByDescending(r => r.CreatedAt).Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        return new TableData<ProductReview> { TotalItems = total, Items = items };
    }

    private void ViewReview(ProductReview review) { _selectedReview = review; _showDetail = true; }
}
