@page "/admin/TechCenter/ProductSettingsTypes"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>产品类型配置</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">产品类型配置</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate" Class="mb-3">新建类型</MudButton>

<MudTable Items="_types" Dense="true" Hover="true" Striped="true" Elevation="1">
    <HeaderContent>
        <MudTh>ID</MudTh><MudTh>代码</MudTh><MudTh>显示名</MudTh><MudTh>导航名</MudTh>
        <MudTh>图标</MudTh><MudTh>排序</MudTh><MudTh>需配比</MudTh><MudTh>需审核</MudTh><MudTh>状态</MudTh><MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ConfigId</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.TypeCode</MudChip></MudTd>
        <MudTd>@context.DisplayName</MudTd><MudTd>@context.NavName</MudTd><MudTd>@(context.Icon ?? "-")</MudTd>
        <MudTd>@context.DisplayOrder</MudTd>
        <MudTd>@(context.RequiresRatio == true ? "是" : "否")</MudTd>
        <MudTd>@(context.RequiresReview == true ? "是" : "否")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "启用" : "停用")</MudChip></MudTd>
        <MudTd><MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => Edit(context))" /></MudTd>
    </RowTemplate>
</MudTable>

<MudDialog @bind-Visible="_showEdit" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">@(_editId > 0 ? "编辑" : "新建")类型</MudText></TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="4"><MudTextField @bind-Value="_code" Label="代码" /></MudItem>
            <MudItem xs="4"><MudTextField @bind-Value="_display" Label="显示名" /></MudItem>
            <MudItem xs="4"><MudTextField @bind-Value="_nav" Label="导航名" /></MudItem>
            <MudItem xs="3"><MudTextField @bind-Value="_icon" Label="图标" /></MudItem>
            <MudItem xs="3"><MudNumericField @bind-Value="_order" Label="排序" /></MudItem>
            <MudItem xs="3"><MudSwitch @bind-Value="_reqRatio" Label="需配比" Color="Color.Info" /></MudItem>
            <MudItem xs="3"><MudSwitch @bind-Value="_reqReview" Label="需审核" Color="Color.Warning" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_desc" Label="描述" Lines="2" /></MudItem>
            <MudItem xs="4"><MudSwitch @bind-Value="_active" Label="启用" Color="Color.Success" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEdit = false)" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    private List<ProductTypeConfig> _types = new();
    private bool _showEdit;
    private int _editId;
    private string _code = "", _display = "", _nav = "", _icon = "", _desc = "";
    private int _order;
    private bool? _reqRatio, _reqReview, _active = true;

    protected override async Task OnInitializedAsync() => _types = await Db.ProductTypeConfigs.OrderBy(t => t.DisplayOrder).ToListAsync();

    private void OpenCreate() { _editId = 0; _code = ""; _display = ""; _nav = ""; _icon = ""; _desc = ""; _order = 0; _reqRatio = false; _reqReview = false; _active = true; _showEdit = true; }

    private void Edit(ProductTypeConfig t) { _editId = t.ConfigId; _code = t.TypeCode; _display = t.DisplayName ?? ""; _nav = t.NavName ?? ""; _icon = t.Icon ?? ""; _desc = t.Description ?? ""; _order = t.DisplayOrder ?? 0; _reqRatio = t.RequiresRatio; _reqReview = t.RequiresReview; _active = t.IsActive; _showEdit = true; }

    private async Task Save()
    {
        if (_editId > 0) { var t = await Db.ProductTypeConfigs.FindAsync(_editId); if (t != null) { t.TypeCode = _code; t.DisplayName = _display; t.NavName = _nav; t.Icon = _icon; t.Description = _desc; t.DisplayOrder = _order; t.RequiresRatio = _reqRatio; t.RequiresReview = _reqReview; t.IsActive = _active; Db.ProductTypeConfigs.Update(t); } }
        else { Db.ProductTypeConfigs.Add(new ProductTypeConfig { TypeCode = _code, DisplayName = _display, NavName = _nav, Icon = _icon, Description = _desc, DisplayOrder = _order, RequiresRatio = _reqRatio, RequiresReview = _reqReview, IsActive = _active, CreatedAt = DateTime.Now }); }
        await Db.SaveChangesAsync(); _showEdit = false; _types = await Db.ProductTypeConfigs.OrderBy(t => t.DisplayOrder).ToListAsync();
        Snackbar.Add("类型已保存", Severity.Success);
    }
}
