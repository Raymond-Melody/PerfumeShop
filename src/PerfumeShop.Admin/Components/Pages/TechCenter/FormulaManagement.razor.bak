@page "/admin/TechCenter/FormulaManagement"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>配方库管理</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">配方库管理</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreate">新建配方</MudButton>
</MudStack>

<MudGrid Class="mb-3">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_search" Placeholder="搜索配方名/编码..." Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect @bind-Value="_typeFilter" Placeholder="产品类型" Clearable="true">
            @foreach (var t in _productTypes)
            {
                <MudSelectItem Value="@t">@t</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3" Class="d-flex align-end">
        <MudText Typo="Typo.body2" Color="Color.Secondary">共 @_total 条配方</MudText>
    </MudItem>
</MudGrid>

<MudTable ServerData="@(new Func<TableState, Task<TableData<Recipe>>>(ServerReload))"
          @ref="_table" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>RecipeID</MudTh>
        <MudTh>配方编码</MudTh>
        <MudTh>配方名称</MudTh>
        <MudTh>产品类型</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>创建时间</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.RecipeId</MudTd>
        <MudTd>@context.RecipeCode</MudTd>
        <MudTd>@context.RecipeName</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@(context.ProductType ?? "-")</MudChip></MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">
                @(context.IsActive == true ? "活跃" : "停用")
            </MudChip>
        </MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => EditRecipe(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => DeleteRecipe(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

@* 成分编辑面板 *@
<MudDialog @bind-Visible="_showIngredients" Options="new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">配方成分 - @_selectedRecipe?.RecipeName</MudText></TitleContent>
    <DialogContent>
        @if (_selectedRecipe != null)
        {
            <MudTable Items="_ingredients" Dense="true" Hover="true" Class="mb-3">
                <HeaderContent>
                    <MudTh>成分名称</MudTh><MudTh>香调ID</MudTh><MudTh>百分比</MudTh><MudTh>操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.IngredientName</MudTd>
                    <MudTd>@context.NoteId</MudTd>
                    <MudTd>@context.Percentage?.ToString("F2")%</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => RemoveIngredient(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_newIngName" Label="成分名称" />
                <MudNumericField @bind-Value="_newIngNoteId" Label="香调ID" />
                <MudNumericField @bind-Value="_newIngPct" Label="百分比" Format="F2" />
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="AddIngredient">添加</MudButton>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showIngredients = false)" Variant="Variant.Text">关闭</MudButton>
    </DialogActions>
</MudDialog>

@* 新建/编辑对话框 *@
<MudDialog @bind-Visible="_showEdit" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">@(_editId > 0 ? "编辑" : "新建")配方</MudText></TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6"><MudTextField @bind-Value="_editCode" Label="配方编码" /></MudItem>
            <MudItem xs="6"><MudTextField @bind-Value="_editName" Label="配方名称" /></MudItem>
            <MudItem xs="6"><MudTextField @bind-Value="_editType" Label="产品类型" /></MudItem>
            <MudItem xs="6"><MudSwitch @bind-Value="_editActive" Label="活跃" Color="Color.Success" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_editDesc" Label="描述" Lines="3" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEdit = false)" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="SaveRecipe" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_saving">
            @_saving ? "保存中..." : "保存"
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudTable<Recipe>? _table;
    private string _search = "";
    private string? _typeFilter;
    private int _total;
    private List<string> _productTypes = new();
    private bool _showEdit, _showIngredients, _saving;

    // 编辑
    private int _editId;
    private string? _editCode, _editName, _editType, _editDesc;
    private bool _editActive;

    // 成分
    private Recipe? _selectedRecipe;
    private List<RecipeIngredient> _ingredients = new();
    private string? _newIngName;
    private int _newIngNoteId;
    private double _newIngPct;

    protected override async Task OnInitializedAsync()
    {
        _productTypes = await Db.Recipes.Where(r => r.ProductType != null)
            .Select(r => r.ProductType!).Distinct().OrderBy(t => t).ToListAsync();
    }

    private async Task<TableData<Recipe>> ServerReload(TableState state)
    {
        var q = Db.Recipes.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(r => (r.RecipeName != null && r.RecipeName.Contains(s)) ||
                             (r.RecipeCode != null && r.RecipeCode.Contains(s)));
        }
        if (!string.IsNullOrWhiteSpace(_typeFilter))
            q = q.Where(r => r.ProductType == _typeFilter);

        _total = await q.CountAsync();
        var items = await q.OrderBy(r => r.RecipeCode).Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        return new TableData<Recipe> { TotalItems = _total, Items = items };
    }

    private void OpenCreate()
    {
        _editId = 0; _editCode = ""; _editName = ""; _editType = ""; _editDesc = ""; _editActive = true;
        _showEdit = true;
    }

    private async Task EditRecipe(Recipe recipe)
    {
        _editId = recipe.RecipeId;
        _editCode = recipe.RecipeCode;
        _editName = recipe.RecipeName;
        _editType = recipe.ProductType;
        _editDesc = recipe.Description;
        _editActive = recipe.IsActive ?? false;
        _showEdit = true;

        // 加载成分
        _selectedRecipe = recipe;
        _ingredients = await Db.RecipeIngredients.AsNoTracking()
            .Where(i => i.RecipeId == recipe.RecipeId).OrderBy(i => i.Id).ToListAsync();
        _showIngredients = true;
    }

    private async Task SaveRecipe()
    {
        _saving = true;
        if (_editId > 0)
        {
            var recipe = await Db.Recipes.FindAsync(_editId);
            if (recipe != null)
            {
                recipe.RecipeCode = _editCode;
                recipe.RecipeName = _editName;
                recipe.ProductType = _editType;
                recipe.Description = _editDesc;
                recipe.IsActive = _editActive;
                recipe.UpdatedAt = DateTime.Now;
                Db.Recipes.Update(recipe);
            }
        }
        else
        {
            Db.Recipes.Add(new Recipe
            {
                RecipeCode = _editCode, RecipeName = _editName, ProductType = _editType,
                Description = _editDesc, IsActive = _editActive, CreatedAt = DateTime.Now
            });
        }
        await Db.SaveChangesAsync();
        _saving = false;
        _showEdit = false;
        Snackbar.Add("配方保存成功", Severity.Success);
        await _table!.ReloadServerData();
    }

    private async Task DeleteRecipe(Recipe recipe)
    {
        Db.Recipes.Remove(recipe);
        await Db.SaveChangesAsync();
        Snackbar.Add($"配方 {recipe.RecipeName} 已删除", Severity.Warning);
        await _table!.ReloadServerData();
    }

    private async Task AddIngredient()
    {
        if (_selectedRecipe == null || string.IsNullOrWhiteSpace(_newIngName)) return;
        var ing = new RecipeIngredient
        {
            RecipeId = _selectedRecipe.RecipeId,
            IngredientName = _newIngName,
            NoteId = _newIngNoteId,
            Percentage = _newIngPct
        };
        Db.RecipeIngredients.Add(ing);
        await Db.SaveChangesAsync();
        _ingredients = await Db.RecipeIngredients.AsNoTracking()
            .Where(i => i.RecipeId == _selectedRecipe.RecipeId).OrderBy(i => i.Id).ToListAsync();
        _newIngName = ""; _newIngNoteId = 0; _newIngPct = 0;
        Snackbar.Add("成分已添加", Severity.Success);
    }

    private async Task RemoveIngredient(RecipeIngredient ing)
    {
        var entity = await Db.RecipeIngredients.FindAsync(ing.Id);
        if (entity != null) { Db.RecipeIngredients.Remove(entity); await Db.SaveChangesAsync(); }
        if (_selectedRecipe != null)
            _ingredients = await Db.RecipeIngredients.AsNoTracking()
                .Where(i => i.RecipeId == _selectedRecipe.RecipeId).OrderBy(i => i.Id).ToListAsync();
        Snackbar.Add("成分已删除", Severity.Warning);
    }
}
