@page "/admin/TechCenter/BaseNoteManagement"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>基调管理</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">基调管理</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">新建基调</MudButton>
</MudStack>

<MudTable ServerData="@(new Func<TableState, Task<TableData<BaseNote>>>(ServerReload))"
          @ref="_table" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>ID</MudTh><MudTh>基调名称</MudTh><MudTh>描述</MudTh><MudTh>成分</MudTh>
        <MudTh>单价</MudTh><MudTh>状态</MudTh><MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.BaseNoteId</MudTd>
        <MudTd>@context.BaseNoteName</MudTd>
        <MudTd>@(context.Description?.Length > 40 ? context.Description[..40] + "..." : context.Description ?? "-")</MudTd>
        <MudTd>@(context.Ingredients?.Length > 40 ? context.Ingredients[..40] + "..." : context.Ingredients ?? "-")</MudTd>
        <MudTd>¥@(context.UnitPrice?.ToString("F2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "启用" : "停用")</MudChip></MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => Edit(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

<MudDialog @bind-Visible="_showEdit" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">@(_editId > 0 ? "编辑" : "新建")基调</MudText></TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6"><MudTextField @bind-Value="_editName" Label="基调名称" Required="true" /></MudItem>
            <MudItem xs="3"><MudNumericField @bind-Value="_editPrice" Label="单价" Format="F2" /></MudItem>
            <MudItem xs="3"><MudSwitch @bind-Value="_editActive" Label="启用" Color="Color.Success" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_editDesc" Label="描述" Lines="2" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_editIngredients" Label="成分" Lines="2" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEdit = false)" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_saving">@(_saving ? "保存中..." : "保存")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudTable<BaseNote>? _table;
    private bool _showEdit, _saving;
    private int _editId;
    private string _editName = "", _editDesc = "", _editIngredients = "";
    private decimal _editPrice;
    private bool _editActive = true;

    private async Task<TableData<BaseNote>> ServerReload(TableState state)
    {
        var total = await Db.BaseNotes.CountAsync();
        var items = await Db.BaseNotes.AsNoTracking().OrderBy(b => b.BaseNoteName)
            .Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        return new TableData<BaseNote> { TotalItems = total, Items = items };
    }

    private void OpenCreate() { _editId = 0; _editName = ""; _editDesc = ""; _editIngredients = ""; _editPrice = 0; _editActive = true; _showEdit = true; }

    private void Edit(BaseNote b) { _editId = b.BaseNoteId; _editName = b.BaseNoteName; _editDesc = b.Description ?? ""; _editIngredients = b.Ingredients ?? ""; _editPrice = b.UnitPrice ?? 0; _editActive = b.IsActive ?? true; _showEdit = true; }

    private async Task Save()
    {
        _saving = true;
        if (_editId > 0)
        {
            var b = await Db.BaseNotes.FindAsync(_editId);
            if (b != null) { b.BaseNoteName = _editName; b.Description = _editDesc; b.Ingredients = _editIngredients; b.UnitPrice = _editPrice; b.IsActive = _editActive; Db.BaseNotes.Update(b); }
        }
        else { Db.BaseNotes.Add(new BaseNote { BaseNoteName = _editName, Description = _editDesc, Ingredients = _editIngredients, UnitPrice = _editPrice, IsActive = _editActive, CreatedAt = DateTime.Now }); }
        await Db.SaveChangesAsync(); _saving = false; _showEdit = false;
        Snackbar.Add("基调保存成功", Severity.Success); await _table!.ReloadServerData();
    }

    private async Task Delete(BaseNote b) { Db.BaseNotes.Remove(b); await Db.SaveChangesAsync(); Snackbar.Add($"基调 {b.BaseNoteName} 已删除", Severity.Warning); await _table!.ReloadServerData(); }
}
