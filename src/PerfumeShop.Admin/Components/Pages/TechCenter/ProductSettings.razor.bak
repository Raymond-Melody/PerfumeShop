@page "/admin/TechCenter/ProductSettings"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>产品配置</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">产品配置</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
    <MudTabPanel Text="产品列表" Icon="@Icons.Material.Filled.ShoppingBag">
        <MudStack Row="true" Class="mb-3">
            <MudTextField @bind-Value="_prodSearch" Placeholder="搜索产品..." Immediate="true" DebounceInterval="300" Style="max-width:300px" />
        </MudStack>
        <MudTable Items="_filteredProducts" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>ID</MudTh><MudTh>产品名称</MudTh><MudTh>分类</MudTh><MudTh>类型</MudTh>
                <MudTh>基准价</MudTh><MudTh>状态</MudTh><MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ProductId</MudTd>
                <MudTd>@context.ProductName</MudTd>
                <MudTd>@(context.Category ?? "-")</MudTd>
                <MudTd>@(context.ProductType ?? "-")</MudTd>
                <MudTd>¥@context.BasePrice.ToString("F2")</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "在售" : "下架")</MudChip></MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => EditProduct(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="产品类型" Icon="@Icons.Material.Filled.Category">
        <MudStack Row="true" Class="mb-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateType">新建类型</MudButton>
        </MudStack>
        <MudTable Items="_typeConfigs" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>ID</MudTh><MudTh>类型代码</MudTh><MudTh>显示名</MudTh><MudTh>导航名</MudTh>
                <MudTh>图标</MudTh><MudTh>排序</MudTh><MudTh>状态</MudTh><MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ConfigId</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small">@context.TypeCode</MudChip></MudTd>
                <MudTd>@context.DisplayName</MudTd>
                <MudTd>@context.NavName</MudTd>
                <MudTd>@(context.Icon ?? "-")</MudTd>
                <MudTd>@context.DisplayOrder</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "启用" : "停用")</MudChip></MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => EditType(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="规格定价" Icon="@Icons.Material.Filled.AttachMoney">
        <MudGrid Class="mb-3">
            <MudItem xs="6">
                <MudSelect @bind-Value="_vpProductId" Label="选择产品" OnSelectedValuesChanged="LoadVolumePrices">
                    @foreach (var p in _products)
                    {
                        <MudSelectItem Value="@p.ProductId">@p.ProductName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
        @if (_vpProductId > 0)
        {
            <MudTable Items="_volumePrices" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>规格</MudTh><MudTh>价格</MudTh><MudTh>倍率</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(_volumes.FirstOrDefault(v => v.VolumeId == context.VolumeId)?.VolumeName ?? $"Vol#{context.VolumeId}")</MudTd>
                    <MudTd>¥@context.Price.ToString("F2")</MudTd>
                    <MudTd>@(_volumes.FirstOrDefault(v => v.VolumeId == context.VolumeId)?.PriceMultiplier?.ToString("F2") ?? "-")x</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>
</MudTabs>

@* 产品编辑 *@
<MudDialog @bind-Visible="_showProdEdit" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">编辑产品</MudText></TitleContent>
    <DialogContent>
        @if (_editProd != null)
        {
            <MudGrid>
                <MudItem xs="6"><MudTextField @bind-Value="_editProd.ProductName" Label="名称" /></MudItem>
                <MudItem xs="3"><MudTextField @bind-Value="_editProd.Category" Label="分类" /></MudItem>
                <MudItem xs="3"><MudTextField @bind-Value="_editProd.ProductType" Label="类型" /></MudItem>
                <MudItem xs="4"><MudNumericField @bind-Value="_editBasePrice" Label="基准价" Format="F2" /></MudItem>
                <MudItem xs="4"><MudNumericField @bind-Value="_editBomCost" Label="BOM成本" Format="F2" /></MudItem>
                <MudItem xs="4"><MudSwitch @bind-Value="_editActive" Label="在售" Color="Color.Success" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_editProd.Description" Label="描述" Lines="2" /></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showProdEdit = false)" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="SaveProduct" Variant="Variant.Filled" Color="Color.Primary">保存</MudButton>
    </DialogActions>
</MudDialog>

@* 类型编辑 *@
<MudDialog @bind-Visible="_showTypeEdit" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">@(_typeEditId > 0 ? "编辑" : "新建")产品类型</MudText></TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="4"><MudTextField @bind-Value="_typeCode" Label="类型代码" /></MudItem>
            <MudItem xs="4"><MudTextField @bind-Value="_typeDisplayName" Label="显示名" /></MudItem>
            <MudItem xs="4"><MudTextField @bind-Value="_typeNavName" Label="导航名" /></MudItem>
            <MudItem xs="4"><MudTextField @bind-Value="_typeIcon" Label="图标" /></MudItem>
            <MudItem xs="4"><MudNumericField @bind-Value="_typeOrder" Label="排序" /></MudItem>
            <MudItem xs="4"><MudSwitch @bind-Value="_typeActive" Label="启用" Color="Color.Success" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_typeDesc" Label="描述" Lines="2" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showTypeEdit = false)" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="SaveType" Variant="Variant.Filled" Color="Color.Primary">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<Product> _products = new();
    private List<ProductTypeConfig> _typeConfigs = new();
    private List<Volume> _volumes = new();
    private List<ProductVolumePrice> _volumePrices = new();
    private string _prodSearch = "";
    private int _vpProductId;
    private bool _showProdEdit, _showTypeEdit;
    private Product? _editProd;
    private decimal _editBasePrice, _editBomCost;
    private bool _editActive;

    private int _typeEditId;
    private string _typeCode = "", _typeDisplayName = "", _typeNavName = "", _typeIcon = "", _typeDesc = "";
    private int _typeOrder;
    private bool _typeActive = true;

    private List<Product> _filteredProducts => string.IsNullOrWhiteSpace(_prodSearch)
        ? _products : _products.Where(p => p.ProductName.Contains(_prodSearch.Trim())).ToList();

    protected override async Task OnInitializedAsync()
    {
        _products = await Db.Products.OrderBy(p => p.ProductName).ToListAsync();
        _typeConfigs = await Db.ProductTypeConfigs.OrderBy(t => t.DisplayOrder).ToListAsync();
        _volumes = await Db.Volumes.OrderBy(v => v.VolumeMl).ToListAsync();
    }

    private void EditProduct(Product p) { _editProd = p; _editBasePrice = p.BasePrice; _editBomCost = p.Bomcost ?? 0; _editActive = p.IsActive ?? true; _showProdEdit = true; }

    private async Task SaveProduct()
    {
        if (_editProd == null) return;
        _editProd.BasePrice = _editBasePrice; _editProd.Bomcost = _editBomCost; _editProd.IsActive = _editActive;
        Db.Products.Update(_editProd); await Db.SaveChangesAsync();
        _showProdEdit = false; _products = await Db.Products.OrderBy(p => p.ProductName).ToListAsync();
        Snackbar.Add("产品已更新", Severity.Success);
    }

    private void OpenCreateType() { _typeEditId = 0; _typeCode = ""; _typeDisplayName = ""; _typeNavName = ""; _typeIcon = ""; _typeDesc = ""; _typeOrder = 0; _typeActive = true; _showTypeEdit = true; }

    private void EditType(ProductTypeConfig t) { _typeEditId = t.ConfigId; _typeCode = t.TypeCode; _typeDisplayName = t.DisplayName ?? ""; _typeNavName = t.NavName ?? ""; _typeIcon = t.Icon ?? ""; _typeDesc = t.Description ?? ""; _typeOrder = t.DisplayOrder ?? 0; _typeActive = t.IsActive ?? true; _showTypeEdit = true; }

    private async Task SaveType()
    {
        if (_typeEditId > 0)
        {
            var t = await Db.ProductTypeConfigs.FindAsync(_typeEditId);
            if (t != null) { t.TypeCode = _typeCode; t.DisplayName = _typeDisplayName; t.NavName = _typeNavName; t.Icon = _typeIcon; t.Description = _typeDesc; t.DisplayOrder = _typeOrder; t.IsActive = _typeActive; Db.ProductTypeConfigs.Update(t); }
        }
        else { Db.ProductTypeConfigs.Add(new ProductTypeConfig { TypeCode = _typeCode, DisplayName = _typeDisplayName, NavName = _typeNavName, Icon = _typeIcon, Description = _typeDesc, DisplayOrder = _typeOrder, IsActive = _typeActive, CreatedAt = DateTime.Now }); }
        await Db.SaveChangesAsync(); _showTypeEdit = false;
        _typeConfigs = await Db.ProductTypeConfigs.OrderBy(t => t.DisplayOrder).ToListAsync();
        Snackbar.Add("类型已保存", Severity.Success);
    }

    private async Task LoadVolumePrices(int productId)
    {
        _vpProductId = productId;
        if (productId > 0) _volumePrices = await Db.ProductVolumePrices.Where(v => v.ProductId == productId).ToListAsync();
        else _volumePrices.Clear();
    }
}
