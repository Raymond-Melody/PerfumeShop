@page "/admin/TechCenter/RecipePublish"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>配方发布</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">配方发布管理</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" Class="mb-4">
    <MudTabPanel Text="Accord发布" Icon="@Icons.Material.Filled.Spa">
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="_selectedRecipeId" Label="选择配方" Clearable="true">
                    @foreach (var r in _recipes)
                    {
                        <MudSelectItem Value="@r.RecipeId">@r.RecipeName (@r.RecipeCode)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="_selectedNoteId" Label="选择香调" Clearable="true" Disabled="@(_selectedRecipeId == 0)">
                    @foreach (var n in _recipeNotes)
                    {
                        <MudSelectItem Value="@n.NoteId">@n.NoteType - Note #@n.NoteId (占比@(n.Percentage)% )</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2"><MudNumericField @bind-Value="_batchSize" Label="批量大小" /></MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PublishAccord" Disabled="@(_selectedRecipeId == 0 || _selectedNoteId == 0)">发布Accord</MudButton>
            </MudItem>
        </MudGrid>

        <MudTable Items="_publishedAccords" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>AccordID</MudTh><MudTh>配方</MudTh><MudTh>香调</MudTh><MudTh>批量</MudTh>
                <MudTh>状态</MudTh><MudTh>发布人</MudTh><MudTh>发布时间</MudTh><MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.AccordRecipeId</MudTd>
                <MudTd>@context.RecipeName</MudTd>
                <MudTd>Note #@context.NoteId</MudTd>
                <MudTd>@context.BatchSize</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Status == "Published" ? Color.Success : Color.Warning)">@context.Status</MudChip></MudTd>
                <MudTd>@context.PublishedBy</MudTd>
                <MudTd>@context.PublishedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
                <MudTd>
                    @if (context.Status == "Published")
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Archive" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => DeprecateAccord(context))" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="产品配方发布" Icon="@Icons.Material.Filled.Inventory2">
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="_pubRecipeId" Label="选择配方" Clearable="true">
                    @foreach (var r in _recipes)
                    {
                        <MudSelectItem Value="@r.RecipeId">@r.RecipeName (@r.RecipeCode)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="_pubProductId" Label="选择产品" Clearable="true">
                    @foreach (var p in _products)
                    {
                        <MudSelectItem Value="@p.ProductId">@p.ProductName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2"><MudNumericField @bind-Value="_pubBatch" Label="批量大小" /></MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="PublishProduct" Disabled="@(_pubRecipeId == 0 || _pubProductId == 0)">发布产品</MudButton>
            </MudItem>
        </MudGrid>

        <MudTable Items="_publishedProducts" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>ID</MudTh><MudTh>配方</MudTh><MudTh>产品</MudTh><MudTh>批量</MudTh>
                <MudTh>状态</MudTh><MudTh>发布人</MudTh><MudTh>发布时间</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ProductRecipeId</MudTd>
                <MudTd>Recipe #@context.RecipeId</MudTd>
                <MudTd>Product #@context.ProductId</MudTd>
                <MudTd>@context.BatchSize</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Status == "Published" ? Color.Success : Color.Warning)">@context.Status</MudChip></MudTd>
                <MudTd>@context.PublishedBy</MudTd>
                <MudTd>@context.PublishedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>
</MudTabs>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<Recipe> _recipes = new();
    private List<Product> _products = new();
    private List<RecipeNote> _recipeNotes = new();
    private List<RecipeAccord> _publishedAccords = new();
    private List<RecipeProduct> _publishedProducts = new();

    private int _selectedRecipeId, _selectedNoteId, _batchSize = 100;
    private int _pubRecipeId, _pubProductId, _pubBatch = 100;

    protected override async Task OnInitializedAsync()
    {
        _recipes = await Db.Recipes.Where(r => r.IsActive == true).OrderBy(r => r.RecipeCode).ToListAsync();
        _products = await Db.Products.OrderBy(p => p.ProductName).ToListAsync();
        _publishedAccords = await Db.RecipeAccords.AsNoTracking().OrderByDescending(a => a.PublishedAt).ToListAsync();
        _publishedProducts = await Db.RecipeProducts.AsNoTracking().OrderByDescending(p => p.PublishedAt).ToListAsync();
    }

    private async Task OnRecipeChanged(int recipeId)
    {
        _selectedRecipeId = recipeId;
        _selectedNoteId = 0;
        if (recipeId > 0)
            _recipeNotes = await Db.RecipeNotes.AsNoTracking().Where(n => n.RecipeId == recipeId).ToListAsync();
        else
            _recipeNotes.Clear();
    }

    private async Task PublishAccord()
    {
        if (_selectedRecipeId == 0 || _selectedNoteId == 0) return;
        var recipe = _recipes.FirstOrDefault(r => r.RecipeId == _selectedRecipeId);
        var accord = new RecipeAccord
        {
            RecipeId = _selectedRecipeId, NoteId = _selectedNoteId,
            BatchSize = _batchSize, Status = "Published",
            PublishedBy = "Admin", PublishedAt = DateTime.Now,
            CreatedAt = DateTime.Now, RecipeName = recipe?.RecipeName
        };
        Db.RecipeAccords.Add(accord);
        Db.RecipePublishLogs.Add(new RecipePublishLog { RecipeId = _selectedRecipeId, PublishType = "Accord", PublishedBy = "Admin", PublishedAt = DateTime.Now });
        await Db.SaveChangesAsync();
        _publishedAccords = await Db.RecipeAccords.AsNoTracking().OrderByDescending(a => a.PublishedAt).ToListAsync();
        Snackbar.Add("Accord发布成功", Severity.Success);
    }

    private async Task DeprecateAccord(RecipeAccord accord)
    {
        accord.Status = "Deprecated";
        Db.RecipeAccords.Update(accord);
        await Db.SaveChangesAsync();
        _publishedAccords = await Db.RecipeAccords.AsNoTracking().OrderByDescending(a => a.PublishedAt).ToListAsync();
        Snackbar.Add("Accord已废弃", Severity.Warning);
    }

    private async Task PublishProduct()
    {
        if (_pubRecipeId == 0 || _pubProductId == 0) return;
        var rp = new RecipeProduct
        {
            RecipeId = _pubRecipeId, ProductId = _pubProductId,
            BatchSize = _pubBatch, Status = "Published",
            PublishedBy = "Admin", PublishedAt = DateTime.Now, CreatedAt = DateTime.Now
        };
        Db.RecipeProducts.Add(rp);
        Db.RecipePublishLogs.Add(new RecipePublishLog { RecipeId = _pubRecipeId, PublishType = "Product", PublishedBy = "Admin", PublishedAt = DateTime.Now });
        await Db.SaveChangesAsync();
        _publishedProducts = await Db.RecipeProducts.AsNoTracking().OrderByDescending(p => p.PublishedAt).ToListAsync();
        Snackbar.Add("产品配方发布成功", Severity.Success);
    }
}
