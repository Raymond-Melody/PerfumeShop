@page "/admin/TechCenter/ProductSettingsModals"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>产品弹窗配置</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">产品弹窗配置预览</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">产品配置中使用的弹窗模板管理，包括产品编辑弹窗、类型编辑弹窗、瓶型配置弹窗。</MudAlert>

<MudGrid>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.EditNote" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                <MudText Typo="Typo.h6">产品编辑弹窗</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">编辑产品名称、分类、类型、基准价、BOM成本、状态等</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/admin/TechCenter/ProductSettings">前往配置</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                <MudText Typo="Typo.h6">类型配置弹窗</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">管理产品类型代码、显示名、图标、排序、配比/审核需求</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="/admin/TechCenter/ProductSettingsTypes">前往配置</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.WineBar" Size="Size.Large" Color="Color.Tertiary" Class="mb-2" />
                <MudText Typo="Typo.h6">瓶型配置弹窗</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">管理产品关联瓶型及自定义定价</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Tertiary" Href="/admin/TechCenter/CreateProductBottlesTable">前往配置</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    // 配置导航页面，无数据逻辑
}
