@page "/admin/TechCenter/NoteManagement"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>香调库管理</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">香调库管理</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreate">新建香调</MudButton>
</MudStack>

<MudGrid Class="mb-3">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_search" Placeholder="搜索香调名..." Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect @bind-Value="_typeFilter" Placeholder="香调类型" Clearable="true">
            <MudSelectItem Value="@("Top")">前调 Top</MudSelectItem>
            <MudSelectItem Value="@("Middle")">中调 Middle</MudSelectItem>
            <MudSelectItem Value="@("Base")">基调 Base</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3" Class="d-flex align-end">
        <MudText Typo="Typo.body2" Color="Color.Secondary">共 @_total 个香调</MudText>
    </MudItem>
</MudGrid>

<MudTable ServerData="@(new Func<TableState, Task<TableData<FragranceNote>>>(ServerReload))"
          @ref="_table" Hover="true" Dense="true" Striped="true" RowsPerPage="20">
    <HeaderContent>
        <MudTh>NoteID</MudTh>
        <MudTh>香调名称</MudTh>
        <MudTh>类型</MudTh>
        <MudTh>建议百分比</MudTh>
        <MudTh>价格加成</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.NoteId</MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                @if (!string.IsNullOrEmpty(context.ImageUrl))
                {
                    <MudAvatar Size="Size.Small"><MudImage Src="@context.ImageUrl" Width="28" Height="28" /></MudAvatar>
                }
                <MudText>@context.NoteName</MudText>
            </MudStack>
        </MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.NoteType == "Top" ? Color.Info : context.NoteType == "Middle" ? Color.Warning : Color.Secondary)">@context.NoteType</MudChip></MudTd>
        <MudTd>@(context.RecommendedPercentage?.ToString() ?? "-")%</MudTd>
        <MudTd>¥@(context.PriceAddition?.ToString("F2") ?? "0.00")</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">
                @(context.IsActive == true ? "启用" : "停用")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => EditNote(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteNote(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent><MudTablePager /></PagerContent>
</MudTable>

<MudDialog @bind-Visible="_showEdit" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent><MudText Typo="Typo.h6">@(_editId > 0 ? "编辑" : "新建")香调</MudText></TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6"><MudTextField @bind-Value="_editName" Label="香调名称" Required="true" /></MudItem>
            <MudItem xs="6">
                <MudSelect @bind-Value="_editType" Label="香调类型" Required="true">
                    <MudSelectItem Value="@("Top")">前调 Top</MudSelectItem>
                    <MudSelectItem Value="@("Middle")">中调 Middle</MudSelectItem>
                    <MudSelectItem Value="@("Base")">基调 Base</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="4"><MudNumericField @bind-Value="_editRecPct" Label="建议百分比" /></MudItem>
            <MudItem xs="4"><MudNumericField @bind-Value="_editPrice" Label="价格加成" Format="F2" /></MudItem>
            <MudItem xs="4"><MudSwitch @bind-Value="_editActive" Label="启用" Color="Color.Success" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_editDesc" Label="描述" Lines="2" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_editIngredients" Label="成分列表" Lines="2" /></MudItem>
            <MudItem xs="6"><MudTextField @bind-Value="_editImageUrl" Label="图片URL" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEdit = false)" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="SaveNote" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_saving">
            @_saving ? "保存中..." : "保存"
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudTable<FragranceNote>? _table;
    private string _search = "";
    private string? _typeFilter;
    private int _total;
    private bool _showEdit, _saving;
    private int _editId;
    private string _editName = "", _editType = "Top", _editDesc = "", _editIngredients = "", _editImageUrl = "";
    private int? _editRecPct;
    private decimal _editPrice;
    private bool _editActive;

    private async Task<TableData<FragranceNote>> ServerReload(TableState state)
    {
        var q = Db.FragranceNotes.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(n => n.NoteName.Contains(s));
        }
        if (!string.IsNullOrWhiteSpace(_typeFilter))
            q = q.Where(n => n.NoteType == _typeFilter);

        _total = await q.CountAsync();
        var items = await q.OrderBy(n => n.NoteType).ThenBy(n => n.NoteName)
            .Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync();
        return new TableData<FragranceNote> { TotalItems = _total, Items = items };
    }

    private void OpenCreate()
    {
        _editId = 0; _editName = ""; _editType = "Top"; _editDesc = ""; _editIngredients = "";
        _editImageUrl = ""; _editRecPct = null; _editPrice = 0; _editActive = true;
        _showEdit = true;
    }

    private void EditNote(FragranceNote note)
    {
        _editId = note.NoteId;
        _editName = note.NoteName; _editType = note.NoteType;
        _editDesc = note.Description ?? ""; _editIngredients = note.Ingredients ?? "";
        _editImageUrl = note.ImageUrl ?? "";
        _editRecPct = note.RecommendedPercentage; _editPrice = note.PriceAddition ?? 0;
        _editActive = note.IsActive ?? true;
        _showEdit = true;
    }

    private async Task SaveNote()
    {
        _saving = true;
        if (_editId > 0)
        {
            var note = await Db.FragranceNotes.FindAsync(_editId);
            if (note != null)
            {
                note.NoteName = _editName; note.NoteType = _editType;
                note.Description = _editDesc; note.Ingredients = _editIngredients;
                note.ImageUrl = _editImageUrl; note.RecommendedPercentage = _editRecPct;
                note.PriceAddition = _editPrice; note.IsActive = _editActive;
                Db.FragranceNotes.Update(note);
            }
        }
        else
        {
            Db.FragranceNotes.Add(new FragranceNote
            {
                NoteName = _editName, NoteType = _editType, Description = _editDesc,
                Ingredients = _editIngredients, ImageUrl = _editImageUrl,
                RecommendedPercentage = _editRecPct, PriceAddition = _editPrice, IsActive = _editActive
            });
        }
        await Db.SaveChangesAsync();
        _saving = false; _showEdit = false;
        Snackbar.Add("香调保存成功", Severity.Success);
        await _table!.ReloadServerData();
    }

    private async Task DeleteNote(FragranceNote note)
    {
        Db.FragranceNotes.Remove(note);
        await Db.SaveChangesAsync();
        Snackbar.Add($"香调 {note.NoteName} 已删除", Severity.Warning);
        await _table!.ReloadServerData();
    }
}
