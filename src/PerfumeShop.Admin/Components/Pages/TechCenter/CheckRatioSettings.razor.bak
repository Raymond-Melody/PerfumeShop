@page "/admin/TechCenter/CheckRatioSettings"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>配比检查</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4">配比设置检查</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">检查所有配方中香调百分比总和是否为100%，以及配比规则配置。</MudAlert>

<MudTable Items="_checks" Dense="true" Hover="true" Striped="true" Elevation="1">
    <HeaderContent>
        <MudTh>配方ID</MudTh><MudTh>配方名称</MudTh><MudTh>配方编码</MudTh><MudTh>香调数</MudTh>
        <MudTh>百分比总和</MudTh><MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.RecipeId</MudTd><MudTd>@context.RecipeName</MudTd><MudTd>@context.RecipeCode</MudTd>
        <MudTd>@context.NoteCount</MudTd>
        <MudTd><strong>@context.PercentSum.ToString("F1")%</strong></MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(Math.Abs(context.PercentSum - 100) < 0.1 ? Color.Success : Color.Error)">
                @(Math.Abs(context.PercentSum - 100) < 0.1 ? "正常" : "异常")
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private List<RatioCheck> _checks = new();

    protected override async Task OnInitializedAsync()
    {
        var recipes = await Db.Recipes.Where(r => r.IsActive == true).ToListAsync();
        foreach (var r in recipes)
        {
            var notes = await Db.RecipeNotes.Where(n => n.RecipeId == r.RecipeId).ToListAsync();
            _checks.Add(new RatioCheck
            {
                RecipeId = r.RecipeId, RecipeName = r.RecipeName ?? "", RecipeCode = r.RecipeCode ?? "",
                NoteCount = notes.Count, PercentSum = notes.Sum(n => n.Percentage ?? 0)
            });
        }
    }

    private class RatioCheck { public int RecipeId { get; set; } public string RecipeName { get; set; } = ""; public string RecipeCode { get; set; } = ""; public int NoteCount { get; set; } public double PercentSum { get; set; } }
}
