@page "/admin/TechCenter/KolReviews"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Module.techcenter")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PerfumeShop.Admin.Services
@inject PerfumeShopContext Db
@inject IAdminAuditor Auditor
@inject AuthenticationStateProvider AuthState

<PageTitle>KOL审核</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-user-check" style="color:#FF5722;"></i> KOL审核</h2><div class="breadcrumb"><a href="/admin/TechCenter" style="color:#00bcd4;text-decoration:none;">技术中心</a> / <span>KOL审核</span></div></div>
@if(_loaded){
<div class="stats-row"><div class="stat-card @(_filter==""?"stat-active":"")" @onclick='()=>FilterBy("")'><div class="stat-value">@(_totalAll)</div><div class="stat-label">总数</div></div><div class="stat-card @(_filter=="pending"?"stat-active":"")" @onclick='()=>FilterBy("pending")' style="border-left:3px solid #ffc107;"><div class="stat-value" style="color:#ffc107;">@(_totalPending)</div><div class="stat-label">待审核</div></div><div class="stat-card @(_filter=="approved"?"stat-active":"")" @onclick='()=>FilterBy("approved")' style="border-left:3px solid #4CAF50;"><div class="stat-value" style="color:#4CAF50;">@(_totalApproved)</div><div class="stat-label">已通过</div></div><div class="stat-card @(_filter=="rejected"?"stat-active":"")" @onclick='()=>FilterBy("rejected")' style="border-left:3px solid #f44336;"><div class="stat-value" style="color:#f44336;">@(_totalRejected)</div><div class="stat-label">已驳回</div></div></div>
@if(!string.IsNullOrEmpty(_msg)){<div class="alert @(_msgType=="err"?"alert-error":"alert-success")">@_msg</div>}
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>商品ID</th><th>用户</th><th>评分</th><th>评论</th><th>状态</th><th>操作</th></tr></thead><tbody>
@foreach(var r in _reviews){var sBadge=r.Status=="approved"?"s-approved":r.Status=="rejected"?"s-rejected":"s-pending";var sLabel=r.Status=="approved"?"已通过":r.Status=="rejected"?"已驳回":"待审核";<tr><td>#@r.ReviewId</td><td style="color:#00bcd4;">@r.ProductId</td><td>@r.UserId</td><td>@(r.Rating.HasValue?r.Rating.Value.ToString():"-") / 5</td><td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(r.Comment??"-")</td><td><span class="status-badge @sBadge">@sLabel</span></td><td><button class="btn-detail" @onclick='()=>OpenDetail(r)' title="查看详情"><i class="fas fa-eye"></i></button>@if(r.Status=="pending"){<button class="btn-edit" @onclick='()=>Approve(r)'>通过</button><button class="btn-reject" @onclick='()=>Reject(r)'>驳回</button>}</td></tr>}
@if(!_reviews.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:40px;">暂无待审核评价</td></tr>}
</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

@* ---- Detail Modal ---- *@
@if(_showDetail&&_detailReview!=null){
<div class="mo" @onclick="CloseDetail"><div class="mc" @onclick:stopPropagation="true" style="max-width:700px;max-height:85vh;overflow-y:auto;"><div class="mh"><h3><i class="fas fa-clipboard-list" style="color:#FF5722;"></i> 评价详情 #@_detailReview.ReviewId</h3><button class="mcl" @onclick="CloseDetail">&times;</button></div>
<div class="mb">
<div class="ds"><div class="dst"><i class="fas fa-info-circle"></i> 基本信息</div>
<table class="dt-info"><tr><td style="color:#888;">产品ID</td><td>@_detailReview.ProductId</td></tr><tr><td style="color:#888;">用户ID</td><td>@_detailReview.UserId</td></tr><tr><td style="color:#888;">评分</td><td>@(_detailReview.Rating.HasValue?_detailReview.Rating.Value.ToString():"-") / 5</td></tr><tr><td style="color:#888;">状态</td><td><span class="status-badge @(_detailReview.Status=="approved"?"s-approved":_detailReview.Status=="rejected"?"s-rejected":"s-pending")">@(_detailReview.Status=="approved"?"已通过":_detailReview.Status=="rejected"?"已驳回":"待审核")</span></td></tr><tr><td style="color:#888;">创建时间</td><td>@(_detailReview.CreatedAt?.ToString("yyyy-MM-dd HH:mm")??"-")</td></tr></table>
</div>
<div class="ds"><div class="dst"><i class="fas fa-comment"></i> 评论内容</div>
<p style="color:#ccc;line-height:1.6;">@(_detailReview.Comment??"无评论内容")</p>
</div>
@if(_detailReview.Status=="pending"){<div style="display:flex;gap:10px;margin-top:16px;"><button class="btn-edit" @onclick='()=>ApproveFromDetail()'><i class="fas fa-check"></i> 通过</button><button class="btn-reject" @onclick='()=>RejectFromDetail()'><i class="fas fa-times"></i> 驳回</button></div>}
</div><div class="mft"><button class="btn-secondary" @onclick="CloseDetail">关闭</button></div></div></div>
}

<style>


.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}
.stat-card{cursor:pointer;background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;transition:all 0.2s;}
.stat-card:hover{transform:translateY(-2px);}
.stat-active{border-color:#FF5722;box-shadow:0 0 10px rgba(255,87,34,0.2);}
.stat-value{font-size:26px;font-weight:bold;color:#e0e0e0;}.stat-label{font-size:13px;color:#888;}
.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}
.orders-table{width:100%;border-collapse:collapse;}
.orders-table th{background:rgba(255,87,34,0.1);color:#FF5722;padding:14px 16px;font-size:13px;text-align:left;}
.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.btn-detail{background:rgba(255,87,34,0.15);color:#FF5722;border:none;padding:6px 10px;border-radius:6px;cursor:pointer;margin-right:4px;}
.btn-edit{background:rgba(76,175,80,0.15);color:#4CAF50;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;margin-right:6px;}
.s-pending{background:rgba(255,193,7,0.2);color:#ffc107;}.s-approved{background:rgba(76,175,80,0.2);color:#81c784;}.s-rejected{background:rgba(244,67,54,0.2);color:#e57373;}
.mo{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:1000;display:flex;align-items:center;justify-content:center;}.mc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;width:90%;max-width:500px;border:1px solid rgba(255,255,255,0.06);}.mh{padding:20px 25px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;align-items:center;}.mh h3{margin:0;color:#e0e0e0;font-size:18px;}.mcl{background:none;border:none;color:#888;font-size:24px;cursor:pointer;}.mb{padding:25px;}.mft{padding:20px 25px;border-top:1px solid rgba(255,255,255,0.06);display:flex;justify-content:flex-end;gap:10px;}
.ds{margin-bottom:20px;padding:15px;background:rgba(255,255,255,0.03);border-radius:8px;}.dst{color:#FF5722;font-size:15px;font-weight:600;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid rgba(255,255,255,0.06);}
.dt-info{width:100%;border-collapse:collapse;}.dt-info td{padding:6px 12px;border-bottom:1px solid rgba(255,255,255,0.03);color:#ccc;font-size:14px;}
.btn-save{background:linear-gradient(135deg,#FF5722,#BF360C);color:#fff;border:none;padding:10px 24px;border-radius:8px;cursor:pointer;}
.btn-secondary{background:#3a3a4a;color:#e0e0e0;border:none;padding:10px 24px;border-radius:8px;cursor:pointer;}
.btn-edit{background:rgba(76,175,80,0.15);color:#4CAF50;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;margin-right:6px;}
.btn-reject{background:rgba(244,67,54,0.15);color:#e57373;border:none;padding:6px 14px;border-radius:6px;cursor:pointer;}
.alert{padding:15px 20px;border-radius:8px;margin-bottom:20px;}
.alert-success{background:rgba(76,175,80,0.15);color:#81c784;}.alert-error{background:rgba(244,67,54,0.15);color:#e57373;}
</style>

@code {
    private bool _loaded,_showDetail;private int _totalAll,_totalPending,_totalApproved,_totalRejected;private string _msg="",_msgType="",_filter="pending";
    private List<ProductReview> _reviews=new();private ProductReview? _detailReview;
    private int _adminId; private string _adminName="";
    protected override async Task OnInitializedAsync(){var st=await AuthState.GetAuthenticationStateAsync();int.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value,out _adminId);_adminName=st.User.FindFirst(ClaimTypes.Name)?.Value??"";await LoadStats();await LoadReviews();_loaded=true;}
    async Task LoadStats(){
        try{_totalAll=await Db.ProductReviews.CountAsync();_totalPending=await Db.ProductReviews.CountAsync(r=>r.Status=="pending");_totalApproved=await Db.ProductReviews.CountAsync(r=>r.Status=="approved");_totalRejected=await Db.ProductReviews.CountAsync(r=>r.Status=="rejected");}catch{}
    }
    async Task LoadReviews(){
        try{var q=Db.ProductReviews.AsNoTracking().AsQueryable();if(!string.IsNullOrEmpty(_filter))q=q.Where(r=>r.Status==_filter);_reviews=await q.OrderByDescending(r=>r.ReviewId).Take(50).ToListAsync();}catch{}
    }
    async void FilterBy(string f){_filter=f;await LoadReviews();await LoadStats();StateHasChanged();}
    void OpenDetail(ProductReview r){_detailReview=r;_showDetail=true;}
    void CloseDetail(){_showDetail=false;}
    async Task ApproveFromDetail(){if(_detailReview!=null){await Approve(_detailReview);CloseDetail();}}
    async Task RejectFromDetail(){if(_detailReview!=null){await Reject(_detailReview);CloseDetail();}}
    async Task Approve(ProductReview r){
        try{r.Status="approved";Db.ProductReviews.Update(r);await Db.SaveChangesAsync();await Auditor.LogAsync(_adminId,_adminName,"KOL评价审核通过","ProductReview",r.ReviewId,$"商品{r.ProductId}");_msg="已通过";_msgType="ok";await Reload();}catch(Exception ex){_msg="失败: "+ex.Message;_msgType="err";}
    }
    async Task Reject(ProductReview r){
        try{r.Status="rejected";Db.ProductReviews.Update(r);await Db.SaveChangesAsync();await Auditor.LogAsync(_adminId,_adminName,"KOL评价审核驳回","ProductReview",r.ReviewId,$"商品{r.ProductId}");_msg="已驳回";_msgType="ok";await Reload();}catch(Exception ex){_msg="失败: "+ex.Message;_msgType="err";}
    }
    async Task Reload(){await LoadReviews();await LoadStats();}
}
