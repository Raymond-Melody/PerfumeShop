@page "/admin/logistics/shipping"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>待发货订单</PageTitle>
<div class="ph"><h2><i class="fas fa-clipboard-check" style="color:#2196F3;"></i> 待发货订单</h2><div class="br"><a href="/admin/logistics" style="text-decoration:none;color:#2196F3;">返回物流中心</a></div></div>
@if(_l){<div class="tc"><table class="ot"><thead><tr><th>订单号</th><th>收货人</th><th>金额</th><th>状态</th><th>时间</th></tr></thead><tbody>@foreach(var o in _items){<tr><td>@o.OrderNo</td><td>@(o.ShippingName??"-")</td><td>@((o.TotalAmount).ToString("N2"))</td><td>@(o.Status??"-")</td><td>@(o.CreatedAt?.ToString("MM-dd HH:mm")??"-")</td></tr>}@if(!_items.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:30px;">暂无待发货订单</td></tr>}</tbody></table></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;color:#888;}.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}.ot th{background:rgba(33,150,243,0.1);color:#2196F3;padding:14px 16px;font-size:13px;text-align:left;}.ot td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}</style>
@code{bool _l;List<Order> _items=new();protected override async Task OnInitializedAsync(){try{_items=await Db.Orders.AsNoTracking().Where(o=>o.Status=="paid").OrderByDescending(o=>o.OrderId).Take(30).ToListAsync();_l=true;}catch{_l=true;}}}
