<!-- V19物流管理 · 发货确认 -->
@page "/admin/logistics/delivery-confirm/{OrderId:int}"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject ISnackbar Snackbar

<PageTitle>发货确认</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-shipping-fast" style="color:#FF9800;"></i> 发货确认</MudText>

@if (_loaded)
{
    if (_order == null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">订单不存在</MudAlert>
        <MudButton Href="/admin/logistics/shipping" Variant="Variant.Filled" Color="Color.Primary">返回列表</MudButton>
    }
    else
    {
        <MudPaper Class="pa-6 mb-4" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <h5 style="color:#00bcd4;margin-bottom:12px;">订单信息</h5>
                    <table style="width:100%;color:#d0d6e0;font-size:14px;">
                        <tr><td style="color:#888;width:100px;">订单号：</td><td style="font-weight:600;color:#00bcd4;">@_order.OrderNo</td></tr>
                        <tr><td style="color:#888;">金额：</td><td>@_order.TotalAmount.ToString("C2")</td></tr>
                        <tr><td style="color:#888;">支付方式：</td><td>@_order.PaymentMethod</td></tr>
                    </table>
                </MudItem>
                <MudItem xs="12" md="6">
                    <h5 style="color:#00bcd4;margin-bottom:12px;">收货信息</h5>
                    <table style="width:100%;color:#d0d6e0;font-size:14px;">
                        <tr><td style="color:#888;width:100px;">收货人：</td><td>@_order.ShippingName</td></tr>
                        <tr><td style="color:#888;">电话：</td><td>@_order.ShippingPhone</td></tr>
                        <tr><td style="color:#888;">地址：</td><td>@_order.ShippingAddress @_order.ShippingCity @_order.ShippingPostalCode</td></tr>
                    </table>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-6" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
            <h5 style="color:#FF9800;margin-bottom:16px;">发货操作</h5>

            @if (!string.IsNullOrEmpty(_order.ShippingStatus) && _order.ShippingStatus != "Pending")
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    当前物流状态：@_order.ShippingStatus &nbsp; 快递公司：@_order.ShippingCompany &nbsp; 运单号：@_order.TrackingNumber
                </MudAlert>
            }

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_selectedCarrierId" Label="快递公司" Required="true" For="@(() => _selectedCarrierId)">
                        @foreach (var c in _carriers)
                        {
                            <MudSelectItem Value="@c.CompanyId">@c.CompanyName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_trackingNumber" Label="运单号" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_shippingNotes" Label="发货备注" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
            </MudGrid>

            <div class="mt-4" style="display:flex;gap:12px;">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.LocalShipping"
                           OnClick="ConfirmDelivery" Disabled="@(_saving)">确认发货</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.DoneAll"
                           OnClick="MarkDelivered" Disabled="@(_saving)">标记已签收</MudButton>
                <MudButton Href="/admin/logistics/shipping" Variant="Variant.Outlined" Color="Color.Default">返回</MudButton>
            </div>
        </MudPaper>
    }
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

@code {
    [Parameter] public int OrderId { get; set; }

    [Inject] private PerfumeShopContext Db { get; set; } = default!;

    private bool _loaded, _saving;
    private Order? _order;
    private List<ShippingCompany> _carriers = new();
    private int _selectedCarrierId;
    private string _trackingNumber = "";
    private string _shippingNotes = "";

    protected override async Task OnInitializedAsync()
    {
        _order = await Db.Orders.FindAsync(OrderId);
        _carriers = await Db.ShippingCompanies.AsNoTracking().Where(c => c.IsActive == true).ToListAsync();
        if (_order != null)
        {
            _trackingNumber = _order.TrackingNumber ?? "";
            _shippingNotes = _order.ShippingNotes ?? "";
        }
        _loaded = true;
    }

    private async Task ConfirmDelivery()
    {
        if (_order == null) return;
        if (_selectedCarrierId == 0) { Snackbar.Add("请选择快递公司", Severity.Warning); return; }
        if (string.IsNullOrWhiteSpace(_trackingNumber)) { Snackbar.Add("请输入运单号", Severity.Warning); return; }

        _saving = true; StateHasChanged();
        try
        {
            var carrier = _carriers.FirstOrDefault(c => c.CompanyId == _selectedCarrierId);
            await Db.Orders.Where(o => o.OrderId == OrderId)
                .ExecuteUpdateAsync(s => s
                    .SetProperty(o => o.ShippingStatus, "InTransit")
                    .SetProperty(o => o.ShippingCompany, carrier?.CompanyName)
                    .SetProperty(o => o.TrackingNumber, _trackingNumber)
                    .SetProperty(o => o.ShippingNotes, _shippingNotes)
                    .SetProperty(o => o.ShippedAt, DateTime.Now)
                    .SetProperty(o => o.UpdatedAt, DateTime.Now));
            Snackbar.Add("发货确认成功！", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"发货失败：{ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task MarkDelivered()
    {
        if (_order == null) return;
        _saving = true; StateHasChanged();
        try
        {
            await Db.Orders.Where(o => o.OrderId == OrderId)
                .ExecuteUpdateAsync(s => s
                    .SetProperty(o => o.ShippingStatus, "Delivered")
                    .SetProperty(o => o.Status, "Delivered")
                    .SetProperty(o => o.DeliveredAt, DateTime.Now)
                    .SetProperty(o => o.UpdatedAt, DateTime.Now));
            Snackbar.Add("已标记为签收！", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"操作失败：{ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }
}
