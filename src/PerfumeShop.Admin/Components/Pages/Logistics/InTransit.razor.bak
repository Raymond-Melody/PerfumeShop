<!-- V19物流管理 · 在途追踪 -->
@page "/admin/logistics/tracking"
@page "/admin/logistics/in-transit"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models

<PageTitle>在途追踪</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-route" style="color:#2196F3;"></i> 在途追踪</MudText>

@if (_loaded)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_searchText" Placeholder="搜索运单号/订单号/收货人..." Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" />
        </MudItem>
    </MudGrid>

    <MudTable Items="@GetFiltered()" Hover="true" Dense="true" Striped="true">
        <HeaderContent>
            <MudTh>订单号</MudTh><MudTh>收货人</MudTh><MudTh>快递公司</MudTh>
            <MudTh>运单号</MudTh><MudTh>发货时间</MudTh><MudTh>在途天数</MudTh><MudTh>操作</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="font-weight:600;color:#00bcd4;">@context.OrderNo</MudTd>
            <MudTd>@context.ShippingName</MudTd>
            <MudTd>@context.ShippingCompany</MudTd>
            <MudTd Style="color:#2196F3;">@context.TrackingNumber</MudTd>
            <MudTd>@context.ShippedAt?.ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd>@((DateTime.Now - (context.ShippedAt ?? DateTime.Now)).Days) 天</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.DoneAll" Size="Size.Small" Color="Color.Success" OnClick="@(() => MarkReceived(context))" Title="确认签收" />
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" Href="@($"/admin/logistics/delivery-confirm/{context.OrderId}")" Title="查看详情" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" />
}

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private bool _loaded;
    private List<Order> _orders = new();
    private string _searchText = "";

    protected override async Task OnInitializedAsync()
    {
        _orders = await Db.Orders.AsNoTracking()
            .Where(o => o.ShippingStatus == "InTransit" || o.ShippingStatus == "Shipped")
            .OrderByDescending(o => o.ShippedAt).Take(200).ToListAsync();
        _loaded = true;
    }

    private List<Order> GetFiltered()
    {
        var q = _orders.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var s = _searchText.Trim();
            q = q.Where(o => o.OrderNo.Contains(s) || (o.TrackingNumber != null && o.TrackingNumber.Contains(s))
                || (o.ShippingName != null && o.ShippingName.Contains(s)));
        }
        return q.ToList();
    }

    private async Task MarkReceived(Order order)
    {
        await Db.Orders.Where(o => o.OrderId == order.OrderId)
            .ExecuteUpdateAsync(s => s
                .SetProperty(o => o.ShippingStatus, "Delivered")
                .SetProperty(o => o.Status, "Delivered")
                .SetProperty(o => o.DeliveredAt, DateTime.Now)
                .SetProperty(o => o.UpdatedAt, DateTime.Now));
        Snackbar.Add($"订单 {order.OrderNo} 已确认签收", Severity.Success);
        _orders.Remove(order);
    }
}
