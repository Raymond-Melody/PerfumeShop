@page "/admin/logistics/tracking"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.logistics")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>在途跟踪</PageTitle>
<div class="ph"><h2><i class="fas fa-route" style="color:#2196F3;"></i> 在途跟踪</h2><div class="br"><a href="/admin/logistics" style="text-decoration:none;color:#2196F3;">返回物流中心</a></div></div>
@if(_l){<div class="tc"><table class="ot"><thead><tr><th>订单号</th><th>收货人</th><th>物流公司</th><th>状态</th></tr></thead><tbody>@foreach(var o in _items){<tr><td>@o.OrderNo</td><td>@(o.ShippingName??"-")</td><td>@(o.ShippingCompany??"-")</td><td>@(o.Status??"-")</td></tr>}@if(!_items.Any()){<tr><td colspan="4" style="text-align:center;color:#666;padding:30px;">暂无在途订单</td></tr>}</tbody></table></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;color:#888;}.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}.ot th{background:rgba(33,150,243,0.1);color:#2196F3;padding:14px 16px;font-size:13px;text-align:left;}.ot td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}</style>
@code{bool _l;List<Order> _items=new();protected override async Task OnInitializedAsync(){try{_items=await Db.Orders.AsNoTracking().Where(o=>o.Status=="shipped"||o.Status=="in_transit").OrderByDescending(o=>o.OrderId).Take(30).ToListAsync();_l=true;}catch{_l=true;}}}
