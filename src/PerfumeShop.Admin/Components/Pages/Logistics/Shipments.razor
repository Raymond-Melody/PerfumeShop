@page "/admin/logistics/shipments"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.logistics")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@using PerfumeShop.Admin.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject PerfumeShopContext Db
@inject IAdminAuditor Auditor
@inject AuthenticationStateProvider AuthState

<PageTitle>运单管理</PageTitle>
<div class="ph"><h2><i class="fas fa-shipping-fast" style="color:#2196F3;"></i> 运单管理</h2><div class="br"><a href="/admin/logistics" style="color:#2196F3;text-decoration:none;">返回物流中心</a></div></div>
@if(!string.IsNullOrEmpty(_msg)){<div class="al @(_msgType=="err"?"al-e":"al-s")">@_msg</div>}
@if(_l){
<div class="tc"><table class="ot"><thead><tr><th>订单号</th><th>收货人</th><th>物流公司</th><th>运单号</th><th>发货时间</th><th>状态</th><th>操作</th></tr></thead><tbody>
@foreach(var o in _items){<tr><td>@o.OrderNo</td><td>@(o.ShippingName??"-")</td><td>@(o.ShippingCompany??"-")</td><td style="font-family:monospace;">@(o.TrackingNumber??"-")</td><td>@(o.ShippedAt?.ToString("MM-dd HH:mm")??"-")</td><td><span class="badge b-t">@(o.Status??"-")</span></td><td><button class="btn-ok" @onclick="()=>Confirm(o)">确认签收</button></td></tr>}
@if(!_items.Any()){<tr><td colspan="7" style="text-align:center;color:#666;padding:30px;">暂无运单</td></tr>}
</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}

<style>
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;}
.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}
.ot th{background:rgba(33,150,243,0.1);color:#2196F3;padding:12px 16px;font-size:13px;text-align:left;}.ot td{padding:12px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.badge{display:inline-block;padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;}.b-t{background:rgba(33,150,243,0.2);color:#90CAF9;}
.btn-ok{background:linear-gradient(135deg,#4CAF50,#1B5E20);color:#fff;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;font-size:13px;}
.al{padding:12px 18px;border-radius:8px;margin-bottom:16px;}.al-s{background:rgba(76,175,80,0.15);color:#81c784;}.al-e{background:rgba(244,67,54,0.15);color:#e57373;}
</style>

@code {
    private bool _l;
    private string _msg = "", _msgType = "";
    private int _actorId; private string _actorName = "";
    private List<Order> _items = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var s = await AuthState.GetAuthenticationStateAsync();
            int.TryParse(s.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out _actorId);
            _actorName = s.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
            await Load();
            _l = true;
        }
        catch { _l = true; }
    }

    private async Task Load() =>
        _items = await Db.Orders.AsNoTracking().Where(o => o.Status == "shipped" || o.Status == "in_transit")
            .OrderByDescending(o => o.OrderId).Take(50).ToListAsync();

    private async Task Confirm(Order order)
    {
        try
        {
            var o = await Db.Orders.FindAsync(order.OrderId);
            if (o != null)
            {
                o.Status = "delivered"; o.ShippingStatus = "delivered"; o.DeliveredAt = DateTime.Now; o.UpdatedAt = DateTime.Now;
                await Db.SaveChangesAsync();
                await Auditor.LogAsync(_actorId, _actorName, "确认签收", "Order", o.OrderId, o.OrderNo);
            }
            _msg = $"订单 {order.OrderNo} 已确认签收"; _msgType = "ok";
            await Load();
        }
        catch (Exception ex) { _msg = "操作失败: " + ex.Message; _msgType = "err"; }
    }
}
