@page "/admin/logistics"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.logistics")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>物流中心</PageTitle>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);"><h2 style="font-size:24px;color:#fff;margin:0;"><i class="fas fa-truck" style="color:#2196F3;"></i> 物流管理中心</h2><span style="color:#888;">发货 · 在途 · 签收</span></div>
@if(_l){<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;"><div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;"><div style="font-size:26px;font-weight:bold;color:#e0e0e0;">@_c1</div><div style="font-size:13px;color:#888;">待发货</div></div><div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;"><div style="font-size:26px;font-weight:bold;color:#2196F3;">@_c2</div><div style="font-size:13px;color:#888;">已发货</div></div><div style="background:linear-gradient(135deg,#2d2d44,#1e1e32);padding:20px;border-radius:10px;text-align:center;"><div style="font-size:26px;font-weight:bold;color:#4CAF50;">@_c3</div><div style="font-size:13px;color:#888;">物流公司</div></div></div>
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;"><a href="/admin/logistics/shipping" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #FF9800;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-box-open" style="color:#FF9800;margin-right:8px;"></i>待发货</div><div style="font-size:12px;color:#888;margin-top:6px;">待发货订单</div></div></a><a href="/admin/logistics/shipments" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #2196F3;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-truck-loading" style="color:#2196F3;margin-right:8px;"></i>运单管理</div><div style="font-size:12px;color:#888;margin-top:6px;">已发货运单</div></div></a><a href="/admin/logistics/tracking" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #2196F3;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-route" style="color:#2196F3;margin-right:8px;"></i>在途跟踪</div><div style="font-size:12px;color:#888;margin-top:6px;">物流状态跟踪</div></div></a><a href="/admin/logistics/returns" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #F44336;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-undo" style="color:#F44336;margin-right:8px;"></i>退货入库</div><div style="font-size:12px;color:#888;margin-top:6px;">退货退款记录</div></div></a><a href="/admin/logistics/carriers" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #4CAF50;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-building" style="color:#4CAF50;margin-right:8px;"></i>物流公司</div><div style="font-size:12px;color:#888;margin-top:6px;">承运商管理</div></div></a><a href="/admin/logistics/report" style="text-decoration:none;"><div style="background:#2d2d44;padding:18px;border-radius:10px;border-left:3px solid #9C27B0;"><div style="font-size:15px;color:#fff;font-weight:600;"><i class="fas fa-chart-bar" style="color:#9C27B0;margin-right:8px;"></i>物流报表</div><div style="font-size:12px;color:#888;margin-top:6px;">发货统计分析</div></div></a></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
@code{bool _l;int _c1,_c2,_c3;protected override async Task OnInitializedAsync(){try{_c1=await Db.Orders.CountAsync(o=>o.Status=="paid");_c2=await Db.Orders.CountAsync(o=>o.Status=="shipped");_c3=await Db.ShippingCompanies.CountAsync();_l=true;}catch{_l=true;}}}
