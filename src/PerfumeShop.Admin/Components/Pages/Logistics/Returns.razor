@page "/admin/logistics/returns"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.logistics")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>退货管理</PageTitle>
<div class="ph"><h2><i class="fas fa-undo-alt" style="color:#2196F3;"></i> 退货管理</h2><div class="br"><a href="/admin/logistics" style="text-decoration:none;color:#2196F3;">返回物流中心</a></div></div>
@if(_l){<div class="tc"><table class="ot"><thead><tr><th>退款ID</th><th>订单ID</th><th>金额</th><th>状态</th><th>日期</th></tr></thead><tbody>@foreach(var r in _items){<tr><td>#@r.RefundId</td><td>@r.OrderId</td><td>@r.RefundAmount.ToString("N2")</td><td>@(r.Status??"-")</td><td>@(r.CreatedAt?.ToString("MM-dd")??"-")</td></tr>}@if(!_items.Any()){<tr><td colspan="5" style="text-align:center;color:#666;padding:30px;">暂无退货记录</td></tr>}</tbody></table></div>}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;padding-bottom:15px;border-bottom:1px solid rgba(255,255,255,0.08);}.ph h2{font-size:24px;color:#fff;margin:0;}.br{font-size:13px;color:#888;}.tc{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;}.ot{width:100%;border-collapse:collapse;}.ot th{background:rgba(33,150,243,0.1);color:#2196F3;padding:14px 16px;font-size:13px;text-align:left;}.ot td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}</style>
@code{bool _l;List<RefundRecord> _items=new();protected override async Task OnInitializedAsync(){try{_items=await Db.RefundRecords.AsNoTracking().OrderByDescending(r=>r.RefundId).Take(30).ToListAsync();_l=true;}catch{_l=true;}}}
