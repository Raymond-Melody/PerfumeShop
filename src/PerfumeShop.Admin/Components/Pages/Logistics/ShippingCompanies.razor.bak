@page "/admin/logistics/carriers"
@page "/admin/logistics/shipping-companies"
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject ISnackbar Snackbar

<PageTitle>快递公司管理</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4"><i class="fas fa-building" style="color:#FF9800;"></i> 快递公司管理</MudText>
@if (_carriers is not null)
{
    @if (_editing)
    {
        <MudPaper Class="pa-6 mb-4" Elevation="0" Style="background:linear-gradient(135deg,#2d2d44,#1e1e32);border:1px solid rgba(255,152,0,0.2);border-radius:12px;max-width:600px;">
            <MudText Typo="Typo.h6" Class="mb-3" Style="color:#FF9800;">@(_editId > 0 ? "编辑快递公司" : "添加快递公司")</MudText>
            <MudTextField @bind-Value="_fn" Label="公司名称" Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <MudGrid><MudItem xs="12" md="6"><MudTextField @bind-Value="_fp" Label="联系人" Variant="Variant.Outlined" /></MudItem><MudItem xs="12" md="6"><MudTextField @bind-Value="_fph" Label="联系电话" Variant="Variant.Outlined" /></MudItem></MudGrid>
            <MudTextField @bind-Value="_fw" Label="网站" Variant="Variant.Outlined" Class="mt-3" />
            <MudTextField @bind-Value="_fnt" Label="备注" Variant="Variant.Outlined" Lines="2" Class="mt-3" />
            <MudSwitch @bind-Checked="_fa" Color="Color.Success" Label="启用" Class="mt-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveForm" Class="mt-3">保存</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="CancelEdit" Class="ml-2 mt-3">取消</MudButton>
        </MudPaper>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="StartAdd" Class="mb-4">添加快递公司</MudButton>
    <MudTable Items="@_carriers" Hover="true" Dense="true" Striped="true">
        <HeaderContent><MudTh>公司名称</MudTh><MudTh>联系人</MudTh><MudTh>联系电话</MudTh><MudTh>网站</MudTh><MudTh>状态</MudTh><MudTh>备注</MudTh><MudTh>操作</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd Style="font-weight:600;">@context.CompanyName</MudTd><MudTd>@context.ContactPerson</MudTd><MudTd>@context.ContactPhone</MudTd><MudTd>@context.Website</MudTd>
            <MudTd><MudChip Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "启用" : "禁用")</MudChip></MudTd>
            <MudTd>@context.Notes</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" OnClick="@(() => StartEdit(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveItem(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else { <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8" /> }
@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    private bool _editing, _fa; private int _editId;
    private string _fn = "", _fp = "", _fph = "", _fw = "", _fnt = "";
    private List<ShippingCompany>? _carriers;

    protected override async Task OnInitializedAsync() { _carriers = await Db.ShippingCompanies.AsNoTracking().OrderBy(c => c.CompanyId).ToListAsync(); }
    private void StartAdd() { _editId = 0; _fn = ""; _fp = ""; _fph = ""; _fw = ""; _fnt = ""; _fa = true; _editing = true; }
    private void StartEdit(ShippingCompany c) { _editId = c.CompanyId; _fn = c.CompanyName; _fp = c.ContactPerson ?? ""; _fph = c.ContactPhone ?? ""; _fw = c.Website ?? ""; _fnt = c.Notes ?? ""; _fa = c.IsActive ?? true; _editing = true; }
    private void CancelEdit() { _editing = false; }
    private async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(_fn)) { Snackbar.Add("请输入公司名称", Severity.Warning); return; }
        if (_editId > 0) { var e = await Db.ShippingCompanies.FindAsync(_editId); if (e != null) { e.CompanyName = _fn; e.ContactPerson = _fp; e.ContactPhone = _fph; e.Website = _fw; e.IsActive = _fa; e.Notes = _fnt; e.UpdatedAt = DateTime.Now; await Db.SaveChangesAsync(); } Snackbar.Add("已更新", Severity.Success); }
        else { Db.ShippingCompanies.Add(new ShippingCompany { CompanyName = _fn, ContactPerson = _fp, ContactPhone = _fph, Website = _fw, IsActive = _fa, Notes = _fnt, CreatedAt = DateTime.Now }); await Db.SaveChangesAsync(); Snackbar.Add("已添加", Severity.Success); }
        _editing = false; _carriers = await Db.ShippingCompanies.AsNoTracking().OrderBy(c => c.CompanyId).ToListAsync();
    }
    private async Task RemoveItem(ShippingCompany c) { var e = await Db.ShippingCompanies.FindAsync(c.CompanyId); if (e != null) { Db.ShippingCompanies.Remove(e); await Db.SaveChangesAsync(); Snackbar.Add("已删除", Severity.Success); _carriers!.Remove(c); } }
}
