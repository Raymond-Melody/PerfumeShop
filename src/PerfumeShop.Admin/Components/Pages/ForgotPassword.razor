@page "/forgot-password"
@using global::System.Security.Cryptography
@using global::System.Text
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
@inject NavigationManager Navigation
@layout PerfumeShop.Admin.Components.Layout.LoginLayout

@* V19 忘记密码页 — 对应 V18 admin/forgot_password.asp *@

<PageTitle>忘记密码 - 管理后台</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center" Style="min-height:100vh;">
    <MudItem xs="12">
        <MudPaper Elevation="8" Class="pa-8" Style="border-radius:12px;">
            <div class="text-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5" Class="mt-2">重置密码</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">请输入您的用户名或邮箱地址</MudText>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">@_success</MudAlert>
            }

            @if (string.IsNullOrEmpty(_success))
            {
                <form method="post" action="/forgot-password" @formname="forgotForm">
                    <AntiforgeryToken />
                    <MudTextField T="string" name="username_or_email" Label="用户名或邮箱地址"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                                  Required="true" RequiredError="请输入用户名或邮箱" Class="mb-4" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               ButtonType="ButtonType.Submit" Size="Size.Large" Class="mb-3">
                        发送重置链接
                    </MudButton>
                </form>
            }

            <div class="text-center mt-3">
                <MudLink Href="/login" Typo="Typo.caption" Color="Color.Primary">&larr; 返回登录页面</MudLink>
            </div>
        </MudPaper>
    </MudItem>
</MudContainer>

@code {
    private string? _error;
    private string? _success;

    [SupplyParameterFromForm] private string? username_or_email { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(username_or_email))
        {
            await ProcessForgot();
        }
    }

    private async Task ProcessForgot()
    {
        var input = username_or_email?.Trim();
        if (string.IsNullOrEmpty(input))
        {
            _error = "请输入用户名或邮箱地址。";
            return;
        }

        try
        {
            // 查找管理员账户
            var admin = await Db.AdminUsers
                .FirstOrDefaultAsync(a => a.Username == input || a.Email == input);

            if (admin == null)
            {
                // 安全考虑：不暴露用户是否存在
                _success = "如果账户存在，重置链接已发送至关联邮箱。";
                return;
            }

            if (string.IsNullOrEmpty(admin.Email))
            {
                _error = "该账户未绑定邮箱，请联系系统管理员重置密码。";
                return;
            }

            // 生成安全重置令牌
            var resetToken = GenerateResetToken();
            var tokenHash = HashTokenForStorage(resetToken);
            var expiry = DateTime.Now.AddHours(1);

            // 更新数据库
            admin.ResetToken = tokenHash;
            admin.ResetTokenExpiry = expiry;
            await Db.SaveChangesAsync();

            // TODO: 发送重置邮件（需集成 EmailService）
            // 当前仅记录日志，令牌直接显示用于测试
            _success = $"密码重置链接已生成。（测试模式）\n令牌: {resetToken}\n过期时间: {expiry:yyyy-MM-dd HH:mm:ss}";
        }
        catch (Exception ex)
        {
            _error = $"系统错误，请稍后重试: {ex.Message}";
        }
    }

    /// <summary>生成随机重置令牌 (对应 V18 GenerateResetToken)</summary>
    private static string GenerateResetToken()
    {
        var bytes = RandomNumberGenerator.GetBytes(32);
        return Convert.ToBase64String(bytes).Replace("+", "-").Replace("/", "_").TrimEnd('=');
    }

    /// <summary>令牌哈希存储 (不存明文)</summary>
    private static string HashTokenForStorage(string token)
    {
        using var sha = SHA256.Create();
        var hash = sha.ComputeHash(Encoding.UTF8.GetBytes(token));
        return Convert.ToHexString(hash).ToLowerInvariant();
    }
}
