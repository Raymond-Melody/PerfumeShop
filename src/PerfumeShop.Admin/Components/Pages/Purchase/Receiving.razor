@page "/admin/Purchase/Receiving"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.purchase")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>收货入库</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-clipboard-check" style="color:#FF9800;"></i> 收货入库</h2><div class="breadcrumb"><a href="/admin/Purchase/Dashboard" style="color:#FF9800;text-decoration:none;">采购中心</a> / <span>收货入库</span></div></div>
@if(_loaded){
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>收货单号</th><th>采购单ID</th><th>数量</th><th>状态</th><th>日期</th></tr></thead><tbody>
@foreach(var r in _items){<tr><td>#@r.ReceiptId</td><td>@(r.ReceiptNo??"-")</td><td>@(r.PurchaseId?.ToString()??"-")</td><td>@(r.TotalReceivedQty?.ToString()??"-")</td><td><span class="sb sn">@(r.Status??"-")</span></td><td>@(r.ReceiptDate?.ToString("yyyy-MM-dd")??"-")</td></tr>}
@if(!_items.Any()){<tr><td colspan="6" style="text-align:center;color:#666;padding:40px;">暂无收货记录</td></tr>}
</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>


.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}
.orders-table{width:100%;border-collapse:collapse;}
.orders-table th{background:rgba(255,152,0,0.1);color:#FF9800;padding:14px 16px;font-size:13px;text-align:left;}
.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.sb{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;}.sn{background:rgba(76,175,80,0.2);color:#81c784;}
</style>
@code{private bool _loaded;private List<PurchaseReceipt> _items=new();protected override async Task OnInitializedAsync(){try{_items=await Db.PurchaseReceipts.AsNoTracking().OrderByDescending(r=>r.ReceiptId).Take(50).ToListAsync();_loaded=true;}catch{_loaded=true;}}}
