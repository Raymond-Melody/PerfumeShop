@page "/admin/Purchase/BottlePurchase"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>瓶子采购</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">瓶子采购管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1">瓶子库存</MudText>
                <MudText Typo="Typo.h5">@_inventories.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/Purchase/OrderCreate"
                   StartIcon="@Icons.Material.Filled.Add">新建瓶子采购单</MudButton>
    </MudItem>
</MudGrid>

<MudTable Items="@_orders" Hover="true" Dense="true" Striped="true" Class="mb-4">
    <HeaderContent>
        <MudTh>采购单号</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>创建时间</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PurchaseNo</MudTd>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd")</MudTd>
    </RowTemplate>
</MudTable>

<MudText Typo="Typo.h6" Class="mb-2">瓶子库存</MudText>
<MudTable Items="@_inventories" Hover="true" Dense="true">
    <HeaderContent>
        <MudTh>瓶子名称</MudTh>
        <MudTh>库存数量</MudTh>
        <MudTh>安全库存</MudTh>
        <MudTh>单位成本</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@(context.BottleName ?? "-")</MudTd>
        <MudTd>@context.StockQty</MudTd>
        <MudTd>@context.SafetyStock</MudTd>
        <MudTd>¥@(context.UnitCost?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">@(context.IsActive == true ? "启用" : "停用")</MudChip></MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();
    private List<BottleInventory> _inventories = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(orderType: "Bottle", pageSize: 50);
        _orders = items;
        _inventories = await Repo.GetBottleInventoriesAsync();
    }
}
