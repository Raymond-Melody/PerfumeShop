@page "/admin/Purchase/PackagingPurchase"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>包装物采购</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">包装物采购管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1">包装物库存</MudText>
                <MudText Typo="Typo.h5">@_inventories.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/Purchase/OrderCreate"
                   StartIcon="@Icons.Material.Filled.Add">新建包装物采购单</MudButton>
    </MudItem>
</MudGrid>

<MudTable Items="@_orders" Hover="true" Dense="true" Striped="true" Class="mb-4">
    <HeaderContent>
        <MudTh>采购单号</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PurchaseNo</MudTd>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
    </RowTemplate>
</MudTable>

<MudText Typo="Typo.h6" Class="mb-2">包装物库存</MudText>
<MudTable Items="@_inventories" Hover="true" Dense="true">
    <HeaderContent>
        <MudTh>物料名称</MudTh>
        <MudTh>物料编码</MudTh>
        <MudTh>库存</MudTh>
        <MudTh>安全库存</MudTh>
        <MudTh>单价</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@(context.ItemName ?? "-")</MudTd>
        <MudTd>@(context.ItemCode ?? "-")</MudTd>
        <MudTd>@context.StockQty @context.Unit</MudTd>
        <MudTd>@context.SafetyStock</MudTd>
        <MudTd>¥@(context.UnitPrice?.ToString("N2") ?? "0.00")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PerfumeShopContext Db { get; set; } = default!;
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();
    private List<PackagingInventory> _inventories = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(orderType: "Packaging", pageSize: 50);
        _orders = items;
        _inventories = await Repo.GetLowStockPackagingAsync();
    }
}
