@page "/admin/Purchase/SupplierManagement"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>供应商管理</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">供应商管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_searchText" Placeholder="搜索供应商..." Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" />
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog"
                   StartIcon="@Icons.Material.Filled.Add">新增供应商</MudButton>
    </MudItem>
</MudGrid>

<MudTable Items="@FilteredSuppliers" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>供应商名称</MudTh>
        <MudTh>分类</MudTh>
        <MudTh>联系人</MudTh>
        <MudTh>电话</MudTh>
        <MudTh>邮箱</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.SupplierName</MudTd>
        <MudTd>@(context.Category ?? "-")</MudTd>
        <MudTd>@(context.ContactPerson ?? "-")</MudTd>
        <MudTd>@(context.Phone ?? "-")</MudTd>
        <MudTd>@(context.Email ?? "-")</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Error)">
                @(context.IsActive == true ? "启用" : "禁用")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info"
                           OnClick="@(() => EditSupplier(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@* 新增/编辑对话框 *@
<MudDialog @bind-Visible="_showDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "编辑" : "新增")供应商</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.SupplierName" Label="供应商名称" Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.Category" Label="分类" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.ContactPerson" Label="联系人" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.Phone" Label="电话" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.Email" Label="邮箱" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_form.Address" Label="地址" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Notes" Label="备注" Lines="2" />
            </MudItem>
            <MudItem xs="12">
                <MudCheckBox @bind-Value="_form.IsActive" Label="启用" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelDialog" Variant="Variant.Text">取消</MudButton>
        <MudButton OnClick="SaveSupplier" Variant="Variant.Filled" Color="Color.Primary">保存</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<Supplier> _suppliers = new();
    private string _searchText = "";
    private bool _showDialog;
    private bool _isEdit;
    private Supplier _form = new();

    private IEnumerable<Supplier> FilteredSuppliers =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _suppliers
            : _suppliers.Where(s => s.SupplierName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                                   || (s.ContactPerson ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _suppliers = await Repo.GetSuppliersAsync();
    }

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _form = new Supplier { IsActive = true };
        _showDialog = true;
    }

    private void EditSupplier(Supplier s)
    {
        _isEdit = true;
        _form = new Supplier
        {
            SupplierId = s.SupplierId,
            SupplierName = s.SupplierName,
            Category = s.Category,
            ContactPerson = s.ContactPerson,
            Phone = s.Phone,
            Email = s.Email,
            Address = s.Address,
            Notes = s.Notes,
            IsActive = s.IsActive
        };
        _showDialog = true;
    }

    private async Task SaveSupplier()
    {
        await Repo.UpsertSupplierAsync(_form);
        Snackbar.Add(_isEdit ? "供应商已更新" : "供应商已创建", Severity.Success);
        _showDialog = false;
        _suppliers = await Repo.GetSuppliersAsync();
    }

    private void CancelDialog() => _showDialog = false;
}
