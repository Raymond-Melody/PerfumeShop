@page "/admin/Purchase/ReceivingCreate"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>新建收货单</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">新建收货单</MudText>

<MudCard>
    <MudCardContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_receipt.PurchaseId" Label="采购单ID" Required="true" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_receipt.SupplierId" Label="供应商" Required="true">
                        @foreach (var s in _suppliers)
                        {
                            <MudSelectItem Value="@s.SupplierId">@s.SupplierName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_receipt.ReceivedBy" Label="收货人" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_receipt.Notes" Label="备注" Lines="2" />
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.h6" Class="mt-4 mb-2">收货明细</MudText>
            @for (int i = 0; i < _details.Count; i++)
            {
                var idx = i;
                <MudGrid Class="mb-2">
                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_details[idx].MaterialId" Label="物料ID" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_details[idx].ReceivedQty" Label="收货数量" Min="0" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_details[idx].AcceptedQty" Label="合格数量" Min="0" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField @bind-Value="_details[idx].RejectedQty" Label="拒收数量" Min="0" />
                    </MudItem>
                    <MudItem xs="12" md="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveDetail(idx))" />
                    </MudItem>
                </MudGrid>
            }
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add" OnClick="AddDetail">添加明细行</MudButton>
        </MudForm>
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/Receiving">取消</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">提交收货单</MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudForm? _form;
    private bool _isValid;
    private PurchaseReceipt _receipt = new();
    private List<PurchaseReceiptDetail> _details = new() { new() { ReceivedQty = 0, AcceptedQty = 0, RejectedQty = 0 } };
    private List<Supplier> _suppliers = new();

    protected override async Task OnInitializedAsync()
    {
        _suppliers = await Repo.GetSuppliersAsync(activeOnly: true);
    }

    private void AddDetail() => _details.Add(new PurchaseReceiptDetail { ReceivedQty = 0, AcceptedQty = 0, RejectedQty = 0 });

    private void RemoveDetail(int idx) => _details.RemoveAt(idx);

    private async Task Submit()
    {
        _receipt.ReceiptDate = DateTime.Now;
        _receipt.TotalReceivedQty = _details.Sum(d => d.ReceivedQty ?? 0);
        await Repo.ReceivePurchaseAsync(_receipt, _details);
        Snackbar.Add("收货单创建成功", Severity.Success);
        Nav.NavigateTo("/admin/Purchase/Receiving");
    }
}
