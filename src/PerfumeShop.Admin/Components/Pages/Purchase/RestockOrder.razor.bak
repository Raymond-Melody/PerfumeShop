@page "/admin/Purchase/RestockOrder"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>补货订单</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">补货订单管理</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    基于智能补货建议快速生成采购订单
</MudAlert>

<MudTable Items="@_orders" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>采购单号</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>创建时间</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PurchaseNo</MudTd>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(pageSize: 50);
        _orders = items.Where(o => o.Remarks != null && o.Remarks.Contains("补货")).ToList();
    }
}
