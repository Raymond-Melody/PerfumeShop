@page "/admin/Purchase/PriceManagement"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>价格管理</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">供应商价格管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudSelect @bind-Value="_supplierFilter" Placeholder="供应商筛选" Clearable="true">
            @foreach (var s in _suppliers)
            {
                <MudSelectItem Value="@s.SupplierId">@s.SupplierName</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

<MudTable Items="@FilteredPrices" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>供应商ID</MudTh>
        <MudTh>物料编码</MudTh>
        <MudTh>物料名称</MudTh>
        <MudTh>单价</MudTh>
        <MudTh>单位</MudTh>
        <MudTh>最小订购量</MudTh>
        <MudTh>生效日期</MudTh>
        <MudTh>到期日期</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>@(context.ItemCode ?? "-")</MudTd>
        <MudTd>@(context.ItemName ?? "-")</MudTd>
        <MudTd>¥@(context.UnitPrice?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd>@(context.Unit ?? "-")</MudTd>
        <MudTd>@(context.MinOrderQty?.ToString() ?? "-")</MudTd>
        <MudTd>@context.EffectiveDate?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>@context.ExpiryDate?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Default)">
                @(context.IsActive == true ? "有效" : "失效")
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<SupplierPrice> _prices = new();
    private List<Supplier> _suppliers = new();
    private int? _supplierFilter;

    private IEnumerable<SupplierPrice> FilteredPrices =>
        _supplierFilter.HasValue ? _prices.Where(p => p.SupplierId == _supplierFilter.Value) : _prices;

    protected override async Task OnInitializedAsync()
    {
        _suppliers = await Repo.GetSuppliersAsync(activeOnly: true);
        _prices = await Repo.GetSupplierPricesAsync();
    }
}
