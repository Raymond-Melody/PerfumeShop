@page "/admin/Purchase/SprayheadPurchase"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>喷头采购</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">喷头采购管理</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/Purchase/OrderCreate"
                   StartIcon="@Icons.Material.Filled.Add">新建喷头采购单</MudButton>
    </MudItem>
</MudGrid>

<MudTable Items="@_orders" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>采购单号</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>创建时间</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PurchaseNo</MudTd>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(orderType: "SprayHead", pageSize: 50);
        _orders = items;
    }
}
