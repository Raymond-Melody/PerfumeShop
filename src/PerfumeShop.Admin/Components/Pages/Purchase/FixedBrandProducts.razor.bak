@page "/admin/Purchase/FixedBrandProducts"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>品牌定香产品管理</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">品牌定香产品管理</MudText>

<MudTable Items="@_products" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>产品编码</MudTh>
        <MudTh>产品名称</MudTh>
        <MudTh>规格</MudTh>
        <MudTh>单价</MudTh>
        <MudTh>售价</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>最小订购量</MudTh>
        <MudTh>交期(天)</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@(context.ProductCode ?? "-")</MudTd>
        <MudTd>@context.ProductName</MudTd>
        <MudTd>@(context.Specification ?? "-")</MudTd>
        <MudTd>¥@(context.UnitPrice?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd>¥@(context.SalePrice?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd>@(context.SupplierName ?? "-")</MudTd>
        <MudTd>@(context.MinOrderQty?.ToString() ?? "-")</MudTd>
        <MudTd>@(context.LeadTimeDays?.ToString() ?? "-")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Status == "active" ? Color.Success : Color.Default)">@context.Status</MudChip></MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<FixedBrandProduct> _products = new();

    protected override async Task OnInitializedAsync()
    {
        _products = await Repo.GetFixedBrandProductsAsync();
    }
}
