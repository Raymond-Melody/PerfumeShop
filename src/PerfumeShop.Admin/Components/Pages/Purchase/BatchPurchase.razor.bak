@page "/admin/Purchase/BatchPurchase"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>批量采购</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">批量采购管理</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    跨品类批量采购下单，支持多供应商拆单
</MudAlert>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/admin/Purchase/OrderCreate"
                   StartIcon="@Icons.Material.Filled.Add">新建批量采购</MudButton>
    </MudItem>
</MudGrid>

<MudTable Items="@_orders" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>采购单号</MudTh>
        <MudTh>类型</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>创建时间</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PurchaseNo</MudTd>
        <MudTd>@(context.OrderType ?? "-")</MudTd>
        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
        <MudTd>@context.CreatedAt?.ToString("yyyy-MM-dd")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(pageSize: 100);
        _orders = items;
    }
}
