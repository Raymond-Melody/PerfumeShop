@page "/admin/Purchase/ReportTrend"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>采购额趋势</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">采购额趋势分析</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudChart ChartType="ChartType.Line" Series="@_series" XAxisLabels="@_labels"
                  Width="100%" Height="400px" />
    </MudCardContent>
</MudCard>

<MudButton Variant="Variant.Outlined" Href="/admin/Purchase/PurchaseReport">返回报表中心</MudButton>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<ChartSeries> _series = new();
    private string[] _labels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        var (orders, _) = await Repo.GetPurchaseOrdersAsync(pageSize: 1000);

        // 按月统计采购额（最近12个月）
        var now = DateTime.Now;
        var monthlyData = new List<double>();
        var monthLabels = new List<string>();

        for (int i = 11; i >= 0; i--)
        {
            var monthStart = new DateTime(now.Year, now.Month, 1).AddMonths(-i);
            var monthEnd = monthStart.AddMonths(1);
            var amount = orders.Where(o => o.CreatedAt >= monthStart && o.CreatedAt < monthEnd).Sum(o => (double)(o.TotalAmount ?? 0));
            monthlyData.Add(amount);
            monthLabels.Add(monthStart.ToString("yyyy-MM"));
        }

        _series = new List<ChartSeries>
        {
            new ChartSeries { Name = "采购额", Data = monthlyData.ToArray() }
        };
        _labels = monthLabels.ToArray();
    }
}
