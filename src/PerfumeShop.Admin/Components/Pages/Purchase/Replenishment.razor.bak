@page "/admin/Purchase/Replenishment"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>智能补货</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">智能补货建议</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    基于历史销售数据、安全库存和供应商交期自动生成补货建议
</MudAlert>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Warning">低库存预警</MudText>
                <MudText Typo="Typo.h4">@_lowStockCount</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Info">待补货物料</MudText>
                <MudText Typo="Typo.h4">@_stats.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mb-2">补货建议列表</MudText>
<MudTable Items="@_stats" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>物料类型</MudTh>
        <MudTh>物料编码</MudTh>
        <MudTh>物料名称</MudTh>
        <MudTh>30天均用量</MudTh>
        <MudTh>90天均用量</MudTh>
        <MudTh>最近下单</MudTh>
        <MudTh>首选供应商</MudTh>
        <MudTh>参考单价</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ItemType</MudTd>
        <MudTd>@(context.ItemCode ?? "-")</MudTd>
        <MudTd>@(context.ItemName ?? "-")</MudTd>
        <MudTd>@(context.Avg30DayUsage?.ToString("N2") ?? "-")</MudTd>
        <MudTd>@(context.Avg90DayUsage?.ToString("N2") ?? "-")</MudTd>
        <MudTd>@(context.LastOrderDate?.ToString("yyyy-MM-dd") ?? "-")</MudTd>
        <MudTd>@(context.PreferredSupplierId?.ToString() ?? "-")</MudTd>
        <MudTd>¥@(context.PreferredUnitPrice?.ToString("N2") ?? "0.00")</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseHistoryStat> _stats = new();
    private int _lowStockCount;

    protected override async Task OnInitializedAsync()
    {
        _stats = await Repo.GetHistoryStatsAsync();
        var lowStock = await Repo.GetLowStockPackagingAsync();
        _lowStockCount = lowStock.Count;
    }
}
