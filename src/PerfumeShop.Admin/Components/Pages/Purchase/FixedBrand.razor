@page "/admin/Purchase/FixedBrand"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Module.purchase")]
@using Microsoft.EntityFrameworkCore
@using PerfumeShop.Data.Models
@inject PerfumeShopContext Db
<PageTitle>品牌定香采购</PageTitle>
<div class="page-header"><h2 class="page-title"><i class="fas fa-boxes" style="color:#FF9800;"></i> 品牌定香采购</h2><div class="breadcrumb"><a href="/admin/Purchase/Dashboard" style="color:#FF9800;text-decoration:none;">采购中心</a> / <span>品牌定香</span></div></div>
@if(_loaded){
<div class="table-container"><table class="orders-table"><thead><tr><th>ID</th><th>产品名称</th><th>规格</th><th>单价</th><th>售价</th><th>状态</th></tr></thead><tbody>
@foreach(var p in _items){<tr><td>#@p.FixedProductId</td><td>@p.ProductName</td><td>@(p.Specification??"-")</td><td>@((p.UnitPrice??0).ToString("N2"))</td><td>@((p.SalePrice??0).ToString("N2"))</td><td><span class="status-badge status-normal">@(p.Status??"-")</span></td></tr>}
@if(!_items.Any()){<tr><td colspan="6" style="text-align:center;color:#666;padding:40px;">暂无品牌定香产品</td></tr>}
</tbody></table></div>
}else{<MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-8"/>}
<style>


.table-container{background:linear-gradient(135deg,#2d2d44,#1e1e32);border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,0.05);}
.orders-table{width:100%;border-collapse:collapse;}
.orders-table th{background:rgba(255,152,0,0.1);color:#FF9800;padding:14px 16px;font-size:13px;text-align:left;}
.orders-table td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,0.05);color:#ccc;font-size:14px;}
.status-badge{display:inline-block;padding:4px 12px;border-radius:12px;font-size:12px;}.status-normal{background:rgba(76,175,80,0.2);color:#81c784;}
</style>
@code {
    private bool _loaded;private List<FixedBrandProduct> _items=new();
    protected override async Task OnInitializedAsync(){
        try{_items=await Db.FixedBrandProducts.AsNoTracking().OrderByDescending(p=>p.FixedProductId).Take(50).ToListAsync();_loaded=true;}catch{_loaded=true;}
    }
}
