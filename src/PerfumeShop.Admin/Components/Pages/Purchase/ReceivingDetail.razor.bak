@page "/admin/Purchase/ReceivingDetail"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>收货单详情</PageTitle>

@if (_receipt == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">收货单详情</MudText>

    <MudCard Class="mb-4">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="6" md="3"><MudText><b>收货单号:</b> @_receipt.ReceiptNo</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>采购单ID:</b> @_receipt.PurchaseId</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>供应商ID:</b> @_receipt.SupplierId</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>收货人:</b> @_receipt.ReceivedBy</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>收货日期:</b> @_receipt.ReceiptDate?.ToString("yyyy-MM-dd")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>总数量:</b> @_receipt.TotalReceivedQty</MudText></MudItem>
                <MudItem xs="12"><MudText><b>备注:</b> @(_receipt.Notes ?? "无")</MudText></MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    @if (_details.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">收货明细</MudText>
        <MudTable Items="@_details" Hover="true" Dense="true" Class="mb-4">
            <HeaderContent>
                <MudTh>物料ID</MudTh>
                <MudTh>收货数量</MudTh>
                <MudTh>合格数量</MudTh>
                <MudTh>拒收数量</MudTh>
                <MudTh>拒收原因</MudTh>
                <MudTh>单价</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.MaterialId</MudTd>
                <MudTd>@context.ReceivedQty</MudTd>
                <MudTd>@context.AcceptedQty</MudTd>
                <MudTd>@context.RejectedQty</MudTd>
                <MudTd>@(context.RejectReason ?? "-")</MudTd>
                <MudTd>¥@(context.UnitPrice?.ToString("N2") ?? "0.00")</MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/Receiving">返回列表</MudButton>
}

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [SupplyParameterFromQuery] public int? Id { get; set; }

    private PurchaseReceipt? _receipt;
    private List<PurchaseReceiptDetail> _details = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var (items, _) = await Repo.GetReceiptsAsync();
            _receipt = items.FirstOrDefault(r => r.ReceiptId == Id.Value);
            if (_receipt != null)
                _details = await Repo.GetReceiptDetailsAsync(_receipt.ReceiptId);
        }
    }
}
