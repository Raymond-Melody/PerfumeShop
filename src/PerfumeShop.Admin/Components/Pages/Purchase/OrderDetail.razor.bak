@page "/admin/Purchase/OrderDetail"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>采购订单详情</PageTitle>

@if (_order == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">采购订单详情</MudText>

    <MudCard Class="mb-4">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="6" md="3"><MudText><b>采购单号:</b> @_order.PurchaseNo</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>状态:</b> <MudChip T="string" Color="@GetStatusColor(_order.Status)">@_order.Status</MudChip></MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>供应商ID:</b> @_order.SupplierId</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>采购类型:</b> @(_order.OrderType ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>总金额:</b> ¥@(_order.TotalAmount?.ToString("N2") ?? "0.00")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>创建时间:</b> @_order.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>预期到货:</b> @(_order.ExpectedDate?.ToString("yyyy-MM-dd") ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>更新时间:</b> @(_order.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</MudText></MudItem>
                <MudItem xs="12"><MudText><b>备注:</b> @(_order.Remarks ?? "无")</MudText></MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    @if (_details.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-2">订单明细</MudText>
        <MudTable Items="@_details" Hover="true" Dense="true" Class="mb-4">
            <HeaderContent>
                <MudTh>物料编码</MudTh>
                <MudTh>物料名称</MudTh>
                <MudTh>规格</MudTh>
                <MudTh>数量</MudTh>
                <MudTh>单位</MudTh>
                <MudTh>单价</MudTh>
                <MudTh>小计</MudTh>
                <MudTh>已收货</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ItemCode</MudTd>
                <MudTd>@context.ItemName</MudTd>
                <MudTd>@(context.Specification ?? "-")</MudTd>
                <MudTd>@context.Quantity</MudTd>
                <MudTd>@(context.Unit ?? "-")</MudTd>
                <MudTd>¥@(context.UnitPrice?.ToString("N2") ?? "0.00")</MudTd>
                <MudTd>¥@(context.TotalPrice?.ToString("N2") ?? "0.00")</MudTd>
                <MudTd>@context.ReceivedQty</MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/OrderList">返回列表</MudButton>
        @if (_order.Status == "draft")
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Approve">审批通过</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Cancel">取消订单</MudButton>
        }
    </MudStack>
}

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [SupplyParameterFromQuery] public int? Id { get; set; }

    private PurchaseOrder? _order;
    private List<PurchaseOrderDetail> _details = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            _order = await Repo.GetPurchaseOrderAsync(Id.Value);
            if (_order != null)
                _details = await Repo.GetPurchaseOrderDetailsAsync(_order.PurchaseId);
        }
    }

    private async Task Approve()
    {
        if (_order == null) return;
        await Repo.ApprovePurchaseOrderAsync(_order.PurchaseId, 1);
        Snackbar.Add("审批成功", Severity.Success);
        Nav.NavigateTo($"/admin/Purchase/OrderDetail?id={_order.PurchaseId}", forceLoad: true);
    }

    private async Task Cancel()
    {
        if (_order == null) return;
        await Repo.CancelPurchaseOrderAsync(_order.PurchaseId, "管理员取消");
        Snackbar.Add("已取消", Severity.Info);
        Nav.NavigateTo($"/admin/Purchase/OrderDetail?id={_order.PurchaseId}", forceLoad: true);
    }

    private Color GetStatusColor(string? status) => status?.ToLower() switch
    {
        "draft" => Color.Warning,
        "approved" => Color.Info,
        "received" => Color.Success,
        "cancelled" => Color.Error,
        _ => Color.Default
    };
}
