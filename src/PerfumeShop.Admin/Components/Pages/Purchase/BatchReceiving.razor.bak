@page "/admin/Purchase/BatchReceiving"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>批量收货</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">批量收货操作</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    选择多个已审批的采购单进行批量收货
</MudAlert>

<MudTable Items="@_orders" Hover="true" Dense="true" MultiSelection="true" @bind-SelectedItems="_selected">
    <HeaderContent>
        <MudTh>采购单号</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>类型</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PurchaseNo</MudTd>
        <MudTd>@(context.SupplierId?.ToString() ?? "-")</MudTd>
        <MudTd>@(context.OrderType ?? "-")</MudTd>
        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
    </RowTemplate>
</MudTable>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudText>已选择 @_selected.Count 项</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="BatchReceive" Disabled="@(_selected.Count == 0)">
        批量收货入库
    </MudButton>
</MudStack>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();
    private HashSet<PurchaseOrder> _selected = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(status: "approved", pageSize: 100);
        _orders = items;
    }

    private async Task BatchReceive()
    {
        foreach (var order in _selected)
        {
            var receipt = new PurchaseReceipt
            {
                PurchaseId = order.PurchaseId,
                SupplierId = order.SupplierId,
                ReceivedBy = "批量收货",
                ReceiptDate = DateTime.Now
            };
            await Repo.ReceivePurchaseAsync(receipt);
        }
        Snackbar.Add($"已批量收货 {_selected.Count} 个订单", Severity.Success);
        var (items, _) = await Repo.GetPurchaseOrdersAsync(status: "approved", pageSize: 100);
        _orders = items;
        _selected = new HashSet<PurchaseOrder>();
    }
}
