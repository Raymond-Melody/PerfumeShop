@page "/admin/Purchase/BaseNoteReceiving"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>基调原料收货</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">基调原料收货</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">此页面专用于基调原料（Base Note）的收货入库操作</MudAlert>

<MudTable Items="@_receipts" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>收货单号</MudTh>
        <MudTh>采购单ID</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>收货数量</MudTh>
        <MudTh>收货日期</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ReceiptNo</MudTd>
        <MudTd>@context.PurchaseId</MudTd>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>@context.TotalReceivedQty</MudTd>
        <MudTd>@context.ReceiptDate?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Success">@context.Status</MudChip></MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<PurchaseReceipt> _receipts = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetReceiptsAsync(pageSize: 100);
        _receipts = items;
    }
}
