@page "/admin/Purchase/FixedBrandReceiving"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>品牌定香收货</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">品牌定香收货入库</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">品牌定香产品专用收货通道</MudAlert>

<MudText Typo="Typo.h6" Class="mb-2">库存一览</MudText>
<MudTable Items="@_inventories" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>产品编码</MudTh>
        <MudTh>产品名称</MudTh>
        <MudTh>库存数量</MudTh>
        <MudTh>安全库存</MudTh>
        <MudTh>平均成本</MudTh>
        <MudTh>最近采购价</MudTh>
        <MudTh>总采购</MudTh>
        <MudTh>总销售</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@(context.ProductCode ?? "-")</MudTd>
        <MudTd>@(context.ProductName ?? "-")</MudTd>
        <MudTd>@context.StockQty</MudTd>
        <MudTd>@context.SafetyStock</MudTd>
        <MudTd>¥@(context.AvgUnitCost?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd>¥@(context.LastPurchasePrice?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd>@context.TotalPurchased</MudTd>
        <MudTd>@context.TotalSold</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<FixedBrandInventory> _inventories = new();

    protected override async Task OnInitializedAsync()
    {
        _inventories = await Repo.GetFixedBrandInventoriesAsync();
    }
}
