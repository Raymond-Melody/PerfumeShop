@page "/admin/Purchase/Receiving"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>收货入库</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">收货入库</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudSelect @bind-Value="_supplierFilter" Placeholder="供应商筛选" Clearable="true">
            @foreach (var s in _suppliers)
            {
                <MudSelectItem Value="@s.SupplierId">@s.SupplierName</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog"
                   StartIcon="@Icons.Material.Filled.Add">新建收货单</MudButton>
    </MudItem>
</MudGrid>

<MudTable ServerData="@(new Func<TableState, Task<TableData<PurchaseReceipt>>>(ServerReload))"
          @ref="_table" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>收货单号</MudTh>
        <MudTh>采购单ID</MudTh>
        <MudTh>供应商ID</MudTh>
        <MudTh>收货数量</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>收货日期</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ReceiptNo</MudTd>
        <MudTd>@context.PurchaseId</MudTd>
        <MudTd>@context.SupplierId</MudTd>
        <MudTd>@context.TotalReceivedQty</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Success">@context.Status</MudChip></MudTd>
        <MudTd>@context.ReceiptDate?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                           OnClick="@(() => ViewDetail(context.ReceiptId))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@* 收货详情对话框 *@
<MudDialog @bind-Visible="_showDetail" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">收货详情</MudText>
    </TitleContent>
    <DialogContent>
        @if (_detailReceipt != null)
        {
            <MudGrid>
                <MudItem xs="6"><MudText><b>收货单号:</b> @_detailReceipt.ReceiptNo</MudText></MudItem>
                <MudItem xs="6"><MudText><b>采购单ID:</b> @_detailReceipt.PurchaseId</MudText></MudItem>
                <MudItem xs="6"><MudText><b>供应商ID:</b> @_detailReceipt.SupplierId</MudText></MudItem>
                <MudItem xs="6"><MudText><b>收货人:</b> @_detailReceipt.ReceivedBy</MudText></MudItem>
                <MudItem xs="12"><MudText><b>备注:</b> @(_detailReceipt.Notes ?? "无")</MudText></MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">关闭</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudTable<PurchaseReceipt>? _table;
    private List<Supplier> _suppliers = new();
    private int? _supplierFilter;
    private bool _showDetail;
    private PurchaseReceipt? _detailReceipt;

    protected override async Task OnInitializedAsync()
    {
        _suppliers = await Repo.GetSuppliersAsync(activeOnly: true);
    }

    private async Task<TableData<PurchaseReceipt>> ServerReload(TableState state)
    {
        var (items, total) = await Repo.GetReceiptsAsync(supplierId: _supplierFilter, page: state.Page + 1, pageSize: state.PageSize);
        return new TableData<PurchaseReceipt> { TotalItems = total, Items = items };
    }

    private async Task ViewDetail(int receiptId)
    {
        var (items, _) = await Repo.GetReceiptsAsync();
        _detailReceipt = items.FirstOrDefault(r => r.ReceiptId == receiptId);
        _showDetail = true;
    }

    private void Cancel() => _showDetail = false;

    private void OpenCreateDialog() => Snackbar.Add("新建收货单功能开发中", Severity.Info);
}
