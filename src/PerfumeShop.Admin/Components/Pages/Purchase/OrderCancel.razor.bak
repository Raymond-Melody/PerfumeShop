@page "/admin/Purchase/OrderCancel"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>取消采购单</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">取消采购单</MudText>

<MudCard>
    <MudCardContent>
        <MudTable Items="@_orders" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>采购单号</MudTh>
                <MudTh>供应商ID</MudTh>
                <MudTh>金额</MudTh>
                <MudTh>状态</MudTh>
                <MudTh>操作</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.PurchaseNo</MudTd>
                <MudTd>@context.SupplierId</MudTd>
                <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip></MudTd>
                <MudTd>
                    @if (context.Status != "cancelled" && context.Status != "received")
                    {
                        <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                   OnClick="@(() => CancelOrder(context.PurchaseId))">取消</MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<PurchaseOrder> _orders = new();

    protected override async Task OnInitializedAsync()
    {
        var (items, _) = await Repo.GetPurchaseOrdersAsync(pageSize: 100);
        _orders = items.Where(o => o.Status != "cancelled" && o.Status != "received").ToList();
    }

    private async Task CancelOrder(int id)
    {
        await Repo.CancelPurchaseOrderAsync(id, "管理员手动取消");
        Snackbar.Add("订单已取消", Severity.Info);
        _orders = _orders.Where(o => o.PurchaseId != id).ToList();
    }

    private Color GetStatusColor(string? status) => status?.ToLower() switch
    {
        "draft" => Color.Warning,
        "approved" => Color.Info,
        _ => Color.Default
    };
}
