@page "/admin/Purchase/FixedBrandReplenishment"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>品牌定香智能补货</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">品牌定香智能补货</MudText>

<MudTable Items="@_inventories" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>产品</MudTh>
        <MudTh>当前库存</MudTh>
        <MudTh>安全库存</MudTh>
        <MudTh>日均销量</MudTh>
        <MudTh>最近采购</MudTh>
        <MudTh>建议补货量</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@(context.ProductName ?? "-")</MudTd>
        <MudTd>@context.StockQty</MudTd>
        <MudTd>@context.SafetyStock</MudTd>
        <MudTd>@(context.DailySalesAvg?.ToString("N2") ?? "0.00")</MudTd>
        <MudTd>@context.LastPurchaseDate?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>
            @{
                var suggestQty = Math.Max(0, (context.SafetyStock ?? 0) - (context.StockQty ?? 0));
            }
            <MudChip T="string" Size="Size.Small" Color="@(suggestQty > 0 ? Color.Warning : Color.Success)">
                @suggestQty
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<FixedBrandInventory> _inventories = new();

    protected override async Task OnInitializedAsync()
    {
        _inventories = await Repo.GetFixedBrandInventoriesAsync();
    }
}
