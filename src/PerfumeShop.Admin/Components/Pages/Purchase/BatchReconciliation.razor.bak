@page "/admin/Purchase/BatchReconciliation"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>批量对账</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">批量对账管理</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    对已收货的采购单进行批量对账确认
</MudAlert>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudSelect @bind-Value="_supplierFilter" Placeholder="供应商筛选" Clearable="true">
            @foreach (var s in _suppliers)
            {
                <MudSelectItem Value="@s.SupplierId">@s.SupplierName</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
</MudGrid>

<MudTable Items="@_receipts" Hover="true" Dense="true" MultiSelection="true" @bind-SelectedItems="_selected">
    <HeaderContent>
        <MudTh>收货单号</MudTh>
        <MudTh>采购单ID</MudTh>
        <MudTh>供应商ID</MudTh>
        <MudTh>收货数量</MudTh>
        <MudTh>收货日期</MudTh>
        <MudTh>状态</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ReceiptNo</MudTd>
        <MudTd>@(context.PurchaseId?.ToString() ?? "-")</MudTd>
        <MudTd>@(context.SupplierId?.ToString() ?? "-")</MudTd>
        <MudTd>@context.TotalReceivedQty</MudTd>
        <MudTd>@context.ReceiptDate?.ToString("yyyy-MM-dd")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
    </RowTemplate>
</MudTable>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudText>已选择 @_selected.Count 项</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ConfirmReconciliation" Disabled="@(_selected.Count == 0)">
        确认对账
    </MudButton>
</MudStack>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<PurchaseReceipt> _receipts = new();
    private List<Supplier> _suppliers = new();
    private int? _supplierFilter;
    private HashSet<PurchaseReceipt> _selected = new();

    protected override async Task OnInitializedAsync()
    {
        _suppliers = await Repo.GetSuppliersAsync(activeOnly: true);
        var (items, _) = await Repo.GetReceiptsAsync(pageSize: 100);
        _receipts = items;
    }

    private void ConfirmReconciliation()
    {
        Snackbar.Add($"已确认对账 {_selected.Count} 项", Severity.Success);
        _selected = new HashSet<PurchaseReceipt>();
    }
}
