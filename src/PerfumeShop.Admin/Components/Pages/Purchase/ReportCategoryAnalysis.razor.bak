@page "/admin/Purchase/ReportCategoryAnalysis"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>品类分析</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">采购品类分布分析</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader><MudText Typo="Typo.h6">品类采购额占比</MudText></MudCardHeader>
            <MudCardContent>
                <MudChart ChartType="ChartType.Pie" Series="@_series" Width="100%" Height="350px" />
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader><MudText Typo="Typo.h6">品类明细</MudText></MudCardHeader>
            <MudCardContent>
                <MudTable Items="@_categoryData" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>品类</MudTh>
                        <MudTh>订单数</MudTh>
                        <MudTh>采购额</MudTh>
                        <MudTh>占比</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Category</MudTd>
                        <MudTd>@context.OrderCount</MudTd>
                        <MudTd>¥@context.Amount.ToString("N2")</MudTd>
                        <MudTd>@context.Percentage.ToString("N1")%</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudButton Variant="Variant.Outlined" Href="/admin/Purchase/PurchaseReport">返回报表中心</MudButton>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<ChartSeries> _series = new();
    private List<CategoryData> _categoryData = new();

    protected override async Task OnInitializedAsync()
    {
        var (orders, _) = await Repo.GetPurchaseOrdersAsync(pageSize: 1000);
        var totalAmount = orders.Sum(o => (double)(o.TotalAmount ?? 0));

        var groups = orders.GroupBy(o => o.OrderType ?? "Other")
            .Select(g => new CategoryData
            {
                Category = g.Key,
                OrderCount = g.Count(),
                Amount = g.Sum(o => o.TotalAmount ?? 0),
                Percentage = totalAmount > 0 ? (decimal)(g.Sum(o => (double)(o.TotalAmount ?? 0)) / totalAmount * 100) : 0
            })
            .OrderByDescending(c => c.Amount)
            .ToList();

        _categoryData = groups;
        _series = groups.Select(g => new ChartSeries { Name = g.Category, Data = new[] { (double)g.Amount } }).ToList();
    }

    private class CategoryData
    {
        public string Category { get; set; } = "";
        public int OrderCount { get; set; }
        public decimal Amount { get; set; }
        public decimal Percentage { get; set; }
    }
}
