@page "/admin/Purchase/FixedBrandDashboard"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>品牌定香概览</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">品牌定香采购概览</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Primary">定香产品</MudText>
                <MudText Typo="Typo.h4">@_products.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Info">采购订单</MudText>
                <MudText Typo="Typo.h4">@_ordersTotal</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Success">库存品类</MudText>
                <MudText Typo="Typo.h4">@_inventories.Count</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader><MudText Typo="Typo.h6">最近订单</MudText></MudCardHeader>
            <MudCardContent>
                <MudTable Items="@_orders" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>采购单号</MudTh>
                        <MudTh>供应商</MudTh>
                        <MudTh>金额</MudTh>
                        <MudTh>状态</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.PurchaseNo</MudTd>
                        <MudTd>@(context.SupplierName ?? "-")</MudTd>
                        <MudTd>¥@(context.TotalAmount?.ToString("N2") ?? "0.00")</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader><MudText Typo="Typo.h6">快捷入口</MudText></MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/FixedBrandProducts">产品管理</MudButton>
                    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/FixedBrandOrders">采购订单</MudButton>
                    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/FixedBrandReceiving">收货入库</MudButton>
                    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/FixedBrandCostProfit">成本利润分析</MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<FixedBrandProduct> _products = new();
    private List<FixedBrandPurchaseOrder> _orders = new();
    private List<FixedBrandInventory> _inventories = new();
    private int _ordersTotal;

    protected override async Task OnInitializedAsync()
    {
        _products = await Repo.GetFixedBrandProductsAsync();
        var (items, total) = await Repo.GetFixedBrandOrdersAsync(pageSize: 5);
        _orders = items;
        _ordersTotal = total;
        _inventories = await Repo.GetFixedBrandInventoriesAsync();
    }
}
