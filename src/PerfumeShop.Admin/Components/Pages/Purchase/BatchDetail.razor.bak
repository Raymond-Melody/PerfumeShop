@page "/admin/Purchase/BatchDetail"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>批次详情</PageTitle>

@if (_batch == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">采购批次详情</MudText>

    <MudCard Class="mb-4">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="6" md="3"><MudText><b>批次号:</b> @(_batch.BatchNo ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>类型:</b> @(_batch.ItemType ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>物料编码:</b> @(_batch.ItemCode ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>物料名称:</b> @(_batch.ItemName ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>采购数量:</b> @_batch.Quantity</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>已收货:</b> @_batch.ReceivedQty</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>剩余:</b> @_batch.RemainingQty</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>单价:</b> ¥@(_batch.UnitPrice?.ToString("N2") ?? "0.00")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>供应商ID:</b> @_batch.SupplierId</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>收货日期:</b> @(_batch.ReceivedDate?.ToString("yyyy-MM-dd") ?? "-")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>成本分配:</b> @(_batch.CostAllocated == true ? "是" : "否")</MudText></MudItem>
                <MudItem xs="6" md="3"><MudText><b>创建时间:</b> @_batch.CreatedAt?.ToString("yyyy-MM-dd")</MudText></MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/PurchaseBatchList">返回列表</MudButton>
}

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [SupplyParameterFromQuery] public int? Id { get; set; }

    private PurchaseBatch? _batch;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
            _batch = await Repo.GetBatchAsync(Id.Value);
    }
}
