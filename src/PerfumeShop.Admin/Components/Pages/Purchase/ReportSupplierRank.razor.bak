@page "/admin/Purchase/ReportSupplierRank"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>供应商排行</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">供应商采购排行</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudChart ChartType="ChartType.Bar" Series="@_series" XAxisLabels="@_labels"
                  Width="100%" Height="400px" />
    </MudCardContent>
</MudCard>

<MudTable Items="@_rankData" Hover="true" Dense="true" Striped="true" Class="mt-4">
    <HeaderContent>
        <MudTh>排名</MudTh>
        <MudTh>供应商</MudTh>
        <MudTh>采购单数</MudTh>
        <MudTh>采购总额</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Rank</MudTd>
        <MudTd>@context.SupplierName</MudTd>
        <MudTd>@context.OrderCount</MudTd>
        <MudTd>¥@context.TotalAmount.ToString("N2")</MudTd>
    </RowTemplate>
</MudTable>

<MudButton Variant="Variant.Outlined" Href="/admin/Purchase/PurchaseReport" Class="mt-4">返回报表中心</MudButton>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private List<ChartSeries> _series = new();
    private string[] _labels = Array.Empty<string>();
    private List<SupplierRankData> _rankData = new();

    protected override async Task OnInitializedAsync()
    {
        var (orders, _) = await Repo.GetPurchaseOrdersAsync(pageSize: 1000);
        var suppliers = await Repo.GetSuppliersAsync();
        var supplierMap = suppliers.ToDictionary(s => s.SupplierId, s => s.SupplierName);

        var ranked = orders.Where(o => o.SupplierId.HasValue)
            .GroupBy(o => o.SupplierId!.Value)
            .Select(g => new SupplierRankData
            {
                SupplierId = g.Key,
                SupplierName = supplierMap.GetValueOrDefault(g.Key, $"ID:{g.Key}"),
                OrderCount = g.Count(),
                TotalAmount = g.Sum(o => o.TotalAmount ?? 0)
            })
            .OrderByDescending(r => r.TotalAmount)
            .Take(10)
            .ToList();

        for (int i = 0; i < ranked.Count; i++) ranked[i].Rank = i + 1;
        _rankData = ranked;

        _series = new List<ChartSeries>
        {
            new ChartSeries { Name = "采购额", Data = ranked.Select(r => (double)r.TotalAmount).ToArray() }
        };
        _labels = ranked.Select(r => r.SupplierName.Length > 6 ? r.SupplierName[..6] + "..." : r.SupplierName).ToArray();
    }

    private class SupplierRankData
    {
        public int Rank { get; set; }
        public int SupplierId { get; set; }
        public string SupplierName { get; set; } = "";
        public int OrderCount { get; set; }
        public decimal TotalAmount { get; set; }
    }
}
