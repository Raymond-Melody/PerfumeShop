@page "/admin/Purchase/PurchaseReport"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>采购报表</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">采购报表中心</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1">采购单总数</MudText>
                <MudText Typo="Typo.h4">@_totalOrders</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Success">采购总额</MudText>
                <MudText Typo="Typo.h4">¥@_totalAmount.ToString("N0")</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Info">供应商数</MudText>
                <MudText Typo="Typo.h4">@_supplierCount</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Color="Color.Warning">批次数</MudText>
                <MudText Typo="Typo.h4">@_batchCount</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader><MudText Typo="Typo.h6">按类型分布</MudText></MudCardHeader>
            <MudCardContent>
                <MudChart ChartType="ChartType.Pie" Series="@_typeSeries" Width="100%" Height="300px" />
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader><MudText Typo="Typo.h6">按状态分布</MudText></MudCardHeader>
            <MudCardContent>
                <MudChart ChartType="ChartType.Donut" Series="@_statusSeries" Width="100%" Height="300px" />
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudStack Row="true" Spacing="2" Class="mt-4">
    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/ReportTrend">采购额趋势</MudButton>
    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/ReportSupplierRank">供应商排行</MudButton>
    <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/ReportCategoryAnalysis">品类分析</MudButton>
</MudStack>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;

    private int _totalOrders;
    private decimal _totalAmount;
    private int _supplierCount;
    private int _batchCount;

    private List<ChartSeries> _typeSeries = new();
    private List<ChartSeries> _statusSeries = new();

    protected override async Task OnInitializedAsync()
    {
        var (orders, total) = await Repo.GetPurchaseOrdersAsync(pageSize: 1000);
        _totalOrders = total;
        _totalAmount = orders.Sum(o => o.TotalAmount ?? 0);

        var suppliers = await Repo.GetSuppliersAsync();
        _supplierCount = suppliers.Count;

        var (batches, batchTotal) = await Repo.GetPurchaseBatchesAsync(pageSize: 1);
        _batchCount = batchTotal;

        // 按类型统计
        var typeGroups = orders.GroupBy(o => o.OrderType ?? "Other").ToDictionary(g => g.Key, g => g.Sum(o => (double)(o.TotalAmount ?? 0)));
        _typeSeries = typeGroups.Select(kv => new ChartSeries { Name = kv.Key, Data = new[] { kv.Value } }).ToList();

        // 按状态统计
        var statusGroups = orders.GroupBy(o => o.Status ?? "Other").ToDictionary(g => g.Key, g => g.Count());
        _statusSeries = statusGroups.Select(kv => new ChartSeries { Name = kv.Key, Data = new[] { (double)kv.Value } }).ToList();
    }
}
