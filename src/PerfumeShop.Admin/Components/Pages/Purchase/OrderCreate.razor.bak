@page "/admin/Purchase/OrderCreate"
@using PerfumeShop.Data.Models
@using PerfumeShop.Data.Repositories

<PageTitle>新建采购单</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">新建采购单</MudText>

<MudCard>
    <MudCardContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_order.SupplierId" Label="供应商" Required="true" RequiredError="请选择供应商">
                        @foreach (var s in _suppliers)
                        {
                            <MudSelectItem Value="@s.SupplierId">@s.SupplierName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="_order.OrderType" Label="采购类型" Required="true" RequiredError="请选择采购类型">
                        <MudSelectItem Value="@("Packaging")">包装物</MudSelectItem>
                        <MudSelectItem Value="@("Bottle")">瓶子</MudSelectItem>
                        <MudSelectItem Value="@("Printing")">印刷品</MudSelectItem>
                        <MudSelectItem Value="@("SprayHead")">喷头</MudSelectItem>
                        <MudSelectItem Value="@("BaseNote")">基调原料</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_expectedDate" Label="预期到货日期" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_order.Remarks" Label="备注" Lines="2" />
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.h6" Class="mt-4 mb-2">订单明细</MudText>
            @for (int i = 0; i < _details.Count; i++)
            {
                var idx = i;
                <MudGrid Class="mb-2">
                    <MudItem xs="12" md="2">
                        <MudTextField @bind-Value="_details[idx].ItemCode" Label="物料编码" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_details[idx].ItemName" Label="物料名称" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField @bind-Value="_details[idx].Quantity" Label="数量" Min="0" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField @bind-Value="_details[idx].UnitPrice" Label="单价" Min="0" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudTextField @bind-Value="_details[idx].Unit" Label="单位" />
                    </MudItem>
                    <MudItem xs="12" md="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveDetail(idx))" />
                    </MudItem>
                </MudGrid>
            }
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add" OnClick="AddDetail">添加明细行</MudButton>
        </MudForm>
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Outlined" Href="/admin/Purchase/OrderList">取消</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">提交采购单</MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Inject] private PurchaseRepository Repo { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private MudForm? _form;
    private bool _isValid;
    private PurchaseOrder _order = new();
    private List<PurchaseOrderDetail> _details = new() { new() { Quantity = 1, Unit = "个" } };
    private DateTime? _expectedDate;
    private List<Supplier> _suppliers = new();

    protected override async Task OnInitializedAsync()
    {
        _suppliers = await Repo.GetSuppliersAsync(activeOnly: true);
    }

    private void AddDetail() => _details.Add(new PurchaseOrderDetail { Quantity = 1, Unit = "个" });

    private void RemoveDetail(int idx) => _details.RemoveAt(idx);

    private async Task Submit()
    {
        _order.ExpectedDate = _expectedDate;
        foreach (var d in _details)
            d.TotalPrice = (decimal)(d.Quantity ?? 0) * (d.UnitPrice ?? 0);
        _order.TotalAmount = _details.Sum(d => d.TotalPrice ?? 0);

        await Repo.CreatePurchaseOrderAsync(_order, _details);
        Snackbar.Add("采购单创建成功", Severity.Success);
        Nav.NavigateTo("/admin/Purchase/OrderList");
    }
}
