@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Authorization
@using global::System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

@if (_isPortal)
{
    @Body
}
else
{
    <MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <MudLayout Class="admin-dashboard v19-admin-layout">
        <MudAppBar Elevation="0" Class="admin-navbar v19-admin-appbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
            <MudText Typo="Typo.h6" Class="admin-nav-brand">
                <i class="fas @_moduleHeaderIcon" style="color:@_moduleColor;"></i>
                <span>@_moduleTitle</span>
            </MudText>
            <MudSpacer />
            <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="mr-2">V19</MudChip>
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Inherit" OnClick="@ToggleDarkMode" />
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
                   Class="sidebar v19-admin-drawer" Style="position:fixed;top:60px;bottom:0;overflow-y:auto;">

            <div class="sidebar-header" style="padding:20px;border-bottom:1px solid rgba(255,255,255,0.06);">
                <h3 style="color:#e0e0e0;margin:0;font-size:16px;display:flex;align-items:center;gap:10px;">
                    <i class="fas @_moduleHeaderIcon" style="color:@_moduleColor;"></i>
                    @_sidebarTitle
                </h3>
                <p style="color:#888;font-size:11px;margin:8px 0 0;">@_moduleDesc</p>
            </div>

            <ul class="sidebar-menu" style="list-style:none;padding:20px 0;margin:0;">
                @foreach (var item in _currentNavItems)
                {
                    if (item.IsSectionTitle)
                    {
                        <li class="sidebar-section-title">@item.Label</li>
                    }
                    else
                    {
                        <li>
                            <a href="@item.Url" class="@(IsActive(item.Url) ? "active" : "")">
                                <i class="fas @item.Icon" style="width:20px;margin-right:10px;text-align:center;"></i>
                                <span>@item.Label</span>
                            </a>
                        </li>
                    }
                }
            </ul>

            <div class="sidebar-footer" style="padding:15px 20px;border-top:1px solid rgba(255,255,255,0.06);">
                <a href="/" style="color:#666;text-decoration:none;font-size:13px;display:flex;align-items:center;gap:8px;">
                    <i class="fas fa-arrow-left"></i> 返回管理中心
                </a>
            </div>
        </MudDrawer>

        <MudMainContent Class="main-content v19-admin-main pa-4">
            @Body
        </MudMainContent>
    </MudLayout>
}

@code {
