@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6">PerfumeShop 管理后台</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="mr-4">V19 Admin</MudText>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">导航菜单</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">运营仪表盘</MudNavLink>

            <MudNavGroup Title="运营管理" Icon="@Icons.Material.Filled.Store" Expanded="true">
                <MudNavLink Href="/admin/orders" Icon="@Icons.Material.Filled.Receipt">订单管理</MudNavLink>
                <MudNavLink Href="/admin/products" Icon="@Icons.Material.Filled.ShoppingBag">商品管理</MudNavLink>
                <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">客户管理</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="营销中心" Icon="@Icons.Material.Filled.Campaign" Expanded="false">
                <MudNavLink Href="/admin/flash-sale" Icon="@Icons.Material.Filled.FlashOn">秒杀管理</MudNavLink>
                <MudNavLink Href="/admin/group-buy" Icon="@Icons.Material.Filled.Groups">拼团管理</MudNavLink>
                <MudNavLink Href="/admin/subscription" Icon="@Icons.Material.Filled.Subscriptions">订阅管理</MudNavLink>
                <MudNavLink Href="/admin/points" Icon="@Icons.Material.Filled.Stars">积分管理</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="系统" Icon="@Icons.Material.Filled.Settings" Expanded="false">
                <MudNavLink Href="/admin/analytics" Icon="@Icons.Material.Filled.Analytics">数据分析</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private MudTheme _theme = new()
    {
        Palette = new Palette
        {
            Primary = "#7C4DFF",
            Secondary = "#FF4081",
            AppbarBackground = "#7C4DFF",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#BB86FC",
            Secondary = "#CF6679",
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
