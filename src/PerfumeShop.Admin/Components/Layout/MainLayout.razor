    // ---- helpers ----
    record V18NavItem(string Icon, string Label, string Url, bool IsSectionTitle = false)
    {
        public static V18NavItem Section(string label) => new("", label, "", IsSectionTitle: true);
    }

    private bool IsActive(string url)
    {
        var current = Navigation.Uri.Replace(Navigation.BaseUri, "/").ToLower().TrimEnd('/');
        url = url.ToLower().TrimEnd('/');
        if (string.IsNullOrEmpty(url)) return false;
        return current == url || (url != "/" && current.StartsWith(url + "/"));
    }

    private MudTheme _theme = new()
    {
        Palette = new() { Primary = "#00bcd4", Secondary = "#26c6da", Tertiary = "#FF9800", Info = "#00bcd4", Success = "#4caf50", Warning = "#ffc107", Error = "#F44336", Dark = "#1a1a2e", TextPrimary = "#e0e0e0", TextSecondary = "#b0b0b0", Surface = "#2d2d44", Background = "#1a1a2e", AppbarBackground = "#1a1a2e", DrawerBackground = "#1a1a2e", DrawerText = "#e0e0e0", DrawerIcon = "#00bcd4" },
        PaletteDark = new() { Primary = "#00bcd4", Secondary = "#26c6da", Info = "#00bcd4", Success = "#66bb6a", Warning = "#ffd54f", Error = "#EF5350", Dark = "#0f0f1a", TextPrimary = "#e0e0e0", TextSecondary = "#b0b0b0", Surface = "#2d2d44", Background = "#1a1a2e", AppbarBackground = "#1a1a2e", DrawerBackground = "#1a1a2e", DrawerText = "#e0e0e0", DrawerIcon = "#00bcd4" }
    };

    protected override async Task OnInitializedAsync()
    {
        _isPortal = Navigation.Uri == Navigation.BaseUri || Navigation.Uri == Navigation.BaseUri + "/";
        await ReadAuthState();
        DetectModule(Navigation.Uri);
        Navigation.LocationChanged += async (s, e) => { _isPortal = e.Location == Navigation.BaseUri || e.Location == Navigation.BaseUri + "/"; await ReadAuthState(); DetectModule(e.Location); StateHasChanged(); };
    }

    async Task ReadAuthState()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var roleCode = state.User.FindFirst("RoleCode")?.Value ?? "";
        _isFinanceManager = roleCode == "FIN_MANAGER" || roleCode == "SUPER_ADMIN";
        _isTechManager = roleCode == "TECH_MANAGER" || roleCode == "SUPER_ADMIN";
    }

    void DetectModule(string uri)
    {
        var p = uri.Replace(Navigation.BaseUri, "/").ToLower();
        if      (p.StartsWith("/admin/finance"))      LoadFinance();
        else if (p.StartsWith("/admin/purchase"))      LoadPurchase();
        else if (p.StartsWith("/admin/techcenter"))    LoadTechCenter();
        else if (p.StartsWith("/admin/system"))        LoadSystem();
        else if (p.StartsWith("/admin/prodcenter"))    LoadProdCenter();
        else if (p.StartsWith("/admin/semifinished"))  LoadSemiFinished();
        else if (p.StartsWith("/admin/logistics"))     LoadLogistics();
        else if (p.StartsWith("/admin/inventory"))     LoadInventory();
        else if (p.StartsWith("/admin/analytics"))     LoadAnalytics();
        else                                           LoadOperation();
    }

